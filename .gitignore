# Dependencies
node_modules

# Build output
dist
.next
.turbo
coverage

# Environment files (commit only .env.example variants)
.env
.env.local
.env.*.local

# OS / IDE noise
.DS_Store
.vscode/*.code-workspace

# TypeScript incremental build cache
*.tsbuildinfo

# Schema / config backups that crept in during refactors. Force-add a
# specific intentional .bak (`git add -f`) only if you really need to
# park one in tree — usually moving it to docs/ or a scratch branch is
# the right call.
*.bak
*.bak.*

# Brain-dump / scratch output files that have ended up at app roots
# (Sprint 1 Story 0.6 cleaned up `apps/api/result.txt`). Drop spec
# content into `docs/` instead; drop ad-hoc test output into a
# git-ignored `tmp/` directory.
result.txt
*.scratch.md

# Runtime-generated storage artifacts — tax-invoice documents, shipping
# labels, exports, etc. These are produced by the running API per order and
# must NEVER be committed (they leak customer/seller PII, GSTINs and invoice
# numbers into the repo, and churn on every test order). The app re-creates
# the directory tree on demand (mkdir -p), so no .gitkeep is needed.
apps/api/storage/

# Terraform (infra/aws/terraform) — state contains generated secrets (DB
# password, JWT + encryption keys); NEVER commit it. The committed *.tfvars
# and *.s3.tfbackend carry no secrets (real creds live in Secrets Manager),
# so they stay tracked; the provider lock (.terraform.lock.hcl) is committed
# on purpose. Auto-loaded tfvars are ignored as a guard against secret leaks.
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfplan
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
*.auto.tfvars
*.auto.tfvars.json

# pnpm-lock.yaml — INTENTIONALLY committed (reproducible installs +
# CI cache hits). Do not add to this ignore file. Listed here as a
# guard against future regressions; remove the explicit !-rule if pnpm
# changes its lockfile name.
!pnpm-lock.yaml
