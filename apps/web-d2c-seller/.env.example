NEXT_PUBLIC_API_URL=http://localhost:8000

# Phase 18 (2026-05-20) — captcha bot-protection on the public seller
# auth endpoints (register, verify-email, resend-verification-otp,
# forgot-password). 'disabled' lets dev sign up without standing up
# a real captcha provider; staging / prod MUST be 'turnstile' or
# 'hcaptcha' paired with a real site key.
NEXT_PUBLIC_CAPTCHA_PROVIDER=disabled
NEXT_PUBLIC_CAPTCHA_SITE_KEY=
