{
  "name": "@sportsmart/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "nest start",
    "dev": "nest start --watch",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:status": "prisma migrate status",
    "seed": "npx ts-node prisma/seed/seed.ts",
    "seed:quick": "npx ts-node prisma/seed/seed.ts --skip-pincodes",
    "seed:pincodes": "npx ts-node prisma/seed/seed-pincodes.ts",
    "seed:metafields": "npx ts-node prisma/seed/seed-metafields.ts",
    "seed:admin": "npx ts-node prisma/seed/seed-admin.ts",
    "seed:catalog": "npx ts-node prisma/seed/seed-catalog.ts",
    "seed:tax": "npx ts-node prisma/seed/seed-tax-master.ts",
    "seed:menu": "npx ts-node prisma/seed/seed-menu.ts",
    "seed:fresh": "npx ts-node prisma/seed/seed.ts --push",
    "seed:smoke": "npx ts-node prisma/seed/seed-smoke-actors.ts",
    "seed:prod": "ts-node --transpile-only prisma/seed/seed-prod.ts",
    "db:reset": "npx ts-node prisma/scripts/guard-not-prod.ts && prisma migrate reset --force && npm run seed",
    "db:fresh": "npx ts-node prisma/scripts/guard-not-prod.ts && prisma migrate reset --force --skip-seed"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.107.0",
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@google/generative-ai": "^0.24.1",
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.0.0",
    "@prisma/client": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/multer": "^2.1.0",
    "bcrypt": "^6.0.0",
    "bwip-js": "^4.11.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "pdfkit": "^0.19.1",
    "prisma": "^6.0.0",
    "puppeteer": "^25.2.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sanitize-html": "^2.17.5",
    "sharp": "^0.35.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0",
    "undici": "^6.26.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.2",
    "tsconfig-paths": "^4.2.0",
    "typescript-eslint": "^8.62.0"
  }
}
