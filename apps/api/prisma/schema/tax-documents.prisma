// ============================================
// Tax Documents — Phase 8 of the GST/tax/invoice system
// ============================================
// Owns the canonical record for every legal tax document Sportsmart
// issues:
//   - TAX_INVOICE                  Regular GSTIN seller, taxable supply
//   - BILL_OF_SUPPLY               Composition / exempt seller
//   - INVOICE_CUM_BILL_OF_SUPPLY   Mixed taxable + exempt supply
//   - CREDIT_NOTE                  Section 34 reversal
//   - DEBIT_NOTE                   Section 34 upward correction (admin)
//   - LEGACY_RECEIPT               Non-tax receipt for pre-GST-module
//                                  historical orders
//
// One SubOrder = one TaxDocument (per the marketplace invoice
// principle in CA.md §2.3). For multi-seller MasterOrders, multiple
// rows here — one per supplier.
//
// Phase 8 ships the schema + DocumentSequenceService. Generation
// service (TaxDocumentService) + PDF renderer arrive in Phase 9.

// ─── Enums ──────────────────────────────────────────────────────

enum DocumentType {
  TAX_INVOICE
  BILL_OF_SUPPLY
  INVOICE_CUM_BILL_OF_SUPPLY
  CREDIT_NOTE
  DEBIT_NOTE
  LEGACY_RECEIPT
}

enum InvoiceType {
  B2C
  B2B
}

// Status lifecycle (per docs/tax/INVOICE_CANCELLATION_POLICY.md):
//   DRAFT → GENERATED → PARTIALLY_REVERSED → FULLY_REVERSED → SUPERSEDED
//   DRAFT → VOIDED_DRAFT (only allowed before number assignment)
//   PDF_PENDING / PDF_GENERATED / PDF_FAILED control the render
//   sub-lifecycle (independent of the legal status).
enum TaxDocumentStatus {
  DRAFT
  GENERATED
  PDF_PENDING
  PDF_GENERATED
  PDF_FAILED
  PARTIALLY_REVERSED
  FULLY_REVERSED
  SUPERSEDED
  VOIDED_DRAFT
}

enum EInvoiceStatus {
  NOT_APPLICABLE
  PENDING
  GENERATED
  FAILED
}

// ─── Models ──────────────────────────────────────────────────────

model TaxDocument {
  id              String       @id @default(uuid())

  // Human-readable number, unique within (supplierGstin, financialYear,
  // documentType). Generated by DocumentSequenceService.
  documentNumber  String       @map("document_number")
  documentType    DocumentType @map("document_type")
  financialYear   String       @map("financial_year")        // "2026-27"

  // Linkage
  masterOrderId   String?      @map("master_order_id")
  subOrderId      String?      @map("sub_order_id")
  sellerId        String?      @map("seller_id")
  // Follow-up #133 — nullable for POS sales (walk-in customer, no User
  // row). The e-commerce path still populates this. Either subOrderId
  // OR posSaleId is set; never both.
  customerId      String?      @map("customer_id")
  // Follow-up #133 — link to FranchisePosSale for the POS invoice
  // generation path. Mutually exclusive with subOrderId.
  posSaleId       String?      @map("pos_sale_id")
  supplierType    SupplierType @map("supplier_type")
  invoiceType     InvoiceType? @map("invoice_type")          // null for non-invoice types

  // ─── Supplier identity (issuer) ──────────────────────────────
  // For MARKETPLACE_SELLER / FRANCHISE: seller's GSTIN.
  // For OWN_BRAND / SPORTSMART: platform's GSTIN.
  // For LEGACY_RECEIPT: may be null (pre-GST history).
  supplierGstin           String?              @map("supplier_gstin")
  sellerRegistrationType  GstRegistrationType? @map("seller_registration_type")
  sellerLegalName         String?              @map("seller_legal_name")
  sellerAddressJson       Json?                @map("seller_address_json")
  sellerStateCode         String?              @map("seller_state_code")

  // ─── Recipient ───────────────────────────────────────────────
  buyerGstin              String?              @map("buyer_gstin")
  buyerLegalName          String?              @map("buyer_legal_name")
  billingAddressJson      Json?                @map("billing_address_json")
  shippingAddressJson     Json?                @map("shipping_address_json")
  placeOfSupplyStateCode  String?              @map("place_of_supply_state_code")

  // ─── Reverse charge ──────────────────────────────────────────
  reverseChargeApplicable Boolean @default(false) @map("reverse_charge_applicable")
  reverseChargeReason     String? @map("reverse_charge_reason")

  // ─── Money (paise) ───────────────────────────────────────────
  taxableAmountInPaise  BigInt @default(0) @map("taxable_amount_in_paise")
  cgstAmountInPaise     BigInt @default(0) @map("cgst_amount_in_paise")
  sgstAmountInPaise     BigInt @default(0) @map("sgst_amount_in_paise")
  igstAmountInPaise     BigInt @default(0) @map("igst_amount_in_paise")
  totalTaxAmountInPaise BigInt @default(0) @map("total_tax_amount_in_paise")
  cessAmountInPaise     BigInt @default(0) @map("cess_amount_in_paise")
  roundOffAmountInPaise BigInt @default(0) @map("round_off_amount_in_paise")
  documentTotalInPaise  BigInt @default(0) @map("document_total_in_paise")
  amountInWords         String? @map("amount_in_words")
  currencyCode          String  @default("INR") @map("currency_code")
  paymentMode           String? @map("payment_mode")

  // ─── Cross-reference (credit / debit notes) ──────────────────
  originalDocumentId     String?  @map("original_document_id")
  originalDocumentNumber String?  @map("original_document_number")
  reason                 String?

  // ─── Status ──────────────────────────────────────────────────
  status TaxDocumentStatus @default(DRAFT)

  // ─── PDF storage ─────────────────────────────────────────────
  pdfUrl           String?   @map("pdf_url")
  pdfStoragePath   String?   @map("pdf_storage_path")
  pdfSha256        String?   @map("pdf_sha_256")
  downloadCount    Int       @default(0) @map("download_count")
  lastDownloadedAt DateTime? @map("last_downloaded_at")
  // Phase 19 GST — retry tracking. The PDF retry cron picks up rows
  // in PDF_PENDING / PDF_FAILED with retry count below the env cap
  // and re-attempts. Provider field records which adapter wrote the
  // row ('stub' / 's3' / 'cloudinary') so a swap doesn't lose the
  // attribution.
  pdfRetryCount        Int       @default(0) @map("pdf_retry_count")
  pdfLastAttemptedAt   DateTime? @map("pdf_last_attempted_at")
  pdfFailureReason     String?   @map("pdf_failure_reason")
  pdfProvider          String?   @map("pdf_provider")

  // ─── E-invoice / IRN readiness ───────────────────────────────
  // Phase 22 — fields wired end-to-end with a stub adapter so the
  // shape is integration-ready. Real NIC IRP integration is flag-
  // gated by EINVOICE_PROVIDER=nic.
  irn                String?         @map("irn")
  ackNo              String?         @map("ack_no")
  ackDate            DateTime?       @map("ack_date")
  signedDocumentJson Json?           @map("signed_document_json")
  qrCodeUrl          String?         @map("qr_code_url")
  einvoiceStatus     EInvoiceStatus  @default(NOT_APPLICABLE) @map("einvoice_status")
  // Phase 22 — retry tracking. EInvoiceRetryCron picks up rows in
  // PENDING / FAILED with retry count below the env cap.
  einvoiceRetryCount       Int       @default(0) @map("einvoice_retry_count")
  einvoiceLastAttemptedAt  DateTime? @map("einvoice_last_attempted_at")
  einvoiceFailureReason    String?   @map("einvoice_failure_reason")
  einvoiceProvider         String?   @map("einvoice_provider")

  // ─── Timestamps ──────────────────────────────────────────────
  generatedAt DateTime? @map("generated_at")
  cancelledAt DateTime? @map("cancelled_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  lines TaxDocumentLine[]

  // Phase 13 GST — wallet adjustments that reference this invoice as
  // the source (TIME_BARRED_CREDIT_NOTE rows carry the "would-have-been"
  // tax breakdown that this document's credit note couldn't reverse).
  walletAdjustments WalletAdjustment[] @relation("WalletAdjustmentSourceInvoice")

  // Phase 15 GST — e-way bills issued against this invoice. Typically
  // a 1:1 link for sub-order-scoped invoices; null on documents that
  // never trigger an EWB (legacy receipts, credit / debit notes).
  eWayBills EWayBill[]

  // Phase 20 GST — download audit rows. One per signed-URL issuance
  // (ALLOWED) plus one per denied attempt (DENIED_*) so flooding /
  // scope-violation attempts leave a trail.
  downloadAudits TaxDocumentDownloadAudit[]

  // Cross-references — by reading not enforced (polymorphic on
  // documentType). Per ADR-001 we avoid hard FKs across module
  // boundaries; lookups happen at service layer.

  // Uniqueness — one document number per (supplier, FY, type).
  // The composite is enforced at the application layer via
  // DocumentSequenceService; this index provides the DB check.
  // For LEGACY_RECEIPT with supplierGstin = NULL, Postgres NULLS
  // DISTINCT lets multiple legacy receipts coexist — adequate since
  // LEGACY_RECEIPT numbers are platform-wide and generated by the
  // dedicated 'PLATFORM' sequence key (see DocumentSequenceService).
  @@unique([supplierGstin, financialYear, documentType, documentNumber], map: "tax_documents_supplier_fy_type_num_uniq")

  @@index([masterOrderId])
  @@index([subOrderId])
  @@index([posSaleId])
  @@index([sellerId])
  @@index([customerId])
  @@index([documentType])
  @@index([status])
  @@index([financialYear])
  @@index([generatedAt])
  @@index([buyerGstin])
  @@map("tax_documents")
}

model TaxDocumentLine {
  id                String  @id @default(uuid())
  documentId        String  @map("document_id")
  // Source snapshot row this line was rendered from (Phase 5
  // OrderItemTaxSnapshot). One line per snapshot row.
  sourceSnapshotId  String? @map("source_snapshot_id")
  // Sequence within the document — preserved across re-renders.
  lineNumber        Int     @map("line_number")
  lineType          TaxLineType @map("line_type")

  // Snapshotted line context
  productId         String? @map("product_id")
  variantId         String? @map("variant_id")
  productName       String  @map("product_name")
  sku               String? @map("sku")
  hsnOrSacCode      String? @map("hsn_or_sac_code")
  uqcCode           String? @map("uqc_code")
  quantity          Decimal @db.Decimal(12, 3)
  unitPriceInPaise  BigInt  @map("unit_price_in_paise")

  // Money (line-level)
  grossAmountInPaise    BigInt  @default(0) @map("gross_amount_in_paise")
  discountAmountInPaise BigInt  @default(0) @map("discount_amount_in_paise")
  taxableAmountInPaise  BigInt  @default(0) @map("taxable_amount_in_paise")
  gstRateBps            Int     @default(0) @map("gst_rate_bps")
  cgstAmountInPaise     BigInt  @default(0) @map("cgst_amount_in_paise")
  sgstAmountInPaise     BigInt  @default(0) @map("sgst_amount_in_paise")
  igstAmountInPaise     BigInt  @default(0) @map("igst_amount_in_paise")
  totalTaxAmountInPaise BigInt  @default(0) @map("total_tax_amount_in_paise")
  cessAmountInPaise     BigInt  @default(0) @map("cess_amount_in_paise")
  lineTotalInPaise      BigInt  @default(0) @map("line_total_in_paise")
  currencyCode          String  @default("INR") @map("currency_code")

  createdAt DateTime @default(now()) @map("created_at")

  document TaxDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, lineNumber], map: "tax_document_lines_doc_line_num_uniq")
  @@index([documentId])
  @@index([sourceSnapshotId])
  @@index([lineType])
  @@map("tax_document_lines")
}

// Per-(supplier-gstin, FY, document-type) monotonic number sequence.
// Each row is the high-water mark for one logical series. Numbers
// never reuse; cancelled / voided documents get their numbers
// "burned" (the sequence still advances). Audit trail of skipped
// numbers lives in `skipped_numbers` JSON.
//
// Concurrency: DocumentSequenceService uses
//   INSERT ... ON CONFLICT (sequence_key) DO UPDATE
//     SET last_number = lastNumber + 1
//     RETURNING last_number, prefix
// — atomic, no SERIALIZABLE transaction, no race window.
//
// sequence_key shape: "{supplierGstin or 'PLATFORM'}|{FY}|{documentType}"
// Example: "36ABCDE1234F1Z5|2026-27|TAX_INVOICE"
model DocumentSequence {
  id              String       @id @default(uuid())
  sequenceKey     String       @unique @map("sequence_key")
  // Supplier identity — null when sequence is platform-wide (LEGACY_RECEIPT).
  supplierGstin   String?      @map("supplier_gstin")
  financialYear   String       @map("financial_year")
  documentType    DocumentType @map("document_type")
  prefix          String       // "SM-INV", "SM-BOS", etc.
  lastNumber      Int          @default(0) @map("last_number")
  // Numbers burnt by voided drafts / cancellations — JSON array of
  // integers. Lets ops prove "we accounted for every number" during
  // GSTR-1 review.
  skippedNumbers  Json         @default("[]") @map("skipped_numbers")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@index([supplierGstin, financialYear, documentType])
  @@map("document_sequences")
}
