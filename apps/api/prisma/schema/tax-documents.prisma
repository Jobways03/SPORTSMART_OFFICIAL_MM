// ============================================
// Tax Documents — Phase 8 of the GST/tax/invoice system
// ============================================
// Owns the canonical record for every legal tax document Sportsmart
// issues:
//   - TAX_INVOICE                  Regular GSTIN seller, taxable supply
//   - BILL_OF_SUPPLY               Composition / exempt seller
//   - INVOICE_CUM_BILL_OF_SUPPLY   Mixed taxable + exempt supply
//   - CREDIT_NOTE                  Section 34 reversal
//   - DEBIT_NOTE                   Section 34 upward correction (admin)
//   - LEGACY_RECEIPT               Non-tax receipt for pre-GST-module
//                                  historical orders
//
// One SubOrder = one TaxDocument (per the marketplace invoice
// principle in CA.md §2.3). For multi-seller MasterOrders, multiple
// rows here — one per supplier.
//
// Phase 8 ships the schema + DocumentSequenceService. Generation
// service (TaxDocumentService) + PDF renderer arrive in Phase 9.

// ─── Enums ──────────────────────────────────────────────────────

enum DocumentType {
  TAX_INVOICE
  BILL_OF_SUPPLY
  INVOICE_CUM_BILL_OF_SUPPLY
  CREDIT_NOTE
  DEBIT_NOTE
  LEGACY_RECEIPT
}

enum InvoiceType {
  B2C
  B2B
}

// Status lifecycle (per docs/tax/INVOICE_CANCELLATION_POLICY.md):
//   DRAFT → GENERATED → PARTIALLY_REVERSED → FULLY_REVERSED → SUPERSEDED
//   DRAFT → VOIDED_DRAFT (only allowed before number assignment)
//   PDF_PENDING / PDF_GENERATED / PDF_FAILED control the render
//   sub-lifecycle (independent of the legal status).
enum TaxDocumentStatus {
  DRAFT
  GENERATED
  PDF_PENDING
  PDF_GENERATED
  PDF_FAILED
  PARTIALLY_REVERSED
  FULLY_REVERSED
  SUPERSEDED
  VOIDED_DRAFT
}

enum EInvoiceStatus {
  NOT_APPLICABLE
  PENDING
  GENERATED
  FAILED
  // Phase 90 (2026-05-23) — E-Invoice audit Gap #8/#17. Pre-Phase-90
  // the cancel path overloaded NOT_APPLICABLE for the post-cancel
  // state, which conflated "never eligible" with "had an IRN, then
  // revoked". CANCELLED is the explicit terminal so admin queues +
  // reporting can distinguish.
  CANCELLED
}

// ─── Models ──────────────────────────────────────────────────────

model TaxDocument {
  id String @id @default(uuid())

  // Human-readable number, unique within (supplierGstin, financialYear,
  // documentType). Generated by DocumentSequenceService.
  documentNumber String       @map("document_number")
  documentType   DocumentType @map("document_type")
  financialYear  String       @map("financial_year") // "2026-27"

  // Linkage
  masterOrderId String?      @map("master_order_id")
  subOrderId    String?      @map("sub_order_id")
  sellerId      String?      @map("seller_id")
  // Follow-up #133 — nullable for POS sales (walk-in customer, no User
  // row). The e-commerce path still populates this. Either subOrderId
  // OR posSaleId is set; never both.
  customerId    String?      @map("customer_id")
  // Follow-up #133 — link to FranchisePosSale for the POS invoice
  // generation path. Mutually exclusive with subOrderId.
  posSaleId     String?      @map("pos_sale_id")
  supplierType  SupplierType @map("supplier_type")
  invoiceType   InvoiceType? @map("invoice_type") // null for non-invoice types
  // Phase 159w (GST Mode Toggle audit B2) — GST mode in effect when this
  // document was issued. Re-validation (refund / credit-note / re-export)
  // recomputes against this snapshot, not the live mode. Nullable for
  // documents issued before 159w.
  gstModeSnapshot GstMode?   @map("gst_mode_snapshot")

  // ─── Supplier identity (issuer) ──────────────────────────────
  // For MARKETPLACE_SELLER / FRANCHISE: seller's GSTIN.
  // For OWN_BRAND / SPORTSMART: platform's GSTIN.
  // For LEGACY_RECEIPT: may be null (pre-GST history).
  supplierGstin          String?              @map("supplier_gstin")
  sellerRegistrationType GstRegistrationType? @map("seller_registration_type")
  sellerLegalName        String?              @map("seller_legal_name")
  sellerAddressJson      Json?                @map("seller_address_json")
  sellerStateCode        String?              @map("seller_state_code")
  // Phase 161 (Platform GST Profile audit B3) — for OWN_BRAND / SPORTSMART
  // supplies, the platform profile that minted this invoice. The supplier
  // identity itself is already SNAPSHOTTED in the seller* columns above
  // (no drift); this FK lets reports group "all invoices under profile X"
  // without a GSTIN-string scan. Null for marketplace-seller / franchise rows.
  platformGstProfileId   String?              @map("platform_gst_profile_id")
  platformGstProfile     PlatformGstProfile?  @relation(fields: [platformGstProfileId], references: [id], onDelete: SetNull)
  // Phase 161 (Customer Tax Profile audit B2) — the buyer profile this B2B
  // invoice was issued to. Buyer identity is already SNAPSHOTTED in the
  // buyer* columns below (no PDF drift); this FK lets the admin join graph
  // resolve "which profile" without a GSTIN-string scan. Null for B2C.
  customerTaxProfileId   String?              @map("customer_tax_profile_id")
  customerTaxProfile     CustomerTaxProfile?  @relation(fields: [customerTaxProfileId], references: [id], onDelete: SetNull)

  // ─── Recipient ───────────────────────────────────────────────
  buyerGstin             String? @map("buyer_gstin")
  buyerLegalName         String? @map("buyer_legal_name")
  billingAddressJson     Json?   @map("billing_address_json")
  shippingAddressJson    Json?   @map("shipping_address_json")
  placeOfSupplyStateCode String? @map("place_of_supply_state_code")

  // ─── Reverse charge ──────────────────────────────────────────
  reverseChargeApplicable Boolean @default(false) @map("reverse_charge_applicable")
  reverseChargeReason     String? @map("reverse_charge_reason")

  // ─── Money (paise) ───────────────────────────────────────────
  taxableAmountInPaise  BigInt  @default(0) @map("taxable_amount_in_paise")
  cgstAmountInPaise     BigInt  @default(0) @map("cgst_amount_in_paise")
  sgstAmountInPaise     BigInt  @default(0) @map("sgst_amount_in_paise")
  igstAmountInPaise     BigInt  @default(0) @map("igst_amount_in_paise")
  totalTaxAmountInPaise BigInt  @default(0) @map("total_tax_amount_in_paise")
  cessAmountInPaise     BigInt  @default(0) @map("cess_amount_in_paise")
  roundOffAmountInPaise BigInt  @default(0) @map("round_off_amount_in_paise")
  documentTotalInPaise  BigInt  @default(0) @map("document_total_in_paise")
  amountInWords         String? @map("amount_in_words")
  currencyCode          String  @default("INR") @map("currency_code")
  paymentMode           String? @map("payment_mode")

  // ─── Cross-reference (credit / debit notes) ──────────────────
  originalDocumentId     String? @map("original_document_id")
  originalDocumentNumber String? @map("original_document_number")
  reason                 String?
  // Phase 164 (Credit Note Generation audit #1/#2/#3) — first-class
  // structured linkage to the originating Return. Replaces the brittle
  // `reason CONTAINS returnNumber` idempotency lookup (which an admin
  // reason override silently defeated) and is the column the
  // partial-unique (original_document_id, return_id) duplicate-CN guard
  // is built on. Nullable: only CREDIT_NOTE rows born from a return
  // carry it; invoices and legacy CNs leave it null.
  returnId               String? @map("return_id")
  // Phase 164 (#14) — when SOME order-item snapshots were missing (legacy
  // orders), the CN is issued covering only the lines that had snapshots.
  // This records how many approved lines were skipped so finance can tell
  // a partial-coverage CN from a complete one. 0 = full coverage.
  partialCoverageLineCount Int   @default(0) @map("partial_coverage_line_count")
  // Phase 164 (#20) — set when the customer-facing CN-issued notification
  // fired successfully, so support can answer "did the customer get it?".
  customerNotifiedAt     DateTime? @map("customer_notified_at")

  // ─── Status ──────────────────────────────────────────────────
  status TaxDocumentStatus @default(DRAFT)

  // ─── PDF storage ─────────────────────────────────────────────
  pdfUrl             String?   @map("pdf_url")
  pdfStoragePath     String?   @map("pdf_storage_path")
  pdfSha256          String?   @map("pdf_sha_256")
  downloadCount      Int       @default(0) @map("download_count")
  lastDownloadedAt   DateTime? @map("last_downloaded_at")
  // Phase 19 GST — retry tracking. The PDF retry cron picks up rows
  // in PDF_PENDING / PDF_FAILED with retry count below the env cap
  // and re-attempts. Provider field records which adapter wrote the
  // row ('stub' / 's3' / 'cloudinary') so a swap doesn't lose the
  // attribution.
  pdfRetryCount      Int       @default(0) @map("pdf_retry_count")
  pdfLastAttemptedAt DateTime? @map("pdf_last_attempted_at")
  pdfFailureReason   String?   @map("pdf_failure_reason")
  pdfProvider        String?   @map("pdf_provider")

  // ─── E-invoice / IRN readiness ───────────────────────────────
  // Phase 22 — fields wired end-to-end with a stub adapter so the
  // shape is integration-ready. Real NIC IRP integration is flag-
  // gated by EINVOICE_PROVIDER=nic.
  irn                              String?        @map("irn")
  ackNo                            String?        @map("ack_no")
  ackDate                          DateTime?      @map("ack_date")
  signedDocumentJson               Json?          @map("signed_document_json")
  qrCodeUrl                        String?        @map("qr_code_url")
  einvoiceStatus                   EInvoiceStatus @default(NOT_APPLICABLE) @map("einvoice_status")
  // Phase 22 — retry tracking. EInvoiceRetryCron picks up rows in
  // PENDING / FAILED with retry count below the env cap.
  einvoiceRetryCount               Int            @default(0) @map("einvoice_retry_count")
  einvoiceLastAttemptedAt          DateTime?      @map("einvoice_last_attempted_at")
  einvoiceFailureReason            String?        @map("einvoice_failure_reason")
  // Phase 160 (e-invoice audit #8) — the NIC business error code (e.g.
  // 2150 duplicate, 2253 mandatory-field-missing) split out from the
  // free-text reason so admin queries can filter by code, not regex.
  einvoiceErrorCode                String?        @map("einvoice_error_code")
  einvoiceProvider                 String?        @map("einvoice_provider")
  // Phase 160 (e-invoice audit — schema gap "generatedBy/generatedAt").
  // Who minted the IRN (admin id or 'system' for the retry cron) + WHEN
  // we minted it (distinct from ackDate, which is NIC's ack timestamp,
  // and from einvoiceLastAttemptedAt, which is the last attempt of any
  // kind incl. failures).
  einvoiceGeneratedBy              String?        @map("einvoice_generated_by")
  einvoiceGeneratedAt              DateTime?      @map("einvoice_generated_at")
  // Phase 90 (2026-05-23) — Gap #19 cancel category + reason audit.
  // Pre-Phase-90 the cancel path only persisted the cancellation
  // envelope inside signedDocumentJson; the row-level columns let
  // admin queries answer "show me all DUPLICATE cancellations this
  // week" without parsing JSON.
  einvoiceCancellationCode         Int?           @map("einvoice_cancellation_code")
  einvoiceCancellationReason       String?        @map("einvoice_cancellation_reason") @db.Text
  einvoiceCancelledBy              String?        @map("einvoice_cancelled_by")
  // Phase 90 (2026-05-23) — Gap #22 retention bound. signedDocumentJson
  // is PII-heavy (full line-item shape, buyer GSTIN). CBIC requires
  // ~8 years; we default to 9 (one year extra for safety) so finance
  // can still query the JSON during the statutory window then a
  // nightly purge strips it while preserving irn/ackNo/ackDate.
  signedDocumentJsonRetentionUntil DateTime?      @map("signed_document_json_retention_until")

  // ─── Timestamps ──────────────────────────────────────────────
  generatedAt DateTime? @map("generated_at")
  cancelledAt DateTime? @map("cancelled_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  lines TaxDocumentLine[]

  // Phase 13 GST — wallet adjustments that reference this invoice as
  // the source (TIME_BARRED_CREDIT_NOTE rows carry the "would-have-been"
  // tax breakdown that this document's credit note couldn't reverse).
  walletAdjustments WalletAdjustment[] @relation("WalletAdjustmentSourceInvoice")

  // Phase 15 GST — e-way bills issued against this invoice. Typically
  // a 1:1 link for sub-order-scoped invoices; null on documents that
  // never trigger an EWB (legacy receipts, credit / debit notes).
  eWayBills EWayBill[]

  // Phase 20 GST — download audit rows. One per signed-URL issuance
  // (ALLOWED) plus one per denied attempt (DENIED_*) so flooding /
  // scope-violation attempts leave a trail.
  downloadAudits    TaxDocumentDownloadAudit[]
  // Phase 90 (2026-05-23) — e-invoice lifecycle audit chain.
  einvoiceAuditLogs EInvoiceAuditLog[]

  // Cross-references — by reading not enforced (polymorphic on
  // documentType). Per ADR-001 we avoid hard FKs across module
  // boundaries; lookups happen at service layer.

  // Uniqueness — one document number per (supplier, FY, type).
  // The composite is enforced at the application layer via
  // DocumentSequenceService; this index provides the DB check.
  // For LEGACY_RECEIPT with supplierGstin = NULL, Postgres NULLS
  // DISTINCT lets multiple legacy receipts coexist — adequate since
  // LEGACY_RECEIPT numbers are platform-wide and generated by the
  // dedicated 'PLATFORM' sequence key (see DocumentSequenceService).
  @@unique([supplierGstin, financialYear, documentType, documentNumber], map: "tax_documents_supplier_fy_type_num_uniq")
  @@index([masterOrderId])
  @@index([subOrderId])
  @@index([posSaleId])
  @@index([sellerId])
  @@index([customerId])
  // Phase 161 (Platform GST Profile audit B3) — "all invoices under profile X".
  @@index([platformGstProfileId])
  // Phase 161 (Customer Tax Profile audit B2) — "all invoices to buyer profile X".
  @@index([customerTaxProfileId])
  @@index([documentType])
  @@index([status])
  @@index([financialYear])
  @@index([generatedAt])
  @@index([buyerGstin])
  // Phase 90 (2026-05-23) — Gap #4 unique-IRN search. The partial
  // UNIQUE on irn (created in the 091000 migration) doubles as a
  // search lookup; this btree index is for the admin queue filter
  // by IRN substring.
  @@index([irn])
  @@index([einvoiceStatus, einvoiceLastAttemptedAt])
  // Phase 164 (Credit Note Generation audit #7) — the prior-CN lookup +
  // cumulative-reversal scan filter by (originalDocumentId [, status]).
  // Without this they are full-table scans on a growing tax_documents.
  @@index([originalDocumentId, status])
  // Phase 164 (#1/#2) — query "the CN(s) for this return" without a text scan.
  @@index([returnId])
  // Phase 163 (Tax Audit Readiness audit #7) — back the readiness scans
  // that filter by (status, retryCount). The leading single-column status
  // index can't serve `einvoiceStatus IN (...) AND einvoiceRetryCount >= N`
  // without re-scanning; these composites do.
  @@index([einvoiceStatus, einvoiceRetryCount])
  @@index([status, pdfRetryCount])
  @@index([signedDocumentJsonRetentionUntil])
  @@map("tax_documents")
}

// Phase 90 (2026-05-23) — Gap #20 chain of custody.
//
// Append-only audit log for the IRN lifecycle. Pre-Phase-90 the
// TaxDocument's own fields were the only audit artifact — mint and
// cancel were single-actor mutations with no trail. This table
// records every CLASSIFY / MINT / CANCEL / RETRY / RESET_RETRY /
// EXHAUSTED action with before/after snapshots so dispute reviews
// can replay the row state.
model EInvoiceAuditLog {
  id                String          @id @default(uuid())
  taxDocumentId     String          @map("tax_document_id")
  action            String
  fromStatus        EInvoiceStatus? @map("from_status")
  toStatus          EInvoiceStatus? @map("to_status")
  actorId           String?         @map("actor_id")
  actorRole         String?         @map("actor_role")
  reason            String?         @db.Text
  providerName      String?         @map("provider_name")
  providerLatencyMs Int?            @map("provider_latency_ms")
  payloadBefore     Json?           @map("payload_before")
  payloadAfter      Json?           @map("payload_after")
  ipAddress         String?         @map("ip_address")
  createdAt         DateTime        @default(now()) @map("created_at")

  taxDocument TaxDocument @relation(fields: [taxDocumentId], references: [id], onDelete: Restrict)

  @@index([taxDocumentId, createdAt(sort: Desc)])
  @@index([action, createdAt])
  @@index([actorId, createdAt])
  @@map("einvoice_audit_logs")
}

model TaxDocumentLine {
  id               String      @id @default(uuid())
  documentId       String      @map("document_id")
  // Source snapshot row this line was rendered from (Phase 5
  // OrderItemTaxSnapshot). One line per snapshot row.
  sourceSnapshotId String?     @map("source_snapshot_id")
  // Sequence within the document — preserved across re-renders.
  lineNumber       Int         @map("line_number")
  lineType         TaxLineType @map("line_type")

  // Snapshotted line context
  productId        String? @map("product_id")
  variantId        String? @map("variant_id")
  productName      String  @map("product_name")
  sku              String? @map("sku")
  hsnOrSacCode     String? @map("hsn_or_sac_code")
  uqcCode          String? @map("uqc_code")
  quantity         Decimal @db.Decimal(12, 3)
  unitPriceInPaise BigInt  @map("unit_price_in_paise")

  // Money (line-level)
  grossAmountInPaise    BigInt @default(0) @map("gross_amount_in_paise")
  discountAmountInPaise BigInt @default(0) @map("discount_amount_in_paise")
  taxableAmountInPaise  BigInt @default(0) @map("taxable_amount_in_paise")
  gstRateBps            Int    @default(0) @map("gst_rate_bps")
  // Phase 159y (GSTR-3B audit #2) — per-line supply classification, captured
  // at invoice generation from the line's HSN/tax snapshot. Lets the GSTR-3B
  // export populate §3.1(b) zero-rated / (c) nil-rated+exempt / (e) non-GST
  // instead of hard-coding them to 0. Nullable: lines written before 159y are
  // treated as TAXABLE (the §3.1(a) default), so historical reports don't shift.
  supplyTaxability      SupplyTaxability? @map("supply_taxability")
  cgstAmountInPaise     BigInt @default(0) @map("cgst_amount_in_paise")
  sgstAmountInPaise     BigInt @default(0) @map("sgst_amount_in_paise")
  igstAmountInPaise     BigInt @default(0) @map("igst_amount_in_paise")
  totalTaxAmountInPaise BigInt @default(0) @map("total_tax_amount_in_paise")
  cessAmountInPaise     BigInt @default(0) @map("cess_amount_in_paise")
  lineTotalInPaise      BigInt @default(0) @map("line_total_in_paise")
  currencyCode          String @default("INR") @map("currency_code")

  createdAt DateTime @default(now()) @map("created_at")

  document TaxDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, lineNumber], map: "tax_document_lines_doc_line_num_uniq")
  @@index([documentId])
  @@index([sourceSnapshotId])
  @@index([lineType])
  @@map("tax_document_lines")
}

// Per-(supplier-gstin, FY, document-type) monotonic number sequence.
// Each row is the high-water mark for one logical series. Numbers
// never reuse; cancelled / voided documents get their numbers
// "burned" (the sequence still advances). Audit trail of skipped
// numbers lives in `skipped_numbers` JSON.
//
// Concurrency: DocumentSequenceService uses
//   INSERT ... ON CONFLICT (sequence_key) DO UPDATE
//     SET last_number = lastNumber + 1
//     RETURNING last_number, prefix
// — atomic, no SERIALIZABLE transaction, no race window.
//
// sequence_key shape: "{supplierGstin or 'PLATFORM'}|{FY}|{documentType}"
// Example: "36ABCDE1234F1Z5|2026-27|TAX_INVOICE"
model DocumentSequence {
  id             String       @id @default(uuid())
  sequenceKey    String       @unique @map("sequence_key")
  // Supplier identity — null when sequence is platform-wide (LEGACY_RECEIPT).
  supplierGstin  String?      @map("supplier_gstin")
  financialYear  String       @map("financial_year")
  documentType   DocumentType @map("document_type")
  prefix         String // "SM-INV", "SM-BOS", etc.
  lastNumber     Int          @default(0) @map("last_number")
  // Numbers burnt by voided drafts / cancellations — JSON array of
  // integers. Lets ops prove "we accounted for every number" during
  // GSTR-1 review.
  skippedNumbers Json         @default("[]") @map("skipped_numbers")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@index([supplierGstin, financialYear, documentType])
  @@map("document_sequences")
}

// Phase 163 (Tax Audit Readiness audit #16) — point-in-time snapshots of
// the readiness posture. Written by the 6-hourly readiness-snapshot cron
// so the dashboard can answer "is readiness improving?" (trend) and a
// forensic review can reconstruct "how many blockers existed on date X?".
// Append-only; never updated. blockersJson holds the full BlockerSummary[]
// for that snapshot (severity + per-code counts).
model TaxReadinessSnapshot {
  id              String   @id @default(uuid())
  // Tax engine mode at snapshot time (OFF / AUDIT / STRICT).
  currentMode     String   @map("current_mode")
  ready           Boolean  @map("ready")
  totalBlockers   Int      @map("total_blockers")
  criticalBlockers Int     @default(0) @map("critical_blockers")
  // Full BlockerSummary[] (code, severity, resourceType, count, sampleIds).
  blockersJson    Json     @map("blockers_json")
  generatedAt     DateTime @map("generated_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([generatedAt(sort: Desc)])
  @@map("tax_readiness_snapshots")
}
