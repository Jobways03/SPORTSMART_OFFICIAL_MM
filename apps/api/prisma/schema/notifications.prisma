// Notifications module — log of every send attempt across channels.
//
// Rows are append-only audit trail: one row per job-attempt. The
// queue (Redis list `notifications:queue`) holds *pending* work; once
// the worker dequeues a job it inserts a row here per attempt with
// status QUEUED → SENT or FAILED. Retried jobs get fresh rows so the
// history is preserved.

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
}

enum NotificationStatus {
  QUEUED // accepted, not yet processed by worker
  SENT // provider returned success
  FAILED // provider returned a non-retryable error
  RETRY // transient failure; will be re-enqueued
}

// Editable templates per (event_key, channel). Worker fetches by key
// and renders Handlebars-style `{{vars}}` against the event payload.
// Code-side fallbacks live in `template-registry.service.ts` so the
// system delivers something sensible even before the table is seeded.
model NotificationTemplate {
  id          String              @id @default(uuid())
  key         String              @unique // e.g. "order.placed.email"
  channel     NotificationChannel
  subject     String? // EMAIL only — null for SMS/WhatsApp
  body        String              @db.Text
  description String?
  active      Boolean             @default(true)
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  @@map("notification_templates")
}

// Per-user opt-in/out. Convention: opt-in is the default — the absence
// of a row means "enabled". Users opt out by inserting `enabled=false`.
// `eventClass` is intentionally coarse (order / refund / ticket /
// wallet / marketing) so users can mute marketing without losing
// transactional alerts.
model NotificationPreference {
  id         String              @id @default(uuid())
  userId     String              @map("user_id")
  eventClass String              @map("event_class")
  channel    NotificationChannel
  enabled    Boolean             @default(true)
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")

  @@unique([userId, eventClass, channel])
  @@index([userId])
  @@map("notification_preferences")
}

/// Phase 8 (PR 8.2) — hard-block list per (channel, destination).
///
/// A row here forces the gate to deny, regardless of user preferences.
/// Used for:
///   - Bounced email addresses (provider permanent-fail).
///   - Spam-complaint reports (we MUST stop sending).
///   - Court-ordered cease-and-desist.
///
/// Distinct from NotificationPreference because the suppression is
/// keyed on the destination string (raw email / phone), not on the
/// user — a user with multiple emails has independent suppression
/// status per address.
model NotificationSuppression {
  id          String              @id @default(uuid())
  channel     NotificationChannel
  destination String
  /// Free-form reason. Common values: "BOUNCED" | "SPAM_COMPLAINT" |
  /// "COMPLIANCE_REQUEST" | "MANUAL_BLOCK".
  reason      String
  /// Optional. When set, the gate ignores the suppression after this
  /// timestamp — used for time-bounded blocks (e.g. "back off 24h
  /// after a transient bounce").
  expiresAt   DateTime?           @map("expires_at")
  /// Free-form actor identifier. Set when a human added the entry;
  /// null for automated additions.
  addedBy     String?             @map("added_by")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  @@unique([channel, destination])
  @@index([destination])
  @@index([expiresAt])
  @@map("notification_suppressions")
}

/// Phase 6 (2026-05-16) — WhatsApp session-window + opt-out state.
///
/// WhatsApp Cloud API constrains outbound messages:
///   • Inside a 24-hour "customer service window" from the user's last
///     inbound message, free-form text is allowed.
///   • Outside the window, only pre-approved HSM templates (with
///     placeholder parameters) may be sent.
///   • Users can opt out at any time by replying STOP / UNSUBSCRIBE.
///     Sending after opt-out is a TOS violation and degrades sender
///     reputation.
///
/// One row per E.164 phone number. The send gate looks up the row,
/// blocks if `optedOutAt` is non-null, and decides text-vs-template
/// from `lastInboundAt`. The inbound webhook updates both fields.
model WhatsappSession {
  id         String  @id @default(uuid())
  /// E.164 phone number without leading "+". Always digits-only so
  /// lookup keys stay stable regardless of how upstream formatted it.
  phoneE164  String  @unique @map("phone_e164")
  /// Optional link to a customer record. Helps ops correlate without
  /// joining via Customer.phoneNumber, which may differ in formatting.
  customerId String? @map("customer_id")

  /// Last inbound message timestamp from this phone. The 24-hour
  /// customer service window starts here. NULL = never replied.
  lastInboundAt  DateTime? @map("last_inbound_at")
  /// Latest outbound timestamp — diagnostic only, not used for gating.
  lastOutboundAt DateTime? @map("last_outbound_at")

  /// When opt-out was recorded. NULL = opted in. Setting this to a
  /// non-null value hard-blocks every outbound to this phone, including
  /// templates, until manually cleared by a compliance request.
  optedOutAt   DateTime? @map("opted_out_at")
  /// Free-form opt-out source: "USER_STOP" | "USER_UNSUBSCRIBE" |
  /// "MANUAL_BLOCK" | "BOUNCED".
  optOutReason String?   @map("opt_out_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([customerId])
  @@index([optedOutAt])
  @@map("whatsapp_sessions")
}

/// Phase 6 (2026-05-16) — raw inbound WhatsApp messages.
///
/// Append-only log of every message Meta forwards to our webhook.
/// Keep the original payload so we can replay if the parsing logic
/// changes. The session row is updated separately and is the source
/// of truth for the 24h window.
model WhatsappInbound {
  id                String   @id @default(uuid())
  /// Provider message id from Meta — used for dedupe (webhook can
  /// deliver the same message multiple times under retry).
  providerMessageId String   @unique @map("provider_message_id")
  /// Sender E.164, digits-only.
  fromPhoneE164     String   @map("from_phone_e164")
  /// Message type from Meta: "text" | "interactive" | "button" | ...
  messageType       String   @map("message_type")
  /// Extracted plain-text body for STOP-keyword detection. May be
  /// empty for non-text messages (sticker, image, etc.).
  textBody          String?  @map("text_body") @db.Text
  /// Whether STOP-keyword detection fired on this message.
  isOptOutSignal    Boolean  @default(false) @map("is_opt_out_signal")
  /// Original Meta webhook payload. Stored as JSON for replay/debug.
  rawPayload        Json     @map("raw_payload")
  receivedAt        DateTime @default(now()) @map("received_at")

  @@index([fromPhoneE164, receivedAt(sort: Desc)])
  @@index([receivedAt(sort: Desc)])
  @@map("whatsapp_inbound")
}

model NotificationLog {
  id      String              @id @default(uuid())
  channel NotificationChannel
  status  NotificationStatus

  // Recipient identity. Either a platform user id (lookup name/email
  // from User/Seller/etc) OR a raw destination string for ad-hoc sends.
  recipientId String? @map("recipient_id")
  destination String // email address, phone number, or wa.me id

  // Optional template the worker rendered + variables passed in.
  templateKey String? @map("template_key")
  subject     String?
  body        String  @db.Text

  // What triggered this notification. e.g. ('order', '<order-id>'),
  // ('refund', '<refund-id>'), ('ticket', '<ticket-id>'). Lets ops
  // trace "why did this email get sent?".
  eventType String? @map("event_type")
  eventId   String? @map("event_id")

  // Provider response on success / error message on failure.
  providerMessageId String? @map("provider_message_id")
  failureReason     String? @map("failure_reason") @db.Text

  // Retry bookkeeping. attemptNumber starts at 1.
  attemptNumber Int @default(1) @map("attempt_number")

  createdAt DateTime  @default(now()) @map("created_at")
  sentAt    DateTime? @map("sent_at")

  @@index([recipientId, createdAt(sort: Desc)])
  @@index([eventType, eventId])
  @@index([channel, status, createdAt(sort: Desc)])
  @@map("notification_logs")
}
