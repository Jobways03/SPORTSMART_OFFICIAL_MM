// ============================================
// Seller Module - owned tables
// ============================================

model Seller {
  id                  String       @id @default(uuid())
  sellerName          String       @map("seller_name")
  sellerShopName      String       @map("seller_shop_name")
  email               String       @unique
  phoneNumber         String       @unique @map("phone_number")
  passwordHash        String       @map("password_hash")
  status              SellerStatus @default(PENDING_APPROVAL)
  failedLoginAttempts Int          @default(0) @map("failed_login_attempts")
  lockUntil           DateTime?    @map("lock_until")
  lastLoginAt         DateTime?    @map("last_login_at")

  // Profile fields
  sellerContactCountryCode    String?                  @map("seller_contact_country_code")
  sellerContactNumber         String?                  @map("seller_contact_number")
  storeAddress                String?                  @map("store_address")
  locality                    String?
  city                        String?
  state                       String?
  country                     String?
  sellerZipCode               String?                  @map("seller_zip_code")
  shortStoreDescription       String?                  @map("short_store_description")
  detailedStoreDescription    String?                  @map("detailed_store_description")
  sellerPolicy                String?                  @map("seller_policy")
  sellerProfileImageUrl       String?                  @map("seller_profile_image_url")
  sellerProfileImagePublicId  String?                  @map("seller_profile_image_public_id")
  sellerShopLogoUrl           String?                  @map("seller_shop_logo_url")
  sellerShopLogoPublicId      String?                  @map("seller_shop_logo_public_id")
  profileCompletionPercentage Int                      @default(0) @map("profile_completion_percentage")
  isEmailVerified             Boolean                  @default(false) @map("is_email_verified")
  verificationStatus          SellerVerificationStatus @default(NOT_VERIFIED) @map("verification_status")
  isProfileCompleted          Boolean                  @default(false) @map("is_profile_completed")
  lastProfileUpdatedAt        DateTime?                @map("last_profile_updated_at")

  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  // ─── GST fields (Phase 1 GST — 2026-05-13) ─────────────────────
  // Primary GSTIN summary on Seller. Detailed multi-GSTIN records
  // live in SellerGstin (one row per state-registered GSTIN).
  // For sellers with a single GSTIN, only this summary block is
  // required + one SellerGstin row marked isPrimary=true.
  // The free-text `state` field above remains for legacy reasons;
  // `gstStateCode` is the canonical 2-digit GST code used by the
  // tax engine. CA review TODO: data-migrate `state` → `gstStateCode`.
  //
  // Verification: admin runs GST format check + (optionally) GST-
  // portal lookup; isGstVerified flips true once approved. Composition
  // sellers issue Bill of Supply rather than Tax Invoice.
  //
  // See docs/tax/GST_ASSUMPTIONS.md §11 (composition seller policy).
  gstin                         String?              @map("gstin")
  legalBusinessName             String?              @map("legal_business_name")
  registeredBusinessAddressJson Json?                @map("registered_business_address_json")
  gstStateCode                  String?              @map("gst_state_code")
  gstRegistrationType           GstRegistrationType  @default(REGULAR) @map("gst_registration_type")
  isGstVerified                 Boolean              @default(false) @map("is_gst_verified")
  gstVerifiedAt                 DateTime?            @map("gst_verified_at")
  gstVerifiedBy                 String?              @map("gst_verified_by")
  gstVerificationNotes          String?              @map("gst_verification_notes")
  // PAN (positions 3-12 of GSTIN). Stored separately for cross-
  // validation. panLast4 used for masked display in admin UI.
  panNumber                     String?              @map("pan_number")
  panLast4                      String?              @map("pan_last_4")
  panVerified                   Boolean              @default(false) @map("pan_verified")

  // ─── Logistics entitlements (admin-controlled) ────────────────
  // Toggled by marketplace admin in web-admin-storefront. The seller
  // picks the actual delivery method per shipment from whatever is
  // enabled here.
  ithinkEnabled         Boolean                       @default(false) @map("ithink_enabled")
  ithinkPickupAddressId String?                       @map("ithink_pickup_address_id")
  ithinkWarehouseStatus IThinkWarehouseApprovalStatus @default(NOT_REGISTERED) @map("ithink_warehouse_status")
  ithinkRegisteredAt    DateTime?                     @map("ithink_registered_at")
  // SHA-256 of (storeAddress + city + state + sellerZipCode +
  // sellerContactNumber) captured at registration time. Profile
  // updates re-compute and compare to detect drift.
  ithinkRegisteredAddressHash String?                 @map("ithink_registered_address_hash")
  selfDeliveryEnabled   Boolean                       @default(false) @map("self_delivery_enabled")
  // Optional pincode allowlist for self-delivery service area. JSON
  // array of pincode strings. NULL = serve everywhere the seller
  // operates; empty array = self-delivery disabled by area.
  selfDeliveryPincodes Json? @map("self_delivery_pincodes")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sessions          SellerSession[]
  passwordResetOtps SellerPasswordResetOtp[]
  products          Product[]
  productMappings   SellerProductMapping[]
  serviceAreas      SellerServiceArea[]
  subOrders         SubOrder[]
  commissionRecords CommissionRecord[]
  sellerSettlements SellerSettlement[]
  gstins            SellerGstin[]      // Phase 1 GST — multi-GSTIN support
  // Phase 16 GST — TCS (Section 52) settlement ledger rows per
  // (sellerId, filingPeriod). One ACTIVE (non-REVERSED) row per
  // pairing enforced by partial UNIQUE index in the migration.
  gstTcsSettlements GstTcsSettlementLedger[]

  @@index([status])
  @@index([isProfileCompleted])
  @@index([isDeleted])
  @@index([verificationStatus])
  @@map("sellers")
}

model SellerSession {
  id           String    @id @default(uuid())
  sellerId     String    @map("seller_id")
  refreshToken String    @map("refresh_token")
  userAgent    String?   @map("user_agent")
  ipAddress    String?   @map("ip_address")
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
  @@index([refreshToken])
  @@map("seller_sessions")
}

model SellerPasswordResetOtp {
  id          String    @id @default(uuid())
  sellerId    String    @map("seller_id")
  otpHash     String    @map("otp_hash")
  purpose     String    @default("PASSWORD_RESET")
  attempts    Int       @default(0)
  maxAttempts Int       @default(5) @map("max_attempts")
  verifiedAt  DateTime? @map("verified_at")
  resetToken  String?   @unique @map("reset_token")
  usedAt      DateTime? @map("used_at")
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
  @@map("seller_password_reset_otps")
}
