// ============================================
// Seller Module - owned tables
// ============================================

/// Legal entity type captured at KYC onboarding (MCA business structures).
/// Shared by Seller and Franchise. Nullable on the models for legacy rows.
enum BusinessEntityType {
  PUBLIC_LIMITED
  PRIVATE_LIMITED
  SOLE_PROPRIETORSHIP
  GENERAL_PARTNERSHIP
  LLP
}

model Seller {
  id                  String       @id @default(uuid())
  // Phase 38 — discriminator that scopes the seller to a single
  // admin team + portal (D2C vs RETAIL). Existing rows are
  // backfilled to D2C in the migration; new rows must declare it
  // at onboarding via the seller-type-specific portal.
  sellerType          SellerType   @default(D2C) @map("seller_type")
  sellerName          String       @map("seller_name")
  sellerShopName      String       @map("seller_shop_name")
  email               String       @unique
  phoneNumber         String       @unique @map("phone_number")
  passwordHash        String       @map("password_hash")
  status              SellerStatus @default(PENDING_APPROVAL)
  failedLoginAttempts Int          @default(0) @map("failed_login_attempts")
  lockUntil           DateTime?    @map("lock_until")
  lastLoginAt         DateTime?    @map("last_login_at")
  // Phase 179 (Top Performers audit #16) — internal/demo/test seller, excluded
  // from public leaderboards & rankings. Default false; ops flips it for seed
  // and QA accounts so they never surface in performance reports.
  isInternal          Boolean      @default(false) @map("is_internal")

  // Profile fields
  sellerContactCountryCode    String?                  @map("seller_contact_country_code")
  sellerContactNumber         String?                  @map("seller_contact_number")
  storeAddress                String?                  @map("store_address")
  locality                    String?
  city                        String?
  state                       String?
  country                     String?
  sellerZipCode               String?                  @map("seller_zip_code")
  shortStoreDescription       String?                  @map("short_store_description")
  detailedStoreDescription    String?                  @map("detailed_store_description")
  sellerPolicy                String?                  @map("seller_policy")
  sellerProfileImageUrl       String?                  @map("seller_profile_image_url")
  sellerProfileImagePublicId  String?                  @map("seller_profile_image_public_id")
  sellerShopLogoUrl           String?                  @map("seller_shop_logo_url")
  sellerShopLogoPublicId      String?                  @map("seller_shop_logo_public_id")
  profileCompletionPercentage Int                      @default(0) @map("profile_completion_percentage")
  isEmailVerified             Boolean                  @default(false) @map("is_email_verified")
  /// Phase 18 (2026-05-20) — exact verification timestamp. The
  /// boolean isEmailVerified answers "verified now?"; the timestamp
  /// answers "exactly when did the OTP-verify transaction land?"
  /// Needed for compliance audit + the future re-verify-on-email-change
  /// path. Nullable because legacy rows verified before this column
  /// existed have no timestamp.
  emailVerifiedAt             DateTime?                @map("email_verified_at")
  verificationStatus          SellerVerificationStatus @default(NOT_VERIFIED) @map("verification_status")
  /// Profile approval lock (2026-06). Set true when an admin APPROVES the
  /// seller (verificationStatus → VERIFIED): the profile page becomes
  /// read-only for the seller and all changes go through the admin's edit
  /// endpoint (which ignores this flag). Cleared on rejection so the seller
  /// can fix & resubmit. Decoupled from status/verificationStatus so an admin
  /// can re-open self-editing later without de-verifying KYC.
  profileLocked               Boolean                  @default(false) @map("profile_locked")
  isProfileCompleted          Boolean                  @default(false) @map("is_profile_completed")
  lastProfileUpdatedAt        DateTime?                @map("last_profile_updated_at")

  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  // ─── GST fields (Phase 1 GST — 2026-05-13) ─────────────────────
  // Primary GSTIN summary on Seller. Detailed multi-GSTIN records
  // live in SellerGstin (one row per state-registered GSTIN).
  // For sellers with a single GSTIN, only this summary block is
  // required + one SellerGstin row marked isPrimary=true.
  // The free-text `state` field above remains for legacy reasons;
  // `gstStateCode` is the canonical 2-digit GST code used by the
  // tax engine. CA review TODO: data-migrate `state` → `gstStateCode`.
  //
  // Verification: admin runs GST format check + (optionally) GST-
  // portal lookup; isGstVerified flips true once approved. Composition
  // sellers issue Bill of Supply rather than Tax Invoice.
  //
  // See docs/tax/GST_ASSUMPTIONS.md §11 (composition seller policy).
  /// Phase 19 (2026-05-20) — @unique pins legal-entity uniqueness.
  /// Two sellers cannot claim the same GSTIN. Postgres treats NULL
  /// as distinct so multiple pre-onboarding rows with `gstin=NULL`
  /// coexist; once submitted, the value must be unique.
  gstin                         String?             @unique @map("gstin")
  legalBusinessName             String?             @map("legal_business_name")
  /// Legal entity type (company / partnership / proprietorship), captured
  /// at KYC submit. Nullable for rows created before this field existed.
  entityType                    BusinessEntityType? @map("entity_type")
  registeredBusinessAddressJson Json?               @map("registered_business_address_json")
  gstStateCode                  String?             @map("gst_state_code")
  gstRegistrationType           GstRegistrationType @default(REGULAR) @map("gst_registration_type")
  isGstVerified                 Boolean             @default(false) @map("is_gst_verified")
  gstVerifiedAt                 DateTime?           @map("gst_verified_at")
  gstVerifiedBy                 String?             @map("gst_verified_by")
  /// Phase 19 (2026-05-20) — historical "admin notes" column. Kept
  /// for backward-compat reads on legacy rows; new approvals write to
  /// `kycApprovalNotes` and rejections write to `kycRejectionReason`
  /// instead of overloading this field.
  gstVerificationNotes          String?             @map("gst_verification_notes")
  /// Phase 19 (2026-05-20) — split from the overloaded
  /// `gstVerificationNotes`. Free-text notes the admin attached on
  /// the approve action (e.g. "verified GSTIN against GSTN portal,
  /// match confirmed").
  kycApprovalNotes              String?             @map("kyc_approval_notes")
  /// Phase 19 (2026-05-20) — split from the overloaded
  /// `gstVerificationNotes`. The exact reason the admin gave for
  /// rejection. Surfaced to the seller in the onboarding UI so they
  /// can fix and resubmit. Replaced by a fresh value on each reject.
  kycRejectionReason            String?             @map("kyc_rejection_reason")
  /// Phase 19 (2026-05-20) — when the most recent admin review
  /// (approve OR reject) was decided. Distinct from
  /// `gstVerifiedAt` which is now reserved for actual GSTN-portal
  /// verification (Phase 19 split).
  kycReviewedAt                 DateTime?           @map("kyc_reviewed_at")
  /// Phase 19 (2026-05-20) — the admin who decided.
  kycReviewedBy                 String?             @map("kyc_reviewed_by")
  /// Phase 19 (2026-05-20) — DPDP / consent-archive: stamps when the
  /// seller ticked "I confirm the information is accurate" on the
  /// KYC submit form. Required for the audit trail; complements the
  /// AuditLog row written by the use case.
  kycConfirmedAccurateAt        DateTime?           @map("kyc_confirmed_accurate_at")
  /// Phase 19 (2026-05-20) — split from `isGstVerified` which was
  /// auto-flipped on admin approval (the audit flagged that as
  /// misleading: approval ≠ GSTN-portal verification). This new
  /// flag flips true ONLY when a separate admin action runs an
  /// actual GSTN-portal lookup. `isGstVerified` is now retained for
  /// backward-compat but no longer auto-flipped by approve.
  isGstinManuallyVerified       Boolean             @default(false) @map("is_gstin_manually_verified")
  /// PAN (positions 3-12 of GSTIN). Stored separately for cross-
  /// validation. panLast4 used for masked display in admin UI.
  ///
  /// Phase 19 (2026-05-20) — @unique pins legal-entity uniqueness.
  /// Same NULL-distinctness as the GSTIN field above.
  panNumber                     String?             @unique @map("pan_number")
  panLast4                      String?             @map("pan_last_4")
  panVerified                   Boolean             @default(false) @map("pan_verified")

  // Phase 27 — Section 194-O sub-threshold exemption.
  // Individual / HUF sellers whose projected aggregate FY gross sale
  // stays under ₹5,00,000 AND who furnish PAN/Aadhaar are exempt
  // from Section 194-O TDS. Admin attests this at onboarding /
  // annual review; flipping back to false re-arms TDS deduction
  // from the next settlement cycle. See docs/tax/TDS_194O_POLICY.md.
  is194OExempt         Boolean   @default(false) @map("is_194o_exempt")
  exempt194OReason     String?   @map("exempt_194o_reason")
  exempt194OAttestedBy String?   @map("exempt_194o_attested_by")
  exempt194OAttestedAt DateTime? @map("exempt_194o_attested_at")
  // Phase 161 (TDS 194-O exempt audit B1) — effective-dating. The TDS
  // compute treats a seller as exempt for a filing period only when the
  // period START falls within [effectiveFrom, effectiveTo). This makes the
  // decision deterministic per-period (resolves the mid-cycle toggle race)
  // and enables annual revalidation: effectiveTo lets an exemption expire,
  // and the revalidation cron flags / revokes stale ones. NULL effectiveFrom
  // = no lower bound (legacy exempt rows backfilled this way stay exempt).
  exempt194OEffectiveFrom DateTime? @map("exempt_194o_effective_from")
  exempt194OEffectiveTo   DateTime? @map("exempt_194o_effective_to")
  // Phase 161 (audit B4) — revocation trail. Un-exempting NO LONGER nulls the
  // attestation fields (history loss); it stamps these instead, preserving
  // "this seller was exempt … attested by X for reason Y" as last-known-good.
  exempt194ORevokedBy     String?   @map("exempt_194o_revoked_by")
  exempt194ORevokedAt     DateTime? @map("exempt_194o_revoked_at")
  exempt194ORevokeReason  String?   @map("exempt_194o_revoke_reason")

  // ─── Logistics entitlements (admin-controlled) ────────────────
  // Toggled by marketplace admin in web-admin-storefront. Self-delivery
  // is the only delivery method today (iThink removed).
  selfDeliveryEnabled         Boolean                       @default(false) @map("self_delivery_enabled")
  // Optional pincode allowlist for self-delivery service area. JSON
  // array of pincode strings. NULL = serve everywhere the seller
  // operates; empty array = self-delivery disabled by area.
  selfDeliveryPincodes        Json?                         @map("self_delivery_pincodes")

  // Phase 75 (2026-05-22) — Phase 73 reject-flow audit Gap #25.
  // Per-seller accept SLA. Pre-Phase-75 every sub-order got the
  // hard-coded 24h `ACCEPT_DEADLINE_MS`; a premium seller with a
  // contractual 1h SLA got the same window as a slow seller. NULL
  // falls back to the platform default (24h). Range 1..168 (1h to
  // 7d) — service-layer guard.
  acceptSlaHours Int? @map("accept_sla_hours")

  // Phase 230/232 (Eligible-node + Allocation-preview audit) — manual
  // fulfillment hold. A seller under fraud investigation / compliance review is
  // flipped to true; the allocator then excludes them from eligibility entirely
  // (not just down-ranked), so a flagged seller cannot be auto-routed or
  // manually reassigned new orders. Independent of `status` (a seller can be
  // ACTIVE for login/catalog but on a fulfillment hold). Default false = no
  // regression. The reason is surfaced to ops + stamped in the audit trail.
  fulfillmentHold       Boolean   @default(false) @map("fulfillment_hold")
  fulfillmentHoldReason String?   @map("fulfillment_hold_reason") @db.Text
  fulfillmentHoldAt     DateTime? @map("fulfillment_hold_at")
  fulfillmentHoldBy     String?   @map("fulfillment_hold_by")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sessions          SellerSession[]
  passwordResetOtps SellerPasswordResetOtp[]
  products          Product[]
  productMappings   SellerProductMapping[]
  serviceAreas      SellerServiceArea[]
  subOrders         SubOrder[]
  commissionRecords CommissionRecord[]
  sellerSettlements SellerSettlement[]
  gstins            SellerGstin[] // Phase 1 GST — multi-GSTIN support
  // Phase 16 GST — TCS (Section 52) settlement ledger rows per
  // (sellerId, filingPeriod). One ACTIVE (non-REVERSED) row per
  // pairing enforced by partial UNIQUE index in the migration.
  gstTcsSettlements GstTcsSettlementLedger[]
  // Phase 27 — Section 194-O Income-Tax TDS ledger rows per
  // (sellerId, filingPeriod) quarterly. One active row per pairing
  // enforced by partial UNIQUE index in the migration.
  tds194OLedgers    Section194OTdsLedger[]
  // Phase 19 (2026-05-20) — single-row 1:1 back-relation. Most
  // sellers will have exactly one bank-details record; the unique
  // constraint on SellerBankDetails.sellerId enforces 1:1.
  bankDetails       SellerBankDetails?

  // Logistics partner registrations — one row per (seller, partner)
  // pair. Tracks whether the seller's pickup address has been
  // registered as a "warehouse" with each courier that requires it
  // (Delhivery). Driven by the admin "Add pickup location to
  // {Partner}" button on the seller detail page. Idempotent: a
  // re-register call updates the existing row in place.
  partnerRegistrations SellerPartnerRegistration[]

  @@index([status])
  @@index([isProfileCompleted])
  @@index([isDeleted])
  @@index([verificationStatus])
  @@index([sellerType])
  // Phase 161 (TDS 194-O exempt audit #1/B1) — revalidation cron scans the
  // active-exempt set + the expiry tail.
  @@index([is194OExempt, exempt194OEffectiveTo])
  // Phase 230 — ops "sellers on fulfillment hold" queue + the allocator's
  // exclusion filter both scan by this flag.
  @@index([fulfillmentHold])
  @@map("sellers")
}

// Phase 161 (TDS 194-O exempt audit #6) — append-only history of every
// §194-O exemption / revocation. The Seller row holds only the current
// state + last-known-good attestation; this answers "was seller X exempt
// during FY26-27, attested by whom, for what reason". No FK to Seller so
// the trail survives an (unlikely) seller deletion — same design as the
// other tax history tables.
model SellerTdsExemptionHistory {
  id           String    @id @default(uuid())
  sellerId     String    @map("seller_id")
  // EXEMPT (granted) | REVOKE (cleared) | REVALIDATE (cron auto-action)
  action       String
  isExempt     Boolean   @map("is_exempt")
  reason       String?   @db.Text
  effectiveFrom DateTime? @map("effective_from")
  effectiveTo  DateTime? @map("effective_to")
  changedBy    String?   @map("changed_by")
  changeReason String?   @db.Text @map("change_reason")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([sellerId, createdAt(sort: Desc)])
  @@map("seller_tds_exemption_history")
}

model SellerSession {
  id                       String    @id @default(uuid())
  sellerId                 String    @map("seller_id")
  /// Phase 21 (2026-05-20) — Stored as SHA-256 hex of the raw refresh
  /// token via `hashRefreshToken()` in core/auth/refresh-token.ts. The
  /// DB column is `refresh_token_hash` (see migration
  /// 20260520180000_seller_session_hardening). The Prisma field name
  /// stays `refreshToken` for backward-compat with existing callers.
  refreshToken             String    @map("refresh_token_hash")
  // Phase 1 / C6 — refresh-token reuse detection. See AdminSession
  // for the contract.
  previousRefreshTokenHash String?   @map("previous_refresh_token_hash")
  userAgent                String?   @map("user_agent")
  ipAddress                String?   @map("ip_address")
  expiresAt                DateTime  @map("expires_at")
  revokedAt                DateTime? @map("revoked_at")
  /// Phase 27 (2026-05-21) — forensic columns; see identity.prisma.
  revokedBy                String?   @map("revoked_by")
  revocationReason         String?   @map("revocation_reason") @db.Text
  /// Phase 27 (2026-05-21) — bumped on each refresh-rotation.
  lastUsedAt               DateTime? @map("last_used_at")
  /// Phase 27 (2026-05-21) — UA-derived label.
  deviceLabel              String?   @map("device_label") @db.VarChar(64)
  createdAt                DateTime  @default(now()) @map("created_at")

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
  @@index([refreshToken])
  @@index([previousRefreshTokenHash])
  // Phase 21 (2026-05-20) — composite index for SellerAuthGuard's
  // per-request "is this session still valid for this seller" lookup.
  @@index([sellerId, revokedAt])
  @@map("seller_sessions")
}

/// Phase 18 (2026-05-20) — Seller OTP table.
///
/// Despite the historical name `SellerPasswordResetOtp`, this table
/// now stores OTPs for BOTH password-reset and email-verification
/// purposes — distinguished by the `purpose` column. We deliberately
/// did NOT rename the model: renaming would force a Prisma client
/// regen + touch 30+ callers. The TypeScript-side `SellerOtpPurpose`
/// union pins the legal values; new purposes added here must update
/// the union in `seller.repository.interface.ts`.
model SellerPasswordResetOtp {
  id          String    @id @default(uuid())
  sellerId    String    @map("seller_id")
  otpHash     String    @map("otp_hash")
  purpose     String    @default("PASSWORD_RESET")
  attempts    Int       @default(0)
  maxAttempts Int       @default(5) @map("max_attempts")
  verifiedAt  DateTime? @map("verified_at")
  resetToken  String?   @unique @map("reset_token")
  usedAt      DateTime? @map("used_at")
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
  /// Phase 18 (2026-05-20) — every OTP lookup queries by (sellerId,
  /// purpose, status fields). The composite index removes the
  /// sequential scan over the seller's full OTP history when the
  /// table grows.
  @@index([sellerId, purpose])
  /// Phase 18 (2026-05-20) — expiry sweep job's predicate.
  @@index([expiresAt])
  @@map("seller_password_reset_otps")
}

/// Phase 19 (2026-05-20) — Seller payout bank details.
///
/// One-to-one with Seller (the @unique on sellerId enforces it).
/// Holds the encrypted account number + last-4 + IFSC + optional
/// UPI VPA so the platform can settle commissions on completed
/// orders. Account number is AES-256 encrypted at rest (mirrors
/// the AFFILIATE_ENCRYPTION_KEY pattern); the API exposes only
/// `accountNumberLast4` outside the encryption boundary.
///
/// `verifiedAt` / `verifiedBy` are admin-side fields for a future
/// penny-drop verification step. The Phase 19 PR only stores the
/// raw details; the verification action is a follow-up.
model SellerBankDetails {
  id                 String    @id @default(uuid())
  sellerId           String    @unique @map("seller_id")
  accountHolderName  String    @map("account_holder_name") @db.VarChar(150)
  /// Stores the AES-256 ciphertext (hex) of the raw account number.
  /// Never the plaintext.
  accountNumberEnc   String    @map("account_number_enc")
  /// Last 4 digits for masked display (admin payout queue, seller
  /// profile reveal). Never used as a lookup key.
  accountNumberLast4 String    @map("account_number_last_4") @db.VarChar(4)
  /// IFSC code (e.g. HDFC0001234). Validated against RBI's regex
  /// at write time.
  ifscCode           String    @map("ifsc_code") @db.VarChar(11)
  bankName           String?   @map("bank_name") @db.VarChar(150)
  upiVpa             String?   @map("upi_vpa") @db.VarChar(100)
  // Phase 153 — optional payout-rail preference (UPI / IMPS / NEFT). The
  // export honours it when the amount is valid for that rail, else falls back
  // to amount-based routing. Plain string (validated in app) to avoid a DB
  // enum migration; RTGS can be added as a rail later.
  preferredPayoutMethod String? @map("preferred_payout_method") @db.VarChar(8)
  verifiedAt         DateTime? @map("verified_at")
  verifiedBy         String?   @map("verified_by")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@map("seller_bank_details")
}

/// Logistics partner registration tracker.
///
/// Records, per (sellerId, partner), whether the seller's pickup
/// address has been registered with the named courier. Driven by the
/// admin "Add pickup location to {Partner}" button on the seller
/// detail page; status reflects the most recent attempt.
///
/// Status semantics:
///   • PENDING    — row exists but no successful partner-side ack yet.
///   • REGISTERED — partner returned 2xx; `warehouseName` populated
///                  with the immutable canonical id (Delhivery echoes
///                  the name the request supplied).
///   • FAILED     — partner returned an error; `lastError` populated
///                  with the verbatim message for admin retry.
///   • NOT_NEEDED — partner advertises `warehouseRegistration: NOT_NEEDED`
///                  via the facade catalogue (Shadowfax). A row in
///                  this state means the admin clicked the button by
///                  mistake; the API short-circuits without calling
///                  the partner.
///
/// The (sellerId, partner) unique constraint enforces idempotency —
/// "Re-register" updates the existing row rather than creating a
/// second one.
model SellerPartnerRegistration {
  id            String    @id @default(uuid())
  sellerId      String    @map("seller_id")
  partner       String    @db.VarChar(32)
  warehouseName String?   @map("warehouse_name") @db.VarChar(128)
  status        String    @default("PENDING") @db.VarChar(16)
  lastError     String?   @map("last_error")
  registeredAt  DateTime? @map("registered_at")
  registeredBy  String?   @map("registered_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@unique([sellerId, partner])
  @@index([sellerId])
  @@index([partner, status])
  @@map("seller_partner_registrations")
}
