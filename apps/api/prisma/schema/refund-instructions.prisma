// Phase 3 — Unified Refund System (ADR-009).
//
// Today's reality:
//   - DisputeRefundHandler.onDecided directly calls
//     walletFacade.creditFromRefund(...) the moment a dispute is decided.
//   - ReturnService.initiateRefund uses RefundGatewayService which
//     branches on paymentMethod and writes RefundTransaction rows for
//     Razorpay refunds, but NOT for wallet refunds, dispute refunds,
//     or goodwill credits.
//
// The result is three parallel paths to "money landed in customer's
// wallet" — only one of them goes through an auditable record. A failed
// dispute wallet credit is logged-and-swallowed; finance reconciliation
// has no row to chase.
//
// Phase 3 fixes that. EVERY refund — return, dispute, goodwill, manual,
// COD, replacement — first creates a RefundInstruction. The Saga
// executor then drives the instruction to terminal state (SUCCESS /
// FAILED / MANUAL_REQUIRED). Dispute decisions stop calling the wallet
// directly.

enum RefundSourceType {
  RETURN
  DISPUTE
  GOODWILL
  MANUAL
  // Replacement orders that need a price-difference settle-up.
  REPLACEMENT
  // Phase 74 (2026-05-22) — Phase 73 approve/reject audit Gap #1.
  // Verifier rejected a prepaid order; refund saga reverses the
  // gateway + wallet portions back to the customer.
  VERIFICATION_REJECTION
}

enum RefundMethod {
  ORIGINAL_PAYMENT
  WALLET
  BANK_TRANSFER
  UPI
  COUPON
  MANUAL
}

enum RefundInstructionStatus {
  PENDING_APPROVAL // high-value or risk-flagged; awaits manager
  // Phase 170 (Refund Queue audit #10) — finance asked the upstream admin for
  // clarification; the instruction is OUT of the "to decide" queue until the
  // question is resolved (then it returns to PENDING_APPROVAL or is decided).
  NEEDS_CLARIFICATION
  APPROVED // ready for execution
  PROCESSING // saga in flight
  SUCCESS // gateway accepted/processed the refund (money in flight to bank)
  // Phase 167 (Refund Execution audit #7) — Razorpay distinguishes
  // `processed` (refund created, debited from our balance) from `settled`
  // (the bank actually credited the customer). SUCCESS = processed; SETTLED
  // is set by the refund.settled webhook so finance sees true settlement.
  SETTLED // bank confirmed the customer was credited
  FAILED // gateway said no AND retries exhausted
  RETRYING // failed once but inside retry budget
  MANUAL_REQUIRED // COD with no UPI/bank → ops to wire manually
  CANCELLED // refund was retracted before execution (admin pre-approval cancel)
  // Phase 171 (Refund Approve/Reject audit #2/#3) — distinguish a FINANCE veto
  // of the money movement from an admin pre-approval CANCELLED. REJECTED is the
  // terminal state for a non-dispute (e.g. RETURN) finance rejection;
  // ROUTED_BACK_TO_DISPUTE is the terminal state for a dispute-sourced rejection
  // that bounced the case back to the dispute team for re-decision.
  REJECTED
  ROUTED_BACK_TO_DISPUTE
}

model RefundInstruction {
  id         String           @id @default(uuid())
  // Polymorphic linkage to the source — RETURN row id, DISPUTE row id,
  // etc. Kept as a String pair (no FK) per the strict-modular-monolith
  // ADR; cross-module FK churn would defeat the boundary discipline.
  sourceType RefundSourceType @map("source_type")
  sourceId   String           @map("source_id")
  customerId String           @map("customer_id")
  // Optional — present for refunds that trace back to an order; absent
  // for goodwill credits not tied to a specific order.
  orderId    String?          @map("order_id")

  // Money — paise as canonical (ADR-004 / ADR-007).
  amountInPaise BigInt @map("amount_in_paise")
  currency      String @default("INR")

  refundMethod RefundMethod            @map("refund_method")
  status       RefundInstructionStatus @default(APPROVED)

  // Idempotency: when present, two callers can't accidentally produce
  // two instructions for the same refund. Nullable because not every
  // caller has an idempotency context (manual ops). When supplied,
  // unique cluster-wide.
  idempotencyKey String? @unique @map("idempotency_key")

  // Cross-system identifiers populated by the saga.
  gatewayRefundId     String? @map("gateway_refund_id")
  walletTransactionId String? @map("wallet_transaction_id")

  failureReason String? @map("failure_reason")
  attempts      Int     @default(0)

  // Phase 12 (ADR-017) — finance approval gate. Refunds above the
  // configured threshold (REFUND_AUTO_APPROVE_THRESHOLD_PAISE) AND all
  // goodwill credits land here as PENDING_APPROVAL. A finance admin
  // with `refunds.approve` permission either approves (saga runs +
  // wallet credits) or rejects (instruction CANCELLED + reason
  // recorded). approvedBy column was added forward-looking in
  // 20260505140000; rejection columns added in 20260507100000.
  approvedBy      String?   @map("approved_by")
  approvedAt      DateTime? @map("approved_at")
  rejectedBy      String?   @map("rejected_by")
  rejectedAt      DateTime? @map("rejected_at")
  rejectionReason String?   @map("rejection_reason")
  processedAt     DateTime? @map("processed_at")

  // Phase 125 — dual-approval (two-person rule) for high-value refunds.
  // Refunds at/above REFUND_DUAL_APPROVAL_THRESHOLD_PAISE require TWO
  // distinct finance approvers (separation of duties). The FIRST approver
  // is recorded here and the instruction stays PENDING_APPROVAL; a second,
  // DISTINCT approver then populates approvedBy and releases the saga.
  // Below the threshold these stay null and a single approvedBy suffices.
  firstApprovedBy String?   @map("first_approved_by")
  firstApprovedAt DateTime? @map("first_approved_at")

  // Phase 170 (Refund Queue audit #6) — approval SLA. Defaulted to
  // createdAt + REFUND_APPROVAL_SLA_HOURS (48h) at create time so the queue can
  // surface overdue instructions (?overdue=true) + finance has an aging report.
  approvalDueBy DateTime? @map("approval_due_by")
  // Phase 170 (#10) — clarification context (the question finance asked + who).
  clarificationNote     String?   @map("clarification_note") @db.Text
  clarificationBy       String?   @map("clarification_by")
  clarificationAt       DateTime? @map("clarification_at")

  // Phase 171 (Refund Approve/Reject audit) — finance-rejection + dispute
  // route-back context.
  //   #4  linkedDisputeId — explicit dispute link (besides the polymorphic
  //       sourceType='DISPUTE'+sourceId), so dispute→refund-history is a fast
  //       indexed lookup. Populated on createForDispute + on reject route-back.
  //   #6  customerVisibleReason — the SAFE, customer-facing message finance
  //       picks, kept SEPARATE from the internal rejectionReason (which can
  //       contain "fraud signals" etc). Customer-facing surfaces read only this.
  //   #1/#3 routedBack* — when/who/why a dispute-sourced refund bounced back.
  linkedDisputeId       String?   @map("linked_dispute_id")
  customerVisibleReason String?   @map("customer_visible_reason") @db.Text
  routedBackAt          DateTime? @map("routed_back_at")
  routedBackBy          String?   @map("routed_back_by")

  // Phase 172 (Goodwill Credit audit #2/#12) — goodwill is piggy-backed on this
  // table (ADR-009 unified refund). These make the goodwill flow first-class:
  //   #2  isGoodwill — explicit marker so finance can filter "goodwill only"
  //       without joining Dispute; populated from customerRemedy on create.
  //   customerRemedy — snapshot of the dispute remedy at instruction time, so
  //       the row is self-describing (refund vs goodwill) for reconciliation.
  //   #12 customerVisibleMessage — the apologetic, customer-facing goodwill
  //       note finance can set at decision time (distinct from the rejection
  //       customerVisibleReason); surfaced in the notification + wallet.
  isGoodwill            Boolean   @default(false) @map("is_goodwill")
  customerRemedy        String?   @map("customer_remedy")
  customerVisibleMessage String?  @map("customer_visible_message") @db.Text

  // Phase 167 (Refund Execution audit #7) — set by the refund.settled webhook.
  settledAt DateTime? @map("settled_at")
  // Phase 167 (#8) — gateway-reconciliation poll tracking so the recon cron
  // backs off (no ~720 redundant gateway GETs over a 24h-stuck window) and a
  // forensic review sees when/how-often/with-what-error we polled the gateway.
  lastPolledAt     DateTime? @map("last_polled_at")
  pollAttemptCount Int       @default(0) @map("poll_attempt_count")
  lastPollError    String?   @map("last_poll_error") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Hot indices.
  @@index([sourceType, sourceId])
  @@index([customerId])
  @@index([status])
  // For the reconciliation cron: "find PROCESSING refunds older than X".
  @@index([status, processedAt])
  // Finance reporting: refunds grouped by method (+ status), e.g.
  // "bank-transfer refunds awaiting approval".
  @@index([refundMethod, status])
  // Phase 170 (#6) — overdue sweep: "PENDING_APPROVAL past approval_due_by".
  @@index([status, approvalDueBy])
  // Phase 171 (#4) — dispute → refund-instruction history lookup.
  @@index([linkedDisputeId])
  // Phase 172 (#2/#17) — "pending goodwill approvals" queue filter.
  @@index([isGoodwill, status])
  // Phase 170 (#16) — status-transition history back-relation.
  statusHistory RefundInstructionStatusHistory[]
  @@map("refund_instructions")
}

// Phase 170 (Refund Queue audit #16) — append-only status-transition trail.
// Pre-170 a multi-step lifecycle (PENDING_APPROVAL → PROCESSING → FAILED →
// manual-fix) overwrote the row, losing every intermediate timestamp/actor
// beyond approvedAt/rejectedAt/processedAt. One row per transition.
model RefundInstructionStatusHistory {
  id            String                   @id @default(uuid())
  instructionId String                   @map("instruction_id")
  fromStatus    RefundInstructionStatus? @map("from_status")
  toStatus      RefundInstructionStatus  @map("to_status")
  // Admin id (polymorphic, no FK per ADR) or a SYSTEM sentinel ('SYSTEM',
  // 'saga', 'recon') for non-human transitions.
  actorId       String?                  @map("actor_id")
  notes         String?                  @db.Text
  occurredAt    DateTime                 @default(now()) @map("occurred_at")

  instruction RefundInstruction @relation(fields: [instructionId], references: [id], onDelete: Cascade)

  @@index([instructionId, occurredAt])
  @@map("refund_instruction_status_history")
}

enum RefundSagaStatus {
  STARTED
  IN_PROGRESS
  COMPLETED
  COMPENSATING
  COMPENSATED
  COMPENSATION_FAILED
  FAILED
}

// Per-saga state. Mirrors the SAGA pattern (Caitie McCaffrey, "Distributed
// Sagas"): forward steps each have a compensating action. `steps` and
// `compensations` are arrays of { name, status, attempts, result, error,
// startedAt, completedAt } records — see RefundSagaService for the shape.
// Phase 100 (2026-05-23) — Phase 98 audit Gap #20 closure.
//
// Idempotent landing zone for Razorpay refund webhook events. The
// `eventId @unique` constraint dedups Razorpay's at-least-once
// delivery. `processed_at` is stamped after the side-effects run
// (Return.status flip + outbox publish) so a failed mid-process
// crash can be safely retried.
model RazorpayRefundWebhookEvent {
  id                String    @id @default(uuid())
  eventId           String    @unique @map("event_id")
  eventType         String    @map("event_type")
  refundId          String?   @map("refund_id")
  paymentId         String?   @map("payment_id")
  rawPayload        Json      @map("raw_payload")
  processedAt       DateTime? @map("processed_at")
  processedOutcome  String?   @map("processed_outcome")
  receivedAt        DateTime  @default(now()) @map("received_at")

  @@index([refundId])
  @@index([receivedAt(sort: Desc)])
  @@map("razorpay_refund_webhook_events")
}

model RefundSaga {
  id            String           @id @default(uuid())
  refundType    RefundSourceType @map("refund_type")
  // Source aggregate id (return/dispute/etc.) — matches the
  // corresponding RefundInstruction.sourceId.
  sourceId      String           @map("source_id")
  // Optional link to the instruction the saga drives. A saga can
  // exist briefly without an instruction (in the create-instruction
  // step), so this is nullable.
  instructionId String?          @map("instruction_id")
  // Phase 96 (2026-05-23) — Phase 99 audit Gap #11 / #15 closure.
  // Mirror RefundInstruction.idempotencyKey so concurrent saga.run
  // calls for the same instruction collapse to one row.
  idempotencyKey       String?  @unique @map("idempotency_key")
  walletTransactionId  String?  @map("wallet_transaction_id")
  gatewayRefundId      String?  @map("gateway_refund_id")
  amountInPaise BigInt           @map("amount_in_paise")
  customerId    String           @map("customer_id")
  status        RefundSagaStatus @default(STARTED)
  steps         Json
  compensations Json?
  startedAt     DateTime         @default(now()) @map("started_at")
  completedAt   DateTime?        @map("completed_at")
  failureReason String?          @map("failure_reason")

  @@index([status, startedAt])
  @@index([sourceId])
  @@index([instructionId])
  @@map("refund_sagas")
}
