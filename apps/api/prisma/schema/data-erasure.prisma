// ============================================
// Data erasure (Phase 7, PR 7.4)
// ============================================
// GDPR-style "right to be forgotten" requests. The processing cron
// picks up PENDING rows, runs them through ErasureService, and writes
// the outcome (IN_PROGRESS / COMPLETED / REJECTED + a structured
// summary of what was redacted vs blocked).
//
// Why a request table rather than a synchronous endpoint:
//   - Erasure is multi-table and slow. We want to process during
//     low-traffic windows, not block the user request.
//   - Audit trail: regulators want to see "we received the request
//     on date X, blocked it for reason Y, completed on date Z".
//   - Reversibility: a 24h delay before processing lets us catch a
//     misclick or compromised account before destroying data.

enum ErasureSubjectType {
  USER       // customer
  SELLER
  AFFILIATE
  FRANCHISE
}

enum ErasureStatus {
  PENDING       // queued, awaiting cron / 24h cooldown
  IN_PROGRESS   // cron picked it up, redaction running
  COMPLETED     // all reachable PII redacted, residual list documented
  REJECTED      // legal-hold prevented erasure (open dispute / unpaid balance)
  CANCELLED     // requester withdrew the request before processing
}

model DataErasureRequest {
  id String @id @default(uuid())

  subjectType ErasureSubjectType @map("subject_type")
  subjectId   String             @map("subject_id")
  /// Snapshot of subject's email at request time. Useful when the user
  /// table row has been redacted — we still have a paper trail of which
  /// account the request applied to.
  subjectEmailSnapshot String? @map("subject_email_snapshot")

  status ErasureStatus @default(PENDING)

  /// "USER_REQUEST" | "ADMIN_ACTION" | "REGULATOR_NOTICE". Drives
  /// the cooldown — admin / regulator actions can bypass the 24h
  /// delay, user requests respect it.
  source String @default("USER_REQUEST")
  /// Set when source != USER_REQUEST. Recorded so the audit trail
  /// shows who initiated.
  requestedByActorType String? @map("requested_by_actor_type")
  requestedByActorId   String? @map("requested_by_actor_id")

  /// Earliest time the cron may process this. Default = createdAt + 24h
  /// for USER_REQUEST source. Skipped (=createdAt) for admin / regulator.
  notBefore DateTime @map("not_before")

  /// Set when status moves to IN_PROGRESS / COMPLETED / REJECTED.
  processingStartedAt DateTime? @map("processing_started_at")
  completedAt         DateTime? @map("completed_at")

  /// Free-form JSON written by the cron:
  ///   {
  ///     "redacted": ["users.first_name", "users.last_name", ...],
  ///     "blocked":  [{ "table": "disputes", "reason": "OPEN dispute D-..." }],
  ///     "filesArchived": 5,
  ///   }
  outcome Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([status, notBefore])
  @@index([subjectType, subjectId])
  @@map("data_erasure_requests")
}
