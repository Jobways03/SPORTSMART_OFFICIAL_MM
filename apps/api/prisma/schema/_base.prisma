// Phase 13 (P1.8) — seller-response lifecycle on returns. Drives the
// "seller has X days to accept or contest" flow that lets sellers
// defend themselves before the platform attributes liability.
enum SellerResponseStatus {
  NOT_REQUIRED
  PENDING
  ACCEPTED
  CONTESTED
  EXPIRED
}

// Phase 13 (P1.14) — replacement / exchange request lifecycle on
// returns. A return whose QC outcome is REPLACEMENT or EXCHANGE
// progresses through these states until the new order is shipped
// (or the request flips back to a refund).
enum ReplacementRequestStatus {
  NONE
  PENDING_STOCK_CHECK
  AWAITING_PAYMENT
  AWAITING_FULFILMENT
  FULFILLED
  CANCELLED
  FALLBACK_TO_REFUND
}

