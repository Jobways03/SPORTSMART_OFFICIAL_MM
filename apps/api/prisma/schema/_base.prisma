// ─── Logistics ───────────────────────────────────────────────────
// How a SubOrder is delivered to the customer. Self-delivery is the
// only method today (iThink removed); the courier-agnostic shipping
// module remains for a future carrier.
enum DeliveryMethod {
  SELF_DELIVERY // Seller / franchise delivers themselves; no courier.
  DELHIVERY     // Booked with Delhivery via the logistics-facade.
}

// Status lifecycle for SELF_DELIVERY shipments — the only delivery
// method today. Progress is driven by manual seller/franchise updates.
enum SelfDeliveryStatus {
  PENDING
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  CANCELLED
}
