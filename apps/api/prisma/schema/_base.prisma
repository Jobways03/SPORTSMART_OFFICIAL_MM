enum InventoryMovementType {
  PROCUREMENT_IN
  ORDER_RESERVE
  ORDER_UNRESERVE
  ORDER_SHIP
  ORDER_RETURN
  ORDER_CANCEL
  POS_SALE
  POS_RETURN
  DAMAGE
  LOSS
  ADJUSTMENT
  AUDIT_CORRECTION
  // Phase 159o (audit #12) — distinguishes stock restored by a courier
  // Return-To-Origin (undelivered shipment coming back to the franchise) from a
  // customer-initiated ORDER_RETURN, so reconciliation/reporting can tell the
  // two apart. NOTE: the franchise RTO-restock path is not yet wired
  // (StockRestoreService restores seller stock only); this value is in place so
  // that wiring uses the correct movement type. Tracked as a shipping/orders
  // follow-up.
  RTO_RESTOCK
  // Phase 159r (POS void/return audit #8) — a POS-sale VOID restock, distinct
  // from a customer POS_RETURN, so daily reconciliation can tell voids from
  // genuine returns.
  POS_VOID
}

