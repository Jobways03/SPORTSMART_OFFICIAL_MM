/// Phase 32 (2026-05-21) — IN_REVIEW value dropped. Zero rows ever
/// carried it (no controller / service / event handler wrote the
/// value) and no admin-claim review flow ships before MVP. Frontend
/// switch cases on the string `'IN_REVIEW'` are now unreachable and
/// can be cleaned up in a follow-up frontend phase (the cases were
/// already dead — they didn't match any row).
enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum MappingApprovalStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  STOPPED
  // Phase 59 (2026-05-22) — bulk admin-initiated suspension of a
  // seller's full catalog (audit Gap #2). Separated from STOPPED
  // (single-mapping admin action, Phase 56/57) so the bulk
  // activate path can target SUSPENDED-only without inadvertently
  // re-activating REJECTED or STOPPED mappings (audit Gap #1).
  SUSPENDED
}

enum OrderStatus {
  PENDING_PAYMENT
  PLACED
  PENDING_VERIFICATION
  VERIFIED
  ROUTED_TO_SELLER
  SELLER_ACCEPTED
  DISPATCHED
  DELIVERED
  CANCELLED
  // Phase 74 (2026-05-22) — verifier rejection. Distinct from
  // CANCELLED (customer-initiated) so analytics + finance can
  // reconcile, refund saga can branch, and the customer
  // notification carries the right copy.
  REJECTED
  EXCEPTION_QUEUE
  // Phase 81 (2026-05-22) — cancel audit Gap #6/#20. A master with
  // some-but-not-all sub-orders cancelled doesn't fit CANCELLED
  // (some are still alive) or any "active" status (some are dead).
  // The mid-flow cancel writer flips master to this state when the
  // cancelled-vs-total ratio is partial; full-cancel still becomes
  // CANCELLED.
  PARTIALLY_CANCELLED
  // Phase 82 (2026-05-23) — packing & shipping audit Gap #12/#13.
  // Master rollup: when some sub-orders have shipped but others are
  // still being packed, DISPATCHED is misleading (sounds like the
  // whole order is in transit). PARTIALLY_SHIPPED is the truthful
  // mid-state; once the last sub-order ships, the rollup moves to
  // DISPATCHED (or DELIVERED on the customer-visible terminal).
  PARTIALLY_SHIPPED
  // Phase 83 (2026-05-23) — delivery audit Gap (Flow #63 carry).
  // Mid-state for "some sub-orders delivered, others still in
  // transit / accepted". Pre-Phase-83 the master stayed at
  // DISPATCHED until every sub-order was DELIVERED, so the
  // customer view said "Shipped" for the entire 7-day window even
  // if 2 of 3 packages had arrived.
  PARTIALLY_DELIVERED
}

