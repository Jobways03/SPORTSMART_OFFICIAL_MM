enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  PICKUP_SCHEDULED
  IN_TRANSIT
  RECEIVED
  QC_APPROVED
  QC_REJECTED
  PARTIALLY_APPROVED
  REFUND_PROCESSING
  REFUNDED
  // Phase 100 (2026-05-23) — Phase 98 audit Gap #18 closure. Terminal
  // state for refunds that exhausted all retries (REFUND_MAX_RETRY_-
  // ATTEMPTS) without success. The customer's case is escalated to
  // ops via the existing RETURN_REFUND_FAILED AdminTask kind; the
  // Return itself stays in this state so dashboards can filter
  // "stuck refunds".
  REFUND_FAILED
  COMPLETED
  CANCELLED
  // Phase 12 (post-Phase-11) — dispute-driven return-status overrides.
  // Set when a dispute decision overturns or confirms an earlier QC
  // verdict; a return that was QC_REJECTED but is later refunded via
  // a dispute moves to DISPUTE_OVERTURNED, etc. GOODWILL_CREDITED is
  // for goodwill-paid returns where no liability was assigned.
  DISPUTE_OVERTURNED
  DISPUTE_PARTIAL_OVERRIDE
  DISPUTE_CONFIRMED
  GOODWILL_CREDITED
}

