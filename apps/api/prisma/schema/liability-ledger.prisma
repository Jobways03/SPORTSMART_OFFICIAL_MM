// Phase 12 (post-Phase-11) — Liability ledger.
//
// Three append-only ledgers recording who bears the cost of a
// customer-favoured dispute outcome. The dispute decides *what* the
// customer receives (CustomerRemedy + RefundInstruction); these
// rows record *who pays* (SellerDebit / LogisticsClaim /
// PlatformExpense) so finance + ops can recover or absorb the cost.
//
// Wallet credit itself happens only via the RefundProcessor saga —
// these rows do NOT trigger payments; they're cost-attribution only.
//
// AdminTask is the generic ops queue used when the saga can't auto-
// resolve (failed refund, disputed seller debit, etc.).
//
// See docs/decisions/016-dispute-liability-ledger.md for the matrix.

enum SellerDebitStatus {
  PENDING
  APPLIED // settlement run picked it up + offset the seller's payout
  CANCELLED // disputed and reversed by ops
}

enum LogisticsClaimStatus {
  PENDING
  SUBMITTED // forwarded to courier ops via API/email
  ACCEPTED // courier acknowledged liability
  RECOVERED // money received from courier
  REJECTED // courier denied — finance reclassifies to PlatformExpense
  CANCELLED
}

enum PlatformExpenseType {
  GOODWILL
  PLATFORM_FAULT
  EXCEPTION
  ROUNDING_ADJUSTMENT
  // Phase 109 (2026-05-25) — GST the platform can no longer reclaim via a
  // credit note on a time-barred return (Section 34 window closed). Booked
  // when the wallet-adjustment refund posts.
  ABSORBED_GST
}

enum LedgerSourceType {
  RETURN
  DISPUTE
  GOODWILL
  MANUAL
  // Phase 87 (2026-05-23) — NDR/RTO audit Gap #9. RTO_DELIVERED is
  // a separate provenance from a customer-initiated Return — the
  // SellerDebit `(sourceType, sourceId)` UNIQUE means RTO + RETURN
  // for the same sub-order can both write (logically separate
  // events), and the source-type tag tells finance which path
  // produced the claw-back.
  RTO
  // Phase 108 (2026-05-25) — seller B2B/off-platform reversal claw-back.
  SELLER_REVERSAL
}

enum AdminTaskKind {
  REFUND_INSTRUCTION_FAILED
  LOGISTICS_CLAIM_REVIEW
  SELLER_DEBIT_DISPUTED
  // Phase 13 — dedicated return-side kinds so finance/ops queue
  // filtering doesn't have to scrape the `reason` text.
  RETURN_REFUND_FAILED
  RETURN_LIABILITY_LEDGER_BACKFILL
  // Phase 12 GST — Section 34 time-bar workflow. TIME_BARRED is
  // opened when a return crosses the 30-Sept-of-FY+1 deadline before
  // the credit note was issued (platform absorbs the GST cost +
  // refund must route through wallet_adjustment). APPROACHING is the
  // 7-day early-warning so ops can chase the credit note out the door
  // before the deadline hits.
  GST_CREDIT_NOTE_TIME_BARRED
  GST_CREDIT_NOTE_TIME_BAR_APPROACHING
  // Phase 15 GST — E-way bill (CBIC Rule 138). FAILED opens when all
  // adapter retries are exhausted; seller cannot ship until resolved.
  // EXPIRED opens when an issued EWB passes validUntil without delivery.
  EWAY_BILL_GENERATION_FAILED
  EWAY_BILL_EXPIRED
  // Phase 16 GST — GSTR-8 monthly filing reminders + TCS compute
  // failures. FILING_DUE opens N days before the 10th-of-month
  // deadline; COMPUTATION_FAILED opens when the per-seller TCS pass
  // crashes (e.g. inconsistent invoice state).
  GSTR8_FILING_DUE
  TCS_COMPUTATION_FAILED
  // Phase 19 GST — opens when the PDF retry cron exhausts retries
  // without a successful render+upload. Ops / finance triages.
  TAX_DOCUMENT_PDF_FAILED
  // Phase 22 GST — e-invoice / NIC IRP workflow.
  //   GENERATION_FAILED   — retry cap exhausted without an IRN; seller
  //                         is above turnover threshold so the invoice
  //                         is non-compliant until resolved.
  //   CANCELLATION_FAILED — admin tried to cancel an IRN within the
  //                         24-hour CBIC window but NIC refused.
  EINVOICE_GENERATION_FAILED
  EINVOICE_CANCELLATION_FAILED
  // Phase 96 (2026-05-23) — Mark Received audit Gap #11 closure.
  // Opened when a return is RECEIVED so the QC team has a dedicated
  // queue row instead of polling `status=RECEIVED`. Unique on
  // (kind=RETURN_QC_PENDING, sourceType=RETURN, sourceId=returnId)
  // via the existing AdminTask uniqueKey index.
  RETURN_QC_PENDING
  // Phase 95 (2026-05-23) — Phase 93 deferred sub-order orphan task.
  RETURN_NOTIFICATION_NO_NODE
  // Phase 168 (COD Mark-Paid audit #11) — opened by the cod-collection-pending
  // recon cron when a COD order has been DELIVERED for longer than the
  // configured window but its paymentStatus is still PENDING (cash not yet
  // marked collected). Unique on (kind, sourceType=MANUAL, sourceId=orderId)
  // dedups re-enqueues across ticks.
  COD_COLLECTION_OVERDUE
  // Phase 169 (Payment Ops audit #2/#18) — opened when a Razorpay dispute
  // (chargeback) lands in a contestable state; the SLA deadline is the
  // gateway's respond_by so finance pushes evidence before it expires.
  // Unique on (kind, sourceType=MANUAL, sourceId=chargebackId).
  CHARGEBACK_EVIDENCE_DUE
  // Phase 170 (Refund Queue audit #11) — finance asked the upstream admin
  // (dispute decider / QC) for clarification on a PENDING_APPROVAL refund.
  // Dedicated kind so ops can filter "refund clarification requests" instead of
  // scraping the generic OTHER bucket. Unique on (kind, sourceType, sourceId).
  REFUND_CLARIFICATION_REQUESTED
  // Phase 171 (Refund Approve/Reject audit #11) — finance REJECTED the refund
  // for a decided dispute; the case is routed back to the dispute team for
  // re-decision. Unique on (kind, sourceType=DISPUTE, sourceId=disputeId).
  DISPUTE_REFUND_REJECTED_NEEDS_REDECISION
  // Phase 234 (Allocation Exception Queue audit #234) — a verified order could
  // not be routed to any fulfillment node and was parked in EXCEPTION_QUEUE
  // (no pincode / unserviceable / no stock / no node mapped / seller-franchise
  // rejected with no fallback). Opened so ops triages the stuck order instead
  // of it sitting silently. Keyed like COD/chargeback (no first-class order
  // LedgerSourceType): unique on (kind, sourceType=MANUAL, sourceId=masterOrderId).
  ORDER_ALLOCATION_EXCEPTION
  OTHER
}

enum AdminTaskStatus {
  OPEN
  CLAIMED
  RESOLVED
  CANCELLED
}

model SellerDebit {
  id                   String            @id @default(uuid())
  sellerId             String            @map("seller_id")
  sourceType           LedgerSourceType  @map("source_type")
  sourceId             String            @map("source_id")
  orderId              String?           @map("order_id")
  subOrderId           String?           @map("sub_order_id")
  amountInPaise        BigInt            @map("amount_in_paise")
  reason               String
  status               SellerDebitStatus @default(PENDING)
  settlementAdjustedAt DateTime?         @map("settlement_adjusted_at")
  // Set by the settlement run when this debit is applied. Lets
  // finance trace which payout cycle absorbed the recovery.
  settlementId         String?           @map("settlement_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // (sourceType, sourceId) — guarantees one debit per dispute / return /
  // manual entry; saga retries / event replays can't double-charge.
  @@unique([sourceType, sourceId])
  @@index([sellerId, status])
  @@index([settlementId])
  @@map("seller_debits")
}

model LogisticsClaim {
  id             String               @id @default(uuid())
  sourceType     LedgerSourceType     @map("source_type")
  sourceId       String               @map("source_id")
  // Free-text courier identifier — kept loose because we don't have a
  // first-class courier model yet. Examples: "Delhivery", "BlueDart",
  // "Ekart". When/if a couriers table lands, normalise.
  courierName    String?              @map("courier_name")
  awbNumber      String?              @map("awb_number")
  amountInPaise  BigInt               @map("amount_in_paise")
  reason         String
  status         LogisticsClaimStatus @default(PENDING)
  submittedAt    DateTime?            @map("submitted_at")
  recoveredAt    DateTime?            @map("recovered_at")
  // Optional FileMetadata pointer for evidence (POD photo, transit
  // tracking screenshot, etc.). Kept nullable + non-FK to avoid
  // tight coupling to the files module.
  evidenceFileId String?              @map("evidence_file_id")
  notes          String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([sourceType, sourceId])
  @@index([status])
  @@index([awbNumber])
  @@map("logistics_claims")
}

model PlatformExpense {
  id            String              @id @default(uuid())
  sourceType    LedgerSourceType    @map("source_type")
  sourceId      String              @map("source_id")
  expenseType   PlatformExpenseType @map("expense_type")
  amountInPaise BigInt              @map("amount_in_paise")
  reason        String

  // Phase 127 — reversal. Unlike SellerDebit/LogisticsClaim there's no
  // in-flight lifecycle to model (a platform expense is just a booked
  // cost), so reversal is a soft mark rather than a status enum. Set when
  // the originating refund is rejected by finance — the money never moved,
  // so the expense must not stand in finance reporting. Non-null reversedAt
  // = excluded from cost totals.
  reversedAt     DateTime? @map("reversed_at")
  reversalReason String?   @map("reversal_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([sourceType, sourceId])
  @@index([expenseType])
  @@map("platform_expenses")
}

model AdminTask {
  id             String           @id @default(uuid())
  kind           AdminTaskKind
  sourceType     LedgerSourceType @map("source_type")
  sourceId       String           @map("source_id")
  status         AdminTaskStatus  @default(OPEN)
  reason         String
  // Optional pre-assignment to a specific admin / team. When null,
  // the task lives in the global queue.
  assignedTo     String?          @map("assigned_to")
  claimedAt      DateTime?        @map("claimed_at")
  resolvedAt     DateTime?        @map("resolved_at")
  resolvedBy     String?          @map("resolved_by")
  resolutionNote String?          @map("resolution_note")

  // Phase 0 (PR 0.14) — deadline for OPEN/CLAIMED tasks; the SLA
  // breach detector cron flips priority and notifies finance once
  // `now() > slaBreachAt`. Null = no SLA (legacy task or admin
  // chose not to gate). Common values:
  //   - REFUND_INSTRUCTION_FAILED → +24h (customer is stuck)
  //   - LOGISTICS_CLAIM_REVIEW    → +48h (slower lane)
  //   - SELLER_DEBIT_DISPUTED     → +72h (negotiation has slack)
  slaBreachAt   DateTime? @map("sla_breach_at")
  // True once the SLA-breach cron has fired the escalation event for
  // this task. Prevents the cron from re-firing every tick.
  slaBreachedAt DateTime? @map("sla_breached_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // (kind, sourceType, sourceId) — saga retries that try to enqueue
  // the same failure twice should hit the existing row, not duplicate
  // it. Ops sees one row per actual problem.
  @@unique([kind, sourceType, sourceId])
  @@index([status])
  @@index([assignedTo])
  // Phase 0 (PR 0.14) — index drives the SLA-breach detector cron's
  // `WHERE status IN (OPEN, CLAIMED) AND slaBreachAt < now() AND
  // slaBreachedAt IS NULL` query.
  @@index([status, slaBreachAt])
  @@map("admin_tasks")
}
