// ============================================
// File URL audit (Phase 7, PR 7.3)
// ============================================
// Every secure-URL issuance writes a row here. Two reasons we want
// the audit:
//   - Incident response: "this PII leaked, who pulled it out and
//     when?" — joinable on requester_id + file_id + window.
//   - Rate limiting: a single requester pulling 100+ URLs for the
//     same KYC doc in 10 minutes is suspicious. The service can
//     consult recent counts before issuing.
//
// Stored independently of audit_logs because the volume profile is
// different: every list-page render of a private file gallery walks
// here, vs audit_logs which is per-business-action.

model FileUrlAudit {
  id String @id @default(uuid())

  fileId       String   @map("file_id")
  /// The actor that asked for the URL. Whichever of the per-actor
  /// IDs is set on the request (userId / adminId / sellerId / …) wins.
  requesterId  String   @map("requester_id")
  requesterRole String? @map("requester_role")
  /// Buckets: "USER" | "ADMIN" | "SELLER" | "FRANCHISE" | "AFFILIATE" | "PUBLIC".
  requesterType String  @map("requester_type")

  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")

  /// Absolute deadline of the URL we minted. Reads "this URL was
  /// good until this timestamp". Null = same as createdAt + 0.
  expiresAt   DateTime? @map("expires_at")
  ttlSeconds  Int       @map("ttl_seconds")

  /// Flag for "rate-limit exceeded — we returned a 429 instead of a URL".
  /// Counted in the same table so a flooding attack still leaves a trail.
  denied      Boolean   @default(false)
  denyReason  String?   @map("deny_reason")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([fileId, createdAt])
  @@index([requesterId, createdAt])
  @@index([denied, createdAt])
  @@map("file_url_audits")
}
