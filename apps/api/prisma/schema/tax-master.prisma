// ============================================
// Tax Master Data — Phase 1 of the GST/tax/invoice system
// ============================================
// Added 2026-05-13 per the 27-phase GST implementation plan.
// See docs/tax/CA.md (especially §A phase log) and
// docs/tax/GST_ASSUMPTIONS.md for the engineering assumptions
// behind every default declared here.
//
// This file owns:
//   - Tax-domain enums (SupplyTaxability, GstRegistrationType,
//     TaxSplitType, LineType, DocumentType — only the ones in
//     scope for Phase 1; document types arrive in Phase 8).
//   - Master / lookup tables: india_states, uqc_master, hsn_master
//   - Supplier / customer tax-profile tables: seller_gstins,
//     customer_tax_profiles, platform_gst_profiles
//   - Runtime config: tax_config
//
// All money fields land in tax-documents.prisma (Phase 8). All
// document/credit-note/e-way-bill/ledger tables also land in
// later phases. Phase 1 is purely additive lookup + profile data.

// ─── Enums ───────────────────────────────────────────────────────

enum SupplyTaxability {
  TAXABLE
  NIL_RATED
  EXEMPT
  NON_GST
  ZERO_RATED
  OUT_OF_SCOPE
}

enum GstRegistrationType {
  REGULAR
  COMPOSITION
  UNREGISTERED
}

// Phase 200 (Customer Tax Profile audit #8) — GSTN portal taxpayer status,
// first-class enum (was a free String). Mirrors GstnTaxpayerStatus in
// infrastructure/gstn/gstn-provider.ts. ACTIVE rows may back a B2B invoice;
// SUSPENDED / CANCELLED / INACTIVE must not (the checkout usability gate +
// STRICT-mode invoice gate read it). UNKNOWN = portal not yet consulted /
// provider error. Persisted on both SellerGstin and CustomerTaxProfile.
enum GstnPortalStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
  INACTIVE
  UNKNOWN
}

// Phase 5 will use these (LineType) and Phase 8 will use these
// (DocumentType). Declaring early so Phase 1 schema can reference
// the enum names without forward-declaration churn.
enum TaxLineType {
  PRODUCT
  SHIPPING
  GIFT_WRAP
  CONVENIENCE_FEE
  COD_FEE
  ROUND_OFF
  DISCOUNT_ADJUSTMENT
}

enum TaxSplitType {
  CGST_SGST
  IGST
}

enum SupplierType {
  MARKETPLACE_SELLER
  FRANCHISE
  OWN_BRAND
  SPORTSMART
}

// Phase 5 GST — derived flag on tax snapshots + summaries. COMPLETE
// for a fully-resolved taxable line; INCOMPLETE in test mode when
// the product is TAXABLE but missing HSN/rate; EXEMPT for NIL_RATED/
// EXEMPT/NON_GST/OUT_OF_SCOPE supplies (separate GSTR-1 reporting).
enum TaxDataStatus {
  COMPLETE
  INCOMPLETE
  EXEMPT
}

// Phase 12 GST — Section 34 credit-note eligibility classification for
// QC-approved returns. The daily time-bar cron classifies each return
// into one of these buckets so finance/ops can decide between issuing
// a real CREDIT_NOTE and recording a `wallet_adjustment` instead.
//   ELIGIBLE                — within Sec 34 window; CreditNoteService
//                             will (or already has) issue a credit note.
//   TIME_BARRED             — past 30 Sept of FY+1; no GST output
//                             reduction possible. Platform absorbs the
//                             GST cost; refund flows via wallet.
//   REQUIRES_FINANCE_REVIEW — borderline (within 7 days of cutoff, or
//                             source invoice has unusual status). A
//                             finance lead must triage manually.
enum CreditNoteEligibilityStatus {
  ELIGIBLE
  TIME_BARRED
  REQUIRES_FINANCE_REVIEW
}

// ─── Master / lookup tables ──────────────────────────────────────

// India state master — canonical 2-digit GST state code list.
// 28 states + 8 union territories + special-region codes per CBIC.
// See docs/tax/GST_ASSUMPTIONS.md §1 (state-code source of truth).
model IndiaState {
  id               String   @id @default(uuid())
  // CBIC 2-digit code as string ("01" .. "38"). Canonical key
  // used across tax-document tables.
  gstStateCode     String   @unique @map("gst_state_code")
  stateName        String   @map("state_name")
  // ISO 3166-2:IN equivalent ("IN-AP", "IN-AR", ...) for any
  // module that needs ISO format. Tax module always uses
  // gstStateCode.
  isoCode          String?  @map("iso_code")
  isUnionTerritory Boolean  @default(false) @map("is_union_territory")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("india_states")
}

// UQC (Unit Quantity Code) master — CBIC standard 38-code list.
// Every tax-invoice line must declare a UQC per Section 31 / Rule 46.
// Seeded by prisma/seed/seed-uqc-master.ts.
model UqcMaster {
  id          String   @id @default(uuid())
  // CBIC short codes: NOS, PCS, KGS, MTR, ...
  code        String   @unique @map("code")
  description String   @map("description")
  isActive    Boolean  @default(true) @map("is_active")
  // Phase 161 (UQC Master audit B2/#9/#11) — mirrors the HsnMaster hardening.
  // createdBy/updatedBy: actor attribution (was never captured — the
  // controller didn't even read req.adminId). version: optimistic-concurrency
  // token. deactivationReason: why a code was retired.
  createdBy          String? @map("created_by")
  updatedBy          String? @map("updated_by")
  version            Int     @default(0)
  deactivationReason String? @map("deactivation_reason")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Phase 161 (audit #7) — append-only field-change history.
  history UqcMasterHistory[]

  @@map("uqc_master")
}

// Phase 161 (UQC Master audit #7) — append-only field-change history.
// description edits overwrote in place (no effectiveFrom/To versioning on
// UQC), so "what did NOS mean in 2024" was unanswerable. One row per
// mutation with before/after snapshot, actor, and reason. The cross-cutting
// AuditPublicFacade row (module 'tax-master') is the compliance mirror.
model UqcMasterHistory {
  id        String   @id @default(uuid())
  uqcId     String   @map("uqc_id")
  // Denormalised so "history for code X" survives a cascade-removed row.
  code      String   @map("code")
  // CREATE / UPDATE / DEACTIVATE / REACTIVATE
  action    String
  oldValues Json?    @map("old_values")
  newValues Json?    @map("new_values")
  changedBy String?  @map("changed_by")
  reason    String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  uqc UqcMaster @relation(fields: [uqcId], references: [id], onDelete: Cascade)

  @@index([uqcId, createdAt(sort: Desc)])
  @@index([code, createdAt(sort: Desc)])
  @@map("uqc_master_history")
}

// HSN master — engineering-seeded stub for sports goods; CA replaces
// with the signed-off list. Supports versioning via effectiveFrom /
// effectiveTo so rate changes mid-year don't rewrite history (snapshots
// on OrderTaxLineSnapshot retain the rate that applied at order time).
//
// CA actions: see docs/tax/HSN_RATE_POLICY.md §7.
model HsnMaster {
  id                String           @id @default(uuid())
  hsnCode           String           @map("hsn_code")
  description       String           @map("description")
  defaultGstRateBps Int              @default(0) @map("default_gst_rate_bps")
  supplyTaxability  SupplyTaxability @default(TAXABLE) @map("supply_taxability")
  defaultUqcCode    String?          @map("default_uqc_code")
  // Free-text classification hint: "apparel", "footwear", "equipment".
  // Helps admin UI suggest the right HSN for a category-bulk operation.
  categoryHint      String?          @map("category_hint")
  isActive          Boolean          @default(true) @map("is_active")
  effectiveFrom     DateTime         @map("effective_from")
  effectiveTo       DateTime?        @map("effective_to")
  // Phase 161 (HSN Master audit B2) — actor attribution. Pre-Phase-161 the
  // service received an `_actor` arg and discarded it; "which admin set the
  // rate for 851713" was unanswerable. Persisted on create + every update.
  createdBy          String?         @map("created_by")
  updatedBy          String?         @map("updated_by")
  // Phase 161 (audit #12) — optimistic-concurrency token. Bumped on every
  // mutating write; update refuses (409) when the caller's expectedVersion
  // has drifted, closing the silent last-write-wins race.
  version            Int             @default(0)
  // Phase 161 (audit #11) — reason captured when a code is deactivated, so
  // a mass/accidental deactivation has an audit trail to roll back from.
  deactivationReason String?         @map("deactivation_reason")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  // Phase 161 (audit #8) — append-only field-change history.
  history HsnMasterHistory[]

  // A HSN code may have multiple effective-period rows (rate changes).
  // No two rows for the same code can have the same effectiveFrom.
  @@unique([hsnCode, effectiveFrom], map: "hsn_master_code_effective_uniq")
  @@index([hsnCode])
  @@index([isActive, effectiveFrom])
  @@map("hsn_master")
}

// Phase 161 (HSN Master audit #8) — append-only field-change history.
//
// The effectiveFrom/effectiveTo versioning captures RATE changes (each is a
// new row), but in-place edits to description / defaultUqcCode / categoryHint
// / isActive overwrote silently — "what was 851713's description in March
// 2026" was unanswerable. This table records a row per mutation with the
// before/after snapshot, the acting admin, and the reason. The cross-cutting
// AuditPublicFacade row (module 'tax-master') is the compliance mirror; this
// is the module-local, queryable-by-code trail.
model HsnMasterHistory {
  id          String   @id @default(uuid())
  hsnMasterId String   @map("hsn_master_id")
  // Denormalised so "history for code X" survives even if the row is later
  // cascade-removed, and so the index can serve code-keyed lookups directly.
  hsnCode     String   @map("hsn_code")
  // CREATE / UPDATE / DEACTIVATE / REACTIVATE / CLOSE_WINDOW
  action      String
  oldValues   Json?    @map("old_values")
  newValues   Json?    @map("new_values")
  changedBy   String?  @map("changed_by")
  reason      String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  hsnMaster HsnMaster @relation(fields: [hsnMasterId], references: [id], onDelete: Cascade)

  @@index([hsnMasterId, createdAt(sort: Desc)])
  @@index([hsnCode, createdAt(sort: Desc)])
  @@map("hsn_master_history")
}

// ─── Supplier / customer GST profiles ────────────────────────────

// Seller's GSTIN(s). Default: one primary row per seller. Multi-GSTIN
// support (different state warehouses) lives here too — Phase 1 ships
// the schema even though most sellers will only have one primary row.
//
// See docs/tax/GST_ASSUMPTIONS.md §11 for composition seller policy.
model SellerGstin {
  id                       String              @id @default(uuid())
  sellerId                 String              @map("seller_id")
  // Full 15-char GSTIN. Validated by GstinValidator before insert.
  gstin                    String              @map("gstin")
  // 2-digit GST state code; MUST equal first 2 chars of gstin.
  // Enforced by application validator + CHECK constraint below.
  stateCode                String              @map("state_code")
  legalName                String              @map("legal_name")
  addressJson              Json                @map("address_json")
  isPrimary                Boolean             @default(false) @map("is_primary")
  isActive                 Boolean             @default(true) @map("is_active")
  registrationType         GstRegistrationType @default(REGULAR) @map("registration_type")
  // Phase 161 (Seller GSTIN Verification audit) — verification result is now
  // first-class + queryable, not buried in the verificationNotes text blob.
  //   B3  isVerified — true ONLY when the provider found the GSTIN AND it is
  //       ACTIVE (mirrors CustomerTaxProfile.isVerified, which SellerGstin lacked).
  //   B2  verifiedAt = timestamp of the last SUCCESSFUL verification only;
  //       lastCheckedAt = every attempt (so a failed re-check doesn't make the
  //       row look "verified" by a verifiedAt-IS-NOT-NULL filter).
  //   B1  legalNameMismatch + gstLegalName — the portal-returned name + the
  //       mismatch flag, queryable for the KYC-review dashboard.
  //   B5  gstnPortalStatus / gstnRawResponseJson / lastVerifiedProvider — the
  //       full provider envelope for the compliance audit trail.
  isVerified               Boolean             @default(false) @map("is_verified")
  verifiedAt               DateTime?           @map("verified_at")
  verifiedBy               String?             @map("verified_by")
  verificationNotes        String?             @db.Text @map("verification_notes")
  legalNameMismatch        Boolean             @default(false) @map("legal_name_mismatch")
  gstLegalName             String?             @map("gst_legal_name")
  // Phase 200 (Customer Tax Profile audit #8) — String → GstnPortalStatus enum.
  gstnPortalStatus         GstnPortalStatus?   @map("gstn_portal_status")
  gstnRawResponseJson      Json?               @map("gstn_raw_response_json")
  // Phase 200 (audit #20) — verificationNotes stays @db.Text: the service
  // (gstn-verification.service.appendNotes) already bounds it to the most
  // recent NOTES_MAX_LINES=50 lines, so an unbounded column never grows
  // without limit and a hard VarChar(2000) would risk a write-time truncation
  // failure on a long line. The bound lives in code, documented here.
  verificationFailureReason String?            @map("verification_failure_reason")
  lastVerifiedProvider     String?             @map("last_verified_provider")
  lastCheckedAt            DateTime?           @map("last_checked_at")
  // Phase 22 — drives the e-invoice applicability check. Aggregate
  // annual turnover (paise). Update on annual-return upload. Crossing
  // the env threshold (TAX_EINVOICE_TURNOVER_THRESHOLD_PAISE, default
  // ₹5 crore) makes B2B supplies subject to NIC IRP per CBIC Rule 48(4).
  aggregateTurnoverInPaise BigInt              @default(0) @map("aggregate_turnover_in_paise")
  // Phase 22 — voluntary opt-in for sub-threshold sellers who want
  // NIC IRP coverage anyway (some buyers require it for ITC reasons).
  einvoiceOptedIn          Boolean             @default(false) @map("einvoice_opted_in")
  createdAt                DateTime            @default(now()) @map("created_at")
  updatedAt                DateTime            @updatedAt @map("updated_at")

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@unique([sellerId, gstin], map: "seller_gstins_seller_gstin_uniq")
  // GSTIN is globally unique (one PAN = one entity = one set of GSTINs
  // across all marketplaces; another seller cannot share another's
  // GSTIN). Application catches this with a friendly error.
  @@unique([gstin], map: "seller_gstins_gstin_global_uniq")
  @@index([sellerId, isActive])
  @@index([stateCode])
  @@index([registrationType])
  // Phase 161 (audit #16/B1) — KYC dashboard filters: verified / mismatched.
  @@index([isVerified])
  @@index([legalNameMismatch])
  @@map("seller_gstins")
}

// Customer tax profile — B2B GSTIN(s). Optional; most customers are
// B2C and have no row. Up to ~5 rows allowed per customer for B2B
// convenience (different entity GSTINs).
//
// See docs/tax/GST_ASSUMPTIONS.md §12.
model CustomerTaxProfile {
  id                 String    @id @default(uuid())
  customerId         String    @map("customer_id")
  gstin              String    @map("gstin")
  legalName          String    @map("legal_name")
  billingAddressJson Json      @map("billing_address_json")
  stateCode          String    @map("state_code")
  isDefault          Boolean   @default(false) @map("is_default")
  isVerified         Boolean   @default(false) @map("is_verified")
  verifiedAt         DateTime? @map("verified_at")
  verifiedBy         String?   @map("verified_by")
  verificationNotes  String?   @db.Text @map("verification_notes")
  // Phase 161 (Seller GSTIN Verification audit #18) — same first-class
  // verification columns as SellerGstin (the customer flow shares the service).
  legalNameMismatch  Boolean   @default(false) @map("legal_name_mismatch")
  gstLegalName       String?   @map("gst_legal_name")
  // Phase 200 (audit #8) — String → GstnPortalStatus enum. Written by the
  // shared GstnVerificationService; read by the checkout usability gate (#6).
  gstnPortalStatus   GstnPortalStatus? @map("gstn_portal_status")
  gstnRawResponseJson Json?    @map("gstn_raw_response_json")
  // Phase 200 (audit #20) — see SellerGstin.verificationNotes: stays @db.Text,
  // bounded in code (appendNotes → NOTES_MAX_LINES) rather than by a VarChar
  // that could truncation-fail.
  verificationFailureReason String? @map("verification_failure_reason")
  lastVerifiedProvider String?  @map("last_verified_provider")
  lastCheckedAt      DateTime? @map("last_checked_at")
  // Phase 161 (Customer Tax Profile audit #18) — set on each B2B order that
  // uses this profile; powers "suggest this as your default" prompts.
  lastSelectedAt     DateTime? @map("last_selected_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  customer User @relation(fields: [customerId], references: [id], onDelete: Cascade)
  // Phase 161 (audit B2) — invoices issued to this profile (snapshot FK).
  // Phase 200 (audit #16) — RETENTION GUARANTEE: a TaxDocument snapshots the
  // buyer identity (buyerGstin / buyerLegalName / billingAddressJson) AT ISSUE
  // TIME and is NEVER mutated when this profile is later edited or hard-deleted.
  // The TaxDocument.customerTaxProfile FK is ON DELETE SET NULL (declared in
  // tax-documents.prisma), so a hard delete nulls only the FK — the snapshotted
  // buyer* columns remain. An issued invoice therefore always carries the
  // GSTIN/name/address that were in effect when it was minted. Order-placement
  // additionally captures MasterOrder.customerTaxProfileSnapshot (audit #11,
  // migration 20260602380000) so invoice GENERATION still succeeds even if the
  // profile is deleted before the order ships.
  taxDocuments TaxDocument[]

  @@unique([customerId, gstin], map: "customer_tax_profiles_user_gstin_uniq")
  // Phase 200 (audit #7) — at most ONE default per customer is also enforced at
  // the DB level by a raw-SQL PARTIAL unique index
  // `customer_tax_profiles_one_default_per_customer_uniq`
  // (UNIQUE (customer_id) WHERE is_default = true) — Prisma can't express a
  // WHERE-partial unique, so it lives in migration 20260602360000. The service
  // already serialises the unset-then-set in one tx; this index is the backstop
  // against a concurrent two-default race.
  @@index([customerId, isDefault])
  @@index([gstin])
  @@index([legalNameMismatch])
  @@map("customer_tax_profiles")
}

// Phase 161 (Customer Tax Profile audit #8) — append-only field-change
// history. legalName / billingAddress / isDefault edits overwrite in place;
// invoices are already protected (TaxDocument snapshots buyer identity), so
// this answers "what did this customer's profile look like before the edit".
// changedBy is the customerId (the customer is the actor) or an admin id.
// NO FK to the profile — profiles are HARD-deleted, and this history (incl.
// the DELETE event) must survive that (same design as GstinVerificationEvent).
model CustomerTaxProfileHistory {
  id         String   @id @default(uuid())
  profileId  String   @map("profile_id")
  customerId String   @map("customer_id")
  // CREATE / UPDATE / SET_DEFAULT / DELETE
  action     String
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  changedBy  String?  @map("changed_by")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([profileId, createdAt(sort: Desc)])
  @@index([customerId, createdAt(sort: Desc)])
  @@map("customer_tax_profile_history")
}

// Phase 161 (Seller GSTIN Verification audit B4/#8) — append-only history of
// every GSTN verification attempt for BOTH SellerGstin and CustomerTaxProfile
// (targetType discriminates). verificationNotes on the row keeps only the
// latest line; this table is the full, queryable audit trail (who checked,
// what the portal returned, mismatch, the raw envelope) so a re-verify no
// longer loses history.
model GstinVerificationEvent {
  id                String   @id @default(uuid())
  // SELLER_GSTIN | CUSTOMER_TAX_PROFILE
  targetType        String   @map("target_type")
  targetId          String   @map("target_id")
  gstin             String   @map("gstin")
  provider          String
  actorId           String?  @map("actor_id")
  found             Boolean
  verified          Boolean
  status            String
  portalLegalName   String?  @map("portal_legal_name")
  legalNameMismatch Boolean  @default(false) @map("legal_name_mismatch")
  failureReason     String?  @db.Text @map("failure_reason")
  rawResponseJson   Json?    @map("raw_response_json")
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([targetType, targetId, createdAt(sort: Desc)])
  @@index([gstin, createdAt(sort: Desc)])
  @@map("gstin_verification_events")
}

// Platform GST profile — Sportsmart's own GSTIN(s). Used when
// `OWN_BRAND` or `SPORTSMART` is the supplier (no marketplace seller).
// Typically one row marked isDefault=true at the start; additional
// rows added if Sportsmart registers in more states.
model PlatformGstProfile {
  id                    String              @id @default(uuid())
  legalBusinessName     String              @map("legal_business_name")
  gstin                 String              @unique @map("gstin")
  registeredAddressJson Json                @map("registered_address_json")
  gstStateCode          String              @map("gst_state_code")
  registrationType      GstRegistrationType @default(REGULAR) @map("registration_type")
  // PAN stored last-4 only for display; full PAN encrypted at rest if
  // needed later (Phase 1 stores it cleartext in panNumber, optional).
  panNumber             String?             @map("pan_number")
  panLast4              String?             @map("pan_last_4")
  panVerified           Boolean             @default(false) @map("pan_verified")
  isDefault             Boolean             @default(false) @map("is_default")
  isActive              Boolean             @default(true) @map("is_active")
  // Phase 161 (Platform GST Profile audit B5/#11/#12) — actor attribution,
  // OCC, and reason capture on the two most consequential mutations.
  // createdBy/updatedBy: which admin touched the platform's own tax identity
  // (was never captured). version: optimistic-concurrency token.
  // deactivationReason / setDefaultReason: why a profile was retired / the
  // default GSTIN switched (every subsequent invoice rides on the default).
  createdBy             String?             @map("created_by")
  updatedBy             String?             @map("updated_by")
  version               Int                 @default(0)
  deactivationReason    String?             @map("deactivation_reason")
  setDefaultReason      String?             @map("set_default_reason")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  // Phase 161 (audit #12) — append-only field-change history.
  history      PlatformGstProfileHistory[]
  // Phase 161 (audit B3) — invoices minted under this profile (snapshot FK).
  taxDocuments TaxDocument[]

  @@index([isDefault, isActive])
  @@index([gstStateCode])
  // Phase 161 (#6) — at-most-one ACTIVE profile per state + at-most-one
  // DEFAULT row are enforced by PARTIAL unique indexes declared in the
  // migration SQL (Prisma can't express `WHERE` on @@unique). See
  // 20260529140000_platform_gst_profile_hardening.
  @@map("platform_gst_profiles")
}

// Phase 161 (Platform GST Profile audit #12) — append-only field-change
// history. legalBusinessName / registeredAddressJson / registrationType /
// isDefault / isActive edits overwrote in place; this records a row per
// mutation with the before/after snapshot, the acting admin, and reason.
// (Historical INVOICES are already protected — TaxDocument snapshots
// sellerLegalName/sellerAddressJson/sellerStateCode at issuance — so this
// answers "what did the PROFILE look like in March 2026", not invoice drift.)
model PlatformGstProfileHistory {
  id        String   @id @default(uuid())
  profileId String   @map("profile_id")
  gstin     String   @map("gstin")
  // CREATE / UPDATE / DEACTIVATE / REACTIVATE / SET_DEFAULT
  action    String
  oldValues Json?    @map("old_values")
  newValues Json?    @map("new_values")
  changedBy String?  @map("changed_by")
  reason    String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  profile PlatformGstProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, createdAt(sort: Desc)])
  @@map("platform_gst_profile_history")
}

// Runtime tax configuration — JSON values for admin-tunable settings.
// Examples:
//   key="required_hsn_length",       value=6
//   key="eway_bill_threshold_paise", value=5000000
//   key="shipping_sac_code",         value="9968"
//   key="shipping_gst_rate_bps",     value=1800
//   key="goodwill_approval_threshold_paise", value=500000
//   key="tcs_rate_bps",              value=100
//   key="default_gst_rate_bps_test_mode", value=1800
//
// Read via TaxConfigService.get<T>(key). Admin UI lists every key
// with current value + last-updated metadata.
model TaxConfig {
  id          String   @id @default(uuid())
  key         String   @unique @map("key")
  value       Json     @map("value")
  description String?  @map("description")
  updatedBy   String?  @map("updated_by")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("tax_config")
}

// Phase 159w (GST Mode Toggle audit) — first-class mode enum, shared by the
// order/invoice snapshot (audit B2) + the append-only history below (audit B3).
// The LIVE mode is still persisted in tax_config (key 'tax_mode' authoritative,
// plus the two legacy boolean flags for back-compat readers); this enum is the
// common vocabulary for snapshots and history.
enum GstMode {
  OFF
  AUDIT
  STRICT
}

// Phase 159w (audit B3 + #9/#11/#16) — append-only record of every tax-mode
// change. The admin "History" table reads this; the AuditPublicFacade row
// (module 'tax-mode', action 'TAX_MODE_CHANGED') is the cross-cutting compliance
// mirror. Written atomically inside TaxModeService.setMode's transaction so a
// regulatory mode flip can never be unattributable.
model GstModeHistory {
  id           String   @id @default(uuid())
  fromMode     GstMode? @map("from_mode")
  toMode       GstMode  @map("to_mode")
  actorId      String?  @map("actor_id")
  reason       String?  @map("reason") @db.Text
  // True when an admin overrode the AUDIT-readiness gate to enter STRICT.
  forced       Boolean  @default(false) @map("forced")
  // Snapshot of TaxAuditReadinessService.totalBlockers at flip time.
  blockerCount Int      @default(0) @map("blocker_count")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("gst_mode_history")
}
