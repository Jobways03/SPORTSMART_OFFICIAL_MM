// ============================================
// Tax Master Data — Phase 1 of the GST/tax/invoice system
// ============================================
// Added 2026-05-13 per the 27-phase GST implementation plan.
// See docs/tax/CA.md (especially §A phase log) and
// docs/tax/GST_ASSUMPTIONS.md for the engineering assumptions
// behind every default declared here.
//
// This file owns:
//   - Tax-domain enums (SupplyTaxability, GstRegistrationType,
//     TaxSplitType, LineType, DocumentType — only the ones in
//     scope for Phase 1; document types arrive in Phase 8).
//   - Master / lookup tables: india_states, uqc_master, hsn_master
//   - Supplier / customer tax-profile tables: seller_gstins,
//     customer_tax_profiles, platform_gst_profiles
//   - Runtime config: tax_config
//
// All money fields land in tax-documents.prisma (Phase 8). All
// document/credit-note/e-way-bill/ledger tables also land in
// later phases. Phase 1 is purely additive lookup + profile data.

// ─── Enums ───────────────────────────────────────────────────────

enum SupplyTaxability {
  TAXABLE
  NIL_RATED
  EXEMPT
  NON_GST
  ZERO_RATED
  OUT_OF_SCOPE
}

enum GstRegistrationType {
  REGULAR
  COMPOSITION
  UNREGISTERED
}

// Phase 5 will use these (LineType) and Phase 8 will use these
// (DocumentType). Declaring early so Phase 1 schema can reference
// the enum names without forward-declaration churn.
enum TaxLineType {
  PRODUCT
  SHIPPING
  GIFT_WRAP
  CONVENIENCE_FEE
  COD_FEE
  ROUND_OFF
  DISCOUNT_ADJUSTMENT
}

enum TaxSplitType {
  CGST_SGST
  IGST
}

enum SupplierType {
  MARKETPLACE_SELLER
  FRANCHISE
  OWN_BRAND
  SPORTSMART
}

// Phase 5 GST — derived flag on tax snapshots + summaries. COMPLETE
// for a fully-resolved taxable line; INCOMPLETE in test mode when
// the product is TAXABLE but missing HSN/rate; EXEMPT for NIL_RATED/
// EXEMPT/NON_GST/OUT_OF_SCOPE supplies (separate GSTR-1 reporting).
enum TaxDataStatus {
  COMPLETE
  INCOMPLETE
  EXEMPT
}

// Phase 12 GST — Section 34 credit-note eligibility classification for
// QC-approved returns. The daily time-bar cron classifies each return
// into one of these buckets so finance/ops can decide between issuing
// a real CREDIT_NOTE and recording a `wallet_adjustment` instead.
//   ELIGIBLE                — within Sec 34 window; CreditNoteService
//                             will (or already has) issue a credit note.
//   TIME_BARRED             — past 30 Sept of FY+1; no GST output
//                             reduction possible. Platform absorbs the
//                             GST cost; refund flows via wallet.
//   REQUIRES_FINANCE_REVIEW — borderline (within 7 days of cutoff, or
//                             source invoice has unusual status). A
//                             finance lead must triage manually.
enum CreditNoteEligibilityStatus {
  ELIGIBLE
  TIME_BARRED
  REQUIRES_FINANCE_REVIEW
}

// ─── Master / lookup tables ──────────────────────────────────────

// India state master — canonical 2-digit GST state code list.
// 28 states + 8 union territories + special-region codes per CBIC.
// See docs/tax/GST_ASSUMPTIONS.md §1 (state-code source of truth).
model IndiaState {
  id                 String   @id @default(uuid())
  // CBIC 2-digit code as string ("01" .. "38"). Canonical key
  // used across tax-document tables.
  gstStateCode       String   @unique @map("gst_state_code")
  stateName          String   @map("state_name")
  // ISO 3166-2:IN equivalent ("IN-AP", "IN-AR", ...) for any
  // module that needs ISO format. Tax module always uses
  // gstStateCode.
  isoCode            String?  @map("iso_code")
  isUnionTerritory   Boolean  @default(false) @map("is_union_territory")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("india_states")
}

// UQC (Unit Quantity Code) master — CBIC standard 38-code list.
// Every tax-invoice line must declare a UQC per Section 31 / Rule 46.
// Seeded by prisma/seed/seed-uqc-master.ts.
model UqcMaster {
  id          String   @id @default(uuid())
  // CBIC short codes: NOS, PCS, KGS, MTR, ...
  code        String   @unique @map("code")
  description String   @map("description")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("uqc_master")
}

// HSN master — engineering-seeded stub for sports goods; CA replaces
// with the signed-off list. Supports versioning via effectiveFrom /
// effectiveTo so rate changes mid-year don't rewrite history (snapshots
// on OrderTaxLineSnapshot retain the rate that applied at order time).
//
// CA actions: see docs/tax/HSN_RATE_POLICY.md §7.
model HsnMaster {
  id                 String           @id @default(uuid())
  hsnCode            String           @map("hsn_code")
  description        String           @map("description")
  defaultGstRateBps  Int              @default(0) @map("default_gst_rate_bps")
  supplyTaxability   SupplyTaxability @default(TAXABLE) @map("supply_taxability")
  defaultUqcCode     String?          @map("default_uqc_code")
  // Free-text classification hint: "apparel", "footwear", "equipment".
  // Helps admin UI suggest the right HSN for a category-bulk operation.
  categoryHint       String?          @map("category_hint")
  isActive           Boolean          @default(true) @map("is_active")
  effectiveFrom      DateTime         @map("effective_from")
  effectiveTo        DateTime?        @map("effective_to")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  // A HSN code may have multiple effective-period rows (rate changes).
  // No two rows for the same code can have the same effectiveFrom.
  @@unique([hsnCode, effectiveFrom], map: "hsn_master_code_effective_uniq")
  @@index([hsnCode])
  @@index([isActive, effectiveFrom])
  @@map("hsn_master")
}

// ─── Supplier / customer GST profiles ────────────────────────────

// Seller's GSTIN(s). Default: one primary row per seller. Multi-GSTIN
// support (different state warehouses) lives here too — Phase 1 ships
// the schema even though most sellers will only have one primary row.
//
// See docs/tax/GST_ASSUMPTIONS.md §11 for composition seller policy.
model SellerGstin {
  id                String             @id @default(uuid())
  sellerId          String             @map("seller_id")
  // Full 15-char GSTIN. Validated by GstinValidator before insert.
  gstin             String             @map("gstin")
  // 2-digit GST state code; MUST equal first 2 chars of gstin.
  // Enforced by application validator + CHECK constraint below.
  stateCode         String             @map("state_code")
  legalName         String             @map("legal_name")
  addressJson       Json               @map("address_json")
  isPrimary         Boolean            @default(false) @map("is_primary")
  isActive          Boolean            @default(true) @map("is_active")
  registrationType  GstRegistrationType @default(REGULAR) @map("registration_type")
  verifiedAt        DateTime?          @map("verified_at")
  verifiedBy        String?            @map("verified_by")
  verificationNotes String?            @map("verification_notes")
  // Phase 22 — drives the e-invoice applicability check. Aggregate
  // annual turnover (paise). Update on annual-return upload. Crossing
  // the env threshold (TAX_EINVOICE_TURNOVER_THRESHOLD_PAISE, default
  // ₹5 crore) makes B2B supplies subject to NIC IRP per CBIC Rule 48(4).
  aggregateTurnoverInPaise BigInt @default(0) @map("aggregate_turnover_in_paise")
  // Phase 22 — voluntary opt-in for sub-threshold sellers who want
  // NIC IRP coverage anyway (some buyers require it for ITC reasons).
  einvoiceOptedIn          Boolean @default(false) @map("einvoice_opted_in")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@unique([sellerId, gstin], map: "seller_gstins_seller_gstin_uniq")
  // GSTIN is globally unique (one PAN = one entity = one set of GSTINs
  // across all marketplaces; another seller cannot share another's
  // GSTIN). Application catches this with a friendly error.
  @@unique([gstin], map: "seller_gstins_gstin_global_uniq")
  @@index([sellerId, isActive])
  @@index([stateCode])
  @@index([registrationType])
  @@map("seller_gstins")
}

// Customer tax profile — B2B GSTIN(s). Optional; most customers are
// B2C and have no row. Up to ~5 rows allowed per customer for B2B
// convenience (different entity GSTINs).
//
// See docs/tax/GST_ASSUMPTIONS.md §12.
model CustomerTaxProfile {
  id                 String   @id @default(uuid())
  customerId         String   @map("customer_id")
  gstin              String   @map("gstin")
  legalName          String   @map("legal_name")
  billingAddressJson Json     @map("billing_address_json")
  stateCode          String   @map("state_code")
  isDefault          Boolean  @default(false) @map("is_default")
  isVerified         Boolean  @default(false) @map("is_verified")
  verifiedAt         DateTime? @map("verified_at")
  verifiedBy         String?  @map("verified_by")
  verificationNotes  String?  @map("verification_notes")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  customer User @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, gstin], map: "customer_tax_profiles_user_gstin_uniq")
  @@index([customerId, isDefault])
  @@index([gstin])
  @@map("customer_tax_profiles")
}

// Platform GST profile — Sportsmart's own GSTIN(s). Used when
// `OWN_BRAND` or `SPORTSMART` is the supplier (no marketplace seller).
// Typically one row marked isDefault=true at the start; additional
// rows added if Sportsmart registers in more states.
model PlatformGstProfile {
  id                    String              @id @default(uuid())
  legalBusinessName     String              @map("legal_business_name")
  gstin                 String              @unique @map("gstin")
  registeredAddressJson Json                @map("registered_address_json")
  gstStateCode          String              @map("gst_state_code")
  registrationType      GstRegistrationType @default(REGULAR) @map("registration_type")
  // PAN stored last-4 only for display; full PAN encrypted at rest if
  // needed later (Phase 1 stores it cleartext in panNumber, optional).
  panNumber             String?             @map("pan_number")
  panLast4              String?             @map("pan_last_4")
  panVerified           Boolean             @default(false) @map("pan_verified")
  isDefault             Boolean             @default(false) @map("is_default")
  isActive              Boolean             @default(true) @map("is_active")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  @@index([isDefault, isActive])
  @@index([gstStateCode])
  @@map("platform_gst_profiles")
}

// Runtime tax configuration — JSON values for admin-tunable settings.
// Examples:
//   key="required_hsn_length",       value=6
//   key="eway_bill_threshold_paise", value=5000000
//   key="shipping_sac_code",         value="9968"
//   key="shipping_gst_rate_bps",     value=1800
//   key="goodwill_approval_threshold_paise", value=500000
//   key="tcs_rate_bps",              value=100
//   key="default_gst_rate_bps_test_mode", value=1800
//
// Read via TaxConfigService.get<T>(key). Admin UI lists every key
// with current value + last-updated metadata.
model TaxConfig {
  id          String   @id @default(uuid())
  key         String   @unique @map("key")
  value       Json     @map("value")
  description String?  @map("description")
  updatedBy   String?  @map("updated_by")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("tax_config")
}
