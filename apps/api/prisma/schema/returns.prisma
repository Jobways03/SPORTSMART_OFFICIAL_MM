// ============================================
// Returns Module - owned tables
// ============================================

model Return {
  id            String @id @default(uuid())
  returnNumber  String @unique @map("return_number") // RET-2026-000001
  subOrderId    String @map("sub_order_id")
  masterOrderId String @map("master_order_id")
  customerId    String @map("customer_id")

  status ReturnStatus @default(REQUESTED)
  // Phase 5 (PR 5.1) — optimistic-lock counter. Incremented on every
  // status mutation. Concurrent writers compare against the version they
  // read; a CAS mismatch surfaces as a 409 instead of a silent state
  // overwrite (e.g. a stale "mark-received" stomping a fresh "rejected").
  version Int @default(0)

  // Initiator
  initiatedBy String  @default("CUSTOMER") @map("initiated_by") // CUSTOMER, ADMIN, SELLER, FRANCHISE
  initiatorId String? @map("initiator_id")

  // Approval
  approvedAt      DateTime? @map("approved_at")
  approvedBy      String?   @map("approved_by")
  rejectedAt      DateTime? @map("rejected_at")
  rejectedBy      String?   @map("rejected_by")
  rejectionReason String?   @map("rejection_reason")

  // Pickup
  pickupScheduledAt    DateTime? @map("pickup_scheduled_at")
  pickupAddress        Json?     @map("pickup_address")
  pickupTrackingNumber String?   @map("pickup_tracking_number")
  pickupCourier        String?   @map("pickup_courier")

  // Receipt at warehouse
  receivedAt DateTime? @map("received_at")
  receivedBy String?   @map("received_by")

  // QC
  qcCompletedAt DateTime?  @map("qc_completed_at")
  qcDecision    QcOutcome? @map("qc_decision")
  qcNotes       String?    @map("qc_notes")

  // Phase 13 — liability attribution captured at QC time. Drives
  // SellerDebit / LogisticsClaim / PlatformExpense ledger writes so
  // returns and disputes share the same money-flow story (ADR-016).
  // Both columns are nullable for back-compat with rows decided
  // before this migration; the QC controller requires them on new
  // submissions whenever any item is approved.
  liabilityParty  LiabilityParty?  @map("liability_party")
  customerRemedy  CustomerRemedy?  @map("customer_remedy")
  qcRationale     String?          @map("qc_rationale")
  qcInternalNotes String?          @map("qc_internal_notes")
  qcCourierName   String?          @map("qc_courier_name")
  qcAwbNumber     String?          @map("qc_awb_number")

  // Phase 13 (P1.8) — seller-response lifecycle. Set at return-creation
  // time based on per-item reasonCategory (see classifyReasonForSellerResponse).
  // Null on legacy rows; QC-side code treats null as "not_required" so
  // historical returns keep working.
  sellerResponseStatus SellerResponseStatus? @map("seller_response_status")
  sellerNotifiedAt     DateTime?             @map("seller_notified_at")
  sellerResponseDueAt  DateTime?             @map("seller_response_due_at")
  sellerRespondedAt    DateTime?             @map("seller_responded_at")
  sellerResponseNotes  String?               @map("seller_response_notes")

  // Phase 13 (P1.11) — risk scoring at intake. 0-100; null on legacy
  // rows. risk_flags is a list of short codes (e.g. ['HIGH_VALUE_NO_EVIDENCE',
  // 'CUSTOMER_ABUSE']) so admin can see which dimensions fired without
  // re-running the scorer. risk_scored_at is the timestamp of the
  // most recent score computation for staleness checks.
  riskScore     Int?      @map("risk_score")
  riskFlags     Json?     @map("risk_flags")
  riskScoredAt  DateTime? @map("risk_scored_at")

  // Phase 13 (P1.14) — replacement / exchange request lifecycle.
  // replacementStatus stays NULL on legacy rows AND on returns whose
  // outcome is a refund (the common path). When QC picks REPLACEMENT
  // or EXCHANGE, the status moves through PENDING_STOCK_CHECK →
  // AWAITING_FULFILMENT (or AWAITING_PAYMENT for exchange-with-diff).
  // The order_id columns are loose pointers (no FK constraint) until
  // the order-creation follow-up lands.
  replacementStatus       ReplacementRequestStatus? @map("replacement_status")
  replacementOrderId      String?                   @map("replacement_order_id")
  exchangeOrderId         String?                   @map("exchange_order_id")
  exchangeTargetVariantId String?                   @map("exchange_target_variant_id")
  exchangePriceDiffPaise  BigInt?                   @map("exchange_price_diff_paise")
  // Phase 13 (P1.14 follow-up) — Razorpay payment for the price-up
  // exchange diff. Stamped at initiateExchangePayment, cleared once
  // verifyExchangePayment confirms the signature.
  exchangeRazorpayOrderId   String?   @map("exchange_razorpay_order_id")
  exchangePaymentCompletedAt DateTime? @map("exchange_payment_completed_at")

  // Refund
  refundMethod      ReturnRefundMethod? @map("refund_method")
  refundAmount      Decimal?            @map("refund_amount") @db.Decimal(10, 2)
  // Phase 1.4 — paise sibling (ADR-007). Authoritative once dual-write
  // soak completes; until then both columns are kept in lockstep by
  // MoneyDualWriteMiddleware whenever MONEY_DUAL_WRITE_ENABLED=true.
  refundAmountInPaise BigInt?           @map("refund_amount_in_paise")
  refundProcessedAt DateTime?           @map("refund_processed_at")
  refundReference   String?             @map("refund_reference")

  // Refund processing tracking (Phase R4)
  refundAttempts      Int       @default(0) @map("refund_attempts")
  refundLastAttemptAt DateTime? @map("refund_last_attempt_at")
  refundFailureReason String?   @map("refund_failure_reason")
  refundInitiatedBy   String?   @map("refund_initiated_by") // ADMIN, SYSTEM
  refundInitiatedAt   DateTime? @map("refund_initiated_at")

  // Misc
  customerNotes String?   @map("customer_notes")
  closedAt      DateTime? @map("closed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  subOrder           SubOrder              @relation(fields: [subOrderId], references: [id], onDelete: Cascade)
  masterOrder        MasterOrder           @relation(fields: [masterOrderId], references: [id], onDelete: Cascade)
  customer           User                  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items              ReturnItem[]
  evidence           ReturnEvidence[]
  statusHistory      ReturnStatusHistory[]
  refundTransactions RefundTransaction[]

  @@index([customerId])
  @@index([subOrderId])
  @@index([masterOrderId])
  @@index([status])
  @@index([returnNumber])
  @@index([liabilityParty])
  @@index([customerRemedy])
  @@index([sellerResponseStatus, sellerResponseDueAt])
  @@index([riskScore])
  @@index([replacementStatus])
  @@map("returns")
}

model ReturnItem {
  id             String               @id @default(uuid())
  returnId       String               @map("return_id")
  orderItemId    String               @map("order_item_id")
  quantity       Int
  reasonCategory ReturnReasonCategory @map("reason_category")
  reasonDetail   String?              @map("reason_detail")

  // QC outcome per item
  qcOutcome          QcOutcome? @map("qc_outcome")
  qcQuantityApproved Int?       @map("qc_quantity_approved")
  qcNotes            String?    @map("qc_notes")

  refundAmount        Decimal? @map("refund_amount") @db.Decimal(10, 2)
  // Phase 1.4 paise sibling (ADR-007).
  refundAmountInPaise BigInt?  @map("refund_amount_in_paise")

  createdAt DateTime @default(now()) @map("created_at")

  return    Return    @relation(fields: [returnId], references: [id], onDelete: Cascade)
  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([returnId])
  @@index([orderItemId])
  @@map("return_items")
}

model ReturnEvidence {
  id          String   @id @default(uuid())
  returnId    String   @map("return_id")
  uploadedBy  String   @map("uploaded_by") // CUSTOMER, FRANCHISE, SELLER, ADMIN
  uploaderId  String?  @map("uploader_id")
  fileType    String   @map("file_type")
  fileUrl     String   @map("file_url")
  publicId    String?  @map("public_id")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  return Return @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@index([returnId])
  @@map("return_evidence")
}

model ReturnStatusHistory {
  id          String        @id @default(uuid())
  returnId    String        @map("return_id")
  fromStatus  ReturnStatus? @map("from_status")
  toStatus    ReturnStatus  @map("to_status")
  changedBy   String        @map("changed_by") // CUSTOMER, ADMIN, SELLER, FRANCHISE, SYSTEM
  changedById String?       @map("changed_by_id")
  notes       String?
  createdAt   DateTime      @default(now()) @map("created_at")

  return Return @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@index([returnId])
  @@map("return_status_history")
}

// ── Refund Transaction audit trail ──────────────────────────────
//
// One row per refund gateway attempt. The Return model's embedded
// `refundAttempts`, `refundReference`, and `refundFailureReason`
// are running-state fields; this table preserves the full history
// so operators can trace every gateway call made for a refund.

enum RefundTransactionStatus {
  INITIATED
  PROCESSED
  FAILED
}

model RefundTransaction {
  id              String                  @id @default(uuid())
  returnId        String                  @map("return_id")
  attemptNumber   Int                     @map("attempt_number")
  amount          Decimal                 @map("amount") @db.Decimal(10, 2)
  // Phase 1.4 paise sibling (ADR-007).
  amountInPaise   BigInt                  @default(0) @map("amount_in_paise")
  gatewayRefundId String?                 @map("gateway_refund_id")
  status          RefundTransactionStatus @default(INITIATED)
  failureReason   String?                 @map("failure_reason")
  actorType       String                  @map("actor_type") // ADMIN, SYSTEM
  actorId         String?                 @map("actor_id")
  createdAt       DateTime                @default(now()) @map("created_at")

  return Return @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@index([returnId])
  @@index([status])
  @@index([createdAt])
  @@map("refund_transactions")
}

model ReturnSequence {
  id         Int @id @default(1)
  lastNumber Int @default(0) @map("last_number")

  @@map("return_sequences")
}
