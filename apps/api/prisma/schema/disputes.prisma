// Disputes module — formal escalation path when a return / order is
// contested by either side (buyer claims wrong item, seller claims
// damage occurred in transit, QC rejected but buyer disagrees).
//
// Tickets module covers free-form support; disputes are the structured
// resolution layer with evidence, internal notes, and an audit-stamped
// final decision.

enum DisputeKind {
  RETURN_REJECTED       // buyer disputes a QC rejection
  WRONG_ITEM_RECEIVED   // buyer says they got the wrong item
  DAMAGED_IN_TRANSIT    // damage between dispatch and delivery
  MISSING_FROM_PARCEL   // partial item missing on delivery
  OTHER
}

enum DisputeStatus {
  OPEN              // filed, awaiting first admin touch
  UNDER_REVIEW      // admin acknowledged + investigating
  AWAITING_INFO     // need info from buyer/seller
  RESOLVED_BUYER    // outcome favours the buyer (refund / replacement)
  RESOLVED_SELLER   // outcome favours the seller (no refund)
  RESOLVED_SPLIT    // partial — e.g. partial refund
  CLOSED            // procedural close (buyer abandoned, dup, etc.)
}

enum DisputeActorType {
  CUSTOMER
  SELLER
  ADMIN
}

// Phase 12 (post-Phase-11) — see ADR-016. Records who pays for the
// customer-favoured outcome of a dispute. NONE is used when the
// dispute is resolved against the customer (no money moves) or when
// the resolution is administrative (CLOSED).
enum LiabilityParty {
  NONE
  SELLER
  LOGISTICS
  PLATFORM
  CUSTOMER
  // Phase 13 completion — return-side attributions that don't map to
  // any of the four core actors. Disputes never write these (the
  // dispute DTO union stays narrow); returns can now record
  // franchise / brand fault and INCONCLUSIVE for cases where QC
  // can't tell who's at fault.
  FRANCHISE
  BRAND
  INCONCLUSIVE
}

// Phase 12 (post-Phase-11) — separates "what the customer gets" from
// "who pays". GOODWILL_CREDIT is a non-recourse payment booked as a
// PlatformExpense; functionally the customer wallet is credited the
// same as a FULL_REFUND but no recovery is attempted from any party.
enum CustomerRemedy {
  FULL_REFUND
  PARTIAL_REFUND
  NO_REFUND
  GOODWILL_CREDIT
  // Phase 13 (P1.14) — return-only outcomes. Disputes never write
  // these (the dispute DTO union stays narrow); they live on the
  // shared enum so the Return.customerRemedy column accepts them
  // without a separate type.
  REPLACEMENT
  EXCHANGE
}

model Dispute {
  id            String        @id @default(uuid())
  disputeNumber String        @unique @map("dispute_number") // DSP-YYYY-NNNNNN
  kind          DisputeKind
  status        DisputeStatus @default(OPEN)
  // Phase 5 (PR 5.2) — optimistic-lock counter. Same shape as Return.version;
  // see returns.prisma for the full rationale.
  version       Int           @default(0)
  // 1-100 — drives queue order (90+ = urgent). Set by admin during triage.
  severity      Int           @default(50)

  // Linked records — at least one should be set.
  masterOrderId String? @map("master_order_id")
  subOrderId    String? @map("sub_order_id")
  returnId      String? @map("return_id")

  // Phase 11 (post-Phase-10) — ticket-as-front-door rebrand. When a
  // support agent decides a ticket needs the formal resolution path
  // (refund decision, audit trail, SLA), they "promote" it. The
  // customer never sees the dispute — they keep talking on the
  // ticket. Admin operations happen on the dispute, and message
  // mirroring keeps both sides in sync. Null = direct-filed dispute
  // (legacy customer/seller/admin filings still work the old way).
  // No Prisma relation because the existing DB index isn't UNIQUE on
  // this column; service code does an explicit `findUnique({ id: })`
  // when it needs the ticket row. The unique side lives on Ticket
  // (`promotedToDisputeId @unique`), which already constrains 1:1.
  sourceTicketId String? @map("source_ticket_id")

  // Polymorphic filer (matches TicketActorType convention; admin-filed
  // disputes happen when an admin escalates on behalf of a buyer).
  filedByType   DisputeActorType @map("filed_by_type")
  filedById     String           @map("filed_by_id")
  filedByName   String           @map("filed_by_name")

  // Initial complaint summary (the first message body, snapshotted).
  summary String @db.Text

  // Triage assignment.
  assignedAdminId String? @map("assigned_admin_id")

  // Decision audit (populated when status transitions to a RESOLVED_*).
  decisionByAdminId      String?   @map("decision_by_admin_id")
  decisionAt             DateTime? @map("decision_at")
  decisionRationale      String?   @map("decision_rationale") @db.Text
  // Refund amount in paise (matches money convention elsewhere). Set
  // for RESOLVED_BUYER (full refund) or RESOLVED_SPLIT (partial). Null
  // for RESOLVED_SELLER. The refund flow reads this to mint the actual
  // wallet credit / gateway refund.
  decisionAmountInPaise  Int?      @map("decision_amount_in_paise")

  // Phase 12 (post-Phase-11) — liability + remedy split. The decision
  // (RESOLVED_BUYER / SPLIT / SELLER) only says *who won*; these two
  // columns record *who pays* and *what the customer gets*. Drives:
  //   - whether a RefundInstruction is created (and for what amount)
  //   - which ledger row is written (SellerDebit / LogisticsClaim /
  //     PlatformExpense)
  //   - the linked-return status update (DISPUTE_OVERTURNED etc.)
  // See docs/decisions/016-dispute-liability-ledger.md for the matrix.
  liabilityParty  LiabilityParty?  @map("liability_party")
  customerRemedy  CustomerRemedy?  @map("customer_remedy")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  messages DisputeMessage[]
  evidence DisputeEvidence[]

  @@index([status, severity(sort: Desc), createdAt(sort: Desc)])
  @@index([filedByType, filedById])
  @@index([masterOrderId])
  @@index([returnId])
  @@index([sourceTicketId])
  @@map("disputes")
}

model DisputeMessage {
  id        String @id @default(uuid())
  disputeId String @map("dispute_id")

  senderType DisputeActorType @map("sender_type")
  senderId   String           @map("sender_id")
  senderName String           @map("sender_name")

  body           String  @db.Text
  // Internal notes hidden from buyer/seller views — admin-only triage.
  isInternalNote Boolean @default(false) @map("is_internal_note")

  // Phase 11 (post-Phase-10) — mirror provenance. Set when this row
  // was auto-created from a customer/seller reply on the promoted
  // ticket. UNIQUE so a retried mirror handler cannot double-write.
  // Null for native dispute messages (admin replies, internal notes).
  mirroredFromTicketMessageId String? @unique @map("mirrored_from_ticket_message_id")

  createdAt DateTime @default(now()) @map("created_at")

  dispute Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId, createdAt])
  @@map("dispute_messages")
}

model DisputeEvidence {
  id        String @id @default(uuid())
  disputeId String @map("dispute_id")

  // Polymorphic linkage — same pattern as ticket attachments. Files
  // live in the existing FileMetadata table.
  fileId   String @map("file_id")
  caption  String?

  uploadedByType DisputeActorType @map("uploaded_by_type")
  uploadedById   String           @map("uploaded_by_id")
  uploadedAt     DateTime         @default(now()) @map("uploaded_at")

  dispute Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId])
  @@map("dispute_evidence")
}

model DisputeSequence {
  id         Int @id @default(1)
  lastNumber Int @default(0) @map("last_number")

  @@map("dispute_sequence")
}
