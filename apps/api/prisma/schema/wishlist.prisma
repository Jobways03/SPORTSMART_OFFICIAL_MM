// ============================================
// Wishlist Module - owned tables
// ============================================
//
// Sprint 3 Story 2.2 — buyer-facing "save for later, not in cart yet".
// Distinct from CartItem: wishlist items don't reserve inventory and
// aren't priced at add-time. Variant-id is nullable so a customer can
// favourite a product abstractly ("any size") or a specific SKU.
//
// Soft semantics:
//  - Unique on (userId, productId, variantId) — a NULL variantId is
//    treated as its own slot (Postgres treats NULLs as distinct in
//    unique indexes by default), so "Product X, any variant" and
//    "Product X, variant V1" can coexist.
//  - On product or variant hard-delete, wishlist rows cascade.

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  variantId String?  @map("variant_id")
  // Customer-supplied note (optional). Useful for "save in 36" /
  // "for Diwali gift". Kept short to discourage repurposing as a
  // freeform notes feature.
  note      String?  @db.VarChar(280)

  // Phase 202 (#13) — price snapshot at add-time (integer paise,
  // BigInt). Wishlist items are explicitly NOT priced for checkout
  // (the cart re-prices), but capturing what the customer saw when
  // they saved the item lets the UI surface "price dropped since you
  // saved this" later without inventing a price-history join. Nullable
  // because (a) legacy rows predate it and (b) an abstract "any
  // variant" save on a variant-priced product has no single price to
  // snapshot. Money discipline: integer paise, serialized as a string
  // on the wire, Number() only at the format boundary.
  unitPriceInPaiseAtAdd BigInt? @map("unit_price_in_paise_at_add")

  createdAt DateTime @default(now()) @map("created_at")

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  // Composite unique — one wishlist slot per (user, product, variant).
  // NULLs in variantId count as distinct per ANSI SQL, which is the
  // behaviour we want (see comment above).
  @@unique([userId, productId, variantId])
  // "List my wishlist newest-first" — primary read pattern.
  @@index([userId, createdAt(sort: Desc)])
  @@map("wishlist_items")
}
