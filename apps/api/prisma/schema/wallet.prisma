// Wallet ledger.
// One wallet per user. Balance is the sum of all COMPLETED transactions
// (we also denormalize `balance_after_in_paise` on each row so the running
// balance is auditable without re-summing the ledger).
//
// Money is stored in paise (₹1 = 100 paise) as BigInt. The pre-PR-2.2
// schema used Int — ~₹21M cap (INT max paise = 2,147,483,647). That's
// plenty for a single retail customer's wallet but reachable on B2B
// franchise wallets, large promo credits, and admin adjustment rounds.
// BigInt removes the cap; the application layer marshals to/from `number`
// at the repository boundary so service code stays in TypeScript's safe-
// integer range (₹90 trillion).

enum WalletTransactionType {
  TOPUP // user-initiated load (via payment gateway)
  REFUND // credit from a refunded return / cancelled order
  CREDIT_ADJUSTMENT // admin manual credit (goodwill, promo)
  DEBIT // user spent at checkout
  DEBIT_ADJUSTMENT // admin manual debit (chargeback, fraud reversal)
}

enum WalletTransactionStatus {
  PENDING // initiated, awaiting external confirmation (e.g. gateway webhook)
  COMPLETED
  FAILED
  REVERSED // posted then reversed (chargeback / dispute upheld against us)
}

model Wallet {
  id             String   @id @default(uuid())
  userId         String   @unique @map("user_id")
  // Sum of COMPLETED transactions. Maintained transactionally with the
  // ledger row insert so the two never disagree.
  // Phase 2 (PR 2.2) — BigInt. See file header for the rationale.
  balanceInPaise BigInt   @default(0) @map("balance_in_paise")
  // Currency is fixed to INR for the platform but stored explicitly so
  // analytics + statement endpoints don't need to scrape it from elsewhere.
  currency       String   @default("INR")
  // Optimistic-locking guard. Bumped on every credit/debit so concurrent
  // mutations (refund + checkout deduction at the same instant) detect
  // conflict at the DB layer instead of silently overwriting.
  version        Int      @default(0)
  // Admin-controlled freeze. When true, all credit/debit calls reject
  // unless the caller passes `bypassBlock: true` (only the unblock
  // endpoint should ever set that). Used for fraud holds & disputes.
  isBlocked        Boolean   @default(false) @map("is_blocked")
  blockedReason    String?   @map("blocked_reason")
  blockedAt        DateTime? @map("blocked_at")
  blockedByAdminId String?   @map("blocked_by_admin_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
  adjustments  WalletAdjustment[]

  @@map("wallets")
}

model WalletTransaction {
  id                  String                  @id @default(uuid())
  walletId            String                  @map("wallet_id")
  // Denormalized for cheap per-user history queries without a join.
  userId              String                  @map("user_id")
  type                WalletTransactionType
  status              WalletTransactionStatus @default(COMPLETED)
  // Signed amount in paise: credits positive, debits negative.
  // Phase 2 (PR 2.2) — BigInt. See file header for the rationale.
  amountInPaise       BigInt                  @map("amount_in_paise")
  // Wallet balance immediately after this row was applied. Lets us
  // render statements + reconcile without re-summing the ledger.
  balanceAfterInPaise BigInt                  @map("balance_after_in_paise")
  // Polymorphic linkage to the upstream record that caused this entry.
  // e.g. ('REFUND', '<refund-id>'), ('TOPUP', '<razorpay-payment-id>'),
  // ('DEBIT', '<order-id>'). Optional for admin-manual adjustments
  // where the only record is the reason / notes themselves.
  referenceType       String?                 @map("reference_type")
  referenceId         String?                 @map("reference_id")
  // Customer-visible description (rendered in /account/wallet).
  description         String
  // Admin-only notes (rendered in admin wallet view, not surfaced to user).
  internalNotes       String?                 @map("internal_notes")
  // For admin manual entries: which admin actor created it. Null for
  // system-generated entries (refund, top-up).
  createdByAdminId    String?                 @map("created_by_admin_id")
  createdAt           DateTime                @default(now()) @map("created_at")

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  adjustments WalletAdjustment[]

  @@index([walletId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([referenceType, referenceId])
  // Phase 3 (PR 3.2) — wallet idempotency. Two writes with the SAME
  // (referenceType, referenceId, type) collide at the DB level, so a
  // refund-credit triggered twice (network retry, replay, manual
  // re-fire) cannot double-credit. Postgres treats NULL as distinct
  // in unique indexes by default, so admin-manual rows (no reference)
  // continue to coexist freely.
  @@unique([referenceType, referenceId, type])
  @@map("wallet_transactions")
}

// Phase 13 GST — Wallet adjustments (goodwill + time-barred refunds).
//
// Business-layer record of "we owe this customer N paise but the
// credit-note path can't (or shouldn't) carry the money". Once
// approved, posts a wallet_transactions row of type CREDIT_ADJUSTMENT
// (the wallet ledger stays the source of truth for the balance).
//
// Separate from wallet_transactions because:
//   1. Carries GST context (source invoice, absorbed tax components)
//      that the wallet ledger doesn't model.
//   2. Approval workflow — small goodwill credits can auto-approve,
//      high-value ones must queue for finance review.
//   3. Phase 12 cron's `GST_CREDIT_NOTE_TIME_BARRED` AdminTask
//      hands work to this table once finance triages.
enum WalletAdjustmentKind {
  // Sec 34 cutoff passed; the credit-note path is unavailable. The
  // refund routes through wallet; the GST cost sticks to the platform
  // (captured in the would_have_been_* columns for GSTR-1/3B audit).
  TIME_BARRED_CREDIT_NOTE
  // Admin-initiated goodwill credit (apology, compensation). No
  // return / GST reversal.
  GOODWILL
  // Admin-initiated debit (chargeback, fraud reversal). Stored as
  // a negative amountInPaise.
  MANUAL_DEBIT
  // Catch-all. Forces `reason` to be meaningful at write time.
  MANUAL_OTHER
}

enum WalletAdjustmentStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  REVERSED
}

model WalletAdjustment {
  id String @id @default(uuid())

  customerId String  @map("customer_id")
  walletId   String? @map("wallet_id")

  // Business context — only TIME_BARRED_CREDIT_NOTE carries the full
  // return / sub-order / source-invoice triple.
  subOrderId          String? @map("sub_order_id")
  returnId            String? @map("return_id")
  sourceTaxDocumentId String? @map("source_tax_document_id")

  // Caller-supplied idempotency key (e.g.
  // `TIME_BARRED_CREDIT_NOTE:${returnId}`). Stops a retried QC
  // submission or cron re-run from inserting a duplicate pending row.
  idempotencyKey String @unique @map("idempotency_key")

  kind   WalletAdjustmentKind
  status WalletAdjustmentStatus @default(PENDING_APPROVAL)

  // Signed paise. + = credit to customer (refund/goodwill); - = debit
  // (chargeback). Passed verbatim to WalletService.credit / .debit.
  amountInPaise BigInt @map("amount_in_paise")
  currency      String @default("INR")

  // "Absorbed GST" snapshot — what the credit note WOULD have reversed
  // if Section 34 weren't time-barring it. Reported separately in
  // GSTR-1 / 3B so finance can show audit how much GST cost the
  // platform absorbed in the period.
  wouldHaveBeenTaxableInPaise   BigInt? @map("would_have_been_taxable_in_paise")
  wouldHaveBeenCgstInPaise      BigInt? @map("would_have_been_cgst_in_paise")
  wouldHaveBeenSgstInPaise      BigInt? @map("would_have_been_sgst_in_paise")
  wouldHaveBeenIgstInPaise      BigInt? @map("would_have_been_igst_in_paise")
  wouldHaveBeenTotalTaxInPaise  BigInt? @map("would_have_been_total_tax_in_paise")

  reason String

  // Audit trail
  requestedByAdminId String?   @map("requested_by_admin_id")
  requestedAt        DateTime  @default(now()) @map("requested_at")
  approvedByAdminId  String?   @map("approved_by_admin_id")
  approvedAt         DateTime? @map("approved_at")
  rejectedByAdminId  String?   @map("rejected_by_admin_id")
  rejectedAt         DateTime? @map("rejected_at")
  rejectionReason    String?   @map("rejection_reason")

  // Set on approval — references the wallet_transactions row that
  // actually moved the money.
  walletTransactionId String? @map("wallet_transaction_id")

  // High-value gate. When true, only wallet.adjustment.approve can
  // flip status to APPROVED. The Phase 13 threshold is env-tunable.
  requiresDualApproval Boolean @default(false) @map("requires_dual_approval")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customer            User                @relation(fields: [customerId], references: [id], onDelete: Restrict)
  wallet              Wallet?             @relation(fields: [walletId], references: [id], onDelete: Restrict)
  return              Return?             @relation(fields: [returnId], references: [id], onDelete: Restrict)
  sourceTaxDocument   TaxDocument?        @relation("WalletAdjustmentSourceInvoice", fields: [sourceTaxDocumentId], references: [id], onDelete: Restrict)
  walletTransaction   WalletTransaction?  @relation(fields: [walletTransactionId], references: [id], onDelete: Restrict)

  @@index([customerId])
  @@index([walletId])
  @@index([status])
  @@index([returnId])
  @@index([sourceTaxDocumentId])
  @@map("wallet_adjustments")
}
