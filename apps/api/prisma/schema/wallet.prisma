// Wallet ledger.
// One wallet per user. Balance is the sum of all COMPLETED transactions
// (we also denormalize `balance_after_in_paise` on each row so the running
// balance is auditable without re-summing the ledger).
//
// Money is stored in paise (₹1 = 100 paise) as BigInt. The pre-PR-2.2
// schema used Int — ~₹21M cap (INT max paise = 2,147,483,647). That's
// plenty for a single retail customer's wallet but reachable on B2B
// franchise wallets, large promo credits, and admin adjustment rounds.
// BigInt removes the cap; the application layer marshals to/from `number`
// at the repository boundary so service code stays in TypeScript's safe-
// integer range (₹90 trillion).

enum WalletTransactionType {
  TOPUP // user-initiated load (via payment gateway)
  REFUND // credit from a refunded return / cancelled order
  CREDIT_ADJUSTMENT // admin manual credit (goodwill, promo)
  DEBIT // user spent at checkout
  DEBIT_ADJUSTMENT // admin manual debit (chargeback, fraud reversal)
  // Phase 182 (Customer Wallet audit #2) — loyalty/cashback rebate earned on a
  // completed purchase (the spec's third wallet pillar).
  LOYALTY_REBATE
  // Phase 183 (Wallet Credit/Debit audit #5) — distinct types so reporting can
  // separate an admin's deliberate manual adjustment from system/goodwill/
  // redemption/reversal entries. (Goodwill is ALSO discriminated by creditType.)
  MANUAL_CREDIT
  MANUAL_DEBIT
  GOODWILL_CREDIT
  ORDER_REDEMPTION
  REVERSAL
}

// Phase 182 (#5) — explicit credit/debit direction. amountInPaise stays SIGNED
// (the reconciliation cron + goodwill ledger sum it with sign); `direction` is
// the explicit, queryable indicator derived from that sign.
enum WalletDirection {
  CREDIT
  DEBIT
}

// Phase 172 (Goodwill Credit audit #8) — finance-reconciliation discriminator
// on top of the coarse WalletTransactionType. A goodwill credit and a genuine
// refund are both `type=REFUND` rows today; creditType separates platform-
// EXPENSE (goodwill) from refund-LIABILITY so reconciliation + reports can split
// them. Nullable: pre-172 rows + non-credit rows carry null.
enum WalletCreditType {
  REFUND_ORIGINAL // money the customer was genuinely owed (return/dispute refund)
  GOODWILL // apology credit — platform expense, non-recoverable
  TIME_BARRED // refund past the return window, booked as goodwill-class
  PROMO // marketing/promo credit
  MANUAL // admin manual credit, uncategorised
  LOYALTY // Phase 182 — loyalty/cashback rebate (platform marketing expense)
}

// Phase 70 (2026-05-22) — Phase 66 audit Gap #8. Minimal saga
// state for the wallet-refund-on-checkout-cancel flow. Pre-Phase-70
// the refund call in CheckoutService was `try { … } catch { /* ignore */ }`
// — a downstream failure left the wallet debited with no audit
// trail and no retry. The saga row is written on either side of
// the call:
//   • PENDING when we're about to attempt
//   • COMPLETED when the wallet credit succeeded
//   • FAILED + lastError + attempts++ when it threw
// A cron sweeps FAILED rows for retry; permanent failures (5
// attempts) emit an ops event so finance can reconcile.
enum WalletRefundSagaStatus {
  PENDING
  COMPLETED
  FAILED
  ABANDONED
}

model WalletRefundSaga {
  id            String                 @id @default(uuid())
  customerId    String                 @map("customer_id")
  orderId       String                 @map("order_id")
  amountInPaise BigInt                 @map("amount_in_paise")
  reason        String
  status        WalletRefundSagaStatus @default(PENDING)
  attempts      Int                    @default(0)
  lastError     String?                @map("last_error")
  lastAttemptAt DateTime?              @map("last_attempt_at")
  completedAt   DateTime?              @map("completed_at")
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")

  // No FK to User to keep cross-module decoupling — the wallet
  // facade re-resolves customerId at retry time. The orderId is a
  // string for the same reason (orders and wallet are separate
  // modules with their own retention policies).

  // (orderId, customerId, amountInPaise) tuple is unique per saga
  // run so retries don't double-write. The partial unique index in
  // the migration enforces this for PENDING rows; COMPLETED rows
  // are kept for audit and don't participate in the unique.
  @@index([status, lastAttemptAt])
  @@index([orderId])
  @@map("wallet_refund_sagas")
}

enum WalletTransactionStatus {
  PENDING // initiated, awaiting external confirmation (e.g. gateway webhook)
  COMPLETED
  FAILED
  REVERSED // posted then reversed (chargeback / dispute upheld against us)
}

model Wallet {
  id               String    @id @default(uuid())
  userId           String    @unique @map("user_id")
  // Sum of COMPLETED transactions. Maintained transactionally with the
  // ledger row insert so the two never disagree.
  // Phase 2 (PR 2.2) — BigInt. See file header for the rationale.
  balanceInPaise   BigInt    @default(0) @map("balance_in_paise")
  // Currency is fixed to INR for the platform but stored explicitly so
  // analytics + statement endpoints don't need to scrape it from elsewhere.
  currency         String    @default("INR")
  // Optimistic-locking guard. Bumped on every credit/debit so concurrent
  // mutations (refund + checkout deduction at the same instant) detect
  // conflict at the DB layer instead of silently overwriting.
  version          Int       @default(0)
  // Admin-controlled freeze. When true, all credit/debit calls reject
  // unless the caller passes `bypassBlock: true` (only the unblock
  // endpoint should ever set that). Used for fraud holds & disputes.
  isBlocked        Boolean   @default(false) @map("is_blocked")
  blockedReason    String?   @map("blocked_reason")
  blockedAt        DateTime? @map("blocked_at")
  blockedByAdminId String?   @map("blocked_by_admin_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
  adjustments  WalletAdjustment[]

  @@map("wallets")
}

model WalletTransaction {
  id                  String                  @id @default(uuid())
  walletId            String                  @map("wallet_id")
  // Denormalized for cheap per-user history queries without a join.
  userId              String                  @map("user_id")
  type                WalletTransactionType
  status              WalletTransactionStatus @default(COMPLETED)
  // Signed amount in paise: credits positive, debits negative.
  // Phase 2 (PR 2.2) — BigInt. See file header for the rationale.
  amountInPaise       BigInt                  @map("amount_in_paise")
  // Wallet balance immediately after this row was applied. Lets us
  // render statements + reconcile without re-summing the ledger.
  balanceAfterInPaise BigInt                  @map("balance_after_in_paise")
  // Phase 182 (#4) — balance immediately BEFORE this row (= balanceAfter −
  // signed amount). Lets a statement render "from X to Y" per line.
  balanceBeforeInPaise BigInt                 @default(0) @map("balance_before_in_paise")
  // Phase 182 (#5) — explicit CREDIT/DEBIT (derived from the sign of amount).
  direction           WalletDirection?        @map("direction")
  // Phase 182 (#9) — per-row currency (mirrors Wallet.currency; INR today).
  currency            String                  @default("INR")
  // Phase 182 (#8) — human-readable source reference (e.g. "RTN-2026-000045",
  // "ORD-2026-000123") for customer-facing display; referenceId stays the UUID.
  referenceNumber     String?                 @map("reference_number")
  // Polymorphic linkage to the upstream record that caused this entry.
  // e.g. ('REFUND', '<refund-id>'), ('TOPUP', '<razorpay-payment-id>'),
  // ('DEBIT', '<order-id>'). Optional for admin-manual adjustments
  // where the only record is the reason / notes themselves.
  referenceType       String?                 @map("reference_type")
  referenceId         String?                 @map("reference_id")
  // Customer-visible description (rendered in /account/wallet).
  description         String
  // Phase 183 (#2) — audit-grade internal REASON (why the adjustment was made),
  // distinct from the customer-facing `description`. Admin-only; stripped from
  // customer responses alongside internalNotes.
  reason              String?                 @map("reason")
  // Admin-only notes (rendered in admin wallet view, not surfaced to user).
  internalNotes       String?                 @map("internal_notes")
  // For admin manual entries: which admin actor created it. Null for
  // system-generated entries (refund, top-up).
  createdByAdminId    String?                 @map("created_by_admin_id")
  // Phase 172 (Goodwill Credit audit #8/#9) — reconciliation discriminator +
  // optional expiry. creditType separates goodwill (platform expense) from a
  // genuine refund (liability); expiresAt is set for goodwill (NOW +
  // GOODWILL_CREDIT_EXPIRY_DAYS) so an expiry sweep can lapse unused credit.
  creditType          WalletCreditType?       @map("credit_type")
  expiresAt           DateTime?               @map("expires_at")
  // Phase 172 (#9) — set on a GOODWILL lot once the expiry sweep has processed
  // it (whether it lapsed a remainder or the lot was already fully spent). Lets
  // the sweep's candidate query skip already-handled lots — no re-scan, no
  // starvation under a batch limit. Does NOT affect balance math (the
  // computeGoodwillState replay reads the ledger, not this marker).
  lapsedAt            DateTime?               @map("lapsed_at")
  createdAt           DateTime                @default(now()) @map("created_at")

  wallet      Wallet             @relation(fields: [walletId], references: [id], onDelete: Cascade)
  adjustments WalletAdjustment[]

  // Phase 3 (PR 3.2) — wallet idempotency. Two writes with the SAME
  // (referenceType, referenceId, type) collide at the DB level, so a
  // refund-credit triggered twice (network retry, replay, manual
  // re-fire) cannot double-credit. Postgres treats NULL as distinct
  // in unique indexes by default, so admin-manual rows (no reference)
  // continue to coexist freely.
  @@unique([referenceType, referenceId, type])
  @@index([walletId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([referenceType, referenceId])
  // Phase 182 (audit §8) — "pending topups for this user" + status filters.
  @@index([userId, status, createdAt(sort: Desc)])
  @@map("wallet_transactions")
}

// Phase 182 (Customer Wallet audit #2/#3) — loyalty/cashback earn ledger. One
// row per (sourceType, sourceId) purchase; idempotent. When POSTED it mints a
// LOYALTY_REBATE wallet credit (back-linked via walletTransactionId) with an
// expiry. The rebate math is config-driven (env: bps + caps); the model keeps
// the eligible/awarded amounts + status for audit and re-run safety.
enum LoyaltyEarnStatus {
  PENDING
  POSTED
  SKIPPED
}

model LoyaltyEarnEvent {
  id                   String            @id @default(uuid())
  userId               String            @map("user_id")
  sourceType           String            @map("source_type") // e.g. ORDER
  sourceId             String            @map("source_id")
  eligibleAmountInPaise BigInt           @map("eligible_amount_in_paise")
  rebateInPaise        BigInt            @default(0) @map("rebate_in_paise")
  // Phase 182 (make-it-100%) — how much of the rebate was clawed back when the
  // order was later refunded (proportional, once per order, clamped to balance).
  clawedBackInPaise    BigInt            @default(0) @map("clawed_back_in_paise")
  rateBps              Int               @default(0) @map("rate_bps")
  status               LoyaltyEarnStatus @default(PENDING)
  skipReason           String?           @map("skip_reason")
  expiresAt            DateTime?         @map("expires_at")
  walletTransactionId  String?           @map("wallet_transaction_id")
  createdAt            DateTime          @default(now()) @map("created_at")
  postedAt             DateTime?         @map("posted_at")

  @@unique([sourceType, sourceId])
  @@index([userId, createdAt])
  @@index([status])
  @@map("loyalty_earn_events")
}

// Phase 13 GST — Wallet adjustments (goodwill + time-barred refunds).
//
// Business-layer record of "we owe this customer N paise but the
// credit-note path can't (or shouldn't) carry the money". Once
// approved, posts a wallet_transactions row of type CREDIT_ADJUSTMENT
// (the wallet ledger stays the source of truth for the balance).
//
// Separate from wallet_transactions because:
//   1. Carries GST context (source invoice, absorbed tax components)
//      that the wallet ledger doesn't model.
//   2. Approval workflow — small goodwill credits can auto-approve,
//      high-value ones must queue for finance review.
//   3. Phase 12 cron's `GST_CREDIT_NOTE_TIME_BARRED` AdminTask
//      hands work to this table once finance triages.
enum WalletAdjustmentKind {
  // Sec 34 cutoff passed; the credit-note path is unavailable. The
  // refund routes through wallet; the GST cost sticks to the platform
  // (captured in the would_have_been_* columns for GSTR-1/3B audit).
  TIME_BARRED_CREDIT_NOTE
  // Admin-initiated goodwill credit (apology, compensation). No
  // return / GST reversal.
  GOODWILL
  // Admin-initiated debit (chargeback, fraud reversal). Stored as
  // a negative amountInPaise.
  MANUAL_DEBIT
  // Catch-all. Forces `reason` to be meaningful at write time.
  MANUAL_OTHER
}

enum WalletAdjustmentStatus {
  PENDING_APPROVAL
  // Intermediate state for dual-approval rows: one admin has signed off,
  // a second distinct admin must approve before money moves. Only rows
  // with requiresDualApproval=true can transition through this state.
  FIRST_APPROVED
  APPROVED
  REJECTED
  REVERSED
}

model WalletAdjustment {
  id String @id @default(uuid())

  customerId String  @map("customer_id")
  walletId   String? @map("wallet_id")

  // Business context — only TIME_BARRED_CREDIT_NOTE carries the full
  // return / sub-order / source-invoice triple.
  subOrderId          String? @map("sub_order_id")
  returnId            String? @map("return_id")
  sourceTaxDocumentId String? @map("source_tax_document_id")

  // Caller-supplied idempotency key (e.g.
  // `TIME_BARRED_CREDIT_NOTE:${returnId}`). Stops a retried QC
  // submission or cron re-run from inserting a duplicate pending row.
  idempotencyKey String @unique @map("idempotency_key")

  kind   WalletAdjustmentKind
  status WalletAdjustmentStatus @default(PENDING_APPROVAL)

  // Signed paise. + = credit to customer (refund/goodwill); - = debit
  // (chargeback). Passed verbatim to WalletService.credit / .debit.
  amountInPaise BigInt @map("amount_in_paise")
  currency      String @default("INR")

  // "Absorbed GST" snapshot — what the credit note WOULD have reversed
  // if Section 34 weren't time-barring it. Reported separately in
  // GSTR-1 / 3B so finance can show audit how much GST cost the
  // platform absorbed in the period.
  wouldHaveBeenTaxableInPaise  BigInt? @map("would_have_been_taxable_in_paise")
  wouldHaveBeenCgstInPaise     BigInt? @map("would_have_been_cgst_in_paise")
  wouldHaveBeenSgstInPaise     BigInt? @map("would_have_been_sgst_in_paise")
  wouldHaveBeenIgstInPaise     BigInt? @map("would_have_been_igst_in_paise")
  wouldHaveBeenTotalTaxInPaise BigInt? @map("would_have_been_total_tax_in_paise")

  reason String

  // Audit trail
  requestedByAdminId     String?   @map("requested_by_admin_id")
  requestedAt            DateTime  @default(now()) @map("requested_at")
  // First sign-off on a dual-approval row. Stays null on single-approval
  // rows (the row goes straight from PENDING_APPROVAL to APPROVED).
  firstApprovedByAdminId String?   @map("first_approved_by_admin_id")
  firstApprovedAt        DateTime? @map("first_approved_at")
  approvedByAdminId      String?   @map("approved_by_admin_id")
  approvedAt             DateTime? @map("approved_at")
  rejectedByAdminId      String?   @map("rejected_by_admin_id")
  rejectedAt             DateTime? @map("rejected_at")
  rejectionReason        String?   @map("rejection_reason")

  // Set on approval — references the wallet_transactions row that
  // actually moved the money.
  walletTransactionId String? @map("wallet_transaction_id")

  // High-value gate. When true, only wallet.adjustment.approve can
  // flip status to APPROVED. The Phase 13 threshold is env-tunable.
  requiresDualApproval Boolean @default(false) @map("requires_dual_approval")

  // Phase 162 (Wallet Adjustments audit #12) — reversal of a POSTED/APPROVED
  // adjustment via a compensating inverse ledger entry (status → REVERSED).
  // Mirrors migration 20260529180000_wallet_adjustment_hardening. (Schema-model
  // drift: that migration + the service code shipped these columns but the
  // Prisma model was never updated; restored here in Phase 172 to unblock tsc.)
  reversedByAdminId      String?   @map("reversed_by_admin_id")
  reversedAt             DateTime? @map("reversed_at")
  reverseReason          String?   @map("reverse_reason")
  reversingTransactionId String?   @map("reversing_transaction_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customer          User               @relation(fields: [customerId], references: [id], onDelete: Restrict)
  wallet            Wallet?            @relation(fields: [walletId], references: [id], onDelete: Restrict)
  return            Return?            @relation(fields: [returnId], references: [id], onDelete: Restrict)
  sourceTaxDocument TaxDocument?       @relation("WalletAdjustmentSourceInvoice", fields: [sourceTaxDocumentId], references: [id], onDelete: Restrict)
  walletTransaction WalletTransaction? @relation(fields: [walletTransactionId], references: [id], onDelete: Restrict)

  @@index([customerId])
  @@index([walletId])
  @@index([status])
  @@index([returnId])
  @@index([sourceTaxDocumentId])
  @@map("wallet_adjustments")
}

// Phase 162 (Wallet Adjustments audit #11) — append-only state-transition trail
// for a wallet adjustment. Mirrors migration 20260529180000 (table
// wallet_adjustment_history); restored to the Prisma model in Phase 172.
model WalletAdjustmentHistory {
  id            String                  @id @default(uuid())
  adjustmentId  String                  @map("adjustment_id")
  customerId    String                  @map("customer_id")
  action        String
  fromStatus    WalletAdjustmentStatus? @map("from_status")
  toStatus      WalletAdjustmentStatus  @map("to_status")
  actorId       String?                 @map("actor_id")
  reason        String?
  amountInPaise BigInt                  @map("amount_in_paise")
  createdAt     DateTime                @default(now()) @map("created_at")

  @@index([adjustmentId, createdAt])
  @@index([customerId, createdAt])
  @@map("wallet_adjustment_history")
}
