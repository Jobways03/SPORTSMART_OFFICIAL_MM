// ============================================
// Seller-Product Mapping Module
// Links sellers to global products for multi-seller fulfillment
// ============================================

model SellerProductMapping {
  id        String  @id @default(uuid())
  sellerId  String  @map("seller_id")
  productId String  @map("product_id")
  variantId String? @map("variant_id")

  // Inventory.
  //
  // Phase 2 (PR 2.4) — three DB-level CHECK constraints back these
  // columns (added via migration 20260512150000):
  //
  //   stock_qty    >= 0
  //   reserved_qty >= 0
  //   reserved_qty <= stock_qty   ← keeps available stock ≥ 0
  //
  // Prisma doesn't model CHECK constraints in the schema, so they
  // live only in the migration SQL. Any raw-SQL or non-Prisma write
  // that violates them will be rejected by Postgres — the typed
  // service guards (PR 1.10's CSV import floor, seller-allocation's
  // `FOR UPDATE` reservation path) stay in place as the primary
  // enforcement layer, and these constraints are the defence-in-depth
  // backstop.
  stockQty          Int @default(0) @map("stock_qty")
  reservedQty       Int @default(0) @map("reserved_qty")
  lowStockThreshold Int @default(5) @map("low_stock_threshold")

  // Seller's internal reference
  sellerInternalSku String? @map("seller_internal_sku")

  // Pricing (seller side — not customer-facing)
  settlementPrice Decimal? @map("settlement_price") @db.Decimal(10, 2)
  procurementCost Decimal? @map("procurement_cost") @db.Decimal(10, 2)

  // Fulfillment
  pickupAddress String?  @map("pickup_address")
  pickupPincode String?  @map("pickup_pincode")
  latitude      Decimal? @db.Decimal(10, 7)
  longitude     Decimal? @db.Decimal(10, 7)
  dispatchSla   Int      @default(2) @map("dispatch_sla") // days to dispatch

  // Status & priority.
  //
  // Phase 56 (2026-05-22) — isActive default flipped from true →
  // false so direct DB inserts (admin seeds, raw SQL) follow the
  // intended "PENDING_APPROVAL until reviewed" lifecycle instead of
  // landing live by accident. The controller already hardcodes
  // false; this aligns the schema's default.
  approvalStatus      MappingApprovalStatus @default(PENDING_APPROVAL) @map("approval_status")
  isActive            Boolean               @default(false) @map("is_active")
  operationalPriority Int                   @default(0) @map("operational_priority") // higher = preferred

  // Phase 56 (2026-05-22) — audit columns. Pre-Phase-56 approve /
  // stop calls were untraceable post-fact; updatedAt was overwritten
  // on every subsequent PATCH. Now each lifecycle transition stamps
  // who did it and when. rejectionReason is the user-visible
  // explanation the seller sees on a REJECTED mapping.
  approvedBy      String?   @map("approved_by")
  approvedAt      DateTime? @map("approved_at")
  rejectedBy      String?   @map("rejected_by")
  rejectedAt      DateTime? @map("rejected_at")
  rejectionReason String?   @map("rejection_reason")
  stoppedBy       String?   @map("stopped_by")
  stoppedAt       DateTime? @map("stopped_at")

  // Phase 59 (2026-05-22) — bulk-suspend audit columns (audit
  // Gap #3). Distinguished from stoppedBy/At (Phase 56 single
  // mapping) so a forensic query can answer "which admin
  // bulk-suspended this seller and why" without joining the
  // tamper-evident audit chain. Same shape for the reverse
  // transition (reactivatedBy/At/Reason) so the audit trail
  // narrates a complete suspend→reactivate cycle.
  suspendedBy        String?   @map("suspended_by")
  suspendedAt        DateTime? @map("suspended_at")
  suspensionReason   String?   @map("suspension_reason")
  reactivatedBy      String?   @map("reactivated_by")
  reactivatedAt      DateTime? @map("reactivated_at")
  reactivationReason String?   @map("reactivation_reason")

  // Phase 60 (2026-05-22) — auto-repair migration tracking (audit
  // Gap #12). When a stale product-level (variantId=null) mapping
  // is fanned out into per-variant mappings, each new row carries
  // a pointer back to its source so a forensic query can answer
  // "which mappings inherited from which migration?" without
  // joining the audit chain. The stale row itself is soft-deleted
  // (deletedAt set, isActive=false) rather than hard-deleted —
  // preserves ledger + reservations + LowStockAlert FK refs
  // (audit Gap #2).
  migratedFromMappingId String?   @map("migrated_from_mapping_id")
  migratedAt            DateTime? @map("migrated_at")

  // Phase 51 (2026-05-21) — soft-delete. Pre-Phase-51 the delete
  // endpoint hard-removed the row, cascading to StockMovement and
  // losing the forensic trail. The soft-delete stamp lets seller +
  // admin reads filter it out while ledger history survives.
  deletedAt DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  seller         Seller             @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  product        Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant        ProductVariant?    @relation(fields: [variantId], references: [id], onDelete: Cascade)
  reservations   StockReservation[]
  // Phase 4 follow-up (2026-05-16) — back-relation to the
  // StockMovement audit ledger. One mapping accumulates many
  // movements over its lifetime; the relation lets admins drill into
  // a mapping's full stock-change history without a manual join.
  stockMovements StockMovement[]

  @@unique([sellerId, productId, variantId])
  @@index([sellerId])
  @@index([productId])
  @@index([variantId])
  @@index([pickupPincode])
  @@index([isActive])
  @@index([approvalStatus])
  @@index([deletedAt])
  // Phase 59 (2026-05-22) — hot suspend/activate query. The bulk
  // endpoint scans by (sellerId, approvalStatus='APPROVED',
  // isActive=true); without this composite, Postgres falls back
  // to the single-column sellerId index plus filter, which
  // re-scans every row of the largest seller's catalog on each
  // call.
  @@index([sellerId, approvalStatus, isActive])
  // Phase 60 (2026-05-22) — composite for the stale-mapping
  // detection pre-check (productId, variantId IS NULL,
  // deletedAt IS NULL). The hot-path GET endpoint now does a
  // count on this composite to skip the heavy fan-out logic when
  // there's nothing stale.
  @@index([productId, variantId, deletedAt])
  // Phase 60 — forensic lookup "show me every mapping migrated
  // from stale X".
  @@index([migratedFromMappingId])
  // Phase 193 (#16) — the storefront PDP / related / facet queries scan
  // active+approved+in-stock mappings for a product; this composite serves
  // that exact predicate without re-scanning the productId index + filter.
  @@index([productId, isActive, approvalStatus])
  @@map("seller_product_mappings")
}

// ============================================
// StockMovement — append-only stock-change ledger (Phase 4, 2026-05-16)
// ============================================
//
// Every stock-changing action on a SellerProductMapping writes one
// row. Pre-2026-05-16 these movements were captured only as audit-log
// rows on the tamper-evident chain — fine for compliance, but slow to
// query ("show me every change to mapping X" needed a full audit-log
// scan). The dedicated table gives finance + ops an indexed
// (mappingId, createdAt) view for drill-down + analytics.
//
// During the soak window `StockMovementLedgerService` writes BOTH
// the audit-log row AND the StockMovement row; once the team has
// confidence in the new path, the audit-log path can drop.

// Phase 53 (2026-05-21) — DAMAGE/LOSS/AUDIT_CORRECTION added so the
// franchise adjustment path can write through the same typed ledger
// once its repo migrates. Pre-Phase-53 these kinds existed only as
// free-string movementType values on a parallel franchise ledger,
// making cross-actor stock reporting awkward.
enum StockMovementKind {
  RESERVED
  RELEASED
  CONFIRMED
  DEDUCTED
  RESTOCKED
  WRITE_OFF
  MANUAL_ADJUST
  INITIAL
  DAMAGE
  LOSS
  AUDIT_CORRECTION
}

model StockMovement {
  id String @id @default(uuid())

  // Phase 53 (2026-05-21) — polymorphic resource pointer. Pre-Phase-53
  // the table was seller-mapping-only via the mandatory mappingId FK.
  // The resourceType discriminator + nullable mappingId let franchise
  // and own-brand stock events land in the same typed ledger so
  // cross-actor reporting is a single-table scan.
  resourceType String @default("SELLER_MAPPING") @map("resource_type") // 'SELLER_MAPPING' | 'FRANCHISE_STOCK' | 'OWN_BRAND_STOCK'
  resourceId   String @default("") @map("resource_id")

  /// FK onto the SellerProductMapping this movement applies to.
  /// Phase 53 — nullable so non-seller resources can write through
  /// the same table. Still populated for SELLER_MAPPING resourceType.
  mappingId String? @map("mapping_id")

  kind          StockMovementKind
  /// Always positive — direction is encoded in `kind`.
  quantityDelta Int               @map("quantity_delta")

  /// Stock totals captured at write time so the ledger reconstructs
  /// the state machine without joining back to live data.
  beforeStockQty    Int  @map("before_stock_qty")
  afterStockQty     Int  @map("after_stock_qty")
  beforeReservedQty Int? @map("before_reserved_qty")
  afterReservedQty  Int? @map("after_reserved_qty")

  /// Free-text reason — orderId for RESERVED/CONFIRMED/RELEASED,
  /// human justification for MANUAL_ADJUST.
  reason String

  /// Optional cross-reference (orderId / returnId / writeOffTicketId).
  referenceType String? @map("reference_type")
  referenceId   String? @map("reference_id")

  /// Actor identification — admin id for manual operations,
  /// 'SYSTEM' for cron-driven movements.
  actorId   String? @map("actor_id")
  actorRole String? @map("actor_role")

  createdAt DateTime @default(now()) @map("created_at")

  mapping SellerProductMapping? @relation(fields: [mappingId], references: [id], onDelete: Cascade)

  // Hot-path indexes:
  //   * (mappingId, createdAt) — drill-down "show this mapping's
  //     last 100 movements". Covers the admin inventory-detail page.
  //   * (referenceType, referenceId) — given an order id, find
  //     every stock movement caused by it.
  //   * (createdAt) — period-bounded scans (daily reports).
  //   * (resourceType, resourceId, createdAt) — Phase 53, the
  //     cross-actor drill-down path.
  @@index([mappingId, createdAt(sort: Desc)])
  @@index([referenceType, referenceId])
  @@index([createdAt])
  @@index([resourceType, resourceId, createdAt(sort: Desc)])
  @@map("stock_movements")
}
