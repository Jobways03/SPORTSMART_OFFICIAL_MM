// ============================================
// Seller-Product Mapping Module
// Links sellers to global products for multi-seller fulfillment
// ============================================

model SellerProductMapping {
  id        String  @id @default(uuid())
  sellerId  String  @map("seller_id")
  productId String  @map("product_id")
  variantId String? @map("variant_id")

  // Inventory.
  //
  // Phase 2 (PR 2.4) — three DB-level CHECK constraints back these
  // columns (added via migration 20260512150000):
  //
  //   stock_qty    >= 0
  //   reserved_qty >= 0
  //   reserved_qty <= stock_qty   ← keeps available stock ≥ 0
  //
  // Prisma doesn't model CHECK constraints in the schema, so they
  // live only in the migration SQL. Any raw-SQL or non-Prisma write
  // that violates them will be rejected by Postgres — the typed
  // service guards (PR 1.10's CSV import floor, seller-allocation's
  // `FOR UPDATE` reservation path) stay in place as the primary
  // enforcement layer, and these constraints are the defence-in-depth
  // backstop.
  stockQty          Int @default(0) @map("stock_qty")
  reservedQty       Int @default(0) @map("reserved_qty")
  lowStockThreshold Int @default(5) @map("low_stock_threshold")

  // Seller's internal reference
  sellerInternalSku String? @map("seller_internal_sku")

  // Pricing (seller side — not customer-facing)
  settlementPrice Decimal? @map("settlement_price") @db.Decimal(10, 2)
  procurementCost Decimal? @map("procurement_cost") @db.Decimal(10, 2)

  // Fulfillment
  pickupAddress String?  @map("pickup_address")
  pickupPincode String?  @map("pickup_pincode")
  latitude      Decimal? @db.Decimal(10, 7)
  longitude     Decimal? @db.Decimal(10, 7)
  dispatchSla   Int      @default(2) @map("dispatch_sla") // days to dispatch

  // Status & priority
  approvalStatus      MappingApprovalStatus @default(PENDING_APPROVAL) @map("approval_status")
  isActive            Boolean               @default(true) @map("is_active")
  operationalPriority Int                   @default(0) @map("operational_priority") // higher = preferred

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  seller         Seller             @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  product        Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant        ProductVariant?    @relation(fields: [variantId], references: [id], onDelete: Cascade)
  reservations   StockReservation[]
  // Phase 4 follow-up (2026-05-16) — back-relation to the
  // StockMovement audit ledger. One mapping accumulates many
  // movements over its lifetime; the relation lets admins drill into
  // a mapping's full stock-change history without a manual join.
  stockMovements StockMovement[]

  @@unique([sellerId, productId, variantId])
  @@index([sellerId])
  @@index([productId])
  @@index([variantId])
  @@index([pickupPincode])
  @@index([isActive])
  @@index([approvalStatus])
  @@map("seller_product_mappings")
}

// ============================================
// StockMovement — append-only stock-change ledger (Phase 4, 2026-05-16)
// ============================================
//
// Every stock-changing action on a SellerProductMapping writes one
// row. Pre-2026-05-16 these movements were captured only as audit-log
// rows on the tamper-evident chain — fine for compliance, but slow to
// query ("show me every change to mapping X" needed a full audit-log
// scan). The dedicated table gives finance + ops an indexed
// (mappingId, createdAt) view for drill-down + analytics.
//
// During the soak window `StockMovementLedgerService` writes BOTH
// the audit-log row AND the StockMovement row; once the team has
// confidence in the new path, the audit-log path can drop.

enum StockMovementKind {
  RESERVED
  RELEASED
  CONFIRMED
  DEDUCTED
  RESTOCKED
  WRITE_OFF
  MANUAL_ADJUST
  INITIAL
}

model StockMovement {
  id String @id @default(uuid())

  /// FK onto the SellerProductMapping this movement applies to.
  mappingId String @map("mapping_id")

  kind          StockMovementKind
  /// Always positive — direction is encoded in `kind`.
  quantityDelta Int               @map("quantity_delta")

  /// Stock totals captured at write time so the ledger reconstructs
  /// the state machine without joining back to live data.
  beforeStockQty    Int  @map("before_stock_qty")
  afterStockQty     Int  @map("after_stock_qty")
  beforeReservedQty Int? @map("before_reserved_qty")
  afterReservedQty  Int? @map("after_reserved_qty")

  /// Free-text reason — orderId for RESERVED/CONFIRMED/RELEASED,
  /// human justification for MANUAL_ADJUST.
  reason String

  /// Optional cross-reference (orderId / returnId / writeOffTicketId).
  referenceType String? @map("reference_type")
  referenceId   String? @map("reference_id")

  /// Actor identification — admin id for manual operations,
  /// 'SYSTEM' for cron-driven movements.
  actorId   String? @map("actor_id")
  actorRole String? @map("actor_role")

  createdAt DateTime @default(now()) @map("created_at")

  mapping SellerProductMapping @relation(fields: [mappingId], references: [id], onDelete: Cascade)

  // Hot-path indexes:
  //   * (mappingId, createdAt) — drill-down "show this mapping's
  //     last 100 movements". Covers the admin inventory-detail page.
  //   * (referenceType, referenceId) — given an order id, find
  //     every stock movement caused by it.
  //   * (createdAt) — period-bounded scans (daily reports).
  @@index([mappingId, createdAt(sort: Desc)])
  @@index([referenceType, referenceId])
  @@index([createdAt])
  @@map("stock_movements")
}
