// COD rule engine + payout batch tables.

enum CodRuleKind {
  PINCODE_ALLOW
  PINCODE_DENY
  VALUE_LIMIT
  SELLER_DENY
  CUSTOMER_RISK
}

model CodRule {
  id          String      @id @default(uuid())
  kind        CodRuleKind
  // 1-1000 — lower = higher priority (evaluated first).
  priority    Int         @default(100)
  // Free-form match conditions. e.g. {"pincodes":["560001","560002"]} or {"maxValueInr":10000}
  conditions  Json
  active      Boolean     @default(true)
  description String?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@index([active, priority])
  @@map("cod_rules")
}

model CodDecisionLog {
  id                String   @id @default(uuid())
  customerId        String?  @map("customer_id")
  pincode           String?
  sellerId          String?  @map("seller_id")
  orderTotalInr     Decimal? @map("order_total_inr") @db.Decimal(10, 2)
  // Phase 1.4 paise sibling (ADR-007).
  orderTotalInPaise BigInt?  @map("order_total_in_paise")
  eligible          Boolean
  // The rule key that decided the outcome (or "default-allow" / "default-deny").
  decidedBy         String   @map("decided_by")
  reason            String?
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([customerId, createdAt(sort: Desc)])
  @@index([eligible, createdAt(sort: Desc)])
  @@map("cod_decision_logs")
}

// ─────────────────────────────────────────────────────────────────
// Payouts — once a settlement is APPROVED, payouts wrap them into a
// bank-export batch. Status flow:
//   DRAFT → EXPORTED → PARTIALLY_PAID → COMPLETED   (or FAILED)
// ─────────────────────────────────────────────────────────────────

enum PayoutBatchStatus {
  DRAFT
  EXPORTED
  PARTIALLY_PAID
  COMPLETED
  FAILED
  // Phase 151 (2026-05-26) — a batch created in error (wrong cycle) can be
  // aborted before payment; releases its settlements' payout lock.
  CANCELLED
}

// Phase 151 — per-row payout lifecycle. Distinct from PayoutBatchStatus:
// PARTIALLY_PAID is a batch-level rollup that's meaningless on a single row.
enum PayoutStatus {
  DRAFT
  EXPORTED
  COMPLETED
  FAILED
  CANCELLED
}

model PayoutBatch {
  id               String            @id @default(uuid())
  status           PayoutBatchStatus @default(DRAFT)
  // Phase 151 — human-readable identifier (e.g. PB-20260526-AB12) for ops +
  // the bank-file batch_reference column.
  batchNumber      String?           @unique @map("batch_number")
  exportedAt       DateTime?         @map("exported_at")
  exportFileId     String?           @map("export_file_id") // FileMetadata.id
  responseFileId   String?           @map("response_file_id") // bank confirmation CSV
  // Phase 151 — sha256 of the exact CSV handed to the bank (tamper / "which
  // file did we send" evidence), + denormalised batch totals for the queue.
  fileHash         String?           @map("file_hash")
  totalAmountInPaise BigInt          @default(0) @map("total_amount_in_paise")
  settlementCount  Int               @default(0) @map("settlement_count")
  notes            String?
  createdByAdminId String?           @map("created_by_admin_id")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  payouts Payout[]
  // Phase 151 — settlements locked into this batch (payoutBatchId). Back-
  // relation for the duplicate-batch guard.
  sellerSettlements SellerSettlement[]
  // Phase 152 — bank-response import history (per upload / manual submit).
  bankResponseImports BankResponseImport[]

  @@index([status])
  @@map("payout_batches")
}

model Payout {
  id            String            @id @default(uuid())
  batchId       String            @map("batch_id")
  // FK to SellerSettlement (cross-module — kept polymorphic-by-id, not relational).
  settlementId  String            @map("settlement_id")
  sellerId      String            @map("seller_id")
  amount        Decimal           @db.Decimal(12, 2)
  // Phase 1.4 paise sibling (ADR-007).
  amountInPaise BigInt            @default(0) @map("amount_in_paise")
  // Phase 151 — row-specific lifecycle enum (was PayoutBatchStatus).
  status        PayoutStatus      @default(DRAFT)
  utrReference  String?           @map("utr_reference")
  failureReason String?           @map("failure_reason")
  // Phase 152 — the amount the bank actually reported paying (from the
  // response), persisted regardless of match outcome (was only in the
  // failureReason text on a mismatch). Lets finance reconcile drift.
  bankPaidAmountInPaise BigInt?   @map("bank_paid_amount_in_paise")
  paidAt        DateTime?         @map("paid_at")
  createdAt     DateTime          @default(now()) @map("created_at")

  batch PayoutBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, settlementId])
  // Phase 151 — a global partial unique on settlementId WHERE status NOT IN
  // (FAILED, CANCELLED) is created in the migration (Prisma can't express a
  // partial unique): a settlement can only sit in ONE active payout at a time.
  @@index([sellerId])
  @@index([status])
  @@map("payouts")
}

// ─────────────────────────────────────────────────────────────────
// Phase 152 — Bank Response Ingestion audit trail.
//
// Every bank-response submission (file upload OR manual modal entry) creates
// one BankResponseImport + one BankResponseRow per row, so finance has a
// system-of-record for "what was uploaded, by whom, when, and what we did with
// each row" — including the raw row JSON for forensics and a file hash that
// blocks re-ingesting the same file twice.
// ─────────────────────────────────────────────────────────────────

enum BankResponseSource {
  FILE_UPLOAD
  MANUAL_ENTRY
}

model BankResponseImport {
  id                 String             @id @default(uuid())
  payoutBatchId      String             @map("payout_batch_id")
  importedByAdminId  String?            @map("imported_by_admin_id")
  source             BankResponseSource @default(MANUAL_ENTRY)
  // sha256 of the uploaded file bytes (file path only). NULL for manual entry.
  fileHash           String?            @map("file_hash")
  fileName           String?            @map("file_name")
  rowCount           Int                @default(0) @map("row_count")
  successCount       Int                @default(0) @map("success_count")
  failCount          Int                @default(0) @map("fail_count")
  skippedCount       Int                @default(0) @map("skipped_count")
  importedAt         DateTime           @default(now()) @map("imported_at")

  batch PayoutBatch          @relation(fields: [payoutBatchId], references: [id], onDelete: Cascade)
  rows  BankResponseRow[]

  // Re-ingesting the SAME file into the SAME batch is blocked (partial unique
  // on file_hash created in the migration — NULL hashes, i.e. manual entries,
  // are exempt so they can be submitted repeatedly).
  @@index([payoutBatchId])
  @@index([importedByAdminId])
  @@map("bank_response_imports")
}

model BankResponseRow {
  id                    String   @id @default(uuid())
  importId              String   @map("import_id")
  rowIndex              Int      @map("row_index")
  // The raw row exactly as received (parsed CSV cell map or the JSON row) —
  // the forensic record if finance disputes what the bank sent.
  rawJson               Json     @map("raw_json")
  settlementId          String?  @map("settlement_id")
  // COMPLETED / FAILED / SKIPPED — the outcome we applied for this row.
  outcome               String
  utrReference          String?  @map("utr_reference")
  failureReason         String?  @map("failure_reason")
  bankPaidAmountInPaise BigInt?  @map("bank_paid_amount_in_paise")
  processedAt           DateTime @default(now()) @map("processed_at")

  import BankResponseImport @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@index([importId])
  @@index([settlementId])
  @@map("bank_response_rows")
}
