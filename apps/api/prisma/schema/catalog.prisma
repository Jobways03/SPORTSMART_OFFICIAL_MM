// ============================================
// Catalog Module - owned tables
// ============================================

model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  imageUrl    String?  @map("image_url")
  parentId    String?  @map("parent_id")
  level       Int      @default(0)
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryHierarchy")

  products                Product[]
  categoryOptionTemplates CategoryOptionTemplate[]
  metafieldDefinitions    MetafieldDefinition[]

  @@index([parentId])
  @@index([slug])
  @@map("categories")
}

model Brand {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  logoUrl   String?  @map("logo_url")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products Product[]

  @@index([slug])
  @@map("brands")
}

model OptionDefinition {
  id          String   @id @default(uuid())
  name        String   @unique
  displayName String   @map("display_name")
  type        String   @default("GENERIC") // COLOR, SIZE, GENERIC
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  values                  OptionValue[]
  categoryOptionTemplates CategoryOptionTemplate[]
  productOptions          ProductOption[]

  @@map("option_definitions")
}

model OptionValue {
  id                 String   @id @default(uuid())
  optionDefinitionId String   @map("option_definition_id")
  value              String
  displayValue       String   @map("display_value")
  sortOrder          Int      @default(0) @map("sort_order")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  optionDefinition OptionDefinition @relation(fields: [optionDefinitionId], references: [id], onDelete: Cascade)

  productOptionValues        ProductOptionValue[]
  productVariantOptionValues ProductVariantOptionValue[]

  @@unique([optionDefinitionId, value])
  @@index([optionDefinitionId])
  @@map("option_values")
}

model CategoryOptionTemplate {
  id                 String   @id @default(uuid())
  categoryId         String   @map("category_id")
  optionDefinitionId String   @map("option_definition_id")
  isRequired         Boolean  @default(false) @map("is_required")
  sortOrder          Int      @default(0) @map("sort_order")
  createdAt          DateTime @default(now()) @map("created_at")

  category         Category         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  optionDefinition OptionDefinition @relation(fields: [optionDefinitionId], references: [id], onDelete: Cascade)

  @@unique([categoryId, optionDefinitionId])
  @@index([categoryId])
  @@map("category_option_templates")
}

model Product {
  id               String           @id @default(uuid())
  productCode      String?          @unique @map("product_code") // Auto-generated PRD-XXXXXX
  sellerId         String?          @map("seller_id")
  title            String
  slug             String           @unique
  shortDescription String?          @map("short_description")
  description      String?
  categoryId       String?          @map("category_id")
  brandId          String?          @map("brand_id")
  status           ProductStatus    @default(DRAFT)
  moderationStatus ModerationStatus @default(PENDING)
  moderationNote   String?          @map("moderation_note")
  hasVariants      Boolean          @default(false) @map("has_variants")

  // Platform pricing (customer-facing price, admin-controlled)
  platformPrice Decimal? @map("platform_price") @db.Decimal(10, 2)

  // Simple product fields (used when hasVariants = false)
  basePrice      Decimal? @map("base_price") @db.Decimal(10, 2)
  compareAtPrice Decimal? @map("compare_at_price") @db.Decimal(10, 2)
  costPrice      Decimal? @map("cost_price") @db.Decimal(10, 2)
  baseSku        String?  @map("base_sku")
  baseStock      Int?     @map("base_stock")
  baseBarcode    String?  @map("base_barcode")

  // Shipping
  weight        Decimal? @db.Decimal(10, 3)
  weightUnit    String?  @default("kg") @map("weight_unit")
  length        Decimal? @db.Decimal(10, 2)
  width         Decimal? @db.Decimal(10, 2)
  height        Decimal? @db.Decimal(10, 2)
  dimensionUnit String?  @default("cm") @map("dimension_unit")

  // Policy
  returnPolicy String? @map("return_policy")
  warrantyInfo String? @map("warranty_info")

  // Duplicate detection
  potentialDuplicateOf String? @map("potential_duplicate_of")

  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  seller   Seller?   @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brand    Brand?    @relation(fields: [brandId], references: [id], onDelete: SetNull)

  variants       ProductVariant[]
  options        ProductOption[]
  optionValues   ProductOptionValue[]
  images         ProductImage[]
  tags           ProductTag[]
  seo            ProductSeo?
  statusHistory  ProductStatusHistory[]
  collectionMaps ProductCollectionMap[]
  discounts      DiscountProduct[]
  cartItems      CartItem[]
  sellerMappings SellerProductMapping[]
  metafields     ProductMetafield[]

  @@index([sellerId])
  @@index([categoryId])
  @@index([brandId])
  @@index([status])
  @@index([moderationStatus])
  @@index([slug])
  @@index([isDeleted])
  @@map("products")
}

model ProductOption {
  id                 String   @id @default(uuid())
  productId          String   @map("product_id")
  optionDefinitionId String   @map("option_definition_id")
  sortOrder          Int      @default(0) @map("sort_order")
  createdAt          DateTime @default(now()) @map("created_at")

  product          Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  optionDefinition OptionDefinition @relation(fields: [optionDefinitionId], references: [id], onDelete: Cascade)

  @@unique([productId, optionDefinitionId])
  @@index([productId])
  @@map("product_options")
}

model ProductOptionValue {
  id            String   @id @default(uuid())
  productId     String   @map("product_id")
  optionValueId String   @map("option_value_id")
  createdAt     DateTime @default(now()) @map("created_at")

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  optionValue OptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@unique([productId, optionValueId])
  @@index([productId])
  @@map("product_option_values")
}

model ProductVariant {
  id             String        @id @default(uuid())
  productId      String        @map("product_id")
  masterSku      String?       @unique @map("master_sku") // Auto-generated PRD-XXXXXX-BLU-08
  title          String?
  sku            String?
  barcode        String?
  price          Decimal       @db.Decimal(10, 2)
  platformPrice  Decimal?      @map("platform_price") @db.Decimal(10, 2)
  compareAtPrice Decimal?      @map("compare_at_price") @db.Decimal(10, 2)
  costPrice      Decimal?      @map("cost_price") @db.Decimal(10, 2)
  stock          Int           @default(0)
  weight         Decimal?      @db.Decimal(10, 3)
  weightUnit     String?       @default("kg") @map("weight_unit")
  length         Decimal?      @db.Decimal(10, 2)
  width          Decimal?      @db.Decimal(10, 2)
  height         Decimal?      @db.Decimal(10, 2)
  dimensionUnit  String?       @default("cm") @map("dimension_unit")
  status         VariantStatus @default(DRAFT)
  sortOrder      Int           @default(0) @map("sort_order")
  isDeleted      Boolean       @default(false) @map("is_deleted")
  deletedAt      DateTime?     @map("deleted_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  product        Product                     @relation(fields: [productId], references: [id], onDelete: Cascade)
  optionValues   ProductVariantOptionValue[]
  images         ProductVariantImage[]
  cartItems      CartItem[]
  sellerMappings SellerProductMapping[]

  @@index([productId])
  @@index([sku])
  @@index([status])
  @@index([isDeleted])
  @@map("product_variants")
}

model ProductVariantOptionValue {
  id            String   @id @default(uuid())
  variantId     String   @map("variant_id")
  optionValueId String   @map("option_value_id")
  createdAt     DateTime @default(now()) @map("created_at")

  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  optionValue OptionValue    @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@unique([variantId, optionValueId])
  @@index([variantId])
  @@map("product_variant_option_values")
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  url       String
  publicId  String?  @map("public_id")
  altText   String?  @map("alt_text")
  sortOrder Int      @default(0) @map("sort_order")
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model ProductVariantImage {
  id        String   @id @default(uuid())
  variantId String   @map("variant_id")
  url       String
  publicId  String?  @map("public_id")
  altText   String?  @map("alt_text")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@map("product_variant_images")
}

model ProductTag {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  tag       String
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, tag])
  @@index([productId])
  @@map("product_tags")
}

model ProductSeo {
  id              String   @id @default(uuid())
  productId       String   @unique @map("product_id")
  metaTitle       String?  @map("meta_title")
  metaDescription String?  @map("meta_description")
  handle          String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_seo")
}

model ProductCollection {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  imageUrl    String?  @map("image_url")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  products  ProductCollectionMap[]
  discounts DiscountCollection[]

  @@index([slug])
  @@map("product_collections")
}

model ProductCollectionMap {
  id           String   @id @default(uuid())
  productId    String   @map("product_id")
  collectionId String   @map("collection_id")
  createdAt    DateTime @default(now()) @map("created_at")

  product    Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection ProductCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([productId, collectionId])
  @@index([productId])
  @@index([collectionId])
  @@map("product_collection_maps")
}

model ProductStatusHistory {
  id         String   @id @default(uuid())
  productId  String   @map("product_id")
  fromStatus String?  @map("from_status")
  toStatus   String   @map("to_status")
  changedBy  String?  @map("changed_by")
  reason     String?
  createdAt  DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_status_history")
}

model ProductCodeSequence {
  id         Int @id @default(1)
  lastNumber Int @default(0) @map("last_number")

  @@map("product_code_sequence")
}

// ── Metafield Definitions ───────────────────────────────────────────────
// Defines what attributes a category (or custom merchant-level) supports.
// Analogous to Shopify's MetafieldDefinition.

model MetafieldDefinition {
  id          String        @id @default(uuid())
  namespace   String        // e.g. "taxonomy", "custom"
  key         String        // e.g. "material", "care_instructions"
  name        String        // Human-readable: "Material"
  description String?
  type        MetafieldType

  // For SINGLE_SELECT / MULTI_SELECT: predefined choices
  // Stored as JSON array of { value, label, sortOrder, colorHex? }
  validations Json?         // e.g. { min, max, regex }
  choices     Json?         // e.g. [{ value: "cotton", label: "Cotton" }]

  // Ownership
  ownerType   String        @default("CATEGORY") @map("owner_type") // CATEGORY or CUSTOM
  categoryId  String?       @map("category_id")  // null for CUSTOM (merchant-level)

  // Display
  pinned      Boolean       @default(false)
  sortOrder   Int           @default(0) @map("sort_order")
  isRequired  Boolean       @default(false) @map("is_required")
  isActive    Boolean       @default(true) @map("is_active")

  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  category        Category?            @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  metafieldValues ProductMetafield[]
  filterConfigs   StorefrontFilter[]

  @@unique([namespace, key, categoryId])
  @@index([categoryId])
  @@index([ownerType])
  @@index([namespace, key])
  @@map("metafield_definitions")
}

// ── Product Metafield Values ────────────────────────────────────────────
// Stores the actual metafield value for a specific product.

model ProductMetafield {
  id                    String   @id @default(uuid())
  productId             String   @map("product_id")
  metafieldDefinitionId String   @map("metafield_definition_id")

  // Value storage — use the appropriate column based on type
  valueText     String?   @map("value_text")
  valueNumeric  Decimal?  @map("value_numeric") @db.Decimal(15, 4)
  valueBoolean  Boolean?  @map("value_boolean")
  valueDate     DateTime? @map("value_date")
  valueJson     Json?     @map("value_json")    // DIMENSION, WEIGHT, VOLUME, MULTI_SELECT, JSON

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product              Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  metafieldDefinition  MetafieldDefinition  @relation(fields: [metafieldDefinitionId], references: [id], onDelete: Cascade)

  @@unique([productId, metafieldDefinitionId])
  @@index([productId])
  @@index([metafieldDefinitionId])
  @@index([metafieldDefinitionId, valueText])
  @@index([metafieldDefinitionId, valueNumeric])
  @@index([metafieldDefinitionId, valueBoolean])
  @@map("product_metafields")
}

// ── Storefront Filter Configuration ─────────────────────────────────────
// Admins configure which metafields/built-in fields become storefront filters.

model StorefrontFilter {
  id                    String   @id @default(uuid())
  metafieldDefinitionId String?  @map("metafield_definition_id")

  // Built-in filter type (when metafieldDefinitionId is null)
  builtInType           String?  @map("built_in_type") // "price_range", "brand", "availability", "variant_option"

  // Display
  label         String
  filterType    String   @map("filter_type") // "checkbox", "price_range", "boolean_toggle", "color_swatch", "text_input"
  sortOrder     Int      @default(0) @map("sort_order")
  isActive      Boolean  @default(true) @map("is_active")

  // Scope
  scopeType     String?  @map("scope_type")  // "CATEGORY", "COLLECTION", "GLOBAL"
  scopeId       String?  @map("scope_id")    // categoryId or collectionId

  // Behavior
  collapsed     Boolean  @default(false)
  showCounts    Boolean  @default(true) @map("show_counts")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  metafieldDefinition MetafieldDefinition? @relation(fields: [metafieldDefinitionId], references: [id], onDelete: Cascade)

  @@index([metafieldDefinitionId])
  @@index([scopeType, scopeId])
  @@index([isActive, sortOrder])
  @@map("storefront_filters")
}
