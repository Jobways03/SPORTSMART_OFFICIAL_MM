// ============================================
// Catalog Module - owned tables
// ============================================

model Category {
  id                        String   @id @default(uuid())
  name                      String
  slug                      String   @unique
  description               String?
  imageUrl                  String?  @map("image_url")
  // Story Phase 5 Cat-1 — wide banner shown on the category landing
  // page. Distinct from `imageUrl` which is the square thumbnail used
  // in nav menus and category grids.
  bannerUrl                 String?  @map("banner_url")
  // SEO blocks — set per-category so search engines pick up the
  // canonical headline / blurb rather than the generic site default.
  // Both nullable; the storefront falls back to `name` + first 160
  // chars of `description` when these are empty.
  metaTitle                 String?  @map("meta_title")
  metaDescription           String?  @map("meta_description")
  parentId                  String?  @map("parent_id")
  level                     Int      @default(0)
  sortOrder                 Int      @default(0) @map("sort_order")
  isActive                  Boolean  @default(true) @map("is_active")
  // Phase 92 (2026-05-23) — Return Eligibility audit Gap #2.
  // Category-level return policy. Resolver falls back to these when
  // Product.* overrides are null. Null = use the global default
  // (RETURN_WINDOW_DAYS env / 14d).
  defaultReturnWindowDays   Int?     @map("default_return_window_days")
  isReturnable              Boolean  @default(true) @map("is_returnable")
  defaultAllowedReasonsJson Json?    @map("default_allowed_reasons_json")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryHierarchy")

  products                Product[]
  categoryOptionTemplates CategoryOptionTemplate[]
  metafieldDefinitions    MetafieldDefinition[]
  // Phase 34 (2026-05-21) — back-relation for the audit log.
  auditLogs               CategoryAuditLog[]

  @@index([parentId])
  @@index([slug])
  // Phase 33 (2026-05-21) — query-pattern indexes.
  //   - `level` filter on admin list page.
  //   - `isActive` for the storefront tree (~352 active rows today;
  //     the flat fetch in findActiveTree benefits from a partial-ish
  //     access pattern).
  //   - `(parentId, isActive, sortOrder)` is what the storefront tree
  //     and the admin "children of X" panel both join + order on.
  @@index([level])
  @@index([isActive])
  @@index([parentId, isActive, sortOrder])
  @@map("categories")
}

/// Phase 34 (2026-05-21) — Category mutation audit trail.
///
/// Every create / update / delete / deactivate / reorder operation
/// against the taxonomy lands a row here. The previous + new state
/// JSON snapshots let an investigator reconstruct what changed and
/// when. The `action` enum is intentionally narrower than the unified
/// AuditLog to keep this table query-friendly for the dedicated
/// "category history" admin view.
///
/// Writes are best-effort: a failure here logs but does NOT roll back
/// the primary mutation. The taxonomy is the source of truth; the
/// audit log is the mirror.
model CategoryAuditLog {
  id            String              @id @default(uuid())
  categoryId    String              @map("category_id")
  action        CategoryAuditAction
  adminId       String?             @map("admin_id")
  previousState Json?               @map("previous_state")
  newState      Json?               @map("new_state")
  reason        String?
  createdAt     DateTime            @default(now()) @map("created_at")

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId, createdAt])
  @@index([adminId, createdAt])
  @@map("category_audit_logs")
}

enum CategoryAuditAction {
  CREATE
  UPDATE
  DELETE
  DEACTIVATE
  REORDER
}

model Brand {
  id              String   @id @default(uuid())
  name            String   @unique
  slug            String   @unique
  logoUrl         String?  @map("logo_url")
  // Phase 35 (2026-05-21) — Cloudinary publicId for the logo asset.
  // Stored alongside `logoUrl` so the controller can:
  //   - delete the old asset when admin replaces the logo
  //   - clean up the asset when admin hard-deletes the brand
  //   - clean up the asset when admin removes the logo
  // Pre-Phase-35 every logo replacement orphaned the prior asset;
  // each brand could accumulate dozens of dead Cloudinary blobs.
  logoPublicId    String?  @map("logo_public_id")
  // Phase 35 — parity with Category. Description for the brand
  // landing page; SEO metadata for search-engine snippets. All
  // optional; storefront falls back to name + first 160 chars of
  // description when omitted.
  description     String?  @db.Text
  metaTitle       String?  @map("meta_title")
  metaDescription String?  @map("meta_description")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  products  Product[]
  // Phase 35 (2026-05-21) — back-relation for the audit log mirror.
  auditLogs BrandAuditLog[]

  @@index([slug])
  // Phase 35 (2026-05-21) — public storefront filters by isActive
  // and orders by name; the composite covers both predicates plus
  // the order without a separate sort.
  @@index([isActive])
  @@index([isActive, name])
  @@map("brands")
}

/// Phase 35 (2026-05-21) — Brand mutation audit trail.
/// Mirrors CategoryAuditLog. Every create / update / delete / deactivate
/// / logo-change / bulk-assign writes a row. Best-effort: failures here
/// log but never roll back the primary mutation. The taxonomy is the
/// source of truth; the audit log is the mirror.
model BrandAuditLog {
  id            String           @id @default(uuid())
  brandId       String           @map("brand_id")
  action        BrandAuditAction
  adminId       String?          @map("admin_id")
  previousState Json?            @map("previous_state")
  newState      Json?            @map("new_state")
  reason        String?
  createdAt     DateTime         @default(now()) @map("created_at")

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId, createdAt])
  @@index([adminId, createdAt])
  @@map("brand_audit_logs")
}

enum BrandAuditAction {
  CREATE
  UPDATE
  DELETE
  DEACTIVATE
  LOGO_CHANGE
  BULK_ASSIGN
}

model OptionDefinition {
  id          String   @id @default(uuid())
  name        String   @unique
  displayName String   @map("display_name")
  type        String   @default("GENERIC") // COLOR, SIZE, GENERIC
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  values                  OptionValue[]
  categoryOptionTemplates CategoryOptionTemplate[]
  productOptions          ProductOption[]

  @@map("option_definitions")
}

model OptionValue {
  id                 String   @id @default(uuid())
  optionDefinitionId String   @map("option_definition_id")
  value              String
  displayValue       String   @map("display_value")
  sortOrder          Int      @default(0) @map("sort_order")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  optionDefinition OptionDefinition @relation(fields: [optionDefinitionId], references: [id], onDelete: Cascade)

  productOptionValues        ProductOptionValue[]
  productVariantOptionValues ProductVariantOptionValue[]

  @@unique([optionDefinitionId, value])
  @@index([optionDefinitionId])
  @@map("option_values")
}

model CategoryOptionTemplate {
  id                 String   @id @default(uuid())
  categoryId         String   @map("category_id")
  optionDefinitionId String   @map("option_definition_id")
  isRequired         Boolean  @default(false) @map("is_required")
  sortOrder          Int      @default(0) @map("sort_order")
  createdAt          DateTime @default(now()) @map("created_at")

  category         Category         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  optionDefinition OptionDefinition @relation(fields: [optionDefinitionId], references: [id], onDelete: Cascade)

  @@unique([categoryId, optionDefinitionId])
  @@index([categoryId])
  @@map("category_option_templates")
}

model Product {
  id               String           @id @default(uuid())
  productCode      String?          @unique @map("product_code") // Auto-generated PRD-XXXXXX
  sellerId         String?          @map("seller_id")
  title            String
  slug             String           @unique
  shortDescription String?          @map("short_description")
  description      String?
  categoryId       String?          @map("category_id")
  brandId          String?          @map("brand_id")
  status           ProductStatus    @default(DRAFT)
  moderationStatus ModerationStatus @default(PENDING) @map("moderation_status")
  moderationNote   String?          @map("moderation_note")

  /// Phase 192 (#4) — structured sport classification (e.g. "cricket",
  /// "football", "running"). Replaces the title-text-search workaround the
  /// storefront used for `?sport=` links. Null until a product is
  /// classified (admin or backfill); the storefront falls back to a title
  /// match for unclassified rows so existing links keep working.
  sport            String?

  // Moderation audit — populated on every admin review action. `moderationNote`
  // is kept for legacy readers but the canonical source is now the three
  // columns below. Each review overwrites these to reflect the latest
  // decision; full history is in ProductStatusHistory.
  moderatorId       String?   @map("moderator_id")
  reviewedAt        DateTime? @map("reviewed_at")
  rejectionReason   String?   @map("rejection_reason")
  changeRequestNote String?   @map("change_request_note")

  hasVariants Boolean @default(false) @map("has_variants")

  // NOVA SM own-brand discriminator. SELLER = third-party marketplace
  // listing (existing default — stock lives in SellerProductMapping).
  // OWN_BRAND = NOVA-owned, fulfilled from OwnBrandWarehouse stock.
  productSource ProductSource @default(SELLER) @map("product_source")
  // Internal NOVA SKU. Format: NV-YYYY-NNNNNN, generated on creation
  // when productSource=OWN_BRAND. Null for SELLER products.
  ownBrandSku   String?       @unique @map("own_brand_sku")

  // Platform pricing (customer-facing price, admin-controlled)
  // procurementPrice: platform-wide default landed cost used by the
  // franchise procurement flow (Option A/B). Distinct from costPrice,
  // which is now display-only. Per-franchise overrides live in
  // FranchiseProcurementPrice (Option C) and take precedence.
  procurementPrice Decimal? @map("procurement_price") @db.Decimal(10, 2)

  // Simple product fields (used when hasVariants = false)
  basePrice      Decimal? @map("base_price") @db.Decimal(10, 2)
  compareAtPrice Decimal? @map("compare_at_price") @db.Decimal(10, 2)
  costPrice      Decimal? @map("cost_price") @db.Decimal(10, 2)
  baseSku        String?  @map("base_sku")
  baseStock      Int?     @map("base_stock")
  baseBarcode    String?  @map("base_barcode")

  // Shipping
  weight        Decimal? @db.Decimal(10, 3)
  weightUnit    String?  @default("kg") @map("weight_unit")
  length        Decimal? @db.Decimal(10, 2)
  width         Decimal? @db.Decimal(10, 2)
  height        Decimal? @db.Decimal(10, 2)
  dimensionUnit String?  @default("cm") @map("dimension_unit")

  // Policy
  returnPolicy             String? @map("return_policy")
  warrantyInfo             String? @map("warranty_info")
  // Phase 92 (2026-05-23) — Return Eligibility audit Gap #1/#2/#11.
  // Structured returnability so the eligibility resolver doesn't
  // depend on free-text parsing. Defaults preserve today's behaviour
  // (everything returnable with the global window) until ops
  // populates per-product overrides.
  isReturnable             Boolean @default(true) @map("is_returnable")
  nonReturnableReason      String? @map("non_returnable_reason")
  returnWindowDaysOverride Int?    @map("return_window_days_override")
  // Per-product allowed reason categories. Null = inherit from
  // category default. Stored as JSON list of ReturnReasonCategory
  // enum values; the resolver normalises before exposing.
  allowedReturnReasonsJson Json?   @map("allowed_return_reasons_json")
  // Phase 92 — Gap #12 partial-quantity policy. False = all-or-nothing
  // (pack-of-N SKUs, sets that can't be split).
  allowPartialReturn       Boolean @default(true) @map("allow_partial_return")

  // ─── Tax fields (Phase 1 GST — 2026-05-13) ──────────────────────
  // See docs/tax/CA.md and docs/tax/HSN_RATE_POLICY.md.
  // Tax-data-status is derived at runtime (not stored) based on
  // whether (hsnCode + gstRateBps + defaultUqcCode) are set for a
  // taxable product. Admin moderation surfaces TAX_DATA_MISSING.
  hsnCode             String?          @map("hsn_code")
  gstRateBps          Int              @default(0) @map("gst_rate_bps")
  supplyTaxability    SupplyTaxability @default(TAXABLE) @map("supply_taxability")
  // Default B2C convention for India e-commerce: prices ARE inclusive
  // of GST. Admin can flip per-product for B2B-only or GST-exclusive
  // catalogs. See docs/tax/GST_ASSUMPTIONS.md §2 row "GST-inclusive".
  taxInclusivePricing Boolean          @default(true) @map("tax_inclusive_pricing")
  // Compensation cess (sports goods generally don't attract cess).
  // Schema-ready for future HSN that may; default 0.
  cessRateBps         Int              @default(0) @map("cess_rate_bps")
  // UQC code per CBIC list (NOS, PCS, KGS, ...). Required at
  // order-line snapshot time; falls back to "NOS" at engine level if
  // missing in non-strict mode.
  defaultUqcCode      String?          @map("default_uqc_code")
  // Free-text classification: e.g. "apparel-under-1000", "footwear",
  // "equipment". Used by admin bulk operations + reports.
  taxCategory         String?          @map("tax_category")
  taxConfigUpdatedBy  String?          @map("tax_config_updated_by")
  taxConfigUpdatedAt  DateTime?        @map("tax_config_updated_at")
  // Phase 37 — admin attestation that the product's tax config (HSN,
  // GST rate, supply taxability, cess) has been reviewed for
  // correctness. Seller-proposed tax fields land with this false;
  // an admin flips it true via the verify-tax-config endpoint. Any
  // subsequent write that changes a tax field auto-resets this to
  // false so a seller can't bypass approval by editing post-attestation.
  // Surfaced on the admin product list so reviewers can prioritise.
  taxConfigVerified   Boolean          @default(false) @map("tax_config_verified")
  taxConfigVerifiedAt DateTime?        @map("tax_config_verified_at")
  taxConfigVerifiedBy String?          @map("tax_config_verified_by")
  // Phase 45 (2026-05-21) — monotonic version on tax-config writes.
  // Incremented on every write that touches a tax column, including
  // attestation flips and resets. verify-tax-config accepts the
  // version the admin reviewed (`expectedVersion`); the service
  // refuses the attest when the row has drifted since the read,
  // closing the read-then-write race that pre-Phase-45 let an admin
  // stamp their name on data they hadn't actually seen.
  taxConfigVersion    Int              @default(0) @map("tax_config_version")

  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  // Phase 249 (#4) — AI-content provenance. Set when a product is saved
  // carrying AI-generated copy (the FE passes the AiGenerationLog id). Lets
  // ops answer "which products have uncurated AI copy", drive a human-review
  // queue, and disclose AI authorship where required.
  aiGenerated     Boolean   @default(false) @map("ai_generated")
  aiGeneratedAt   DateTime? @map("ai_generated_at")
  aiPromptVersion String?   @map("ai_prompt_version")
  aiHumanReviewed Boolean   @default(false) @map("ai_human_reviewed")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  seller   Seller?   @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brand    Brand?    @relation(fields: [brandId], references: [id], onDelete: SetNull)

  variants                 ProductVariant[]
  options                  ProductOption[]
  optionValues             ProductOptionValue[]
  images                   ProductImage[]
  tags                     ProductTag[]
  seo                      ProductSeo?
  statusHistory            ProductStatusHistory[]
  collectionMaps           ProductCollectionMap[]
  discounts                DiscountProduct[]
  cartItems                CartItem[]
  sellerMappings           SellerProductMapping[]
  metafields               ProductMetafield[]
  franchiseCatalogMappings FranchiseCatalogMapping[]
  // Sprint 3 Story 2.2 — see wishlist.prisma.
  wishlistItems            WishlistItem[]
  // Story 3.5 — quantity-based pricing tiers for upsell hints on PDP.
  // Display-only at v1; cart-time application is a separate story.
  pricingTiers             ProductPricingTier[]
  // User-generated reviews (see product-reviews.prisma).
  reviews                  ProductReview[]
  // Phase 193 (#15) — back-in-stock notify requests (see back-in-stock.prisma).
  backInStockRequests      BackInStockRequest[]
  // Phase 45 (2026-05-21) — append-only audit trail of tax-config
  // attestation transitions (ATTESTED / RESET / EDITED / BULK_EDITED).
  // CA-compliance audits demand the historical chain, not just the
  // last writer that sits in the Product columns.
  taxAttestations          TaxAttestationLog[]

  @@index([sellerId])
  @@index([categoryId])
  @@index([brandId])
  @@index([status])
  @@index([moderationStatus])
  @@index([slug])
  @@index([isDeleted])
  // Phase 192 (#4) — sport facet lookups.
  @@index([sport, status])
  @@map("products")
}

/// Phase 45 (2026-05-21) — tax-config attestation audit trail.
///
/// Pre-Phase-45 the only record of who attested a product was the
/// taxConfigVerified{At,By} columns on Product — last-writer-wins,
/// no historical chain. CA audits compare the attestation evidence
/// against the data at the time of attestation; without a log there's
/// no way to prove A attested v1, B reset, A re-attested v2. This
/// table captures every transition so the auditor can reconstruct
/// the timeline.
model TaxAttestationLog {
  id                   String               @id @default(uuid())
  productId            String               @map("product_id")
  action               TaxAttestationAction
  // Snapshot of the tax fields at the time of the transition. NULLs
  // are legal — e.g. for a RESET, the new* columns are NULL because
  // the attestation was cleared, not the data.
  prevHsn              String?              @map("prev_hsn")
  prevGstRateBps       Int?                 @map("prev_gst_rate_bps")
  prevSupplyTaxability String?              @map("prev_supply_taxability")
  prevUqcCode          String?              @map("prev_uqc_code")
  newHsn               String?              @map("new_hsn")
  newGstRateBps        Int?                 @map("new_gst_rate_bps")
  newSupplyTaxability  String?              @map("new_supply_taxability")
  newUqcCode           String?              @map("new_uqc_code")
  // The taxConfigVersion at the moment of the transition. Verifying
  // admin can pin their attestation to the exact version they
  // reviewed.
  taxConfigVersion     Int                  @map("tax_config_version")
  actorId              String               @map("actor_id")
  // SELLER / ADMIN / SYSTEM — the audit can scope by role.
  actorRole            String               @map("actor_role")
  reviewerNote         String?              @map("reviewer_note")
  createdAt            DateTime             @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
  @@index([actorId, createdAt])
  @@map("tax_attestation_logs")
}

enum TaxAttestationAction {
  ATTESTED
  RESET
  EDITED
  BULK_EDITED
}

// Story 3.5 — Product Pricing Tiers (display-only at v1).
//
// Each row represents one rung on the quantity ladder:
//   "Save 10% if you buy 5 or more — current 3, add 2 more to unlock"
//
// We store the discount as a *percent* of unit price rather than a
// fixed amount so the tier auto-tracks price changes (no stale
// per-paise math to refresh when the seller updates base price).
//
// Scope decision (2026-05-13): cart-time price mutation is OUT.
// Operators populate the tiers; PDP renders the ladder + active tier;
// checkout still charges the base price. Wiring tiers into actual
// pricing requires stacking-vs-coupon semantics, refund-line basis,
// and commission-base policy — none of which is decided yet. Adding
// it carelessly silently changes settlement.
model ProductPricingTier {
  id        String  @id @default(uuid())
  productId String  @map("product_id")
  // Nullable — tier can target a specific variant OR apply to all
  // variants when null. ANSI NULLs-distinct unique enforces "one tier
  // per (product, variant, minQuantity)" without collapsing the
  // "any variant" case across variants.
  variantId String? @map("variant_id")

  // Inclusive lower bound: tier applies when cart line quantity >=
  // minQuantity. Multiple tiers per product form a ladder; the
  // highest matching tier wins at display time.
  minQuantity Int  @map("min_quantity")
  // Phase 44 (2026-05-21) — inclusive upper bound for closed-range
  // tiers (e.g. "Buy 10-24: 5% off"). NULL = unbounded. Migration
  // adds a CHECK (max_quantity IS NULL OR max_quantity >= min_quantity).
  maxQuantity Int? @map("max_quantity")

  // Phase 44 — pricing modes are mutually exclusive. Exactly one of
  // discountPercent / fixedUnitPrice must be set; the migration adds
  // a CHECK constraint for that invariant.
  //
  // discountPercent — percent off the line's list unit price (0-100,
  // enforced at the service layer).
  discountPercent Decimal? @map("discount_percent") @db.Decimal(5, 2)
  // fixedUnitPrice — absolute override (e.g. "₹999 at 50+"). Keeps
  // the same Decimal(10,2) scale as variant.price / product.basePrice.
  fixedUnitPrice  Decimal? @map("fixed_unit_price") @db.Decimal(10, 2)

  // Phase 44 — optional schedule window. NULL on either end means
  // open-ended on that side. The active-check is
  //   isActive=true AND (startAt IS NULL OR startAt <= NOW)
  //                AND (endAt IS NULL OR endAt > NOW)
  startAt DateTime? @map("start_at")
  endAt   DateTime? @map("end_at")

  // Optional override copy ("Buy 5+ save 10%"). Falls back to a
  // formatted default when null. Useful when ops wants a campaign
  // tagline instead of the bare math.
  displayLabel String? @map("display_label")

  // Off by default so creates can be staged before going live.
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  // Phase 44 (2026-05-21) — back-relations from the snapshot columns
  // on CartItem / OrderItem so a tier can find every line that
  // referenced it (useful for audit + commission re-computation).
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@unique([productId, variantId, minQuantity], name: "product_variant_qty_unique")
  @@index([productId])
  @@index([productId, isActive])
  // Phase 44 — covers the resolver's "active tiers in window for
  // product+variant" query.
  @@index([productId, isActive, variantId])
  @@map("product_pricing_tiers")
}

model ProductOption {
  id                 String   @id @default(uuid())
  productId          String   @map("product_id")
  optionDefinitionId String   @map("option_definition_id")
  sortOrder          Int      @default(0) @map("sort_order")
  createdAt          DateTime @default(now()) @map("created_at")

  product          Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  optionDefinition OptionDefinition @relation(fields: [optionDefinitionId], references: [id], onDelete: Cascade)

  @@unique([productId, optionDefinitionId])
  @@index([productId])
  @@map("product_options")
}

model ProductOptionValue {
  id            String   @id @default(uuid())
  productId     String   @map("product_id")
  optionValueId String   @map("option_value_id")
  createdAt     DateTime @default(now()) @map("created_at")

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  optionValue OptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@unique([productId, optionValueId])
  @@index([productId])
  @@map("product_option_values")
}

model ProductVariant {
  id               String        @id @default(uuid())
  productId        String        @map("product_id")
  masterSku        String?       @unique @map("master_sku") // Auto-generated PRD-XXXXXX-BLU-08
  title            String?
  sku              String?
  barcode          String?
  price            Decimal       @db.Decimal(10, 2)
  procurementPrice Decimal?      @map("procurement_price") @db.Decimal(10, 2)
  compareAtPrice   Decimal?      @map("compare_at_price") @db.Decimal(10, 2)
  costPrice        Decimal?      @map("cost_price") @db.Decimal(10, 2)
  stock            Int           @default(0)
  weight           Decimal?      @db.Decimal(10, 3)
  weightUnit       String?       @default("kg") @map("weight_unit")
  length           Decimal?      @db.Decimal(10, 2)
  width            Decimal?      @db.Decimal(10, 2)
  height           Decimal?      @db.Decimal(10, 2)
  dimensionUnit    String?       @default("cm") @map("dimension_unit")
  status           VariantStatus @default(DRAFT)
  sortOrder        Int           @default(0) @map("sort_order")

  // ─── Tax overrides (Phase 1 GST — 2026-05-13) ───────────────────
  // Variants override their parent product's tax fields ONLY if a
  // value is set here. Nullable everywhere so default behaviour is
  // "inherit from product". See docs/tax/HSN_RATE_POLICY.md §1.
  gstRateBpsOverride          Int?     @map("gst_rate_bps_override")
  hsnCodeOverride             String?  @map("hsn_code_override")
  taxInclusivePricingOverride Boolean? @map("tax_inclusive_pricing_override")
  uqcCodeOverride             String?  @map("uqc_code_override")

  // Phase 41 (2026-05-21) — deterministic fingerprint of the option-
  // value combination this variant represents. Computed as
  //   sha256(sorted_join(optionValueIds, '|'))
  // by VariantGeneratorService at create time. The DB-level
  // @@unique([productId, optionFingerprint]) below makes "two variants
  // representing the same Red/Large combination on one product"
  // physically impossible — the unique violation surfaces as a P2002
  // which the controller maps to 409.
  //
  // Nullable so the migration can backfill existing rows in a follow-up
  // step; new rows always set it.
  optionFingerprint String? @map("option_fingerprint")

  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  product                  Product                     @relation(fields: [productId], references: [id], onDelete: Cascade)
  optionValues             ProductVariantOptionValue[]
  images                   ProductVariantImage[]
  cartItems                CartItem[]
  sellerMappings           SellerProductMapping[]
  franchiseCatalogMappings FranchiseCatalogMapping[]
  // Sprint 3 Story 2.2 — see wishlist.prisma.
  wishlistItems            WishlistItem[]

  // Phase 4 follow-up (2026-05-16) — per-product SKU uniqueness.
  // The application layer already enforces this in
  // PrismaVariantRepository (create + update); the DB-level constraint
  // closes the race window where two concurrent creates would both
  // pass the app-level check and both insert. NULL skus are allowed
  // (digital goods, draft variants without a real SKU yet) and are
  // not unique-compared by PostgreSQL.
  //
  // The migration includes a pre-flight query the team runs first to
  // surface any existing duplicates; once those are resolved the
  // constraint can be added safely.
  @@unique([productId, sku], name: "product_variants_product_sku_unique")
  @@index([productId])
  @@index([sku])
  @@index([status])
  @@index([isDeleted])
  // Phase 41 (2026-05-21) — covers the "active variants for this
  // product" query used by storefront PDP + cart validation.
  @@index([productId, status])
  // Phase 41 — partial unique declared in raw SQL in the migration
  // (Prisma DSL has no partial-index support):
  //   CREATE UNIQUE INDEX product_variants_option_fingerprint_unique
  //     ON product_variants (product_id, option_fingerprint)
  //     WHERE option_fingerprint IS NOT NULL AND is_deleted = false;
  @@map("product_variants")
}

model ProductVariantOptionValue {
  id            String   @id @default(uuid())
  variantId     String   @map("variant_id")
  optionValueId String   @map("option_value_id")
  createdAt     DateTime @default(now()) @map("created_at")

  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  optionValue OptionValue    @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@unique([variantId, optionValueId])
  @@index([variantId])
  @@map("product_variant_option_values")
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  url       String
  publicId  String?  @map("public_id")
  altText   String?  @map("alt_text")
  sortOrder Int      @default(0) @map("sort_order")
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Cluster E (#5) — Cloudinary orphan-sweep delete retry tracking.
  // A row whose asset delete keeps failing increments deleteAttemptCount;
  // once it reaches the cap the sweep sets deleteFailed=true and skips it
  // on subsequent runs (escalation instead of retrying forever).
  deleteAttemptCount Int      @default(0) @map("delete_attempt_count")
  lastDeleteError    String?  @map("last_delete_error")
  deleteFailed       Boolean  @default(false) @map("delete_failed")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  // Phase 29 (2026-05-21) — partial unique index enforces "at most
  // one primary image per product." Declared in raw SQL because
  // Prisma's schema DSL does not support partial indexes:
  //   CREATE UNIQUE INDEX product_images_one_primary_idx
  //     ON product_images (product_id) WHERE is_primary = TRUE;
  // See migration 20260521160000_product_image_one_primary. The
  // upload controller catches the resulting P2002 and retries with
  // isPrimary=false.
  @@map("product_images")
}

model ProductVariantImage {
  id        String   @id @default(uuid())
  variantId String   @map("variant_id")
  url       String
  publicId  String?  @map("public_id")
  altText   String?  @map("alt_text")
  sortOrder Int      @default(0) @map("sort_order")
  // Phase 41 (2026-05-21) — explicit hero-image flag. Mirrors the
  // Phase 29 pattern on ProductImage so the storefront and cart
  // line-item thumbnail can pick the canonical image without relying
  // on the implicit sortOrder=0 convention (easy to break across
  // queries). Partial unique declared in raw SQL in the migration.
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Cluster E (#5) — Cloudinary orphan-sweep delete retry tracking.
  // Mirrors ProductImage: escalate a permanently-failing asset delete
  // to deleteFailed=true past the retry cap instead of retrying daily.
  deleteAttemptCount Int      @default(0) @map("delete_attempt_count")
  lastDeleteError    String?  @map("last_delete_error")
  deleteFailed       Boolean  @default(false) @map("delete_failed")

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@map("product_variant_images")
}

model ProductTag {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  tag       String
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, tag])
  @@index([productId])
  @@map("product_tags")
}

model ProductSeo {
  id              String   @id @default(uuid())
  productId       String   @unique @map("product_id")
  metaTitle       String?  @map("meta_title")
  metaDescription String?  @map("meta_description")
  handle          String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_seo")
}

model ProductCollection {
  id            String    @id @default(uuid())
  name          String    @unique
  slug          String    @unique
  description   String?
  imageUrl      String?   @map("image_url")
  // Phase 37 (2026-05-21) — Cloudinary publicId for the hero image.
  // Stored alongside imageUrl so admin replace + delete can clean
  // up the prior asset. Same orphan-proofing pattern as Brand
  // (Phase 35).
  imagePublicId String?   @map("image_public_id")
  // Phase 37 (2026-05-21) — accessibility / WCAG. Storefront should
  // emit <img alt={...}> from this field; falls back to name if null.
  imageAltText  String?   @map("image_alt_text")
  isActive      Boolean   @default(true) @map("is_active")
  // Phase 37 (2026-05-21) — soft delete. Pre-Phase-37 a collection
  // hard-deleted mid-sale removed all join rows + 404'd the
  // storefront page with no undo. Now: delete sets deletedAt; the
  // public storefront filters `deletedAt: null`; admin can restore.
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  products  ProductCollectionMap[]
  discounts DiscountCollection[]
  // Phase 37 (2026-05-21) — back-relation for the audit log mirror.
  auditLogs CollectionAuditLog[]

  @@index([slug])
  // Phase 37 (2026-05-21) — query-pattern indexes. Storefront list
  // filters isActive + deletedAt; admin list filters deletedAt.
  @@index([isActive])
  @@index([deletedAt])
  @@map("product_collections")
}

model ProductCollectionMap {
  id           String   @id @default(uuid())
  productId    String   @map("product_id")
  collectionId String   @map("collection_id")
  // Phase 37 (2026-05-21) — explicit sort order for the collection
  // landing page. Pre-Phase-37 products were ordered by attach time
  // (createdAt); marketers couldn't put the bestseller first. The
  // storefront query now orders by (sortOrder, createdAt) so
  // existing rows fall back to attach-time within the default 0
  // bucket. Admin reorder endpoint stamps this column.
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")

  product    Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection ProductCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([productId, collectionId])
  @@index([productId])
  @@index([collectionId])
  // Phase 37 (2026-05-21) — composite for the storefront's
  // "products in collection X ordered" query.
  @@index([collectionId, sortOrder])
  @@map("product_collection_maps")
}

/// Phase 37 (2026-05-21) — Collection mutation audit trail. Mirrors
/// CategoryAuditLog (Phase 34) + BrandAuditLog (Phase 35). Every
/// create / update / delete / restore / image change / product
/// attach / detach / reorder writes a row. Best-effort: failures
/// here log but never roll back the primary mutation.
model CollectionAuditLog {
  id            String                @id @default(uuid())
  collectionId  String                @map("collection_id")
  action        CollectionAuditAction
  adminId       String?               @map("admin_id")
  previousState Json?                 @map("previous_state")
  newState      Json?                 @map("new_state")
  reason        String?
  createdAt     DateTime              @default(now()) @map("created_at")

  collection ProductCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@index([collectionId, createdAt])
  @@index([adminId, createdAt])
  @@map("collection_audit_logs")
}

enum CollectionAuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  IMAGE_CHANGE
  ATTACH
  DETACH
  REORDER
}

model ProductStatusHistory {
  id         String   @id @default(uuid())
  productId  String   @map("product_id")
  fromStatus String?  @map("from_status")
  toStatus   String   @map("to_status")
  changedBy  String?  @map("changed_by")
  reason     String?
  createdAt  DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_status_history")
}

model ProductCodeSequence {
  id         Int @id @default(1)
  lastNumber Int @default(0) @map("last_number")

  @@map("product_code_sequence")
}

// ── Metafield Definitions ───────────────────────────────────────────────
// Defines what attributes a category (or custom merchant-level) supports.
// Analogous to Shopify's MetafieldDefinition.

model MetafieldDefinition {
  id          String        @id @default(uuid())
  namespace   String // e.g. "taxonomy", "custom"
  key         String // e.g. "material", "care_instructions"
  name        String // Human-readable: "Material"
  description String?
  type        MetafieldType

  // For SINGLE_SELECT / MULTI_SELECT: predefined choices
  // Stored as JSON array of { value, label, sortOrder, colorHex? }
  validations Json? // e.g. { min, max, regex }
  choices     Json? // e.g. [{ value: "cotton", label: "Cotton" }]

  // Ownership
  ownerType  String  @default("CATEGORY") @map("owner_type") // CATEGORY or CUSTOM
  categoryId String? @map("category_id") // null for CUSTOM (merchant-level)

  // Display
  pinned     Boolean @default(false)
  sortOrder  Int     @default(0) @map("sort_order")
  isRequired Boolean @default(false) @map("is_required")
  isActive   Boolean @default(true) @map("is_active")

  // Phase 40 (2026-05-21) — filterability is now a first-class flag
  // on the definition. Pre-Phase-40 admins had to create a full
  // StorefrontFilter config row per definition just to toggle visibility
  // on the storefront filter sidebar (heavy + confusing). The flag
  // here is the single source of truth; StorefrontFilter rows remain
  // as optional per-scope overrides (custom label / type / collapsed).
  //
  // defaultFilterType narrows the rendering hint when the definition
  // type alone is ambiguous (e.g. SINGLE_LINE_TEXT used as a text
  // input vs checkbox). defaultFilterLabel overrides `name` when
  // the storefront facet should read differently from the admin
  // label. filterDisplayOrder controls the position when the auto-
  // generated config is used.
  isFilterable       Boolean @default(false) @map("is_filterable")
  defaultFilterType  String? @map("default_filter_type")
  defaultFilterLabel String? @map("default_filter_label")
  filterDisplayOrder Int     @default(0) @map("filter_display_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  category        Category?                     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  metafieldValues ProductMetafield[]
  filterConfigs   StorefrontFilter[]
  // Phase 39 (2026-05-21) — back-relation for the audit log mirror.
  auditLogs       MetafieldDefinitionAuditLog[]

  @@unique([namespace, key, categoryId])
  @@index([categoryId])
  @@index([ownerType])
  @@index([namespace, key])
  // Phase 39 (2026-05-21) — covers the required-check query that
  // submit-for-review + approve both run.
  @@index([isRequired, categoryId])
  @@index([isActive])
  // Phase 40 (2026-05-21) — covers the storefront filter listing
  // query ("which active filterable defs apply to this category?").
  @@index([isFilterable, categoryId])
  @@map("metafield_definitions")
}

/// Phase 39 (2026-05-21) — definition mutation audit trail. Same
/// shape as the Phase 34-37 audit-log models. Best-effort: failures
/// log but never roll back the primary mutation.
model MetafieldDefinitionAuditLog {
  id                    String                         @id @default(uuid())
  metafieldDefinitionId String                         @map("metafield_definition_id")
  action                MetafieldDefinitionAuditAction
  adminId               String?                        @map("admin_id")
  previousState         Json?                          @map("previous_state")
  newState              Json?                          @map("new_state")
  reason                String?
  createdAt             DateTime                       @default(now()) @map("created_at")

  metafieldDefinition MetafieldDefinition @relation(fields: [metafieldDefinitionId], references: [id], onDelete: Cascade)

  @@index([metafieldDefinitionId, createdAt])
  @@index([adminId, createdAt])
  @@map("metafield_definition_audit_logs")
}

enum MetafieldDefinitionAuditAction {
  CREATE
  UPDATE
  DELETE
  DEACTIVATE
  REACTIVATE
  BULK_ASSIGN
}

// ── Product Metafield Values ────────────────────────────────────────────
// Stores the actual metafield value for a specific product.

model ProductMetafield {
  id                    String @id @default(uuid())
  productId             String @map("product_id")
  metafieldDefinitionId String @map("metafield_definition_id")

  // Value storage — use the appropriate column based on type
  valueText    String?   @map("value_text")
  valueNumeric Decimal?  @map("value_numeric") @db.Decimal(15, 4)
  valueBoolean Boolean?  @map("value_boolean")
  valueDate    DateTime? @map("value_date")
  valueJson    Json?     @map("value_json") // DIMENSION, WEIGHT, VOLUME, MULTI_SELECT, JSON

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product             Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  // Phase 39 (2026-05-21) — Restrict (was Cascade). Pre-Phase-39 a
  // definition delete silently destroyed every product's value for
  // that attribute (1,285 definitions × N products = unbounded data
  // loss with one click). Restrict means admins must clear values
  // first; the controller already checks _count.metafieldValues
  // before allowing the delete + falls back to deactivate when
  // values exist, so the new constraint just hardens the contract
  // at the DB layer.
  metafieldDefinition MetafieldDefinition @relation(fields: [metafieldDefinitionId], references: [id], onDelete: Restrict)

  @@unique([productId, metafieldDefinitionId])
  @@index([productId])
  @@index([metafieldDefinitionId])
  @@index([metafieldDefinitionId, valueText])
  @@index([metafieldDefinitionId, valueNumeric])
  @@index([metafieldDefinitionId, valueBoolean])
  @@map("product_metafields")
}

// ── Storefront Filter Configuration ─────────────────────────────────────
// Admins configure which metafields/built-in fields become storefront filters.

model StorefrontFilter {
  id                    String  @id @default(uuid())
  metafieldDefinitionId String? @map("metafield_definition_id")

  // Built-in filter type (when metafieldDefinitionId is null)
  builtInType String? @map("built_in_type") // "price_range", "brand", "availability", "variant_option"

  // Display
  label      String
  filterType String  @map("filter_type") // "checkbox", "price_range", "boolean_toggle", "color_swatch", "text_input"
  sortOrder  Int     @default(0) @map("sort_order")
  isActive   Boolean @default(true) @map("is_active")

  // Scope
  scopeType String? @map("scope_type") // "CATEGORY", "COLLECTION", "GLOBAL"
  scopeId   String? @map("scope_id") // categoryId or collectionId

  // Behavior
  collapsed  Boolean @default(false)
  showCounts Boolean @default(true) @map("show_counts")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Phase 40 (2026-05-21) — Cascade → Restrict. Pre-Phase-40 deleting
  // a metafield definition silently dropped every per-scope filter
  // config pointing at it. Combined with the Phase 39 FK-restrict on
  // ProductMetafield this gives admins a consistent contract: clear
  // the dependents first, then delete.
  metafieldDefinition MetafieldDefinition? @relation(fields: [metafieldDefinitionId], references: [id], onDelete: Restrict)

  @@index([metafieldDefinitionId])
  @@index([scopeType, scopeId])
  @@index([isActive, sortOrder])
  // Phase 40 (2026-05-21) — partial unique declared in raw SQL in the
  // migration (Prisma DSL does not support partial indexes). Prevents
  // duplicate per-scope filter configs for the same definition.
  //   CREATE UNIQUE INDEX storefront_filters_def_scope_unique
  //     ON storefront_filters (metafield_definition_id, scope_type, COALESCE(scope_id, ''))
  //     WHERE metafield_definition_id IS NOT NULL;
  // Phase 194 (#5) — symmetric partial unique for built-in rows, so an
  // admin can't register two `brand`/`price_range`/`availability` configs
  // for the same scope (migration 20260602310000):
  //   CREATE UNIQUE INDEX storefront_filters_builtin_scope_unique
  //     ON storefront_filters (built_in_type, COALESCE(scope_type, ''), COALESCE(scope_id, ''))
  //     WHERE built_in_type IS NOT NULL;
  @@map("storefront_filters")
}
