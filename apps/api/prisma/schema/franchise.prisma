// ── Procurement (franchise stock replenishment) ────────────

model ProcurementRequest {
  id            String            @id @default(uuid())
  requestNumber String            @unique @map("request_number")
  franchiseId   String            @map("franchise_id")
  status        ProcurementStatus @default(DRAFT)

  totalRequestedAmount Decimal @default(0) @map("total_requested_amount") @db.Decimal(12, 2)
  totalApprovedAmount  Decimal @default(0) @map("total_approved_amount") @db.Decimal(12, 2)
  procurementFeeRate   Decimal @default(5) @map("procurement_fee_rate") @db.Decimal(5, 2)
  procurementFeeAmount Decimal @default(0) @map("procurement_fee_amount") @db.Decimal(12, 2)
  finalPayableAmount   Decimal @default(0) @map("final_payable_amount") @db.Decimal(12, 2)

  requestedAt  DateTime? @map("requested_at")
  approvedAt   DateTime? @map("approved_at")
  approvedBy   String?   @map("approved_by")
  dispatchedAt DateTime? @map("dispatched_at")
  receivedAt   DateTime? @map("received_at")
  settledAt    DateTime? @map("settled_at")

  // Phase 235/236 (Procurement audits) — first-class actor columns. The
  // ProcurementRequestEvent history (Phase 159p) already records the actor per
  // transition, but these make "who created / dispatched / received / cancelled
  // this" queryable directly on the header without a join. requestedByStaffId is
  // the franchise staff/user who created it (falls back to the org id until
  // multi-user staff auth is wired here). cancelledAt + cancellationReason
  // replace stuffing the cancel reason into the free-form `notes` column.
  requestedByStaffId String?   @map("requested_by_staff_id")
  dispatchedBy       String?   @map("dispatched_by")
  receivedBy         String?   @map("received_by")
  cancelledBy        String?   @map("cancelled_by")
  cancelledAt        DateTime? @map("cancelled_at")
  cancellationReason String?   @map("cancellation_reason") @db.Text

  /// Phase 7 (2026-05-16) — SLA timestamps. `slaApproveBy` is set on
  /// `submitRequest` to `requestedAt + PROCUREMENT_APPROVAL_SLA_HOURS`
  /// (default 48h). The breach cron emits `procurement.sla_breached`
  /// for requests still SUBMITTED past their deadline; ops can see
  /// from `slaBreachedAt` which were already notified so we don't
  /// re-notify on every tick.
  slaApproveBy  DateTime? @map("sla_approve_by")
  slaBreachedAt DateTime? @map("sla_breached_at")

  // Shipment tracking — captured by admin on /dispatch so the franchise can
  // answer "where is my shipment?" without a support ping.
  trackingNumber     String?   @map("tracking_number")
  carrierName        String?   @map("carrier_name")
  expectedDeliveryAt DateTime? @map("expected_delivery_at")

  // Rejection reason separated from `notes` so the audit trail stays clean.
  // `notes` stays for free-form commentary from either side.
  rejectionReason String? @map("rejection_reason")

  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  franchise FranchisePartner         @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  items     ProcurementRequestItem[]
  events    ProcurementRequestEvent[]

  @@index([franchiseId, status])
  @@index([status])
  @@index([requestNumber])
  @@index([status, slaApproveBy])
  @@map("procurement_requests")
}

/// Phase 159p (audit #12 + audit-trail gap) — append-only transition history
/// for a procurement request. Pre-159p only a single `approvedBy` column
/// existed, so "who submitted / dispatched / received / settled / cancelled
/// this, and when" was unanswerable. One row per status transition.
model ProcurementRequestEvent {
  id                   String   @id @default(uuid())
  procurementRequestId String   @map("procurement_request_id")
  // SUBMITTED | APPROVED | PARTIALLY_APPROVED | REJECTED | DISPATCHED |
  // RECEIVED | PARTIALLY_RECEIVED | SETTLED | CANCELLED
  action               String
  fromStatus           String?  @map("from_status")
  toStatus             String   @map("to_status")
  actorId              String?  @map("actor_id")
  actorType            String   @map("actor_type") // ADMIN | FRANCHISE | SYSTEM
  reason               String?
  createdAt            DateTime @default(now()) @map("created_at")

  request ProcurementRequest @relation(fields: [procurementRequestId], references: [id], onDelete: Cascade)

  @@index([procurementRequestId, createdAt])
  @@map("procurement_request_events")
}

model ProcurementRequestItem {
  id                   String                @id @default(uuid())
  procurementRequestId String                @map("procurement_request_id")
  productId            String                @map("product_id")
  variantId            String?               @map("variant_id")
  globalSku            String                @map("global_sku")
  productTitle         String                @default("") @map("product_title")
  variantTitle         String?               @map("variant_title")
  status               ProcurementItemStatus @default(PENDING)

  requestedQty  Int @map("requested_qty")
  approvedQty   Int @default(0) @map("approved_qty")
  sourcedQty    Int @default(0) @map("sourced_qty")
  dispatchedQty Int @default(0) @map("dispatched_qty")
  receivedQty   Int @default(0) @map("received_qty")
  damagedQty    Int @default(0) @map("damaged_qty")

  // Phase 237 (Pricing Snapshot audit) — MRP (customer-facing base price)
  // captured at REQUEST creation so finance can compute procurement margin
  // against the price that existed when the franchise raised the request, even
  // after the product's basePrice later changes. The landed/fee/final cost
  // fields below remain admin-determined at APPROVAL (the platform has no
  // pre-approval pricing-rule engine — that is a separate, deferred build, so a
  // full "cost snapshot at creation" is not possible; the MRP is the one price
  // that IS known at creation time).
  mrpSnapshot              Decimal? @map("mrp_snapshot") @db.Decimal(10, 2)
  sourceSellerId           String?  @map("source_seller_id")
  landedUnitCost           Decimal? @map("landed_unit_cost") @db.Decimal(10, 2)
  procurementFeePerUnit    Decimal? @map("procurement_fee_per_unit") @db.Decimal(10, 2)
  finalUnitCostToFranchise Decimal? @map("final_unit_cost_to_franchise") @db.Decimal(10, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  procurementRequest ProcurementRequest @relation(fields: [procurementRequestId], references: [id], onDelete: Cascade)

  @@index([procurementRequestId])
  // Phase 235 — per-product analytics ("how much of SKU X have franchises
  // procured / received") without a full-table scan.
  @@index([productId])
  @@map("procurement_request_items")
}

model ProcurementSequence {
  id         Int @id @default(1)
  lastNumber Int @default(0) @map("last_number")

  @@map("procurement_sequences")
}

// ── POS Sales (offline/walk-in tracking) ───────────────────

model FranchisePosSale {
  id            String  @id @default(uuid())
  saleNumber    String  @unique @map("sale_number")
  franchiseId   String  @map("franchise_id")
  saleType      PosSaleType @default(WALK_IN) @map("sale_type")
  customerName  String?     @map("customer_name")
  customerPhone String?     @map("customer_phone")

  grossAmount    Decimal @map("gross_amount") @db.Decimal(10, 2)
  discountAmount Decimal @default(0) @map("discount_amount") @db.Decimal(10, 2)
  taxAmount      Decimal @default(0) @map("tax_amount") @db.Decimal(10, 2)
  netAmount      Decimal @map("net_amount") @db.Decimal(10, 2)

  // Phase 26 GST (POS) — sale-level CGST/SGST snapshot. POS sales are
  // always intra-state (walk-in customer at franchise location) so IGST
  // is always 0 today; the column is kept for shape parity with
  // tax_documents.cgst/sgst/igst in case of future PHONE_ORDER cross-
  // state delivery. Sum across items equals these.
  cgstAmount         Decimal @default(0) @map("cgst_amount") @db.Decimal(10, 2)
  sgstAmount         Decimal @default(0) @map("sgst_amount") @db.Decimal(10, 2)
  igstAmount         Decimal @default(0) @map("igst_amount") @db.Decimal(10, 2)
  // 2-digit GSTIN state code at the time of sale (e.g. 36 = Telangana).
  // Snapshotted so a later franchise relocation doesn't rewrite history.
  placeOfSupplyState String? @map("place_of_supply_state")

  paymentMethod PosPaymentMethod @default(CASH) @map("payment_method")
  status        PosSaleStatus    @default(COMPLETED)

  // Phase 159q (audit #6) — payment settlement state + reference. Physical-POS
  // sales are COMPLETED on record; an integrated gateway (follow-up) would set
  // PENDING and flip via webhook. paymentReference holds the UPI txn id / card
  // auth code when supplied.
  paymentStatus    PosPaymentStatus    @default(COMPLETED) @map("payment_status")
  paymentReference String?             @map("payment_reference")
  paymentSettledAt DateTime?           @map("payment_settled_at")

  // Phase 159q (audit #10) — tax-invoice generation state (was log-only).
  taxInvoiceStatus PosTaxInvoiceStatus @default(PENDING) @map("tax_invoice_status")
  taxInvoiceId     String?             @map("tax_invoice_id")

  // Phase 159q (audit #13) — commission rate snapshotted at sale time so a
  // cross-cycle return reverses at the ORIGINAL rate, not today's.
  commissionRate Decimal? @map("commission_rate") @db.Decimal(5, 2)

  // Phase 159r (POS void/return audit #11) — total refunded back to the
  // customer across all returns of this sale, so "sales with refund > X" is
  // answerable without aggregating the ledger.
  refundedAmount Decimal @default(0) @map("refunded_amount") @db.Decimal(10, 2)

  soldAt           DateTime  @default(now()) @map("sold_at")
  createdByStaffId String?   @map("created_by_staff_id")
  voidedAt         DateTime? @map("voided_at")
  voidReason       String?   @map("void_reason")
  // Phase 159r (audit #10) — void/return actor + return audit columns.
  voidedBy         String?   @map("voided_by")
  returnedAt       DateTime? @map("returned_at")
  returnedBy       String?   @map("returned_by")
  returnReason     String?   @map("return_reason")
  createdAt        DateTime  @default(now()) @map("created_at")

  franchise FranchisePartner       @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  items     FranchisePosSaleItem[]
  returns   FranchisePosReturn[]

  @@index([franchiseId, soldAt])
  @@index([status])
  @@index([saleNumber])
  // Phase 159q (audit #15) — daily report groups by paymentMethod.
  @@index([franchiseId, paymentMethod, soldAt])
  // Phase 159s (POS report audit) — void/return count queries filter on status
  // within the day range.
  @@index([franchiseId, status, soldAt])
  @@map("franchise_pos_sales")
}

/// Phase 159r (POS void/return audit #6) — a customer return as a first-class
/// record, not just a status flip on the sale. One row per return event; a sale
/// can have several (partial returns). Anchors the refund + (future) credit note.
model FranchisePosReturn {
  id              String          @id @default(uuid())
  returnNumber    String          @unique @map("return_number")
  saleId          String          @map("sale_id")
  franchiseId     String          @map("franchise_id")
  refundAmount    Decimal         @map("refund_amount") @db.Decimal(10, 2)
  refundMethod    PosRefundMethod @map("refund_method")
  refundReference String?         @map("refund_reference")
  returnReason    String?         @map("return_reason")
  returnedBy      String?         @map("returned_by")
  returnedAt      DateTime        @default(now()) @map("returned_at")
  createdAt       DateTime        @default(now()) @map("created_at")

  sale  FranchisePosSale         @relation(fields: [saleId], references: [id], onDelete: Cascade)
  items FranchisePosReturnItem[]

  @@index([saleId])
  @@index([franchiseId, returnedAt])
  @@map("franchise_pos_returns")
}

model FranchisePosReturnItem {
  id         String                 @id @default(uuid())
  returnId   String                 @map("return_id")
  saleItemId String                 @map("sale_item_id")
  returnQty  Int                    @map("return_qty")
  condition  PosReturnItemCondition @default(SALEABLE)
  createdAt  DateTime               @default(now()) @map("created_at")

  posReturn FranchisePosReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@index([returnId])
  @@index([saleItemId])
  @@map("franchise_pos_return_items")
}

// Phase 242 (POS Reconciliation audit) — end-of-day cash-vs-bank reconciliation.
// BOUNDED CORE: one row per (franchise, business day). The franchise submits the
// physically-counted cash + the bank-deposit amount/reference; the server computes
// `expectedCashInPaise` AUTHORITATIVELY from the day's CASH sales net of refunds
// (the IST-windowed, refund-adjusted daily report — the client's expected value is
// never trusted), then records `varianceInPaise` and a MATCHED/VARIANCE status.
// All money is BigInt paise (platform money convention). The admin approve/reject/
// resolve workflow, deposit-proof S3 upload, bank-statement auto-match, and the
// POS_RECONCILIATION_ADJUSTMENT ledger linkage are the surfaced follow-on.
model FranchisePosReconciliation {
  id          String   @id @default(uuid())
  franchiseId String   @map("franchise_id")
  // The business day being reconciled (IST). Stored as a date-only value.
  businessDate DateTime @map("business_date") @db.Date

  // Server-computed (authoritative) expected cash for the day = CASH sales net of
  // cash refunds, IST window. The client never supplies this.
  expectedCashInPaise BigInt @map("expected_cash_in_paise")
  // Physically counted cash in the drawer (franchise input).
  actualCashInPaise   BigInt @map("actual_cash_in_paise")
  // Amount deposited to the bank (franchise input) + its UTR/slip reference.
  bankDepositInPaise  BigInt @default(0) @map("bank_deposit_in_paise")
  bankDepositReference String? @map("bank_deposit_reference") @db.VarChar(64)
  // variance = actualCash - expectedCash (signed; negative = short).
  varianceInPaise     BigInt @map("variance_in_paise")
  // Snapshot of the expected-cash computation inputs so the figure is reproducible
  // even after later late voids/returns mutate the underlying sales.
  expectedSnapshotJson Json?  @map("expected_snapshot_json")

  status   PosReconciliationStatus @default(SUBMITTED)
  notes    String?                 @db.Text

  submittedByStaffId String?   @map("submitted_by_staff_id")
  submittedAt        DateTime  @default(now()) @map("submitted_at")
  // Follow-on admin workflow columns (declared now so the model is complete; the
  // approve/reject/resolve endpoints are surfaced, not yet built).
  reviewedByAdminId  String?   @map("reviewed_by_admin_id")
  reviewedAt         DateTime? @map("reviewed_at")
  resolutionReason   String?   @map("resolution_reason") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // One reconciliation per franchise per business day.
  @@unique([franchiseId, businessDate])
  @@index([franchiseId, businessDate])
  @@index([status])
  @@map("franchise_pos_reconciliations")
}

model FranchisePosSaleItem {
  id           String  @id @default(uuid())
  saleId       String  @map("sale_id")
  productId    String  @map("product_id")
  variantId    String? @map("variant_id")
  globalSku    String  @map("global_sku")
  franchiseSku String? @map("franchise_sku")
  productTitle String  @map("product_title")
  variantTitle String? @map("variant_title")
  quantity     Int
  // Phase 159r (POS void/return audit #1) — cumulative units returned across ALL
  // return rounds. The over-return guard checks returnedQty + thisReturn <=
  // quantity; pre-159r only the per-call qty was checked against the original,
  // so 5+5+5 against a 5-unit line slipped through.
  returnedQty  Int     @default(0) @map("returned_qty")
  unitPrice    Decimal @map("unit_price") @db.Decimal(10, 2)
  lineDiscount Decimal @default(0) @map("line_discount") @db.Decimal(10, 2)
  lineTotal    Decimal @map("line_total") @db.Decimal(10, 2)

  // Phase 26 GST (POS) — per-item tax snapshot. Snapshotted at sale time
  // so later catalog HSN / rate changes don't rewrite history. Pricing
  // mode for POS is always INCLUSIVE (retail price quotes include GST).
  // gstRateBps stored as basis points (1800 = 18%) for arithmetic
  // precision; matches OrderItemTaxSnapshot convention.
  hsnCode       String? @map("hsn_code")
  gstRateBps    Int     @default(0) @map("gst_rate_bps")
  taxableAmount Decimal @default(0) @map("taxable_amount") @db.Decimal(10, 2)
  cgstAmount    Decimal @default(0) @map("cgst_amount") @db.Decimal(10, 2)
  sgstAmount    Decimal @default(0) @map("sgst_amount") @db.Decimal(10, 2)
  igstAmount    Decimal @default(0) @map("igst_amount") @db.Decimal(10, 2)

  createdAt DateTime @default(now()) @map("created_at")

  sale FranchisePosSale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@map("franchise_pos_sale_items")
}

model PosSaleSequence {
  id         Int @id @default(1)
  lastNumber Int @default(0) @map("last_number")

  @@map("pos_sale_sequences")
}

// Monotonic sequence for franchise partner codes (SM-FR-XXXXXX). Replaces
// the count()+1 pattern which broke after any soft-delete by recycling
// numbers and producing collisions.
model FranchiseCodeSequence {
  id         Int @id @default(1)
  lastNumber Int @default(0) @map("last_number")

  @@map("franchise_code_sequences")
}

// ── Finance Ledger (franchise commission tracking) ─────────

model FranchiseFinanceLedger {
  id          String                @id @default(uuid())
  franchiseId String                @map("franchise_id")
  sourceType  FranchiseLedgerSource @map("source_type")
  sourceId    String                @map("source_id")
  description String?

  baseAmount     Decimal @map("base_amount") @db.Decimal(12, 2)
  rate           Decimal @db.Decimal(5, 2)
  computedAmount Decimal @map("computed_amount") @db.Decimal(12, 2)

  // Legacy signed "earning" model — retained because the settlement aggregator
  // sums these with sign. Phase 181 adds the canonical double-entry fields below.
  platformEarning  Decimal @default(0) @map("platform_earning") @db.Decimal(12, 2)
  franchiseEarning Decimal @default(0) @map("franchise_earning") @db.Decimal(12, 2)

  // Phase 181 (Franchise Ledger audit) — canonical double-entry columns. Exactly
  // one of debit/credit is positive (NEVER negative, #2/#3); from the franchise's
  // balance perspective credit raises and debit lowers what the platform owes.
  // `balanceAfterInPaise` is the running-balance snapshot AT THIS ENTRY (#1),
  // written under a per-franchise advisory lock so it is consistent + point-in-
  // time-recallable. Paise BigInt = exact money (#7).
  debitInPaise        BigInt  @default(0) @map("debit_in_paise")
  creditInPaise       BigInt  @default(0) @map("credit_in_paise")
  balanceAfterInPaise BigInt  @default(0) @map("balance_after_in_paise")
  currency            String  @default("INR")

  // #5 — queryable actor (manual adjustments/penalties); system posts flag true.
  createdByAdminId String?  @map("created_by_admin_id")
  createdBySystem  Boolean  @default(true) @map("created_by_system")
  // #4/#8 — deterministic dedup key for event-sourced posts (`type:sourceId`);
  // NULL for legitimately-repeatable ADJUSTMENT/PENALTY. @unique enforces it.
  idempotencyKey   String?  @unique @map("idempotency_key")

  status            FranchiseLedgerStatus @default(PENDING)
  settlementBatchId String?               @map("settlement_batch_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  franchise       FranchisePartner     @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  settlementBatch FranchiseSettlement? @relation(fields: [settlementBatchId], references: [id])
  statusHistory   FranchiseLedgerStatusHistory[]

  @@index([franchiseId, status])
  @@index([sourceType, sourceId])
  @@index([settlementBatchId])
  @@index([createdAt])
  // Phase 181 — paginated reads + filtered drill-down + actor audit.
  @@index([franchiseId, createdAt])
  @@index([franchiseId, sourceType, createdAt])
  @@index([createdByAdminId, createdAt])
  @@map("franchise_finance_ledger")
}

// Phase 181 (#14) — immutable status-transition history. Entries are immutable;
// a status change (e.g. → REVERSED, → SETTLED) appends a history row with actor +
// reason instead of being a silent edit.
model FranchiseLedgerStatusHistory {
  id            String   @id @default(uuid())
  ledgerEntryId String   @map("ledger_entry_id")
  fromStatus    String   @map("from_status")
  toStatus      String   @map("to_status")
  actorAdminId  String?  @map("actor_admin_id")
  reason        String?
  occurredAt    DateTime @default(now()) @map("occurred_at")

  ledgerEntry FranchiseFinanceLedger @relation(fields: [ledgerEntryId], references: [id], onDelete: Cascade)

  @@index([ledgerEntryId])
  @@map("franchise_ledger_status_history")
}

// Phase 181 (#11) — two-person control for punitive penalties at/above the env
// threshold. The penalty is NOT posted to the ledger until a SECOND admin (≠ the
// requester) approves; the ledger entry id is back-linked on approval.
enum FranchisePenaltyApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model FranchisePenaltyApproval {
  id                 String                         @id @default(uuid())
  franchiseId        String                         @map("franchise_id")
  amount             Decimal                        @db.Decimal(12, 2)
  reason             String
  status             FranchisePenaltyApprovalStatus @default(PENDING)
  requestedByAdminId String                         @map("requested_by_admin_id")
  approvedByAdminId  String?                        @map("approved_by_admin_id")
  decisionReason     String?                        @map("decision_reason")
  ledgerEntryId      String?                        @map("ledger_entry_id")
  createdAt          DateTime                       @default(now()) @map("created_at")
  decidedAt          DateTime?                      @map("decided_at")

  franchise FranchisePartner @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([franchiseId])
  @@map("franchise_penalty_approvals")
}

// ── Franchise Settlement (payout cycles) ───────────────────

model FranchiseSettlement {
  id            String @id @default(uuid())
  cycleId       String @map("cycle_id")
  franchiseId   String @map("franchise_id")
  franchiseName String @map("franchise_name")

  totalOnlineOrders     Int     @default(0) @map("total_online_orders")
  totalOnlineAmount     Decimal @default(0) @map("total_online_amount") @db.Decimal(12, 2)
  totalOnlineCommission Decimal @default(0) @map("total_online_commission") @db.Decimal(12, 2)

  totalProcurements      Int     @default(0) @map("total_procurements")
  totalProcurementAmount Decimal @default(0) @map("total_procurement_amount") @db.Decimal(12, 2)
  totalProcurementFees   Decimal @default(0) @map("total_procurement_fees") @db.Decimal(12, 2)

  totalPosSales  Int     @default(0) @map("total_pos_sales")
  totalPosAmount Decimal @default(0) @map("total_pos_amount") @db.Decimal(12, 2)
  totalPosFees   Decimal @default(0) @map("total_pos_fees") @db.Decimal(12, 2)

  reversalAmount   Decimal @default(0) @map("reversal_amount") @db.Decimal(12, 2)
  adjustmentAmount Decimal @default(0) @map("adjustment_amount") @db.Decimal(12, 2)

  grossFranchiseEarning Decimal @default(0) @map("gross_franchise_earning") @db.Decimal(12, 2)
  totalPlatformEarning  Decimal @default(0) @map("total_platform_earning") @db.Decimal(12, 2)
  netPayableToFranchise Decimal @default(0) @map("net_payable_to_franchise") @db.Decimal(12, 2)

  // Phase 250 (Franchise tax) — §52 TCS / §194-O TDS / commission-GST deduction
  // snapshots, mirroring SellerSettlement. Applied to the ONLINE-facilitated
  // portion only (POS counter sales are not operator-facilitated supplies). The
  // franchise net wired = netPayableToFranchise − tcsDeducted − tdsDeducted −
  // totalCommissionGst. The ledger rows carry the statutory lifecycle; these
  // denorm columns keep the payout statement a single-table read.
  tcsLedgerId        String? @map("tcs_ledger_id")
  tcsDeductedInPaise BigInt  @default(0) @map("tcs_deducted_in_paise")
  tcsRateBpsSnapshot Int     @default(100) @map("tcs_rate_bps_snapshot")
  tcsFilingPeriod    String? @map("tcs_filing_period")

  tdsLedgerId        String? @map("tds_ledger_id")
  tdsDeductedInPaise BigInt  @default(0) @map("tds_deducted_in_paise")
  tdsRateBpsSnapshot Int     @default(100) @map("tds_rate_bps_snapshot")
  tdsFilingPeriod    String? @map("tds_filing_period")
  tdsSkipReason      String? @map("tds_skip_reason")

  commissionGstRateBps              Int     @default(1800) @map("commission_gst_rate_bps")
  commissionGstSplitType            String? @map("commission_gst_split_type")
  cgstOnCommissionInPaise           BigInt  @default(0) @map("cgst_on_commission_in_paise")
  sgstOnCommissionInPaise           BigInt  @default(0) @map("sgst_on_commission_in_paise")
  igstOnCommissionInPaise           BigInt  @default(0) @map("igst_on_commission_in_paise")
  totalCommissionGstInPaise         BigInt  @default(0) @map("total_commission_gst_in_paise")
  commissionGstMarketplaceStateCode String? @map("commission_gst_marketplace_state_code")
  commissionGstFranchiseStateCode   String? @map("commission_gst_franchise_state_code")

  status           FranchiseSettlementStatus @default(PENDING)
  paidAt           DateTime?                 @map("paid_at")
  paymentReference String?                   @map("payment_reference")
  // Phase 146 — payout provenance (mirrors SellerSettlement.paidByAdminId).
  paidByAdminId    String?                   @map("paid_by_admin_id")
  // Phase 178 (Outstanding Payables audit) — SLA / aging / hold / partial-pay.
  payoutDueBy       DateTime? @map("payout_due_by")
  holdReason        String?   @map("hold_reason")
  frozenAt          DateTime? @map("frozen_at")
  frozenByAdminId   String?   @map("frozen_by_admin_id")
  paidAmountInPaise BigInt    @default(0) @map("paid_amount_in_paise")

  // Phase 251 — dynamic settlement charge rules. When chargeRulesApplied, the
  // wired payout deducts dynamicChargeTotalInPaise (the sum of chargeLines)
  // instead of the legacy commission-GST/TCS/TDS. Frozen per-settlement so a
  // later rule edit never changes a historical franchise payout.
  dynamicChargeTotalInPaise BigInt  @default(0) @map("dynamic_charge_total_in_paise")
  chargeRulesApplied        Boolean @default(false) @map("charge_rules_applied")

  createdAt        DateTime                  @default(now()) @map("created_at")
  updatedAt        DateTime                  @updatedAt @map("updated_at")

  cycle         SettlementCycle          @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  franchise     FranchisePartner         @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  ledgerEntries FranchiseFinanceLedger[]
  paidByAdmin   Admin?                   @relation("FranchiseSettlementPaidBy", fields: [paidByAdminId], references: [id], onDelete: SetNull)
  // Phase 177 (#4) — itemized adjustments behind the net `adjustmentAmount`.
  adjustments   FranchiseSettlementAdjustment[]
  // Phase 250 (Franchise tax) — party-generic statutory ledger links.
  tcsLedger     GstTcsSettlementLedger? @relation(fields: [tcsLedgerId], references: [id], onDelete: Restrict)
  tdsLedger     Section194OTdsLedger?   @relation(fields: [tdsLedgerId], references: [id], onDelete: Restrict)
  // Phase 251 — frozen rule-wise dynamic charge breakup for this settlement.
  chargeLines   FranchiseSettlementChargeLine[]

  @@unique([cycleId, franchiseId])
  @@index([cycleId])
  @@index([franchiseId])
  @@index([status])
  // Phase 178 (#1) — aging / overdue queries scan by (status, payoutDueBy).
  @@index([status, payoutDueBy])
  @@map("franchise_settlements")
}

/// Frozen per-franchise-settlement charge breakup (Phase 251). Mirrors
/// SettlementChargeLine (seller side): one row per dynamic charge rule applied
/// to a FranchiseSettlement at cycle creation, snapshotting rule name + rate +
/// base amount + computed amount so the breakup (and net payout) never change
/// when a rule is later edited — historical franchise settlements stay immutable.
model FranchiseSettlementChargeLine {
  id                String   @id @default(uuid())
  settlementId      String   @map("settlement_id")
  /// The rule that produced this line (nullable so a later rule delete doesn't
  /// cascade-destroy history).
  ruleId            String?  @map("rule_id")
  ruleName          String   @map("rule_name")
  baseType          String   @map("base_type")
  baseRuleId        String?  @map("base_rule_id")
  baseAmountInPaise BigInt   @map("base_amount_in_paise")
  rateBps           Int      @map("rate_bps")
  amountInPaise     BigInt   @map("amount_in_paise")
  priority          Int      @default(0)
  createdAt         DateTime @default(now()) @map("created_at")

  settlement FranchiseSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([settlementId])
  @@map("franchise_settlement_charge_lines")
}

/// Phase 177 (Per-Franchise Accounts audit #4 / audit #145 gap) — itemized
/// settlement adjustments for a franchise. The seller side has
/// `SettlementAdjustment`; the franchise side previously only had a net
/// `FranchiseSettlement.adjustmentAmount` column with no line items. Each row is
/// one penalty / correction / claw-back against a PENDING franchise settlement.
/// Creating a row shifts the settlement's `adjustmentAmount` AND
/// `netPayableToFranchise` by the (signed) row amount, in one transaction; only
/// PENDING settlements may be adjusted (a PAID one needs a reversal flow).
/// Reuses the generic SettlementAdjustmentType / SettlementAdjustmentStatus enums.
model FranchiseSettlementAdjustment {
  id           String @id @default(uuid())
  settlementId String @map("settlement_id")
  franchiseId  String @map("franchise_id")

  // Signed: negative = deduction from the payout, positive = credit.
  amount        Decimal @db.Decimal(12, 2)
  amountInPaise BigInt  @default(0) @map("amount_in_paise")

  adjustmentType SettlementAdjustmentType   @default(MANUAL_CORRECTION) @map("adjustment_type")
  status         SettlementAdjustmentStatus @default(ACTIVE)

  notes            String?   @db.Text
  createdByAdminId String?   @map("created_by_admin_id")
  voidedByAdminId  String?   @map("voided_by_admin_id")
  voidedAt         DateTime? @map("voided_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  settlement FranchiseSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([settlementId])
  @@index([franchiseId, status])
  @@map("franchise_settlement_adjustments")
}

// ── Franchise Staff ───────────────────────────────────────────

model FranchiseStaff {
  id    String @id @default(uuid())
  franchiseId String @map("franchise_id")
  name  String
  // Phase 159t (staff audit #5/#6) — email is NO LONGER globally unique (that
  // leaked existence across franchises + blocked multi-franchise employees +
  // orphaned soft-deleted rows). Uniqueness is now a PARTIAL unique index
  // (franchise_id, email) WHERE status <> 'TERMINATED', defined in the
  // migration (Prisma can't express partial uniques). Same for phone (#16).
  email String
  phone String?
  // Phase 159u (staff-auth B4) — nullable: an INVITED staff has no password
  // until they activate via the emailed invite token + set their own.
  passwordHash String? @map("password_hash")
  role  FranchiseStaffRole   @default(POS_OPERATOR)
  // Phase 159t (audit #12) — richer lifecycle than the isActive boolean.
  // isActive is kept (synced) for back-compat with existing reads.
  status   FranchiseStaffStatus @default(ACTIVE)
  isActive Boolean              @default(true) @map("is_active")

  // Phase 159u (staff-auth B2) — per-staff permission overrides on top of the
  // role defaults (resolveStaffPermissions). Null = pure role defaults.
  permissions Json? @map("permissions")
  // Phase 159u (staff-auth B4) — invitation/activation. SHA-256(token).
  inviteTokenHash String?   @map("invite_token_hash")
  inviteExpiresAt DateTime? @map("invite_expires_at")

  // Phase 159t (audit #8/#15) — lifecycle audit + activity columns.
  createdBy        String?   @map("created_by")
  suspendedBy      String?   @map("suspended_by")
  suspendedAt      DateTime? @map("suspended_at")
  suspensionReason String?   @map("suspension_reason")
  lastLoginAt      DateTime? @map("last_login_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  franchise FranchisePartner       @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  sessions  FranchiseStaffSession[]

  @@index([franchiseId, isActive])
  @@index([franchiseId, status])
  @@index([inviteTokenHash])
  @@map("franchise_staff")
}

/// Phase 159u (staff-auth B1) — staff refresh-session, mirroring
/// FranchiseSession. `refreshToken` stores SHA-256(rawToken), never plaintext.
/// Rotated on refresh; revoked on logout and on suspend/terminate.
model FranchiseStaffSession {
  id           String    @id @default(uuid())
  staffId      String    @map("staff_id")
  refreshToken String    @map("refresh_token")
  userAgent    String?   @map("user_agent")
  ipAddress    String?   @map("ip_address")
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  lastUsedAt   DateTime? @map("last_used_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  staff FranchiseStaff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([refreshToken])
  @@index([staffId, revokedAt])
  @@map("franchise_staff_sessions")
}
