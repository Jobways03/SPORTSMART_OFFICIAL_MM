// ============================================
// Franchise Module - owned tables
// ============================================

model FranchisePartner {
  id                 String                      @id @default(uuid())
  franchiseCode      String                      @unique @map("franchise_code")
  ownerName          String                      @map("owner_name")
  businessName       String                      @map("business_name")
  email              String                      @unique
  phoneNumber        String                      @unique @map("phone_number")
  passwordHash       String                      @map("password_hash")
  status             FranchiseStatus             @default(PENDING)
  verificationStatus FranchiseVerificationStatus @default(NOT_VERIFIED) @map("verification_status")

  // Login tracking
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockUntil           DateTime? @map("lock_until")
  lastLoginAt         DateTime? @map("last_login_at")

  // Location
  state    String?
  city     String?
  address  String?
  pincode  String?
  locality String?
  country  String?

  // Compliance — Phase 20 (2026-05-20) @unique constraints.
  // Postgres treats NULL as distinct so multiple pre-onboarding rows
  // with `gstNumber=NULL` coexist; once set, the value must be
  // unique across all non-deleted franchises.
  gstNumber    String? @unique @map("gst_number")
  panNumber    String? @unique @map("pan_number")
  gstStateCode String? @map("gst_state_code")
  panLast4     String? @map("pan_last_4")

  /// Phase 20 (2026-05-20) — KYC submission snapshot timestamp +
  /// JSON snapshot of the payload the franchise submitted. The
  /// snapshot is the canonical record of what the franchise
  /// declared at the moment of submission (admin reviewers can
  /// diff this against the live row to spot post-submission
  /// edits).
  kycSubmittedAt          DateTime? @map("kyc_submitted_at")
  kycSubmittedPayloadJson Json?     @map("kyc_submitted_payload_json")
  /// Phase 20 (2026-05-20) — DPDP / consent-archive timestamp.
  kycConfirmedAccurateAt  DateTime? @map("kyc_confirmed_accurate_at")

  /// Phase 20 (2026-05-20) — admin-review audit columns. Split out
  /// from the previously decorative status/verification flips so
  /// admin actions are queryable + a rejection reason is durably
  /// stored on the row (not just on an event payload nobody
  /// consumed).
  verificationReviewedAt      DateTime? @map("verification_reviewed_at")
  verificationReviewedBy      String?   @map("verification_reviewed_by")
  verificationRejectionReason String?   @map("verification_rejection_reason")
  verificationApprovalNotes   String?   @map("verification_approval_notes")
  /// Phase 20 (2026-05-20) — approval-action audit columns. The
  /// status field carries the current value; these record exactly
  /// when the admin moved PENDING → APPROVED and APPROVED → ACTIVE
  /// (two-step model).
  approvedAt                  DateTime? @map("approved_at")
  approvedBy                  String?   @map("approved_by")
  activatedAt                 DateTime? @map("activated_at")
  activatedBy                 String?   @map("activated_by")
  // Phase 159i — actor + reason for the suspend/deactivate transitions (audit:
  // only approve/activate were stamped; the FranchiseStatusHistory table is the
  // full ordered trail).
  suspendedAt                 DateTime? @map("suspended_at")
  suspendedBy                 String?   @map("suspended_by")
  suspensionReason            String?   @map("suspension_reason") @db.Text
  deactivatedAt               DateTime? @map("deactivated_at")
  deactivatedBy               String?   @map("deactivated_by")
  deactivationReason          String?   @map("deactivation_reason") @db.Text
  /// Phase 20 (2026-05-20) — exact moment isEmailVerified flipped
  /// to true. Distinct from the boolean which only answers "now?".
  emailVerifiedAt             DateTime? @map("email_verified_at")

  // Commission rates (per-franchise configurable)
  onlineFulfillmentRate Decimal @default(15) @map("online_fulfillment_rate") @db.Decimal(5, 2)
  procurementFeeRate    Decimal @default(5) @map("procurement_fee_rate") @db.Decimal(5, 2)

  // Contract
  contractStartDate DateTime? @map("contract_start_date")
  contractEndDate   DateTime? @map("contract_end_date")

  // Warehouse
  warehouseAddress String? @map("warehouse_address")
  warehousePincode String? @map("warehouse_pincode")

  // ─── Logistics entitlements (franchise-admin controlled) ──────
  // Toggled by franchise admin in web-franchise-admin. Self-delivery
  // is the only delivery method today (iThink removed).
  selfDeliveryEnabled         Boolean                       @default(false) @map("self_delivery_enabled")
  selfDeliveryPincodes        Json?                         @map("self_delivery_pincodes")

  // Profile & branding
  profileImageUrl             String? @map("profile_image_url")
  profileImagePublicId        String? @map("profile_image_public_id")
  logoUrl                     String? @map("logo_url")
  logoPublicId                String? @map("logo_public_id")
  assignedZone                String? @map("assigned_zone")
  profileCompletionPercentage Int     @default(0) @map("profile_completion_percentage")
  isProfileCompleted          Boolean @default(false) @map("is_profile_completed")
  isEmailVerified             Boolean @default(false) @map("is_email_verified")

  // Soft delete
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  sessions            FranchiseSession[]
  passwordResetOtps   FranchisePasswordResetOtp[]
  catalogMappings     FranchiseCatalogMapping[]
  stock               FranchiseStock[]
  inventoryLedger     FranchiseInventoryLedger[]
  subOrders           SubOrder[]
  procurementRequests ProcurementRequest[]
  posSales            FranchisePosSale[]
  financeLedger       FranchiseFinanceLedger[]
  settlements         FranchiseSettlement[]
  staff               FranchiseStaff[]
  procurementPrices   FranchiseProcurementPrice[]
  /// Phase 20 (2026-05-20) — 1:1 bank details back-relation.
  bankDetails         FranchiseBankDetails?
  /// Phase 159i — ordered status-transition trail.
  statusHistory       FranchiseStatusHistory[]
  /// Phase 159j — ordered KYC-verification-transition trail.
  verificationHistory FranchiseVerificationEvent[]
  /// Phase 159l — append-only procurement-price change trail.
  procurementPriceHistory FranchiseProcurementPriceHistory[]
  /// Phase 159m — admin-assigned pincode coverage + its change trail.
  pincodeMappings       FranchisePincodeMapping[]
  pincodeMappingEvents  FranchisePincodeMappingEvent[]
  /// Phase 159n — catalog-mapping decision trail.
  catalogMappingEvents  FranchiseCatalogMappingEvent[]

  @@index([status])
  @@index([isProfileCompleted])
  @@index([assignedZone])
  @@index([state])
  @@index([email])
  @@index([phoneNumber])
  @@index([isDeleted])
  @@index([verificationStatus])
  // Scanned every hour by FranchiseReservationCleanupService.checkExpiredContracts
  // (status=ACTIVE, contractEndDate<now). Without this index the sweep
  // does a seq scan on the whole franchise table.
  @@index([contractEndDate])
  @@map("franchise_partners")
}

// Phase 159i — append-only franchise status-transition log. The dedicated
// actor columns on FranchisePartner hold the LATEST actor per transition type;
// this keeps the full ordered timeline (who moved it from what to what + why).
model FranchiseStatusHistory {
  id               String   @id @default(uuid())
  franchiseId      String   @map("franchise_id")
  fromStatus       String   @map("from_status")
  toStatus         String   @map("to_status")
  changedByAdminId String?  @map("changed_by_admin_id")
  reason           String?  @db.Text
  createdAt        DateTime @default(now()) @map("created_at")

  franchise FranchisePartner @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  @@index([franchiseId, createdAt])
  @@map("franchise_status_history")
}

// Phase 159j — append-only franchise KYC-verification-transition log. Mirrors
// FranchiseStatusHistory but for the verification lifecycle
// (NOT_VERIFIED → UNDER_REVIEW → VERIFIED/REJECTED). The dedicated
// verificationReviewedBy/At + reason columns on FranchisePartner hold the
// LATEST reviewer; this keeps the full ordered who-moved-it-from-what-to-what
// trail so a flipped verdict (e.g. VERIFIED → NOT_VERIFIED) is reconstructable.
model FranchiseVerificationEvent {
  id               String   @id @default(uuid())
  franchiseId      String   @map("franchise_id")
  fromStatus       String   @map("from_status")
  toStatus         String   @map("to_status")
  changedByAdminId String?  @map("changed_by_admin_id")
  reason           String?  @db.Text
  createdAt        DateTime @default(now()) @map("created_at")

  franchise FranchisePartner @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  @@index([franchiseId, createdAt])
  @@map("franchise_verification_events")
}

// Per-franchise negotiated procurement price. When a row exists for
// (franchise, product, variant), the procurement approval modal
// pre-fills landedUnitCost from this table instead of the
// variant-level default (ProductVariant.costPrice). Write-back on
// approval targets this row so subsequent approvals for the same
// franchise + SKU keep its negotiated price, while other franchises
// continue to default to the platform-wide cost.
//
// variantId is nullable for product-level mappings (rare).
model FranchiseProcurementPrice {
  id             String   @id @default(uuid())
  franchiseId    String   @map("franchise_id")
  productId      String   @map("product_id")
  variantId      String?  @map("variant_id")
  landedUnitCost Decimal  @map("landed_unit_cost") @db.Decimal(10, 2)
  notes          String?
  createdBy      String?  @map("created_by")
  // Phase 159l — last-modifier (was lost on overwrite; only createdBy existed)
  // + optimistic-concurrency version (bumped on every update; the upsert path
  // does a version-CAS so two concurrent admin edits can't silently clobber).
  updatedBy      String?  @map("updated_by")
  version        Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  franchise FranchisePartner @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  @@unique([franchiseId, productId, variantId])
  @@index([franchiseId])
  @@map("franchise_procurement_prices")
}

// Phase 159l — append-only audit trail for per-franchise procurement-price
// changes (audit #4/#13/#14). Keyed on franchiseId + product/variant rather
// than the price-row id so the history survives a row DELETE (the "what was
// the negotiated price on date X / who changed it / why" question must be
// answerable even after the override is removed). Mirrors
// FranchiseStatusHistory / FranchiseVerificationEvent.
model FranchiseProcurementPriceHistory {
  id                 String   @id @default(uuid())
  franchiseId        String   @map("franchise_id")
  productId          String   @map("product_id")
  variantId          String?  @map("variant_id")
  action             String // UPSERT_CREATE | UPSERT_UPDATE | DELETE | APPROVAL_WRITEBACK
  oldLandedUnitCost  Decimal? @map("old_landed_unit_cost") @db.Decimal(10, 2)
  newLandedUnitCost  Decimal? @map("new_landed_unit_cost") @db.Decimal(10, 2)
  changeReason       String?  @map("change_reason")
  changedByAdminId   String?  @map("changed_by_admin_id")
  createdAt          DateTime @default(now()) @map("created_at")

  franchise FranchisePartner @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  @@index([franchiseId, productId, variantId, createdAt])
  @@map("franchise_procurement_price_history")
}

// Phase 159m — admin-assigned pincode → franchise coverage map. Consulted by
// the routing engine (serviceability + allocation) in "supplement" mode: when
// a customer pincode has ≥1 active mapping, ONLY mapped franchises are eligible
// (ranked by priority desc, then distance); a pincode with no mapping falls
// back to distance-based discovery. Multi-franchise-per-pincode is allowed
// (unique on franchiseId+pincode); an admin achieves strict 1-of-N by mapping
// each pincode to a single franchise.
model FranchisePincodeMapping {
  id           String    @id @default(uuid())
  franchiseId  String    @map("franchise_id")
  pincode      String // 6-digit Indian PIN
  // Higher wins when multiple franchises map the same pincode. 0..1000.
  priority     Int       @default(100)
  isActive     Boolean   @default(true) @map("is_active")
  reason       String?
  assignedById String?   @map("assigned_by_id")
  assignedAt   DateTime  @default(now()) @map("assigned_at")
  removedById  String?   @map("removed_by_id")
  removedAt    DateTime? @map("removed_at")
  // Optimistic-concurrency token; bumped on every update (version-CAS).
  version      Int       @default(0)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  franchise FranchisePartner @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  @@unique([franchiseId, pincode])
  // Hot path: routing looks up active franchises for a pincode.
  @@index([pincode, isActive])
  @@index([franchiseId, isActive])
  @@map("franchise_pincode_mappings")
}

// Phase 159m — append-only audit trail for pincode-mapping changes. Keyed on
// franchiseId + pincode so it survives a mapping-row delete (who assigned /
// removed / re-prioritised a pincode, when, why).
model FranchisePincodeMappingEvent {
  id          String   @id @default(uuid())
  mappingId   String?  @map("mapping_id")
  franchiseId String   @map("franchise_id")
  pincode     String
  // ASSIGNED | REACTIVATED | DEACTIVATED | REMOVED | PRIORITY_CHANGED | BULK_ASSIGNED
  action      String
  oldValue    Json?    @map("old_value")
  newValue    Json?    @map("new_value")
  reason      String?
  actorId     String?  @map("actor_id")
  createdAt   DateTime @default(now()) @map("created_at")

  franchise FranchisePartner @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  @@index([franchiseId, createdAt])
  @@index([mappingId])
  @@map("franchise_pincode_mapping_events")
}

model FranchiseSession {
  id                       String    @id @default(uuid())
  franchisePartnerId       String    @map("franchise_partner_id")
  /// Phase 20 (2026-05-20) — column stores SHA-256(rawRefreshToken).
  /// Despite the name, never plaintext. Same contract as the
  /// customer + seller session tables. Eventual rename to
  /// `refresh_token_hash` is deferred to avoid cascading caller
  /// changes; the doc comment is load-bearing for incident review.
  refreshToken             String    @map("refresh_token")
  // Phase 1 / C6 — refresh-token reuse detection. See AdminSession
  // for the contract.
  previousRefreshTokenHash String?   @map("previous_refresh_token_hash")
  userAgent                String?   @map("user_agent")
  ipAddress                String?   @map("ip_address")
  expiresAt                DateTime  @map("expires_at")
  revokedAt                DateTime? @map("revoked_at")
  /// Phase 27 (2026-05-21) — forensic columns; see identity.prisma.
  revokedBy                String?   @map("revoked_by")
  revocationReason         String?   @map("revocation_reason") @db.Text
  /// Phase 27 (2026-05-21) — bumped on each refresh-rotation.
  lastUsedAt               DateTime? @map("last_used_at")
  /// Phase 27 (2026-05-21) — UA-derived label.
  deviceLabel              String?   @map("device_label") @db.VarChar(64)
  createdAt                DateTime  @default(now()) @map("created_at")

  franchisePartner FranchisePartner @relation(fields: [franchisePartnerId], references: [id], onDelete: Cascade)

  @@index([franchisePartnerId])
  @@index([refreshToken])
  @@index([previousRefreshTokenHash])
  /// Phase 20 (2026-05-20) — coverage indexes for the per-request
  /// guard lookup + the revoke-all sweep.
  @@index([franchisePartnerId, revokedAt])
  @@index([franchisePartnerId, expiresAt])
  @@map("franchise_sessions")
}

/// Phase 20 (2026-05-20) — Franchise payout bank details.
/// One-to-one with FranchisePartner. Account number AES-256-GCM
/// encrypted via FRANCHISE_BANK_ENCRYPTION_KEY; last-4 stored
/// separately for masked display. Mirrors SellerBankDetails.
model FranchiseBankDetails {
  id                 String    @id @default(uuid())
  franchisePartnerId String    @unique @map("franchise_partner_id")
  accountHolderName  String    @map("account_holder_name") @db.VarChar(150)
  accountNumberEnc   String    @map("account_number_enc")
  accountNumberLast4 String    @map("account_number_last_4") @db.VarChar(4)
  ifscCode           String    @map("ifsc_code") @db.VarChar(11)
  bankName           String?   @map("bank_name") @db.VarChar(150)
  upiVpa             String?   @map("upi_vpa") @db.VarChar(100)
  verifiedAt         DateTime? @map("verified_at")
  verifiedBy         String?   @map("verified_by")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  franchisePartner FranchisePartner @relation(fields: [franchisePartnerId], references: [id], onDelete: Cascade)

  @@map("franchise_bank_details")
}

/// Phase 20 (2026-05-20) — Franchise OTP table.
///
/// Stores OTPs for BOTH password-reset and email-verification
/// purposes, distinguished by the `purpose` column. Model name kept
/// for backward-compat; the TypeScript-side `FranchiseOtpPurpose`
/// union pins the legal values.
model FranchisePasswordResetOtp {
  id                 String    @id @default(uuid())
  franchisePartnerId String    @map("franchise_partner_id")
  otpHash            String    @map("otp_hash")
  purpose            String    @default("PASSWORD_RESET")
  attempts           Int       @default(0)
  maxAttempts        Int       @default(5) @map("max_attempts")
  verifiedAt         DateTime? @map("verified_at")
  resetToken         String?   @unique @map("reset_token")
  usedAt             DateTime? @map("used_at")
  expiresAt          DateTime  @map("expires_at")
  createdAt          DateTime  @default(now()) @map("created_at")

  franchisePartner FranchisePartner @relation(fields: [franchisePartnerId], references: [id], onDelete: Cascade)

  @@index([franchisePartnerId])
  /// Phase 20 (2026-05-20) — every OTP lookup queries by (partnerId,
  /// purpose, status). Composite index removes the full-scan over a
  /// franchise's OTP history.
  @@index([franchisePartnerId, purpose])
  /// Phase 20 (2026-05-20) — expiry-sweep job predicate.
  @@index([expiresAt])
  @@map("franchise_password_reset_otps")
}

// ── Catalog Mapping (global SKU → franchise local SKU) ─────

model FranchiseCatalogMapping {
  id                           String                @id @default(uuid())
  franchiseId                  String                @map("franchise_id")
  productId                    String                @map("product_id")
  variantId                    String?               @map("variant_id")
  globalSku                    String                @map("global_sku")
  franchiseSku                 String?               @map("franchise_sku")
  barcode                      String?
  isListedForOnlineFulfillment Boolean               @default(true) @map("is_listed_for_online_fulfillment")
  isActive                     Boolean               @default(true) @map("is_active")
  approvalStatus               MappingApprovalStatus @default(PENDING_APPROVAL) @map("approval_status")
  // Phase 159n (audit #5) — admin-decision actor/reason attribution. The
  // status column carries the current value; these record who/when/why so a
  // REJECTED/STOPPED mapping is explicable to the franchise + auditors.
  approvedById      String?   @map("approved_by_id")
  approvedAt        DateTime? @map("approved_at")
  rejectedById      String?   @map("rejected_by_id")
  rejectedAt        DateTime? @map("rejected_at")
  rejectionReason   String?   @map("rejection_reason")
  stoppedById       String?   @map("stopped_by_id")
  stoppedAt         DateTime? @map("stopped_at")
  stopReason        String?   @map("stop_reason")
  removedById       String?   @map("removed_by_id")
  removedAt         DateTime? @map("removed_at")
  // Optimistic-concurrency token; bumped on every admin decision / franchise
  // edit so a concurrent approve-vs-edit can't silently clobber.
  version           Int       @default(0)
  createdAt                    DateTime              @default(now()) @map("created_at")
  updatedAt                    DateTime              @updatedAt @map("updated_at")

  franchise FranchisePartner @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant?  @relation(fields: [variantId], references: [id])

  @@unique([franchiseId, productId, variantId])
  @@index([franchiseId, isActive])
  @@index([productId])
  @@index([approvalStatus])
  // Phase 159n — per-franchise "my pending mappings" query + the
  // variant-soft-delete cleanup handler's updateMany WHERE variantId.
  @@index([franchiseId, approvalStatus])
  @@index([variantId])
  @@map("franchise_catalog_mappings")
}

// Phase 159n (audit #5/#10-history) — append-only catalog-mapping decision
// trail (created / edited-resubmitted / approved / rejected / stopped /
// removed). Mirrors the other franchise lifecycle history tables.
model FranchiseCatalogMappingEvent {
  id          String   @id @default(uuid())
  mappingId   String?  @map("mapping_id")
  franchiseId String   @map("franchise_id")
  productId   String   @map("product_id")
  variantId   String?  @map("variant_id")
  // CREATED | EDITED_RESUBMITTED | APPROVED | REJECTED | STOPPED | REMOVED
  action      String
  reason      String?
  actorId     String?  @map("actor_id")
  actorRole   String   @map("actor_role") // ADMIN | FRANCHISE
  createdAt   DateTime @default(now()) @map("created_at")

  franchise FranchisePartner @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  @@index([franchiseId, createdAt])
  @@index([mappingId])
  @@map("franchise_catalog_mapping_events")
}

// ── Franchise Stock (computed snapshot) ─────────────────────

model FranchiseStock {
  id           String  @id @default(uuid())
  franchiseId  String  @map("franchise_id")
  productId    String  @map("product_id")
  variantId    String? @map("variant_id")
  globalSku    String  @map("global_sku")
  franchiseSku String? @map("franchise_sku")

  onHandQty         Int @default(0) @map("on_hand_qty")
  reservedQty       Int @default(0) @map("reserved_qty")
  availableQty      Int @default(0) @map("available_qty")
  damagedQty        Int @default(0) @map("damaged_qty")
  inTransitQty      Int @default(0) @map("in_transit_qty")
  lowStockThreshold Int @default(5) @map("low_stock_threshold")

  lastRestockedAt DateTime? @map("last_restocked_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  franchise FranchisePartner @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  @@unique([franchiseId, productId, variantId])
  @@index([franchiseId, availableQty])
  @@index([franchiseId])
  @@index([productId])
  @@map("franchise_stock")
}

// ── Franchise Inventory Ledger (immutable movements) ───────

model FranchiseInventoryLedger {
  id            String                @id @default(uuid())
  franchiseId   String                @map("franchise_id")
  productId     String                @map("product_id")
  variantId     String?               @map("variant_id")
  globalSku     String                @map("global_sku")
  movementType  InventoryMovementType @map("movement_type")
  quantityDelta Int                   @map("quantity_delta")
  referenceType String                @map("reference_type") // ORDER, PROCUREMENT, POS_SALE, MANUAL
  referenceId   String?               @map("reference_id")
  remarks       String?
  beforeQty     Int                   @map("before_qty")
  afterQty      Int                   @map("after_qty")
  actorType     String                @map("actor_type") // SYSTEM, ADMIN, FRANCHISE_OWNER, STAFF
  actorId       String?               @map("actor_id")
  createdAt     DateTime              @default(now()) @map("created_at")

  franchise FranchisePartner @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  @@index([franchiseId, productId])
  @@index([referenceType, referenceId])
  @@index([createdAt])
  @@index([movementType])
  @@map("franchise_inventory_ledger")
}

// ── Procurement (franchise stock replenishment) ────────────

model ProcurementRequest {
  id            String            @id @default(uuid())
  requestNumber String            @unique @map("request_number")
  franchiseId   String            @map("franchise_id")
  status        ProcurementStatus @default(DRAFT)

  totalRequestedAmount Decimal @default(0) @map("total_requested_amount") @db.Decimal(12, 2)
  totalApprovedAmount  Decimal @default(0) @map("total_approved_amount") @db.Decimal(12, 2)
  procurementFeeRate   Decimal @default(5) @map("procurement_fee_rate") @db.Decimal(5, 2)
  procurementFeeAmount Decimal @default(0) @map("procurement_fee_amount") @db.Decimal(12, 2)
  finalPayableAmount   Decimal @default(0) @map("final_payable_amount") @db.Decimal(12, 2)

  requestedAt  DateTime? @map("requested_at")
  approvedAt   DateTime? @map("approved_at")
  approvedBy   String?   @map("approved_by")
  dispatchedAt DateTime? @map("dispatched_at")
  receivedAt   DateTime? @map("received_at")
  settledAt    DateTime? @map("settled_at")

  /// Phase 7 (2026-05-16) — SLA timestamps. `slaApproveBy` is set on
  /// `submitRequest` to `requestedAt + PROCUREMENT_APPROVAL_SLA_HOURS`
  /// (default 48h). The breach cron emits `procurement.sla_breached`
  /// for requests still SUBMITTED past their deadline; ops can see
  /// from `slaBreachedAt` which were already notified so we don't
  /// re-notify on every tick.
  slaApproveBy  DateTime? @map("sla_approve_by")
  slaBreachedAt DateTime? @map("sla_breached_at")

  // Shipment tracking — captured by admin on /dispatch so the franchise can
  // answer "where is my shipment?" without a support ping.
  trackingNumber     String?   @map("tracking_number")
  carrierName        String?   @map("carrier_name")
  expectedDeliveryAt DateTime? @map("expected_delivery_at")

  // Rejection reason separated from `notes` so the audit trail stays clean.
  // `notes` stays for free-form commentary from either side.
  rejectionReason String? @map("rejection_reason")

  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  franchise FranchisePartner         @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  items     ProcurementRequestItem[]
  events    ProcurementRequestEvent[]

  @@index([franchiseId, status])
  @@index([status])
  @@index([requestNumber])
  @@index([status, slaApproveBy])
  @@map("procurement_requests")
}

/// Phase 159p (audit #12 + audit-trail gap) — append-only transition history
/// for a procurement request. Pre-159p only a single `approvedBy` column
/// existed, so "who submitted / dispatched / received / settled / cancelled
/// this, and when" was unanswerable. One row per status transition.
model ProcurementRequestEvent {
  id                   String   @id @default(uuid())
  procurementRequestId String   @map("procurement_request_id")
  // SUBMITTED | APPROVED | PARTIALLY_APPROVED | REJECTED | DISPATCHED |
  // RECEIVED | PARTIALLY_RECEIVED | SETTLED | CANCELLED
  action               String
  fromStatus           String?  @map("from_status")
  toStatus             String   @map("to_status")
  actorId              String?  @map("actor_id")
  actorType            String   @map("actor_type") // ADMIN | FRANCHISE | SYSTEM
  reason               String?
  createdAt            DateTime @default(now()) @map("created_at")

  request ProcurementRequest @relation(fields: [procurementRequestId], references: [id], onDelete: Cascade)

  @@index([procurementRequestId, createdAt])
  @@map("procurement_request_events")
}

model ProcurementRequestItem {
  id                   String                @id @default(uuid())
  procurementRequestId String                @map("procurement_request_id")
  productId            String                @map("product_id")
  variantId            String?               @map("variant_id")
  globalSku            String                @map("global_sku")
  productTitle         String                @default("") @map("product_title")
  variantTitle         String?               @map("variant_title")
  status               ProcurementItemStatus @default(PENDING)

  requestedQty  Int @map("requested_qty")
  approvedQty   Int @default(0) @map("approved_qty")
  sourcedQty    Int @default(0) @map("sourced_qty")
  dispatchedQty Int @default(0) @map("dispatched_qty")
  receivedQty   Int @default(0) @map("received_qty")
  damagedQty    Int @default(0) @map("damaged_qty")

  sourceSellerId           String?  @map("source_seller_id")
  landedUnitCost           Decimal? @map("landed_unit_cost") @db.Decimal(10, 2)
  procurementFeePerUnit    Decimal? @map("procurement_fee_per_unit") @db.Decimal(10, 2)
  finalUnitCostToFranchise Decimal? @map("final_unit_cost_to_franchise") @db.Decimal(10, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  procurementRequest ProcurementRequest @relation(fields: [procurementRequestId], references: [id], onDelete: Cascade)

  @@index([procurementRequestId])
  @@map("procurement_request_items")
}

model ProcurementSequence {
  id         Int @id @default(1)
  lastNumber Int @default(0) @map("last_number")

  @@map("procurement_sequences")
}

// ── POS Sales (offline/walk-in tracking) ───────────────────

model FranchisePosSale {
  id            String  @id @default(uuid())
  saleNumber    String  @unique @map("sale_number")
  franchiseId   String  @map("franchise_id")
  saleType      PosSaleType @default(WALK_IN) @map("sale_type")
  customerName  String?     @map("customer_name")
  customerPhone String?     @map("customer_phone")

  grossAmount    Decimal @map("gross_amount") @db.Decimal(10, 2)
  discountAmount Decimal @default(0) @map("discount_amount") @db.Decimal(10, 2)
  taxAmount      Decimal @default(0) @map("tax_amount") @db.Decimal(10, 2)
  netAmount      Decimal @map("net_amount") @db.Decimal(10, 2)

  // Phase 26 GST (POS) — sale-level CGST/SGST snapshot. POS sales are
  // always intra-state (walk-in customer at franchise location) so IGST
  // is always 0 today; the column is kept for shape parity with
  // tax_documents.cgst/sgst/igst in case of future PHONE_ORDER cross-
  // state delivery. Sum across items equals these.
  cgstAmount         Decimal @default(0) @map("cgst_amount") @db.Decimal(10, 2)
  sgstAmount         Decimal @default(0) @map("sgst_amount") @db.Decimal(10, 2)
  igstAmount         Decimal @default(0) @map("igst_amount") @db.Decimal(10, 2)
  // 2-digit GSTIN state code at the time of sale (e.g. 36 = Telangana).
  // Snapshotted so a later franchise relocation doesn't rewrite history.
  placeOfSupplyState String? @map("place_of_supply_state")

  paymentMethod PosPaymentMethod @default(CASH) @map("payment_method")
  status        PosSaleStatus    @default(COMPLETED)

  // Phase 159q (audit #6) — payment settlement state + reference. Physical-POS
  // sales are COMPLETED on record; an integrated gateway (follow-up) would set
  // PENDING and flip via webhook. paymentReference holds the UPI txn id / card
  // auth code when supplied.
  paymentStatus    PosPaymentStatus    @default(COMPLETED) @map("payment_status")
  paymentReference String?             @map("payment_reference")
  paymentSettledAt DateTime?           @map("payment_settled_at")

  // Phase 159q (audit #10) — tax-invoice generation state (was log-only).
  taxInvoiceStatus PosTaxInvoiceStatus @default(PENDING) @map("tax_invoice_status")
  taxInvoiceId     String?             @map("tax_invoice_id")

  // Phase 159q (audit #13) — commission rate snapshotted at sale time so a
  // cross-cycle return reverses at the ORIGINAL rate, not today's.
  commissionRate Decimal? @map("commission_rate") @db.Decimal(5, 2)

  // Phase 159r (POS void/return audit #11) — total refunded back to the
  // customer across all returns of this sale, so "sales with refund > X" is
  // answerable without aggregating the ledger.
  refundedAmount Decimal @default(0) @map("refunded_amount") @db.Decimal(10, 2)

  soldAt           DateTime  @default(now()) @map("sold_at")
  createdByStaffId String?   @map("created_by_staff_id")
  voidedAt         DateTime? @map("voided_at")
  voidReason       String?   @map("void_reason")
  // Phase 159r (audit #10) — void/return actor + return audit columns.
  voidedBy         String?   @map("voided_by")
  returnedAt       DateTime? @map("returned_at")
  returnedBy       String?   @map("returned_by")
  returnReason     String?   @map("return_reason")
  createdAt        DateTime  @default(now()) @map("created_at")

  franchise FranchisePartner       @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  items     FranchisePosSaleItem[]
  returns   FranchisePosReturn[]

  @@index([franchiseId, soldAt])
  @@index([status])
  @@index([saleNumber])
  // Phase 159q (audit #15) — daily report groups by paymentMethod.
  @@index([franchiseId, paymentMethod, soldAt])
  // Phase 159s (POS report audit) — void/return count queries filter on status
  // within the day range.
  @@index([franchiseId, status, soldAt])
  @@map("franchise_pos_sales")
}

/// Phase 159r (POS void/return audit #6) — a customer return as a first-class
/// record, not just a status flip on the sale. One row per return event; a sale
/// can have several (partial returns). Anchors the refund + (future) credit note.
model FranchisePosReturn {
  id              String          @id @default(uuid())
  returnNumber    String          @unique @map("return_number")
  saleId          String          @map("sale_id")
  franchiseId     String          @map("franchise_id")
  refundAmount    Decimal         @map("refund_amount") @db.Decimal(10, 2)
  refundMethod    PosRefundMethod @map("refund_method")
  refundReference String?         @map("refund_reference")
  returnReason    String?         @map("return_reason")
  returnedBy      String?         @map("returned_by")
  returnedAt      DateTime        @default(now()) @map("returned_at")
  createdAt       DateTime        @default(now()) @map("created_at")

  sale  FranchisePosSale         @relation(fields: [saleId], references: [id], onDelete: Cascade)
  items FranchisePosReturnItem[]

  @@index([saleId])
  @@index([franchiseId, returnedAt])
  @@map("franchise_pos_returns")
}

model FranchisePosReturnItem {
  id         String                 @id @default(uuid())
  returnId   String                 @map("return_id")
  saleItemId String                 @map("sale_item_id")
  returnQty  Int                    @map("return_qty")
  condition  PosReturnItemCondition @default(SALEABLE)
  createdAt  DateTime               @default(now()) @map("created_at")

  posReturn FranchisePosReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@index([returnId])
  @@index([saleItemId])
  @@map("franchise_pos_return_items")
}

model FranchisePosSaleItem {
  id           String  @id @default(uuid())
  saleId       String  @map("sale_id")
  productId    String  @map("product_id")
  variantId    String? @map("variant_id")
  globalSku    String  @map("global_sku")
  franchiseSku String? @map("franchise_sku")
  productTitle String  @map("product_title")
  variantTitle String? @map("variant_title")
  quantity     Int
  // Phase 159r (POS void/return audit #1) — cumulative units returned across ALL
  // return rounds. The over-return guard checks returnedQty + thisReturn <=
  // quantity; pre-159r only the per-call qty was checked against the original,
  // so 5+5+5 against a 5-unit line slipped through.
  returnedQty  Int     @default(0) @map("returned_qty")
  unitPrice    Decimal @map("unit_price") @db.Decimal(10, 2)
  lineDiscount Decimal @default(0) @map("line_discount") @db.Decimal(10, 2)
  lineTotal    Decimal @map("line_total") @db.Decimal(10, 2)

  // Phase 26 GST (POS) — per-item tax snapshot. Snapshotted at sale time
  // so later catalog HSN / rate changes don't rewrite history. Pricing
  // mode for POS is always INCLUSIVE (retail price quotes include GST).
  // gstRateBps stored as basis points (1800 = 18%) for arithmetic
  // precision; matches OrderItemTaxSnapshot convention.
  hsnCode       String? @map("hsn_code")
  gstRateBps    Int     @default(0) @map("gst_rate_bps")
  taxableAmount Decimal @default(0) @map("taxable_amount") @db.Decimal(10, 2)
  cgstAmount    Decimal @default(0) @map("cgst_amount") @db.Decimal(10, 2)
  sgstAmount    Decimal @default(0) @map("sgst_amount") @db.Decimal(10, 2)
  igstAmount    Decimal @default(0) @map("igst_amount") @db.Decimal(10, 2)

  createdAt DateTime @default(now()) @map("created_at")

  sale FranchisePosSale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@map("franchise_pos_sale_items")
}

model PosSaleSequence {
  id         Int @id @default(1)
  lastNumber Int @default(0) @map("last_number")

  @@map("pos_sale_sequences")
}

// Monotonic sequence for franchise partner codes (SM-FR-XXXXXX). Replaces
// the count()+1 pattern which broke after any soft-delete by recycling
// numbers and producing collisions.
model FranchiseCodeSequence {
  id         Int @id @default(1)
  lastNumber Int @default(0) @map("last_number")

  @@map("franchise_code_sequences")
}

// ── Finance Ledger (franchise commission tracking) ─────────

model FranchiseFinanceLedger {
  id          String                @id @default(uuid())
  franchiseId String                @map("franchise_id")
  sourceType  FranchiseLedgerSource @map("source_type")
  sourceId    String                @map("source_id")
  description String?

  baseAmount     Decimal @map("base_amount") @db.Decimal(12, 2)
  rate           Decimal @db.Decimal(5, 2)
  computedAmount Decimal @map("computed_amount") @db.Decimal(12, 2)

  platformEarning  Decimal @default(0) @map("platform_earning") @db.Decimal(12, 2)
  franchiseEarning Decimal @default(0) @map("franchise_earning") @db.Decimal(12, 2)

  status            FranchiseLedgerStatus @default(PENDING)
  settlementBatchId String?               @map("settlement_batch_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  franchise       FranchisePartner     @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  settlementBatch FranchiseSettlement? @relation(fields: [settlementBatchId], references: [id])

  @@index([franchiseId, status])
  @@index([sourceType, sourceId])
  @@index([settlementBatchId])
  @@index([createdAt])
  @@map("franchise_finance_ledger")
}

// ── Franchise Settlement (payout cycles) ───────────────────

model FranchiseSettlement {
  id            String @id @default(uuid())
  cycleId       String @map("cycle_id")
  franchiseId   String @map("franchise_id")
  franchiseName String @map("franchise_name")

  totalOnlineOrders     Int     @default(0) @map("total_online_orders")
  totalOnlineAmount     Decimal @default(0) @map("total_online_amount") @db.Decimal(12, 2)
  totalOnlineCommission Decimal @default(0) @map("total_online_commission") @db.Decimal(12, 2)

  totalProcurements      Int     @default(0) @map("total_procurements")
  totalProcurementAmount Decimal @default(0) @map("total_procurement_amount") @db.Decimal(12, 2)
  totalProcurementFees   Decimal @default(0) @map("total_procurement_fees") @db.Decimal(12, 2)

  totalPosSales  Int     @default(0) @map("total_pos_sales")
  totalPosAmount Decimal @default(0) @map("total_pos_amount") @db.Decimal(12, 2)
  totalPosFees   Decimal @default(0) @map("total_pos_fees") @db.Decimal(12, 2)

  reversalAmount   Decimal @default(0) @map("reversal_amount") @db.Decimal(12, 2)
  adjustmentAmount Decimal @default(0) @map("adjustment_amount") @db.Decimal(12, 2)

  grossFranchiseEarning Decimal @default(0) @map("gross_franchise_earning") @db.Decimal(12, 2)
  totalPlatformEarning  Decimal @default(0) @map("total_platform_earning") @db.Decimal(12, 2)
  netPayableToFranchise Decimal @default(0) @map("net_payable_to_franchise") @db.Decimal(12, 2)

  status           FranchiseSettlementStatus @default(PENDING)
  paidAt           DateTime?                 @map("paid_at")
  paymentReference String?                   @map("payment_reference")
  // Phase 146 — payout provenance (mirrors SellerSettlement.paidByAdminId).
  paidByAdminId    String?                   @map("paid_by_admin_id")
  createdAt        DateTime                  @default(now()) @map("created_at")
  updatedAt        DateTime                  @updatedAt @map("updated_at")

  cycle         SettlementCycle          @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  franchise     FranchisePartner         @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  ledgerEntries FranchiseFinanceLedger[]
  paidByAdmin   Admin?                   @relation("FranchiseSettlementPaidBy", fields: [paidByAdminId], references: [id], onDelete: SetNull)

  @@unique([cycleId, franchiseId])
  @@index([cycleId])
  @@index([franchiseId])
  @@index([status])
  @@map("franchise_settlements")
}

// ── Franchise Staff ───────────────────────────────────────────

model FranchiseStaff {
  id    String @id @default(uuid())
  franchiseId String @map("franchise_id")
  name  String
  // Phase 159t (staff audit #5/#6) — email is NO LONGER globally unique (that
  // leaked existence across franchises + blocked multi-franchise employees +
  // orphaned soft-deleted rows). Uniqueness is now a PARTIAL unique index
  // (franchise_id, email) WHERE status <> 'TERMINATED', defined in the
  // migration (Prisma can't express partial uniques). Same for phone (#16).
  email String
  phone String?
  // Phase 159u (staff-auth B4) — nullable: an INVITED staff has no password
  // until they activate via the emailed invite token + set their own.
  passwordHash String? @map("password_hash")
  role  FranchiseStaffRole   @default(POS_OPERATOR)
  // Phase 159t (audit #12) — richer lifecycle than the isActive boolean.
  // isActive is kept (synced) for back-compat with existing reads.
  status   FranchiseStaffStatus @default(ACTIVE)
  isActive Boolean              @default(true) @map("is_active")

  // Phase 159u (staff-auth B2) — per-staff permission overrides on top of the
  // role defaults (resolveStaffPermissions). Null = pure role defaults.
  permissions Json? @map("permissions")
  // Phase 159u (staff-auth B4) — invitation/activation. SHA-256(token).
  inviteTokenHash String?   @map("invite_token_hash")
  inviteExpiresAt DateTime? @map("invite_expires_at")

  // Phase 159t (audit #8/#15) — lifecycle audit + activity columns.
  createdBy        String?   @map("created_by")
  suspendedBy      String?   @map("suspended_by")
  suspendedAt      DateTime? @map("suspended_at")
  suspensionReason String?   @map("suspension_reason")
  lastLoginAt      DateTime? @map("last_login_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  franchise FranchisePartner       @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  sessions  FranchiseStaffSession[]

  @@index([franchiseId, isActive])
  @@index([franchiseId, status])
  @@index([inviteTokenHash])
  @@map("franchise_staff")
}

/// Phase 159u (staff-auth B1) — staff refresh-session, mirroring
/// FranchiseSession. `refreshToken` stores SHA-256(rawToken), never plaintext.
/// Rotated on refresh; revoked on logout and on suspend/terminate.
model FranchiseStaffSession {
  id           String    @id @default(uuid())
  staffId      String    @map("staff_id")
  refreshToken String    @map("refresh_token")
  userAgent    String?   @map("user_agent")
  ipAddress    String?   @map("ip_address")
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  lastUsedAt   DateTime? @map("last_used_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  staff FranchiseStaff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([refreshToken])
  @@index([staffId, revokedAt])
  @@map("franchise_staff_sessions")
}
