// ============================================
// Franchise Module - owned tables
// ============================================

model FranchisePartner {
  id                String                      @id @default(uuid())
  franchiseCode     String                      @unique @map("franchise_code")
  ownerName         String                      @map("owner_name")
  businessName      String                      @map("business_name")
  email             String                      @unique
  phoneNumber       String                      @unique @map("phone_number")
  passwordHash      String                      @map("password_hash")
  status            FranchiseStatus              @default(PENDING)
  verificationStatus FranchiseVerificationStatus @default(NOT_VERIFIED) @map("verification_status")

  // Login tracking
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockUntil           DateTime? @map("lock_until")
  lastLoginAt         DateTime? @map("last_login_at")

  // Location
  state    String?
  city     String?
  address  String?
  pincode  String?
  locality String?
  country  String?

  // Compliance
  gstNumber String? @map("gst_number")
  panNumber String? @map("pan_number")

  // Commission rates (per-franchise configurable)
  onlineFulfillmentRate Decimal @default(15) @map("online_fulfillment_rate") @db.Decimal(5, 2)
  procurementFeeRate    Decimal @default(5)  @map("procurement_fee_rate")   @db.Decimal(5, 2)

  // Contract
  contractStartDate DateTime? @map("contract_start_date")
  contractEndDate   DateTime? @map("contract_end_date")

  // Warehouse
  warehouseAddress String? @map("warehouse_address")
  warehousePincode String? @map("warehouse_pincode")

  // Profile & branding
  profileImageUrl             String?  @map("profile_image_url")
  profileImagePublicId        String?  @map("profile_image_public_id")
  logoUrl                     String?  @map("logo_url")
  logoPublicId                String?  @map("logo_public_id")
  assignedZone                String?  @map("assigned_zone")
  profileCompletionPercentage Int      @default(0) @map("profile_completion_percentage")
  isProfileCompleted          Boolean  @default(false) @map("is_profile_completed")
  isEmailVerified             Boolean  @default(false) @map("is_email_verified")

  // Soft delete
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  sessions          FranchiseSession[]
  passwordResetOtps FranchisePasswordResetOtp[]
  catalogMappings   FranchiseCatalogMapping[]
  stock               FranchiseStock[]
  inventoryLedger     FranchiseInventoryLedger[]
  subOrders           SubOrder[]
  procurementRequests ProcurementRequest[]
  posSales            FranchisePosSale[]
  financeLedger       FranchiseFinanceLedger[]
  settlements         FranchiseSettlement[]
  staff               FranchiseStaff[]
  procurementPrices   FranchiseProcurementPrice[]

  @@index([status])
  @@index([isProfileCompleted])
  @@index([assignedZone])
  @@index([state])
  @@index([email])
  @@index([phoneNumber])
  @@index([isDeleted])
  @@index([verificationStatus])
  // Scanned every hour by FranchiseReservationCleanupService.checkExpiredContracts
  // (status=ACTIVE, contractEndDate<now). Without this index the sweep
  // does a seq scan on the whole franchise table.
  @@index([contractEndDate])
  @@map("franchise_partners")
}

// Per-franchise negotiated procurement price. When a row exists for
// (franchise, product, variant), the procurement approval modal
// pre-fills landedUnitCost from this table instead of the
// variant-level default (ProductVariant.costPrice). Write-back on
// approval targets this row so subsequent approvals for the same
// franchise + SKU keep its negotiated price, while other franchises
// continue to default to the platform-wide cost.
//
// variantId is nullable for product-level mappings (rare).
model FranchiseProcurementPrice {
  id              String   @id @default(uuid())
  franchiseId     String   @map("franchise_id")
  productId       String   @map("product_id")
  variantId       String?  @map("variant_id")
  landedUnitCost  Decimal  @map("landed_unit_cost") @db.Decimal(10, 2)
  notes           String?
  createdBy       String?  @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  franchise FranchisePartner @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  @@unique([franchiseId, productId, variantId])
  @@index([franchiseId])
  @@map("franchise_procurement_prices")
}

model FranchiseSession {
  id                 String    @id @default(uuid())
  franchisePartnerId String    @map("franchise_partner_id")
  refreshToken       String    @map("refresh_token")
  userAgent          String?   @map("user_agent")
  ipAddress          String?   @map("ip_address")
  expiresAt          DateTime  @map("expires_at")
  revokedAt          DateTime? @map("revoked_at")
  createdAt          DateTime  @default(now()) @map("created_at")

  franchisePartner FranchisePartner @relation(fields: [franchisePartnerId], references: [id], onDelete: Cascade)

  @@index([franchisePartnerId])
  @@index([refreshToken])
  @@map("franchise_sessions")
}

model FranchisePasswordResetOtp {
  id                 String    @id @default(uuid())
  franchisePartnerId String    @map("franchise_partner_id")
  otpHash            String    @map("otp_hash")
  purpose            String    @default("PASSWORD_RESET")
  attempts           Int       @default(0)
  maxAttempts        Int       @default(5) @map("max_attempts")
  verifiedAt         DateTime? @map("verified_at")
  resetToken         String?   @unique @map("reset_token")
  usedAt             DateTime? @map("used_at")
  expiresAt          DateTime  @map("expires_at")
  createdAt          DateTime  @default(now()) @map("created_at")

  franchisePartner FranchisePartner @relation(fields: [franchisePartnerId], references: [id], onDelete: Cascade)

  @@index([franchisePartnerId])
  @@map("franchise_password_reset_otps")
}

// ── Catalog Mapping (global SKU → franchise local SKU) ─────

model FranchiseCatalogMapping {
  id                          String                @id @default(uuid())
  franchiseId                 String                @map("franchise_id")
  productId                   String                @map("product_id")
  variantId                   String?               @map("variant_id")
  globalSku                   String                @map("global_sku")
  franchiseSku                String?               @map("franchise_sku")
  barcode                     String?
  isListedForOnlineFulfillment Boolean              @default(true) @map("is_listed_for_online_fulfillment")
  isActive                    Boolean               @default(true) @map("is_active")
  approvalStatus              MappingApprovalStatus  @default(PENDING_APPROVAL) @map("approval_status")
  createdAt                   DateTime              @default(now()) @map("created_at")
  updatedAt                   DateTime              @updatedAt @map("updated_at")

  franchise FranchisePartner @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant?  @relation(fields: [variantId], references: [id])

  @@unique([franchiseId, productId, variantId])
  @@index([franchiseId, isActive])
  @@index([productId])
  @@index([approvalStatus])
  @@map("franchise_catalog_mappings")
}

// ── Franchise Stock (computed snapshot) ─────────────────────

model FranchiseStock {
  id                String   @id @default(uuid())
  franchiseId       String   @map("franchise_id")
  productId         String   @map("product_id")
  variantId         String?  @map("variant_id")
  globalSku         String   @map("global_sku")
  franchiseSku      String?  @map("franchise_sku")

  onHandQty         Int      @default(0) @map("on_hand_qty")
  reservedQty       Int      @default(0) @map("reserved_qty")
  availableQty      Int      @default(0) @map("available_qty")
  damagedQty        Int      @default(0) @map("damaged_qty")
  inTransitQty      Int      @default(0) @map("in_transit_qty")
  lowStockThreshold Int      @default(5) @map("low_stock_threshold")

  lastRestockedAt   DateTime? @map("last_restocked_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  franchise FranchisePartner @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  @@unique([franchiseId, productId, variantId])
  @@index([franchiseId, availableQty])
  @@index([franchiseId])
  @@index([productId])
  @@map("franchise_stock")
}

// ── Franchise Inventory Ledger (immutable movements) ───────

model FranchiseInventoryLedger {
  id            String                @id @default(uuid())
  franchiseId   String                @map("franchise_id")
  productId     String                @map("product_id")
  variantId     String?               @map("variant_id")
  globalSku     String                @map("global_sku")
  movementType  InventoryMovementType @map("movement_type")
  quantityDelta Int                   @map("quantity_delta")
  referenceType String                @map("reference_type") // ORDER, PROCUREMENT, POS_SALE, MANUAL
  referenceId   String?               @map("reference_id")
  remarks       String?
  beforeQty     Int                   @map("before_qty")
  afterQty      Int                   @map("after_qty")
  actorType     String                @map("actor_type") // SYSTEM, ADMIN, FRANCHISE_OWNER, STAFF
  actorId       String?               @map("actor_id")
  createdAt     DateTime              @default(now()) @map("created_at")

  franchise FranchisePartner @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  @@index([franchiseId, productId])
  @@index([referenceType, referenceId])
  @@index([createdAt])
  @@index([movementType])
  @@map("franchise_inventory_ledger")
}

// ── Procurement (franchise stock replenishment) ────────────

model ProcurementRequest {
  id                    String            @id @default(uuid())
  requestNumber         String            @unique @map("request_number")
  franchiseId           String            @map("franchise_id")
  status                ProcurementStatus @default(DRAFT)

  totalRequestedAmount  Decimal           @default(0) @map("total_requested_amount") @db.Decimal(12, 2)
  totalApprovedAmount   Decimal           @default(0) @map("total_approved_amount") @db.Decimal(12, 2)
  procurementFeeRate    Decimal           @default(5) @map("procurement_fee_rate") @db.Decimal(5, 2)
  procurementFeeAmount  Decimal           @default(0) @map("procurement_fee_amount") @db.Decimal(12, 2)
  finalPayableAmount    Decimal           @default(0) @map("final_payable_amount") @db.Decimal(12, 2)

  requestedAt           DateTime?         @map("requested_at")
  approvedAt            DateTime?         @map("approved_at")
  approvedBy            String?           @map("approved_by")
  dispatchedAt          DateTime?         @map("dispatched_at")
  receivedAt            DateTime?         @map("received_at")
  settledAt             DateTime?         @map("settled_at")

  // Shipment tracking — captured by admin on /dispatch so the franchise can
  // answer "where is my shipment?" without a support ping.
  trackingNumber        String?           @map("tracking_number")
  carrierName           String?           @map("carrier_name")
  expectedDeliveryAt    DateTime?         @map("expected_delivery_at")

  // Rejection reason separated from `notes` so the audit trail stays clean.
  // `notes` stays for free-form commentary from either side.
  rejectionReason       String?           @map("rejection_reason")

  notes                 String?
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  franchise FranchisePartner       @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  items     ProcurementRequestItem[]

  @@index([franchiseId, status])
  @@index([status])
  @@index([requestNumber])
  @@map("procurement_requests")
}

model ProcurementRequestItem {
  id                       String                @id @default(uuid())
  procurementRequestId     String                @map("procurement_request_id")
  productId                String                @map("product_id")
  variantId                String?               @map("variant_id")
  globalSku                String                @map("global_sku")
  productTitle             String                @default("") @map("product_title")
  variantTitle             String?               @map("variant_title")
  status                   ProcurementItemStatus @default(PENDING)

  requestedQty             Int                   @map("requested_qty")
  approvedQty              Int                   @default(0) @map("approved_qty")
  sourcedQty               Int                   @default(0) @map("sourced_qty")
  dispatchedQty            Int                   @default(0) @map("dispatched_qty")
  receivedQty              Int                   @default(0) @map("received_qty")
  damagedQty               Int                   @default(0) @map("damaged_qty")

  sourceSellerId           String?               @map("source_seller_id")
  landedUnitCost           Decimal?              @map("landed_unit_cost") @db.Decimal(10, 2)
  procurementFeePerUnit    Decimal?              @map("procurement_fee_per_unit") @db.Decimal(10, 2)
  finalUnitCostToFranchise Decimal?              @map("final_unit_cost_to_franchise") @db.Decimal(10, 2)

  createdAt                DateTime              @default(now()) @map("created_at")
  updatedAt                DateTime              @updatedAt @map("updated_at")

  procurementRequest ProcurementRequest @relation(fields: [procurementRequestId], references: [id], onDelete: Cascade)

  @@index([procurementRequestId])
  @@map("procurement_request_items")
}

model ProcurementSequence {
  id         Int @id @default(1)
  lastNumber Int @default(0) @map("last_number")

  @@map("procurement_sequences")
}

// ── POS Sales (offline/walk-in tracking) ───────────────────

model FranchisePosSale {
  id              String        @id @default(uuid())
  saleNumber      String        @unique @map("sale_number")
  franchiseId     String        @map("franchise_id")
  saleType        String        @default("WALK_IN") @map("sale_type") // WALK_IN, PHONE_ORDER, LOCAL_DELIVERY
  customerName    String?       @map("customer_name")
  customerPhone   String?       @map("customer_phone")

  grossAmount     Decimal       @map("gross_amount") @db.Decimal(10, 2)
  discountAmount  Decimal       @default(0) @map("discount_amount") @db.Decimal(10, 2)
  taxAmount       Decimal       @default(0) @map("tax_amount") @db.Decimal(10, 2)
  netAmount       Decimal       @map("net_amount") @db.Decimal(10, 2)

  paymentMethod   String        @default("CASH") @map("payment_method") // CASH, UPI, CARD
  status          PosSaleStatus @default(COMPLETED)

  soldAt          DateTime      @default(now()) @map("sold_at")
  createdByStaffId String?      @map("created_by_staff_id")
  voidedAt        DateTime?     @map("voided_at")
  voidReason      String?       @map("void_reason")
  createdAt       DateTime      @default(now()) @map("created_at")

  franchise FranchisePartner     @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  items     FranchisePosSaleItem[]

  @@index([franchiseId, soldAt])
  @@index([status])
  @@index([saleNumber])
  @@map("franchise_pos_sales")
}

model FranchisePosSaleItem {
  id           String  @id @default(uuid())
  saleId       String  @map("sale_id")
  productId    String  @map("product_id")
  variantId    String? @map("variant_id")
  globalSku    String  @map("global_sku")
  franchiseSku String? @map("franchise_sku")
  productTitle String  @map("product_title")
  variantTitle String? @map("variant_title")
  quantity     Int
  unitPrice    Decimal @map("unit_price") @db.Decimal(10, 2)
  lineDiscount Decimal @default(0) @map("line_discount") @db.Decimal(10, 2)
  lineTotal    Decimal @map("line_total") @db.Decimal(10, 2)
  createdAt    DateTime @default(now()) @map("created_at")

  sale FranchisePosSale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@map("franchise_pos_sale_items")
}

model PosSaleSequence {
  id         Int @id @default(1)
  lastNumber Int @default(0) @map("last_number")

  @@map("pos_sale_sequences")
}

// Monotonic sequence for franchise partner codes (SM-FR-XXXXXX). Replaces
// the count()+1 pattern which broke after any soft-delete by recycling
// numbers and producing collisions.
model FranchiseCodeSequence {
  id         Int @id @default(1)
  lastNumber Int @default(0) @map("last_number")

  @@map("franchise_code_sequences")
}

// ── Finance Ledger (franchise commission tracking) ─────────

model FranchiseFinanceLedger {
  id                 String                @id @default(uuid())
  franchiseId        String                @map("franchise_id")
  sourceType         FranchiseLedgerSource @map("source_type")
  sourceId           String                @map("source_id")
  description        String?

  baseAmount         Decimal               @map("base_amount") @db.Decimal(12, 2)
  rate               Decimal               @db.Decimal(5, 2)
  computedAmount     Decimal               @map("computed_amount") @db.Decimal(12, 2)

  platformEarning    Decimal               @default(0) @map("platform_earning") @db.Decimal(12, 2)
  franchiseEarning   Decimal               @default(0) @map("franchise_earning") @db.Decimal(12, 2)

  status             FranchiseLedgerStatus @default(PENDING)
  settlementBatchId  String?               @map("settlement_batch_id")

  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")

  franchise          FranchisePartner      @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  settlementBatch    FranchiseSettlement?  @relation(fields: [settlementBatchId], references: [id])

  @@index([franchiseId, status])
  @@index([sourceType, sourceId])
  @@index([settlementBatchId])
  @@index([createdAt])
  @@map("franchise_finance_ledger")
}

// ── Franchise Settlement (payout cycles) ───────────────────

model FranchiseSettlement {
  id                        String                     @id @default(uuid())
  cycleId                   String                     @map("cycle_id")
  franchiseId               String                     @map("franchise_id")
  franchiseName             String                     @map("franchise_name")

  totalOnlineOrders         Int                        @default(0) @map("total_online_orders")
  totalOnlineAmount         Decimal                    @default(0) @map("total_online_amount") @db.Decimal(12, 2)
  totalOnlineCommission     Decimal                    @default(0) @map("total_online_commission") @db.Decimal(12, 2)

  totalProcurements         Int                        @default(0) @map("total_procurements")
  totalProcurementAmount    Decimal                    @default(0) @map("total_procurement_amount") @db.Decimal(12, 2)
  totalProcurementFees      Decimal                    @default(0) @map("total_procurement_fees") @db.Decimal(12, 2)

  totalPosSales             Int                        @default(0) @map("total_pos_sales")
  totalPosAmount            Decimal                    @default(0) @map("total_pos_amount") @db.Decimal(12, 2)
  totalPosFees              Decimal                    @default(0) @map("total_pos_fees") @db.Decimal(12, 2)

  reversalAmount            Decimal                    @default(0) @map("reversal_amount") @db.Decimal(12, 2)
  adjustmentAmount          Decimal                    @default(0) @map("adjustment_amount") @db.Decimal(12, 2)

  grossFranchiseEarning     Decimal                    @default(0) @map("gross_franchise_earning") @db.Decimal(12, 2)
  totalPlatformEarning      Decimal                    @default(0) @map("total_platform_earning") @db.Decimal(12, 2)
  netPayableToFranchise     Decimal                    @default(0) @map("net_payable_to_franchise") @db.Decimal(12, 2)

  status                    FranchiseSettlementStatus  @default(PENDING)
  paidAt                    DateTime?                  @map("paid_at")
  paymentReference          String?                    @map("payment_reference")
  createdAt                 DateTime                   @default(now()) @map("created_at")
  updatedAt                 DateTime                   @updatedAt @map("updated_at")

  cycle                     SettlementCycle            @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  franchise                 FranchisePartner           @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  ledgerEntries             FranchiseFinanceLedger[]

  @@unique([cycleId, franchiseId])
  @@index([cycleId])
  @@index([franchiseId])
  @@index([status])
  @@map("franchise_settlements")
}

// ── Franchise Staff ───────────────────────────────────────────

model FranchiseStaff {
  id            String             @id @default(uuid())
  franchiseId   String             @map("franchise_id")
  name          String
  email         String             @unique
  phone         String?
  passwordHash  String             @map("password_hash")
  role          FranchiseStaffRole @default(POS_OPERATOR)
  isActive      Boolean            @default(true) @map("is_active")

  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  franchise FranchisePartner @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  @@index([franchiseId, isActive])
  @@index([email])
  @@map("franchise_staff")
}
