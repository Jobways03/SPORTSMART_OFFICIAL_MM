# ===========================================
# SPORTSMART API - Local Development
# ===========================================
#
# IMPORTANT: this file is committed to version control. NEVER put real
# credentials here. Copy it to `.env` and fill in real values locally.
# `.env` is gitignored.

NODE_ENV=development
PORT=8000

APP_NAME=sportsmart-api
APP_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:4000,http://localhost:4001,http://localhost:4002,http://localhost:4003,http://localhost:4004,http://localhost:4005

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sportsmart_dev?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# JWT — separate secret per actor type. Each must be at least 32 chars.
# Generate with: openssl rand -base64 32
JWT_CUSTOMER_SECRET=replace-me-with-a-strong-random-string-min32-chars
JWT_SELLER_SECRET=replace-me-with-a-strong-random-string-min32-chars
JWT_FRANCHISE_SECRET=replace-me-with-a-strong-random-string-min32-chars
JWT_ADMIN_SECRET=replace-me-with-a-strong-random-string-min32-chars
JWT_REFRESH_SECRET=replace-me-with-a-strong-random-string-min32-chars
JWT_ACCESS_TTL=1d
JWT_REFRESH_TTL=30d

# S3 (optional in dev)
S3_BUCKET=sportsmart-dev
S3_REGION=ap-south-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Razorpay (optional in dev)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# Shiprocket (optional in dev)
# SHIPROCKET_EMAIL=
# SHIPROCKET_PASSWORD=
# SHIPROCKET_WEBHOOK_TOKEN=

# OpenSearch (optional in dev)
# OPENSEARCH_NODE=http://localhost:9200

# Cloudinary (optional in dev)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Admin Seed (used by seed script — choose a strong password locally)
ADMIN_SEED_NAME=Super Admin
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=

# Commission — late-reversal guard. Reject return reversals that land more
# than this many days after the commission's settlement was paid out. Set
# to 0 to disable the guard.
COMMISSION_REVERSAL_WINDOW_DAYS=30

# Settlement cycle automation. When enabled, the API periodically rolls the
# next settlement cycle forward by SETTLEMENT_CYCLE_PERIOD_DAYS days as soon
# as each period has fully closed. Leave disabled in dev; turn on in prod.
SETTLEMENT_AUTO_CYCLE_ENABLED=false
SETTLEMENT_CYCLE_PERIOD_DAYS=7
SETTLEMENT_AUTO_CYCLE_INTERVAL_MINUTES=60

# Order acceptance SLA. If a seller/franchise doesn't accept a sub-order
# within this many minutes, the background job auto-rejects on their behalf
# and triggers re-routing. Set to 0 to disable.
ORDER_ACCEPTANCE_SLA_MINUTES=60
ORDER_ACCEPTANCE_SLA_CHECK_SECONDS=60

# Routing engine scoring weights (must sum to 1.0).
# Distance = closer node wins; Stock = fuller inventory wins; SLA = faster dispatch wins.
ROUTING_DISTANCE_WEIGHT=0.7
ROUTING_STOCK_WEIGHT=0.2
ROUTING_SLA_WEIGHT=0.1

# Refund processor. Polls Razorpay for pending refund statuses and auto-retries
# failed gateway calls. Set interval to 0 to disable.
REFUND_POLL_INTERVAL_SECONDS=120
REFUND_RETRY_BACKOFF_MINUTES=15

# Stale-return processor. Returns stuck beyond this many days in non-terminal
# states get auto-cancelled, auto-closed, or escalated to admin. Set to 0 to disable.
RETURN_STALE_DAYS=30
RETURN_STALE_CHECK_INTERVAL_MINUTES=60

# Payment poller. Checks Razorpay for orders stuck in PENDING_PAYMENT and
# auto-cancels orders past the payment window.
PAYMENT_POLL_INTERVAL_SECONDS=60
PAYMENT_WINDOW_MINUTES=30

# ─── AI (Google Gemini - FREE tier) ────────────────────
# Get your free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ─── Email (SMTP / Gmail App Password) ───────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=

# ─── WhatsApp (Meta Cloud API) ───────────────────────────
# WHATSAPP_API_URL=https://graph.facebook.com/v18.0
# WHATSAPP_API_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# Reverse-proxy hops to trust for req.ip (rate-limit keys on client IP).
# 0 = dev (no proxy). Set to 1 when behind a single ALB / nginx in prod.
TRUST_PROXY_HOPS=0
