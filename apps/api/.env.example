# ===========================================
# SPORTSMART API - Local Development
# ===========================================
#
# IMPORTANT: this file is committed to version control. NEVER put real
# credentials here. Copy it to `.env` and fill in real values locally.
# `.env` is gitignored.

NODE_ENV=development
PORT=8000

APP_NAME=sportsmart-api
APP_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:4000,http://localhost:4001,http://localhost:4002,http://localhost:4003,http://localhost:4004,http://localhost:4005,http://localhost:4006,http://localhost:4007,http://localhost:4008,http://localhost:4009

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sportsmart_dev?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# JWT — separate secret per actor type. Each must be at least 32 chars.
# In production, replace EVERY placeholder. The boot guard rejects
# placeholder secrets (`replace-me-…`) when NODE_ENV=production.
# Generate with: openssl rand -base64 32
JWT_CUSTOMER_SECRET=replace-me-with-a-strong-random-string-min32-chars
JWT_SELLER_SECRET=replace-me-with-a-strong-random-string-min32-chars
JWT_FRANCHISE_SECRET=replace-me-with-a-strong-random-string-min32-chars
JWT_ADMIN_SECRET=replace-me-with-a-strong-random-string-min32-chars
JWT_AFFILIATE_SECRET=replace-me-with-a-strong-random-string-min32-chars
JWT_REFRESH_SECRET=replace-me-with-a-strong-random-string-min32-chars

# Phase 10 — Admin MFA encryption key.
# 32-byte key for AES-256 encryption of admin TOTP secrets at rest.
# Generate with: openssl rand -hex 32
# REQUIRED in prod (PR 10.8 — listed in requiredInProd, so prod refuses
# to boot without it). The PR 10.6 login-challenge verify path reads
# this on every MFA-enrolled admin login; deploy without it and the
# first enrolled admin to log in hits a 500.
# Dev / staging: optional — leave the placeholder if you don't exercise
# the MFA path locally; replace with a real `openssl rand -hex 32`
# value to verify MFA enrollment + login end-to-end.
ADMIN_MFA_ENCRYPTION_KEY=replace-me-with-a-strong-random-string-min32-chars

# Phase 19 (2026-05-20) — Seller payout bank-account encryption key.
# AES-256-GCM. 32 bytes (64 hex chars or 44 base64 chars). Required
# in prod (the env-schema requiredInProd gate rejects an empty value
# at boot). Optional in dev — bank-details PATCH refuses writes with
# code BANK_DETAILS_UNAVAILABLE when unset.
# Generate with: openssl rand -hex 32
SELLER_BANK_ENCRYPTION_KEY=replace-me-with-a-strong-random-string-min32-chars

# Phase 20 (2026-05-20) — Franchise payout bank-account encryption.
# Same shape as SELLER_BANK_ENCRYPTION_KEY but dedicated to the
# franchise side so a leak does not cross-contaminate. Optional in
# dev (bank-details PATCH refuses writes with code
# BANK_DETAILS_UNAVAILABLE); required in production.
FRANCHISE_BANK_ENCRYPTION_KEY=replace-me-with-a-strong-random-string-min32-chars

# AFFILIATE_ENCRYPTION_KEY — symmetric key for affiliate-side sensitive
# data (bank account numbers, IFSC, UPI handles) stored encrypted in
# affiliate_kyc_documents. Same 32-byte hex/base64 shape as
# ADMIN_MFA_ENCRYPTION_KEY. REQUIRED in prod; optional in dev when the
# affiliate KYC path isn't exercised. Generate with: openssl rand -hex 32
AFFILIATE_ENCRYPTION_KEY=replace-me-with-a-strong-random-string-min32-chars

# Phase 154 — gate affiliate payouts on KYC verification (PMLA / RBI). Default
# ON (enforced) when unset. Set to 'false' ONLY to deliberately pause the gate.
AFFILIATE_KYC_GATE_ENABLED=true

# Phase 17 (2026-05-20) — JWT access TTL.
#
# 15-minute access TTL bounds a stolen-token replay window to 15
# minutes; refresh-rotation refills for live sessions automatically.
# Longer values widen the replay window from any cookie / log /
# browser-cache exfiltration. Test/staging may override to ease debug.
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Phase 17 (2026-05-20) — absolute session lifetime cap (days).
#
# refresh-rotation slides expiresAt forward on every refresh, so a
# daily-active session is functionally immortal without this guard.
# Past N days from Session.createdAt the refresh use-case revokes
# the row and forces re-login. 60d is the operational default;
# tighten in high-paranoia deployments.
SESSION_ABSOLUTE_LIFETIME_DAYS=60

# ─── Phase 16 (2026-05-20) — Captcha bot-protection ───────────────
# Provider for the captcha verifier service used on customer
# register / verify-otp / resend-otp endpoints. 'disabled' is for
# local dev only — production MUST be 'turnstile' or 'hcaptcha'.
CAPTCHA_PROVIDER=disabled
# Secret key from the captcha provider, paired with the public site
# key embedded in the frontend (NEXT_PUBLIC_CAPTCHA_SITE_KEY). Leave
# empty when CAPTCHA_PROVIDER=disabled.
CAPTCHA_SECRET=

# ─── Phase 4 — Authorization (ADR-010, ADR-019) ────────────────────
# PermissionsGuard enforcement mode.
#   false: log-only soak. Routes that fail @Permissions checks log a
#     WARN with event=authz.deny and let the request through. Audit
#     row records wouldHaveBlocked=true. Default for safe rollout.
#   true:  strict enforce. Failed permission checks return 403 with
#     problem-type=permission-denied.
# Recommendation: soak in staging for 2 weeks reading the deny logs,
# flip true once no SUPER_ADMIN actor is showing wouldHaveBeenBlocked.
PERMISSIONS_GUARD_STRICT=true

# Global auth safety net (GlobalAuthGuard). 'false' = SOAK (log
# event=authz.unguarded for any route missing both an auth @UseGuards and
# @Public(), but allow it). 'true' = STRICT (401 those routes). Flip to true
# once the SOAK logs show zero unguarded routes (already the case in this repo).
GLOBAL_AUTH_GUARD_STRICT=false

# Node cluster workers per process (src/cluster.ts). Unset/1 = single process.
# 0 = one worker per CPU core. N = N workers. Crons stay single-fire via
# leader election, so >1 is safe.
CLUSTER_WORKERS=1

# ABAC PolicyGuard (ResourcePolicy) strictness.
#   false: a route with @Policy(...) but no matching ALLOW rule lets
#     the request through. DENY rules are always enforced.
#   true:  no matching ALLOW rule → 403.
ABAC_ENABLED=false

# Write a row to authorization_audits for every guard decision
# (allow + deny). Default ON — buffered + batched so the write cost
# is negligible. Set false to suppress all guard audit writes.
AUTHZ_AUDIT_ENABLED=true

# Cloudflare R2 object storage (optional in dev; REQUIRED in prod).
# Set R2_ACCOUNT_ID (endpoint derived as https://<id>.r2.cloudflarestorage.com)
# or set R2_ENDPOINT directly. R2 speaks the S3 API.
R2_ACCOUNT_ID=
R2_ENDPOINT=
R2_BUCKET=sportsmart-dev
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Public/custom-domain delivery base for PUBLIC media assets (e.g. https://media.example.com).
R2_PUBLIC_BASE_URL=

# Google "Sign in with Google" (storefront) — the OAuth Web Client ID. This is
# the PUBLIC client id (the same value baked into the storefront as
# NEXT_PUBLIC_GOOGLE_CLIENT_ID); the API uses it as the audience when verifying
# the Google ID token. Optional everywhere — empty disables the feature (the
# /auth/google endpoint returns "not configured" and the storefront hides the
# button). NO client secret is needed (ID-token verification only).
GOOGLE_CLIENT_ID=

# Razorpay — optional in dev, REQUIRED in prod (env schema's
# requiredInProd gate rejects empty/missing values when NODE_ENV
# is production). Empty-value lines below mean "the operator must
# fill these before the boot guard passes." Uncomment with real
# test credentials locally if you need to exercise the gateway path.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Shiprocket (optional in dev)
# SHIPROCKET_EMAIL=
# SHIPROCKET_PASSWORD=
# SHIPROCKET_WEBHOOK_TOKEN=
# SHIPROCKET_WEBHOOK_HMAC_SECRET=
# Phase 86 (2026-05-23) — Gap #15. Comma-separated IPv4/IPv6 + CIDR
# allowlist for carrier webhook source IPs. Unset / empty = pass-through
# (HMAC + idempotency remain primary defense); populate in production
# with Shiprocket's published webhook IPs to harden against signature-key
# compromise. Example: SHIPROCKET_WEBHOOK_IP_ALLOWLIST=52.66.0.0/16,3.6.12.0/24
# SHIPROCKET_WEBHOOK_IP_ALLOWLIST=

# OpenSearch (optional in dev)
# OPENSEARCH_NODE=http://localhost:9200

# Admin Seed (used by seed script — choose a strong password locally)
ADMIN_SEED_NAME=Super Admin
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=

# Commission — late-reversal guard. Reject return reversals that land more
# than this many days after the commission's settlement was paid out. Set
# to 0 to disable the guard.
COMMISSION_REVERSAL_WINDOW_DAYS=30

# Settlement cycle automation. When enabled, the API periodically rolls the
# next settlement cycle forward by SETTLEMENT_CYCLE_PERIOD_DAYS days as soon
# as each period has fully closed. Leave disabled in dev; turn on in prod.
SETTLEMENT_AUTO_CYCLE_ENABLED=false
SETTLEMENT_CYCLE_PERIOD_DAYS=7
SETTLEMENT_AUTO_CYCLE_INTERVAL_MINUTES=60

# Order acceptance SLA. If a seller/franchise doesn't accept a sub-order
# within this many minutes, the background job auto-rejects on their behalf
# and triggers re-routing. Set to 0 to disable.
ORDER_ACCEPTANCE_SLA_MINUTES=60
ORDER_ACCEPTANCE_SLA_CHECK_SECONDS=60

# Sprint cleanup 2026-05-13 — return window in days. Customer can file
# a return up to this many days after sub-order delivery. **PROD: 14**.
# Local dev / demo can set a fractional value (e.g. 0.0014 ≈ 2 min) to
# test the post-window commission confirm path quickly.
RETURN_WINDOW_DAYS=14

# Routing engine scoring weights (must sum to 1.0).
# Distance = closer node wins; Stock = fuller inventory wins; SLA = faster dispatch wins.
#
# Sprint 4 Story 3.2 — to run strict proximity-only (per the MASTER_PLAN
# Phase 3 v1 "keep v1 strictly proximity, resist SLA/cost weighting"
# guidance), set:
#   ROUTING_DISTANCE_WEIGHT=1.0
#   ROUTING_STOCK_WEIGHT=0
#   ROUTING_SLA_WEIGHT=0
# The composite scoring path is wired in code; the weights are the
# operational lever. Stock + SLA weighting can be re-enabled in a
# later phase once the proximity rule's behaviour is stable in prod.
ROUTING_DISTANCE_WEIGHT=0.7
ROUTING_STOCK_WEIGHT=0.2
ROUTING_SLA_WEIGHT=0.1

# Refund processor. Polls Razorpay for pending refund statuses and auto-retries
# failed gateway calls. Set interval to 0 to disable.
REFUND_POLL_INTERVAL_SECONDS=120
REFUND_RETRY_BACKOFF_MINUTES=15

# Stale-return processor. Returns stuck beyond this many days in non-terminal
# states get auto-cancelled, auto-closed, or escalated to admin. Set to 0 to disable.
RETURN_STALE_DAYS=30
RETURN_STALE_CHECK_INTERVAL_MINUTES=60

# Payment poller. Checks Razorpay for orders stuck in PENDING_PAYMENT and
# auto-cancels orders past the payment window.
PAYMENT_POLL_INTERVAL_SECONDS=60
PAYMENT_WINDOW_MINUTES=30

# ─── Option B — Deferred ONLINE order creation ───────────
# When ON, an ONLINE checkout creates a CheckoutSession intent (NOT a
# MasterOrder); the real order is materialized only when the gateway payment
# is captured (sync verify + webhook + a recovery cron). A never-completed
# checkout simply expires — no half-made order reaches the admin. COD and
# wallet-fully-covered checkouts are unaffected. Keep OFF until staging QA
# has validated the full capture→materialize→reconcile loop.
CHECKOUT_DEFERRED_ORDER_CREATION=false
# Deferred-capture recovery cron (the missed-webhook backstop): per-tick batch
# size + min seconds between polls of the same session.
DEFERRED_CAPTURE_BATCH=20
DEFERRED_CAPTURE_BACKOFF_SECONDS=180
# CheckoutSession reconciler (re-link/fail stuck-PAID, auto-refund FAILED,
# expire abandoned). _ENABLED pauses it for incident response (also requires
# CHECKOUT_DEFERRED_ORDER_CREATION on); _RECONCILE_BATCH caps per-tick rows;
# _STUCK_GRACE_MINUTES is how long a PAID-with-no-order session must sit before
# it's treated as a crashed materialize.
CHECKOUT_SESSION_RECONCILIATION_ENABLED=true
CHECKOUT_SESSION_RECONCILE_BATCH=50
CHECKOUT_SESSION_STUCK_GRACE_MINUTES=5

# ─── AI (Google Gemini - FREE tier) ────────────────────
# Get your free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ─── Email (SMTP / Gmail App Password) ───────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=
# Inbox that "Contact us" form submissions are emailed to. Defaults to
# support@sportsmart.com when unset.
SUPPORT_EMAIL=support@sportsmart.com

# ─── WhatsApp (Meta Cloud API) ───────────────────────────
# WHATSAPP_API_URL=https://graph.facebook.com/v18.0
# WHATSAPP_API_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# Reverse-proxy hops to trust for req.ip (rate-limit keys on client IP).
#
# Phase 17 (2026-05-20) — production guidance:
#   • Direct connect (dev / no proxy):       TRUST_PROXY_HOPS=0
#   • Behind a single ALB / nginx / CDN:     TRUST_PROXY_HOPS=1
#   • Behind a chain (CDN -> ALB):           TRUST_PROXY_HOPS=2
#
# IMPORTANT: in production this MUST be set to the real hop count
# upstream. With TRUST_PROXY_HOPS=0 behind a proxy, every per-IP
# rate-limit key + every access-log row sees the proxy IP (one value)
# rather than the real client IP — defeating both the @Throttle
# decorator and forensic IP tracking. With TRUST_PROXY_HOPS too HIGH,
# a client can spoof its IP via X-Forwarded-For.
TRUST_PROXY_HOPS=0

# ─── Phase 1.1 — Idempotency Keys (ADR-003) ─────────────
# When ON, endpoints decorated with @Idempotent() require X-Idempotency-Key
# and dedupe on it (Stripe-style). Default OFF for backward compatibility;
# flip to true after PR 1.6 staging soak. See docs/runbooks/idempotency-keys.md.
IDEMPOTENCY_ENABLED=false
IDEMPOTENCY_TTL_HOURS=24
IDEMPOTENCY_SWEEP_INTERVAL_MINUTES=15

# ─── Phase 1.3 — Problem-Details (RFC 7807) errors (ADR-005) ─────────
# When ON, error responses use application/problem+json with
# {type, title, status, detail, instance, errors[]} shape. OFF keeps
# the legacy {success, message, code, timestamp} shape so existing
# frontends keep parsing during cutover.
PROBLEM_DETAILS_ENABLED=false
PROBLEM_DETAILS_BASE_URI=https://api.sportsmart.com/problems

# ─── Phase 1.5 — Business duplicate prevention (ADR-006) ────────────
# When ON, return / dispute / ticket creation paths reject duplicate
# active cases with 409 + a row in `case_duplicates`. Default ON;
# set to false only to restore the old silent-duplicate behaviour.
CASE_DUPLICATE_PREVENTION_ENABLED=true

# ─── Phase 1.4 — Money paise dual-write (ADR-007) ───────────────────
# When ON, services that opt in via MoneyDualWriteHelper.applyPaise()
# populate the new `*_in_paise` BIGINT columns alongside their Decimal
# siblings. Off by default; flip ON for staging soak before PR 1.4b
# swaps read paths.
MONEY_DUAL_WRITE_ENABLED=false

# ─── Phase 2 — Transactional Outbox (ADR-008) ───────────────────────
# Phased flag plan:
#   1. Soak with OUTBOX_DUAL_WRITE=true (writes outbox AND direct emit).
#      Verify outbox_events drains via OUTBOX_ENABLED=true publisher cron.
#   2. After 2-week soak: flip OUTBOX_AUTHORITATIVE=true (publisher cron
#      becomes the sole emitter; direct emit suppressed).
# Safety interlock: API refuses to boot if AUTHORITATIVE=true unless both
# ENABLED and DUAL_WRITE are also true.
OUTBOX_ENABLED=false
OUTBOX_DUAL_WRITE=false
OUTBOX_AUTHORITATIVE=false
EVENT_DEDUP_ENABLED=false
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=100
OUTBOX_MAX_ATTEMPTS=10

# ─── Phase 3 — Unified Refund System (ADR-009) ──────────────────────
# REFUND_INSTRUCTION_REQUIRED: when ON, every refund goes through a
# RefundInstruction row (auditable). When OFF, dispute decisions still
# directly credit the wallet (legacy path).
# REFUND_SAGA_ENABLED: when ON, RefundSagaService persists per-step
# state in refund_sagas. When OFF, steps run inline without persistence.
REFUND_INSTRUCTION_REQUIRED=false
REFUND_SAGA_ENABLED=false
REFUND_SAGA_MAX_STEP_ATTEMPTS=5

# ─── Phase 12 (ADR-017) — Finance approval gate ─────────────────────
# REFUND_AUTO_APPROVE_THRESHOLD_PAISE: dispute refunds at or below this
# amount auto-execute. Above it → status=PENDING_APPROVAL, reviewed at
# /dashboard/finance/refund-approvals. Set to 0 to gate every dispute.
# REFUND_GOODWILL_REQUIRES_APPROVAL: when ON, GOODWILL_CREDIT refunds
# always queue regardless of amount.
# REFUND_DUAL_APPROVAL_THRESHOLD_PAISE: refunds at/above this amount need
# TWO distinct finance approvers (two-person rule). The first approval is
# recorded and held; a second, different admin must approve to release the
# money. Default ₹1,00,000.
REFUND_AUTO_APPROVE_THRESHOLD_PAISE=1000000
REFUND_GOODWILL_REQUIRES_APPROVAL=true
REFUND_DUAL_APPROVAL_THRESHOLD_PAISE=10000000
# RBAC_ORPHAN_SWEEP_ENABLED: nightly cron that revokes role assignments whose
# underlying role/permission was deleted (prevents orphaned grants lingering).
# Default true; set false only to pause the sweep during a migration.
RBAC_ORPHAN_SWEEP_ENABLED=true
# DISPUTE_REFUND_RECOVERY_SWEEP_ENABLED: recovers customer refunds stranded
# when a crash hits between decide()'s status commit and the refund-instruction
# create. DISPUTE_REFUND_RECOVERY_LOOKBACK_MINUTES bounds the scan window.
DISPUTE_REFUND_RECOVERY_SWEEP_ENABLED=true
DISPUTE_REFUND_RECOVERY_LOOKBACK_MINUTES=1440
# DISPUTE_HIGH_VALUE_DECISION_THRESHOLD_PAISE: dispute decisions awarding at/above
# this amount require the disputes.decide.high_value permission (runtime check).
DISPUTE_HIGH_VALUE_DECISION_THRESHOLD_PAISE=5000000

# Reconciliation crons. Each independently flagged. Recommend turning
# ON in staging for the soak; flip ON in prod after each settles.
WALLET_LEDGER_RECON_ENABLED=false
WALLET_LEDGER_RECON_INTERVAL_MINUTES=1440
REFUND_GATEWAY_RECON_ENABLED=false
REFUND_GATEWAY_RECON_INTERVAL_MINUTES=60
COD_REFUND_PENDING_ENABLED=false
COD_REFUND_PENDING_INTERVAL_MINUTES=240
COD_REFUND_PENDING_STUCK_HOURS=48

# Story 1.4 cleanup — guardrail thresholds layered on top of the
# admin-editable cod_rules engine. The rule engine is the dynamic
# policy source of truth; these set the absolute upper/lower bound a
# misconfigured rule set still can't bypass. Tune per business policy.
COD_FALLBACK_MAX_ORDER_VALUE_INR=10000
COD_FALLBACK_MIN_ORDER_VALUE_INR=100
# Repeated-cancellation guard: N cancelled COD orders in M days blocks
# the customer from using COD again.
COD_ABUSE_RECENT_CANCEL_LIMIT=3
COD_ABUSE_LOOKBACK_DAYS=30

# ─── Phase 5 / 6 — Observability + Compliance crons ─────────────────
# All of the flags below are PROD-REQUIRED: the env schema's
# requiredOnInProd gate refuses to boot prod unless they resolve
# truthy. Stay default-off in dev/test/staging so CI doesn't fire
# escalations / write retention-policy rows / pin Merkle anchors
# against pristine fixtures. Flip each to `true` in prod after the
# corresponding cron's staging soak completes.
#
# CRON_HEARTBEAT_ENABLED — heartbeat detector wired into every @Cron
#   service (PRs 5.1–5.5). Off in prod means silent crons stay silent.
CRON_HEARTBEAT_ENABLED=false
# SLA_BREACH_DETECTOR_ENABLED — walks non-terminal returns / disputes
#   / tickets every 5 min and emits sla.breached for downstream paging.
SLA_BREACH_DETECTOR_ENABLED=false
# AUDIT_CHAIN_ANCHOR_ENABLED — hourly Merkle anchor that tamper-
#   evidence verification depends on; off in prod means the chain-walk
#   verifier scans unboundedly far back.
AUDIT_CHAIN_ANCHOR_ENABLED=false
# INTEGRITY_VERIFIER_ENABLED — only mechanism that catches silent file
#   tampering (KYC docs, invoices, return-evidence photos). Off in
#   prod, the hourly re-hash never runs.
INTEGRITY_VERIFIER_ENABLED=false
# ERASURE_PROCESSOR_ENABLED — drains the DataErasureRequest queue.
#   Off in prod, DPDPA §12 / GDPR Article 17 statutory windows are
#   missed silently with monetary regulatory exposure.
ERASURE_PROCESSOR_ENABLED=false
# RETENTION_ENFORCER_ENABLED — proactive companion to ERASURE_PROCESSOR.
#   Walks RetentionPolicy rows daily and applies DELETE/ARCHIVE/REDACT.
#   Off in prod, every retention policy in the admin console is
#   decorative — DPDPA §8(7) / GDPR storage-limitation breach.
#   RETENTION_ENFORCER_DRY_RUN stays an operator rollout lever; the
#   _ENABLED flag only forces the cron to run.
RETENTION_ENFORCER_ENABLED=false
RETENTION_ENFORCER_DRY_RUN=true
