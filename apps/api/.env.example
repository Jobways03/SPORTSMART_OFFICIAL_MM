# ===========================================
# SPORTSMART API - Local Development
# ===========================================
#
# IMPORTANT: this file is committed to version control. NEVER put real
# credentials here. Copy it to `.env` and fill in real values locally.
# `.env` is gitignored.

NODE_ENV=development
PORT=8000

APP_NAME=sportsmart-api
APP_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:4000,http://localhost:4001,http://localhost:4002,http://localhost:4003,http://localhost:4004,http://localhost:4005,http://localhost:4006,http://localhost:4007

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sportsmart_dev?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# JWT — separate secret per actor type. Each must be at least 32 chars.
# In production, replace EVERY placeholder. The boot guard rejects
# placeholder secrets (`replace-me-…`) when NODE_ENV=production.
# Generate with: openssl rand -base64 32
JWT_CUSTOMER_SECRET=replace-me-with-a-strong-random-string-min32-chars
JWT_SELLER_SECRET=replace-me-with-a-strong-random-string-min32-chars
JWT_FRANCHISE_SECRET=replace-me-with-a-strong-random-string-min32-chars
JWT_ADMIN_SECRET=replace-me-with-a-strong-random-string-min32-chars
JWT_AFFILIATE_SECRET=replace-me-with-a-strong-random-string-min32-chars
JWT_REFRESH_SECRET=replace-me-with-a-strong-random-string-min32-chars
JWT_ACCESS_TTL=1d
JWT_REFRESH_TTL=30d

# ─── Phase 4 — Authorization (ADR-010, ADR-019) ────────────────────
# PermissionsGuard enforcement mode.
#   false: log-only soak. Routes that fail @Permissions checks log a
#     WARN with event=authz.deny and let the request through. Audit
#     row records wouldHaveBlocked=true. Default for safe rollout.
#   true:  strict enforce. Failed permission checks return 403 with
#     problem-type=permission-denied.
# Recommendation: soak in staging for 2 weeks reading the deny logs,
# flip true once no SUPER_ADMIN actor is showing wouldHaveBeenBlocked.
PERMISSIONS_GUARD_STRICT=false

# ABAC PolicyGuard (ResourcePolicy) strictness.
#   false: a route with @Policy(...) but no matching ALLOW rule lets
#     the request through. DENY rules are always enforced.
#   true:  no matching ALLOW rule → 403.
ABAC_ENABLED=false

# Write a row to authorization_audits for every guard decision
# (allow + deny). Default ON — buffered + batched so the write cost
# is negligible. Set false to suppress all guard audit writes.
AUTHZ_AUDIT_ENABLED=true

# S3 (optional in dev)
S3_BUCKET=sportsmart-dev
S3_REGION=ap-south-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Razorpay (optional in dev)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# Shiprocket (optional in dev)
# SHIPROCKET_EMAIL=
# SHIPROCKET_PASSWORD=
# SHIPROCKET_WEBHOOK_TOKEN=

# OpenSearch (optional in dev)
# OPENSEARCH_NODE=http://localhost:9200

# Cloudinary (optional in dev)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Admin Seed (used by seed script — choose a strong password locally)
ADMIN_SEED_NAME=Super Admin
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=

# Commission — late-reversal guard. Reject return reversals that land more
# than this many days after the commission's settlement was paid out. Set
# to 0 to disable the guard.
COMMISSION_REVERSAL_WINDOW_DAYS=30

# Settlement cycle automation. When enabled, the API periodically rolls the
# next settlement cycle forward by SETTLEMENT_CYCLE_PERIOD_DAYS days as soon
# as each period has fully closed. Leave disabled in dev; turn on in prod.
SETTLEMENT_AUTO_CYCLE_ENABLED=false
SETTLEMENT_CYCLE_PERIOD_DAYS=7
SETTLEMENT_AUTO_CYCLE_INTERVAL_MINUTES=60

# Order acceptance SLA. If a seller/franchise doesn't accept a sub-order
# within this many minutes, the background job auto-rejects on their behalf
# and triggers re-routing. Set to 0 to disable.
ORDER_ACCEPTANCE_SLA_MINUTES=60
ORDER_ACCEPTANCE_SLA_CHECK_SECONDS=60

# Routing engine scoring weights (must sum to 1.0).
# Distance = closer node wins; Stock = fuller inventory wins; SLA = faster dispatch wins.
ROUTING_DISTANCE_WEIGHT=0.7
ROUTING_STOCK_WEIGHT=0.2
ROUTING_SLA_WEIGHT=0.1

# Refund processor. Polls Razorpay for pending refund statuses and auto-retries
# failed gateway calls. Set interval to 0 to disable.
REFUND_POLL_INTERVAL_SECONDS=120
REFUND_RETRY_BACKOFF_MINUTES=15

# Stale-return processor. Returns stuck beyond this many days in non-terminal
# states get auto-cancelled, auto-closed, or escalated to admin. Set to 0 to disable.
RETURN_STALE_DAYS=30
RETURN_STALE_CHECK_INTERVAL_MINUTES=60

# Payment poller. Checks Razorpay for orders stuck in PENDING_PAYMENT and
# auto-cancels orders past the payment window.
PAYMENT_POLL_INTERVAL_SECONDS=60
PAYMENT_WINDOW_MINUTES=30

# ─── AI (Google Gemini - FREE tier) ────────────────────
# Get your free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ─── Email (SMTP / Gmail App Password) ───────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=

# ─── WhatsApp (Meta Cloud API) ───────────────────────────
# WHATSAPP_API_URL=https://graph.facebook.com/v18.0
# WHATSAPP_API_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# Reverse-proxy hops to trust for req.ip (rate-limit keys on client IP).
# 0 = dev (no proxy). Set to 1 when behind a single ALB / nginx in prod.
TRUST_PROXY_HOPS=0

# ─── Phase 1.1 — Idempotency Keys (ADR-003) ─────────────
# When ON, endpoints decorated with @Idempotent() require X-Idempotency-Key
# and dedupe on it (Stripe-style). Default OFF for backward compatibility;
# flip to true after PR 1.6 staging soak. See docs/runbooks/idempotency-keys.md.
IDEMPOTENCY_ENABLED=false
IDEMPOTENCY_TTL_HOURS=24
IDEMPOTENCY_SWEEP_INTERVAL_MINUTES=15

# ─── Phase 1.3 — Problem-Details (RFC 7807) errors (ADR-005) ─────────
# When ON, error responses use application/problem+json with
# {type, title, status, detail, instance, errors[]} shape. OFF keeps
# the legacy {success, message, code, timestamp} shape so existing
# frontends keep parsing during cutover.
PROBLEM_DETAILS_ENABLED=false
PROBLEM_DETAILS_BASE_URI=https://api.sportsmart.com/problems

# ─── Phase 1.5 — Business duplicate prevention (ADR-006) ────────────
# When ON, return / dispute / ticket creation paths reject duplicate
# active cases with 409 + a row in `case_duplicates`. Default OFF.
CASE_DUPLICATE_PREVENTION_ENABLED=false

# ─── Phase 1.4 — Money paise dual-write (ADR-007) ───────────────────
# When ON, services that opt in via MoneyDualWriteHelper.applyPaise()
# populate the new `*_in_paise` BIGINT columns alongside their Decimal
# siblings. Off by default; flip ON for staging soak before PR 1.4b
# swaps read paths.
MONEY_DUAL_WRITE_ENABLED=false

# ─── Phase 2 — Transactional Outbox (ADR-008) ───────────────────────
# Phased flag plan:
#   1. Soak with OUTBOX_DUAL_WRITE=true (writes outbox AND direct emit).
#      Verify outbox_events drains via OUTBOX_ENABLED=true publisher cron.
#   2. After 2-week soak: flip OUTBOX_AUTHORITATIVE=true (publisher cron
#      becomes the sole emitter; direct emit suppressed).
# Safety interlock: API refuses to boot if AUTHORITATIVE=true unless both
# ENABLED and DUAL_WRITE are also true.
OUTBOX_ENABLED=false
OUTBOX_DUAL_WRITE=false
OUTBOX_AUTHORITATIVE=false
EVENT_DEDUP_ENABLED=false
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=100
OUTBOX_MAX_ATTEMPTS=10

# ─── Phase 3 — Unified Refund System (ADR-009) ──────────────────────
# REFUND_INSTRUCTION_REQUIRED: when ON, every refund goes through a
# RefundInstruction row (auditable). When OFF, dispute decisions still
# directly credit the wallet (legacy path).
# REFUND_SAGA_ENABLED: when ON, RefundSagaService persists per-step
# state in refund_sagas. When OFF, steps run inline without persistence.
REFUND_INSTRUCTION_REQUIRED=false
REFUND_SAGA_ENABLED=false
REFUND_SAGA_MAX_STEP_ATTEMPTS=5

# ─── Phase 12 (ADR-017) — Finance approval gate ─────────────────────
# REFUND_AUTO_APPROVE_THRESHOLD_PAISE: dispute refunds at or below this
# amount auto-execute. Above it → status=PENDING_APPROVAL, reviewed at
# /dashboard/finance/refund-approvals. Set to 0 to gate every dispute.
# REFUND_GOODWILL_REQUIRES_APPROVAL: when ON, GOODWILL_CREDIT refunds
# always queue regardless of amount.
REFUND_AUTO_APPROVE_THRESHOLD_PAISE=1000000
REFUND_GOODWILL_REQUIRES_APPROVAL=true

# Reconciliation crons. Each independently flagged. Recommend turning
# ON in staging for the soak; flip ON in prod after each settles.
WALLET_LEDGER_RECON_ENABLED=false
WALLET_LEDGER_RECON_INTERVAL_MINUTES=1440
REFUND_GATEWAY_RECON_ENABLED=false
REFUND_GATEWAY_RECON_INTERVAL_MINUTES=60
COD_REFUND_PENDING_ENABLED=false
COD_REFUND_PENDING_INTERVAL_MINUTES=240
COD_REFUND_PENDING_STUCK_HOURS=48
