# Mobile storefront env vars — copy to .env (gitignored) and edit.
# Loaded at build time by react-native-dotenv (see babel.config.js).
# After changing any value, restart Metro with --reset-cache.

# Razorpay key ID for the native checkout sheet. Use a TEST key in dev
# (starts with rzp_test_). Live keys (rzp_live_) only in production builds.
# Without this, the Pay button shows a clear error and no Razorpay sheet
# is opened.
RAZORPAY_KEY_ID=

# API base URL. Defaults:
#   iOS simulator  → http://localhost:8000
#   Android emulator → http://10.0.2.2:8000  (10.0.2.2 is the host
#                                              loopback alias the emulator sees)
# Override here when pointing at staging or a tunnelled localhost (ngrok).
API_URL=

# Sentry DSN for crash + error reporting. Get one from sentry.io after
# creating a React Native project. Leave empty in dev to skip — Sentry
# silently no-ops when the DSN isn't set.
SENTRY_DSN=
# Environment tag attached to every event. Common values: development,
# staging, production. Defaults to "development" if blank.
SENTRY_ENVIRONMENT=

# PostHog product-analytics key. Get one from posthog.com after creating
# a project. Empty = analytics is a no-op (track()/identify() return
# silently). Use a dev project key in development so events don't pollute
# the production funnel.
POSTHOG_API_KEY=
# PostHog host. Default cloud is https://us.i.posthog.com. EU residency
# is https://eu.i.posthog.com. Self-hosted: your own URL.
POSTHOG_HOST=
