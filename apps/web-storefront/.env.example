NEXT_PUBLIC_API_URL=http://localhost:8000

# Razorpay public key id (test-mode by default). Required for the
# checkout modal — never include the secret here. Without this set,
# the storefront falls back to COD-only at place-order.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Phase 16 (2026-05-20) — captcha bot-protection for the customer
# register / verify-otp / resend-otp pages. Leave blank to disable
# the captcha widget on the frontend (must match
# CAPTCHA_PROVIDER=disabled on the API side). In staging / prod, set
# to a Cloudflare Turnstile site key.
NEXT_PUBLIC_CAPTCHA_PROVIDER=disabled
NEXT_PUBLIC_CAPTCHA_SITE_KEY=

# Google "Sign in with Google" OAuth public client id (baked into the
# bundle at build — public by design, never a secret). Leave blank to
# hide the Google button (the storefront degrades gracefully and
# renders password auth only). Must match the API's configured client
# id used to verify the credential at POST /auth/google.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
