# ─── Application ─────────────────────────────────────────────────
NODE_ENV=development
LOGISTICS_FACADE_PORT=4100
LOG_LEVEL=debug

# ─── Storage ─────────────────────────────────────────────────────
# Separate DB from apps/api: this service owns its own shipments,
# tracking events, returns, NDR, RTO, QC and remittance tables. Run
# `pnpm --filter @sportsmart/logistics-facade prisma:migrate-dev`
# after pointing at a fresh DB to bring up the schema.
LOGISTICS_DATABASE_URL=postgresql://logistics:logistics@localhost:5432/sportsmart_logistics?schema=public

# Redis is used for partner-webhook dedup (SET NX), idempotency
# fallback cache, and (future) leader-elected cron locks. Sharing the
# apps/api Redis instance is fine — keys are namespaced under
# `logistics:*`.
LOGISTICS_REDIS_URL=redis://localhost:6379/2

# ─── Inter-service auth ───────────────────────────────────────────
# Single shared secret accepted on the `Authorization: ApiKey <token>`
# header. M0 only — in M1 this is replaced by per-caller keys backed
# by an ApiKey table (mirrors apps/api/src/core/api-keys/).
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=replace-me-internal-api-key-must-be-32-chars

# ─── Cors / docs ─────────────────────────────────────────────────
# Comma-separated origins allowed to hit /docs in non-prod.
CORS_ORIGINS=http://localhost:4005,http://localhost:8000

# ─── Shadowfax — direct courier integration (Indian last-mile) ────
# Use STAGING URL + testing token in every environment except production.
# Both hosts are partner-issued; ask the Shadowfax account manager for
# the testing token and merchant code from the partner portal.
SHADOWFAX_API_URL=https://dale.staging.shadowfax.in/api
SHADOWFAX_QR_API_URL=https://saruman.staging.shadowfax.in/api
SHADOWFAX_API_TOKEN=replace-me-with-testing-token-from-partner-portal
SHADOWFAX_CLIENT_CODE=replace-me-ask-shadowfax-account-manager
SHADOWFAX_WEBHOOK_TOKEN=replace-me-generate-a-strong-random-secret
SHADOWFAX_REQUEST_TIMEOUT_MS=15000
SHADOWFAX_MAX_RETRIES=2

# ─── Delhivery — direct courier integration (Indian B2C, nationwide) ──
# Use STAGING URL + sandbox token in every environment except production.
# Get the staging token from your Delhivery onboarding email or account manager.
DELHIVERY_API_URL=https://staging-express.delhivery.com   # VERIFY against one.delhivery.com/developer-portal/documents/b2c
DELHIVERY_API_TOKEN=replace-me-with-staging-token-from-delhivery
DELHIVERY_CLIENT_NAME=replace-me-ask-delhivery-account-manager
DELHIVERY_WEBHOOK_TOKEN=replace-me-generate-a-strong-random-secret
DELHIVERY_REQUEST_TIMEOUT_MS=15000
DELHIVERY_MAX_RETRIES=2

# Delhivery requires the pickup_location.name to exactly match a warehouse
# registered in the Delhivery One panel (case + space sensitive).
DELHIVERY_PICKUP_WAREHOUSE_NAME=replace-me-with-warehouse-name-from-delhivery-one-panel
