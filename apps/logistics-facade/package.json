{
  "name": "@sportsmart/logistics-facade",
  "version": "0.0.1",
  "private": true,
  "description": "Multi-courier logistics aggregation facade. Owns the partner integrations (Delhivery, Bluedart, etc.), tracking webhook ingestion, NDR/RTO/QC flows, and COD remittance reconciliation. Apps/api consumes this service over HTTP.",
  "scripts": {
    "start": "nest start",
    "dev": "nest start --watch",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.config.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate-dev": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "smoke:shadowfax": "tsx scripts/shadowfax-smoke.ts",
    "smoke:delhivery": "tsx scripts/delhivery-smoke.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/throttler": "^6.0.0",
    "@prisma/client": "^6.0.0",
    "@sportsmart/logistics-contracts": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.8.1",
    "dotenv": "^17.0.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^25.9.2",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "prisma": "^6.0.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.8.1",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.58.2"
  }
}
