# =========================================================================
# SPORTSMART MARKETPLACE — Root Environment Pointer
# =========================================================================
#
# This file is intentionally minimal. The repo is a monorepo and each app
# loads its own .env from its own directory:
#
#   apps/api/.env             ← backend config (DATABASE_URL, JWT secrets,
#                                Razorpay, iThink, etc.) — see
#                                apps/api/.env.example for the full set
#                                (~280 lines, fully documented)
#
#   apps/web-admin/.env       ← NEXT_PUBLIC_API_URL + NEXT_PUBLIC_SELLER_URL
#   apps/web-admin-storefront/.env
#   apps/web-storefront/.env
#   apps/web-seller/.env
#   apps/web-franchise/.env
#   apps/web-franchise-admin/.env
#   apps/web-affiliate/.env
#   apps/web-affiliate-admin/.env
#                             ← each just sets NEXT_PUBLIC_API_URL
#
# Local-dev bring-up (one-time, per fresh clone):
#
#   cp apps/api/.env.example apps/api/.env
#   for d in apps/web-*; do cp "$d/.env.example" "$d/.env"; done
#   # edit apps/api/.env to set DATABASE_URL, JWT_*_SECRET, etc.
#
# Convention: the API binds PORT=8000 (set in apps/api/.env). Frontend
# .env files reference http://localhost:8000 to match. Do not set a
# different PORT here — nothing reads it.
#
# NO TOOL READS THIS ROOT FILE. It exists only to flag the convention
# above. Do not add real config here — it will be silently ignored.
