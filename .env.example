# =========================================================================
# SPORTSMART MARKETPLACE — Root Environment Pointer
# =========================================================================
#
# This file is intentionally minimal. The repo is a monorepo and each app
# loads its own .env from its own directory:
#
#   apps/api/.env             ← backend config (DATABASE_URL, JWT secrets,
#                                Razorpay, iThink, etc.) — see
#                                apps/api/.env.example for the full set
#                                (~280 lines, fully documented)
#
#   apps/web-d2c-seller-admin/.env    ← NEXT_PUBLIC_API_URL + NEXT_PUBLIC_SELLER_URL=http://localhost:4003
#   apps/web-retail-seller-admin/.env ← NEXT_PUBLIC_API_URL + NEXT_PUBLIC_SELLER_URL=http://localhost:4009
#   apps/web-admin-storefront/.env
#   apps/web-storefront/.env
#   apps/web-d2c-seller/.env
#   apps/web-retail-seller/.env
#   apps/web-franchise/.env
#   apps/web-franchise-admin/.env
#   apps/web-affiliate/.env
#   apps/web-affiliate-admin/.env
#                             ← each just sets NEXT_PUBLIC_API_URL
#
# Local-dev bring-up (one-time, per fresh clone):
#
#   cp apps/api/.env.example apps/api/.env
#   for d in apps/web-*; do cp "$d/.env.example" "$d/.env"; done
#   # edit apps/api/.env to set DATABASE_URL, JWT_*_SECRET, etc.
#
# Convention: the API binds PORT=8000 (set in apps/api/.env). Frontend
# .env files reference http://localhost:8000 to match. Do not set a
# different PORT here — nothing reads it.
#
# NO TOOL READS THIS ROOT FILE. It exists only to flag the convention
# above. Do not add real config here — it will be silently ignored.
 ===========================================                                                                                                                                                           
    # SPORTSMART API — Local Development                                                                                                                                                                  
    # ===========================================                                                                                                                                                         
    NODE_ENV=development                                                                                                                                                                                  
    PORT=8000                                                                                                                                                                                             
    APP_NAME=sportsmart-api                                                                                                                                                                               
    APP_URL=http://localhost:8000                                                                                                                                                                         
    # Added :4008 and :4009 for retail-seller-admin and retail-seller                                                                                                                                     
    CORS_ORIGINS=http://localhost:4000,http://localhost:4001,http://localhost:4002,http://localhost:4003,http://localhost:4004,http://localhost:4005,http://localhost:4006,http://localhost:4007,http://l 
  oca                                                                                                                                                                                                     
    lhost:4008,http://localhost:4009                                                                                                                                                                      
    # Database                                                                                                                                                                                            
    DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sportsmart_dev?sslmode=disable&connection_limit=30&pool_timeout=30                                                                         
    # Redis                                                                                                                                                                                               
    REDIS_URL=redis://localhost:6379                                                                                                                                                                      
    # JWT — separate secret per actor type (dev values)                                                                                                                                                   
    JWT_CUSTOMER_SECRET=dev-customer-secret-change-in-production-32chars                                                                                                                                  
    JWT_SELLER_SECRET=dev-seller-secret-change-in-production-min32ch                                                                                                                                      
    JWT_FRANCHISE_SECRET=dev-franchise-secret-change-in-prod-min32ch                                                                                                                                      
    JWT_ADMIN_SECRET=dev-admin-secret-change-in-production-min32chars                                                                                                                                     
    JWT_AFFILIATE_SECRET=dev-affiliate-secret-change-in-prod-min32ch                                                                                                                                      
    JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production-min16                                                                                                                                      
    JWT_ACCESS_TTL=1d                                                                                                                                                                                     
    JWT_REFRESH_TTL=30d                                                                                                                                                                                   
    # Cookie domain pinning. Blank in dev (cookies use request host).                                                                                                                                     
    # Set to `.sportsmart.com` in prod so cookies share across subdomains.                                                                                                                                
    AUTH_COOKIE_DOMAIN=                                                                                                                                                                                   
    # Encryption keys (AES-256, 32-byte hex)                                                                                                                                                              
    AFFILIATE_ENCRYPTION_KEY=0f8e8b6e3c2a1d5f7e9c4b8a3d2e1f6c5b4a3d2e1f6c5b4a3d2e1f6c5b4a3d2e                                                                                                             
    ADMIN_MFA_ENCRYPTION_KEY=bd4dd3b9ca19792064a3d5054336899c1aa227ea914a4028b4b5ce40ce29f01a                                                                                                             
    # ─── Phase 4 — Authorization (soak mode in dev) ───────────                                                                                                                                          
    PERMISSIONS_GUARD_STRICT=false                                                                                                                                                                        
    ABAC_ENABLED=false                                                                                                                                                                                    
    AUTHZ_AUDIT_ENABLED=true                                                                                                                                                                              
    # S3 (optional in dev)                                                                                                                                                                                
    S3_BUCKET=sportsmart-dev                                                                                                                                                                              
    S3_REGION=ap-south-1                                                                                                                                                                                  
    S3_ACCESS_KEY=dev-access-key                                                                                                                                                                          
    S3_SECRET_KEY=dev-secret-key                                                                                                                                                                          
    # Razorpay (optional in dev)                                                                                                                                                                          
    RAZORPAY_KEY_ID=                                                                                                                                                                                      
    RAZORPAY_KEY_SECRET=                                                                                                                                                                                  
    RAZORPAY_WEBHOOK_SECRET=                                                                                                                                                                              
    # iThink Logistics (optional in dev)                                                                                                                                                                  
    ITHINK_BASE_URL=                                                                                                                                                                                      
    ITHINK_TRACK_URL=                                                                                                                                                                                     
    ITHINK_ACCESS_TOKEN=                                                                                                                                                                                  
    ITHINK_SECRET_KEY=                                                                                                                                                                                    
    ITHINK_DEFAULT_LOGISTICS=delhivery                                                                                                                                                                    
    ITHINK_HTTP_TIMEOUT_MS=15000                                                                                                                                                                          
    ITHINK_HTTP_MAX_RETRIES=2                                                                                                                                                                             
    ITHINK_TRACKING_POLL_ENABLED=false                                                                                                                                                                    
    ITHINK_TRACKING_POLL_INTERVAL_MINUTES=25                                                                                                                                                              
    ITHINK_USE_SANDBOX=true                                                                                                                                                                               
    # Cloudinary (your real dev creds)                                                                                                                                                                    
